---
// Import global CSS so Astro bundles it for production
import "../styles/global.css";
import "../styles/snipcart.css";
import { siteConfig } from "../lib/site.config";
import { getEntry } from "astro:content";
import CartToast from "../components/ui/CartToast.astro";
import AnnouncementBar from "../components/ui/AnnouncementBar.astro";
import PopupModal from "../components/ui/PopupModal.astro";
import Navbar from "../components/features/Navbar.astro";
import Footer from "../components/features/Footer.astro";
import SideDrawer from "../components/ui/SideDrawer.astro";
import Lightbox from "../components/ui/Lightbox.astro";

// Fetch Global Settings
const siteSettings = await getEntry("settings", "site");
const announcement_bar = siteSettings?.data?.announcement_bar;
const popup_modal = siteSettings?.data?.popup_modal;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${siteConfig.name} | ${siteConfig.tagline}`,
  description = siteConfig.description,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={siteConfig.assets.favicon} />
    <title>{title}</title>

    <!-- Snipcart v3 Preconnect for performance -->
    <link rel="preconnect" href="https://cdn.snipcart.com" />
    <link rel="preconnect" href="https://app.snipcart.com" />

    <!-- Snipcart CSS (v3.7.5) -->
    <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.7.5/default/snipcart.css" />

    <!-- Snipcart JS (v3.7.5, async loading) -->
    <script async src="https://cdn.snipcart.com/themes/v3.7.5/default/snipcart.js" is:inline></script>

    <script define:vars={{ apiKey: import.meta.env.PUBLIC_SNIPCART_API_KEY }} is:inline>
      window.SnipcartSettings = {
        publicApiKey: apiKey,
        loadStrategy: "on-idle",
        modalStyle: "overlay",
        addProductBehavior: "none",
        templatesUrl: "/snipcart-templates.html"
      };

      document.addEventListener('snipcart.ready', () => {
        // --- 1. LOCALIZATION OVERRIDES FOR EMAIL HINTS ---
        Snipcart.api.session.setLanguage('en', {
          address_form: {
            email: "Email (Please use a Gmail address)"
          },
          signin_form: {
            email: "Email (Please use a Gmail address to access discounts)"
          },
          register_form: {
            email: "Email (Please use a Gmail address)"
          }
        });

        // --- 2. NO LOGIN = NO DISCOUNT STATE SYNC ---
        // Dynamically track if the user is signed in to hide discount inputs
        const toggleGuestState = () => {
          const state = Snipcart.store.getState();
          if (state && state.customer && state.customer.status === 'SignedOut') {
            document.body.classList.add('zav-guest-user');
          } else {
            document.body.classList.remove('zav-guest-user');
          }
        };
        Snipcart.store.subscribe(toggleGuestState);
        toggleGuestState(); // Run initial setup

        // --- 3. DUAL-LAYER VALIDATION API HOOK ---
        Snipcart.events.on('page.validating', (ev, data) => {
          if (ev.type === 'shipping-address' || ev.type === 'billing-address' || ev.name === 'shipping-address' || ev.name === 'billing-address') {
            // PHONE VALIDATION
            const phoneInput = document.querySelector('snipcart-input[name="phone"] input, input[name="phone"], input[name="shipping[phone]"], input[name="billing[phone]"], [name="phone"]');
            let digits = '';
            if (phoneInput) {
              digits = String(phoneInput.value).replace(/\D/g, '');
            } else if (data && data.phone) {
              digits = String(data.phone).replace(/\D/g, '');
            }

            if (digits.length !== 10) {
              const msg = digits.length === 0 ? 'Phone number is required.' : 'Please enter a valid 10-digit mobile number.';
              if (typeof ev.addError === 'function') {
                ev.addError('phone', msg);
              } else if (ev.errors && Array.isArray(ev.errors)) {
                ev.errors.push({ id: 'phone', message: msg });
              }
            }

            // GMAIL VALIDATION
            const emailInput = document.querySelector('snipcart-input[name="email"] input, input[name="email"], input[type="email"]');
            let email = '';
            if (emailInput) {
              email = String(emailInput.value).trim().toLowerCase();
            } else if (data && data.email) {
              email = String(data.email).trim().toLowerCase();
            }

            if (email && !email.endsWith('@gmail.com')) {
              const msg = 'Only Gmail addresses (@gmail.com) are accepted to prevent spam.';
              if (typeof ev.addError === 'function') {
                ev.addError('email', msg);
              } else if (ev.errors && Array.isArray(ev.errors)) {
                ev.errors.push({ id: 'email', message: msg });
              }
            }
          }
        });

        // 2. HTML5 Physical DOM Validation (Browser-level block) + Digit Stripper
        document.addEventListener('input', (e) => {
          if (e.target && e.target.tagName === 'INPUT') {
            const name = e.target.name || '';
            if (name === 'phone' || name.includes('phone')) {
              // Strip letters and limit length instantly
              const digits = e.target.value.replace(/\D/g, '').slice(0, 10);
              if (e.target.value !== digits) {
                e.target.value = digits;
                e.target.dispatchEvent(new Event('input', { bubbles: true }));
              }
              // Set HTML5 validity: Modern browsers physically block the <form> submit
              if (digits.length < 10) {
                e.target.setCustomValidity('Please enter a valid 10-digit mobile number.');
              } else {
                e.target.setCustomValidity(''); 
              }
            }

            // GMAIL Physical Block: applies to EVERY email input inside checkout
            if ((name === 'email' || e.target.type === 'email') && e.target.value.length > 0) {
              const emailVal = e.target.value.trim().toLowerCase();
              if (!emailVal.endsWith('@gmail.com')) {
                e.target.setCustomValidity('Please use a Gmail address (@gmail.com).');
              } else {
                e.target.setCustomValidity(''); 
              }
            }
          }
        }, true);

        // Upsell Bridge: fires a dom event when a product is added to cart


        Snipcart.events.on('item.added', (item) => {
          console.log('[Upsell Bridge] Item added:', item.name);
          const event = new CustomEvent('zeliavance:item-added', {
            detail: {
              id: item.id,
              name: item.name,
              image: item.image,
              price: item.unitPrice,
              options: item.customFields || []
            }
          });
          document.dispatchEvent(event);
        });

        // --- 4. AMAZON-STYLE INCLUSIVE TAXES HIDER ---
        function hideTaxes() {
          const taxTitles = document.querySelectorAll('.snipcart-summary-fees__title, .snipcart-cart-summary-fees__title, .snipcart-summary-fees__item, .snipcart-cart-summary-fees__item');
          taxTitles.forEach(el => {
            // Target the text directly regardless of casing or extra characters like (?)
            if (el.textContent && /taxes/i.test(el.textContent)) {
              // If it's the title, hide the parent row. If it's already the row, hide it directly.
              const row = el.classList.contains('snipcart-summary-fees__item') || el.classList.contains('snipcart-cart-summary-fees__item') 
                ? el 
                : el.closest('.snipcart-cart-summary-fees__item, .snipcart-summary-fees__item');
              
              if (row && row.style.display !== 'none') {
                row.style.setProperty('display', 'none', 'important');
              }
            }
          });
        }

        const taxObserver = new MutationObserver(hideTaxes);
        taxObserver.observe(document.body, { childList: true, subtree: true });

        // --- 5. COD / PAY LATER LOGIN RESTRICTION ---
        // We only allow "Pay later" (COD) for signed-in users to minimize RTO risk.
        function updatePayLaterVisibility() {
          const state = window.Snipcart.store.getState();
          const isSignedIn = state.customer && state.customer.status === 'SignedIn';
          
          console.log('[COD Restriction] Status Check:', { 
            customerStatus: state.customer?.status, 
            isSignedIn 
          });

          // Look for either the container OR the button with the Pay Later text/label
          const payLaterElements = document.querySelectorAll('.snipcart-payment-methods-list-item, .snipcart-payment-methods-list-item__button');
          
          payLaterElements.forEach(el => {
            const hasPayLaterText = /pay later/i.test(el.textContent || '') || /pay later/i.test(el.getAttribute('aria-label') || '');
            
            if (hasPayLaterText) {
              const target = el.classList.contains('snipcart-payment-methods-list-item') ? el : el.closest('.snipcart-payment-methods-list-item');
              
              if (target) {
                if (!isSignedIn) {
                  console.log('[COD Restriction] Hiding Pay Later for guest');
                  target.style.setProperty('display', 'none', 'important');
                } else {
                  console.log('[COD Restriction] Showing Pay Later for signed-in user');
                  target.style.setProperty('display', '', '');
                }
              }
            }
          });
        }

        // Subscribe to store updates to catch login/logout events in real-time
        window.Snipcart.store.subscribe(updatePayLaterVisibility);

        // Also use an observer to catch the payment list as soon as it's rendered by Snipcart
        const payLaterObserver = new MutationObserver(updatePayLaterVisibility);
        payLaterObserver.observe(document.body, { childList: true, subtree: true });
      });
    </script>

  </head>
  <body class="flex flex-col min-h-screen">
    <AnnouncementBar data={announcement_bar} />
    <Navbar />

    <main class="grow">
      <slot />
    </main>

    <Footer />

    {/* Multi-purpose Side Drawer (Upsell, Quick Shop, Master Set) */}
    <SideDrawer />

    {/* Global Product Addition Notification */}
    <CartToast />

    <!-- Snipcart Root Container -->
    <div
      hidden
      id="snipcart"
      data-api-key={import.meta.env.PUBLIC_SNIPCART_API_KEY}
      data-config-modal-style="overlay"
      data-currency="INR"
      data-config-add-product-behavior="none"
    >
    </div>

    <!-- Alpine.js is now handled by @astrojs/alpinejs integration -->
    <!-- The entrypoint in astro.config.mjs registers the wishlist store before Alpine starts -->

    <!-- Global Snipcart Event Handler (Intent-Based Coupon System) -->
    <script src="../scripts/snipcart-events.ts"></script>
    <script src="../scripts/behaviors/options-sync.ts"></script>

    <PopupModal data={popup_modal} />
    <Lightbox />
  </body>
</html>


