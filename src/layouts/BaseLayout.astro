---
interface Props {
  title?: string;
}

const { title = "Zaviona E-commerce" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Global Styles including TailwindCSS and Theme -->
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <slot />

    <!-- Alpine.js is now handled by @astrojs/alpinejs integration -->
    <!-- The entrypoint in astro.config.mjs registers the wishlist store before Alpine starts -->
  </body>
</html>
