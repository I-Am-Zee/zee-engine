---
// Import global CSS so Astro bundles it for production
import "../styles/global.css";
import { getEntry } from "astro:content";
import PopupCoupon from "../components/ui/PopupCoupon.astro";
import PopupNewsletter from "../components/ui/PopupNewsletter.astro";
import Navbar from "../components/features/Navbar.astro";
import Footer from "../components/features/Footer.astro";
import SideDrawer from "../components/ui/SideDrawer.astro";
import AffiliateQuickView from "../components/features/AffiliateQuickView.astro";
import Lightbox from "../components/ui/Lightbox.astro";

const isAffiliate = import.meta.env.PUBLIC_AFFILIATE === 'true';
const gateway = import.meta.env.PUBLIC_IMAGE_GATEWAY_URL || "";

const rawBrandId = import.meta.env.PUBLIC_BRAND_ID;
let brandId = rawBrandId;

// Fallback logic (must match astro.config.mjs and content/config.ts)
if (!brandId) {
  brandId = isAffiliate ? 'sample-affiliate' : 'sample-brand';
}

// Dynamic Favicon Strategy: R2 Gateway (Production) -> Local Fallback (Dev)
const faviconUrl = gateway ? `${gateway}/${brandId}/assets/brand/favicon.svg` : "/favicon.svg";

// Fetch Modular Settings from Content Layer
const brandSettings = await getEntry("settings", "brand");
const marketingSettings = await getEntry("settings", "marketing");
const shippingSettings = await getEntry("settings", "shipping");
const affiliateSettings = isAffiliate ? await getEntry("settings", "affiliate_settings") : null;

const threshold = shippingSettings?.data?.free_shipping_threshold || 3000;
const discount_popup = marketingSettings?.data?.discount_popup;
const newsletter_popup = marketingSettings?.data?.newsletter_popup;

interface Props {
  pageTitle?: string;
  title?: string; // Legacy support
  description?: string;
  hideHeader?: boolean;
}

const {
  pageTitle,
  title,
  description = brandSettings?.data?.description,
  hideHeader = false,
} = Astro.props;

const brandName = brandSettings?.data?.name;
const fullTitle = pageTitle ? `${pageTitle} | ${brandName}` : (title || brandName);

const defaultRegionId = affiliateSettings?.data?.regions?.[0]?.id || 'india';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <noscript>
      <style>
        img { opacity: 1 !important; }
      </style>
    </noscript>
    <meta name="description" content={description} />
    
    <!-- Global Assets - Always sourced from public or R2 -->
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    
    <title>{fullTitle}</title>

    <!-- Universal Interactivity: Email Obfuscation Fix for ViewTransitions -->
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const cloudflareScript = document.querySelector('script[src*="email-decode.min.js"]');
        if (cloudflareScript) {
          const newScript = document.createElement('script');
          newScript.src = cloudflareScript.src;
          newScript.dataset.astroRerun = "";
          cloudflareScript.replaceWith(newScript);
        }
      });
    </script>
    {isAffiliate && (
      <script is:inline define:vars={{ defaultRegionId }}>
        // Synchronous Zero-CLS Pre-hydration
        try {
          const brandId = document.documentElement.dataset.brandId;
          const savedRegion = localStorage.getItem(`${brandId}_region`);
          const savedExpiry = localStorage.getItem(`${brandId}_region_expiry`);
          const now = new Date().getTime();
          
          if (savedRegion && savedExpiry && now < Number(savedExpiry)) {
            document.documentElement.dataset.activeRegion = savedRegion;
          } else {
            document.documentElement.dataset.activeRegion = defaultRegionId;
          }
        } catch (e) {
          document.documentElement.dataset.activeRegion = defaultRegionId;
        }
      </script>
    )}
    <slot name="head" />
  </head>
  <body class="flex flex-col min-h-screen" data-brand-id={brandId} data-regions={isAffiliate ? JSON.stringify(affiliateSettings?.data?.regions || []) : undefined}>
    {!hideHeader && (
      <Navbar />
    )}

    <main class="grow">
      {/* Engine Scripts (BrandEngine or AffiliateEngine) will be injected here by EngineLayout */}
      <slot />
    </main>

    <Footer />

    {/* Universal Interactivity Components */}
    {isAffiliate ? (
      <AffiliateQuickView />
    ) : (
      <SideDrawer threshold={threshold} />
    )}
    <PopupCoupon data={discount_popup} />
    <PopupNewsletter data={newsletter_popup} />
    <Lightbox />
  </body>
</html>
