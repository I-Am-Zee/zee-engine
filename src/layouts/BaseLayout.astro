---
// Import global CSS so Astro bundles it for production
import "../styles/global.css";
import { siteConfig } from "../lib/site.config";
import { getEntry } from "astro:content";
import CartToast from "../components/ui/CartToast.astro";
import AnnouncementBar from "../components/ui/AnnouncementBar.astro";
import PopupModal from "../components/ui/PopupModal.astro";
import Navbar from "../components/features/Navbar.astro";
import Footer from "../components/features/Footer.astro";
import SideDrawer from "../components/ui/SideDrawer.astro";

// Fetch Global Settings
const siteSettings = await getEntry("settings", "site");
const announcement_bar = siteSettings?.data?.announcement_bar;
const popup_modal = siteSettings?.data?.popup_modal;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${siteConfig.name} | ${siteConfig.tagline}`,
  description = siteConfig.description,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={siteConfig.assets.favicon} />
    <title>{title}</title>

    <!-- Snipcart v3 Preconnect for performance -->
    <link rel="preconnect" href="https://cdn.snipcart.com" />
    <link rel="preconnect" href="https://app.snipcart.com" />

    <!-- Snipcart CSS (using v3.4.0 - Vanilla/Default styling) -->
    <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.4.0/default/snipcart.css" />

    <!-- Snipcart JS (using v3.4.0, async loading) -->
    <script async src="https://cdn.snipcart.com/themes/v3.4.0/default/snipcart.js" is:inline></script>

    <script define:vars={{ apiKey: import.meta.env.PUBLIC_SNIPCART_API_KEY }} is:inline>
      window.SnipcartSettings = {
        publicApiKey: apiKey,
        loadStrategy: "on-idle",
        modalStyle: "overlay",
        addProductBehavior: "none", // Don't auto-open cart
      };

      // Inline Listener for immediate response to item.added
      document.addEventListener('snipcart.ready', () => {
        Snipcart.events.on('item.added', (item) => {
          console.log('[Upsell Bridge] Item added:', item.name);
          const event = new CustomEvent('zaviona:item-added', {
            detail: {
              id: item.id,
              name: item.name,
              image: item.image,
              price: item.unitPrice,
              options: item.customFields || []
            }
          });
          document.dispatchEvent(event);
        });
      });
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <AnnouncementBar data={announcement_bar} />
    <Navbar />

    <main class="grow">
      <slot />
    </main>

    <Footer />

    {/* Multi-purpose Side Drawer (Upsell, Quick Shop, Master Set) */}
    <SideDrawer />

    {/* Global Product Addition Notification */}
    <CartToast />

    <!-- Snipcart Root Container -->
    <div
      hidden
      id="snipcart"
      data-api-key={import.meta.env.PUBLIC_SNIPCART_API_KEY}
      data-config-modal-style="overlay"
      data-currency="INR"
      data-config-add-product-behavior="none"
    >
    </div>

    <!-- Alpine.js is now handled by @astrojs/alpinejs integration -->
    <!-- The entrypoint in astro.config.mjs registers the wishlist store before Alpine starts -->

    <!-- Global Snipcart Event Handler (Intent-Based Coupon System) -->
    <script src="../scripts/snipcart-events.ts"></script>
    <script src="../scripts/behaviors/options-sync.ts"></script>

    <PopupModal data={popup_modal} />
  </body>
</html>
