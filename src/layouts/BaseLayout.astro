---
// Import global CSS so Astro bundles it for production
import "../styles/global.css";
import { getEntry } from "astro:content";
import AnnouncementBar from "../components/ui/AnnouncementBar.astro";
import PopupModal from "../components/ui/PopupModal.astro";
import Navbar from "../components/features/Navbar.astro";
import Footer from "../components/features/Footer.astro";
import SideDrawer from "../components/ui/SideDrawer.astro";
import Lightbox from "../components/ui/Lightbox.astro";

// Fetch Modular Settings from Content Layer
const brandSettings = await getEntry("settings", "brand");
const marketingSettings = await getEntry("settings", "marketing");

const announcement_bar = marketingSettings?.data?.announcement_bar;
const popup_modal = marketingSettings?.data?.popup_modal;

interface Props {
  pageTitle?: string;
  title?: string; // Legacy support
  description?: string;
}

const {
  pageTitle,
  title,
  description = brandSettings?.data?.description,
} = Astro.props;

const brandName = brandSettings?.data?.name;
const fullTitle = pageTitle ? `${pageTitle} | ${brandName}` : (title || brandName);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    
    {/* Global Assets - Always sourced from public or R2 */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{fullTitle}</title>

    {/* Universal Interactivity: Email Obfuscation Fix for ViewTransitions */}
    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const cloudflareScript = document.querySelector('script[src*="email-decode.min.js"]');
        if (cloudflareScript) {
          const newScript = document.createElement('script');
          newScript.src = cloudflareScript.src;
          newScript.dataset.astroRerun = "";
          cloudflareScript.replaceWith(newScript);
        }
      });
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <AnnouncementBar data={announcement_bar} />
    <Navbar />

    <main class="grow">
      {/* Engine Scripts (BrandEngine or AffiliateEngine) will be injected here by EngineLayout */}
      <slot />
    </main>

    <Footer />

    {/* Universal Interactivity Components */}
    <SideDrawer />
    <PopupModal data={popup_modal} />
    <Lightbox />
  </body>
</html>



