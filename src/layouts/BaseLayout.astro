---
import CartToast from "../components/ui/CartToast.astro";

// Import custom Snipcart styling
import "../styles/snipcart-custom.css";

interface Props {
  title?: string;
}

const { title = "Zaviona E-commerce" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Global Styles including TailwindCSS and Theme -->
    <link rel="stylesheet" href="/src/styles/global.css" />

    <!-- Snipcart v3 Preconnect for performance -->
    <link rel="preconnect" href="https://cdn.snipcart.com" />
    <link rel="preconnect" href="https://app.snipcart.com" />

    <!-- Snipcart CSS (using v3.4.0 as in reference) -->
    <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.4.0/default/snipcart.css" />

    <!-- Snipcart JS (using v3.4.0 as in reference, async loading) -->
    <script async src="https://cdn.snipcart.com/themes/v3.4.0/default/snipcart.js"></script>

    <script define:vars={{ apiKey: import.meta.env.PUBLIC_SNIPCART_API_KEY }}>
      window.SnipcartSettings = {
        publicApiKey: apiKey,
        loadStrategy: 'on-idle',
        modalStyle: 'overlay',
        addProductBehavior: 'none'
      };
    </script>
  </head>
  <body>
    <slot />

    <!-- Cart Toast Notification -->
    <CartToast autoDismissMs={4000} />

    <!-- Snipcart Root Container -->
    <div
      hidden
      id="snipcart"
      data-api-key={import.meta.env.PUBLIC_SNIPCART_API_KEY}
      data-config-modal-style="overlay"
      data-currency="INR"
      data-config-add-product-behavior="none"
    >
    </div>

    <!-- Alpine.js is now handled by @astrojs/alpinejs integration -->
    <!-- The entrypoint in astro.config.mjs registers the wishlist store before Alpine starts -->
  </body>
</html>
