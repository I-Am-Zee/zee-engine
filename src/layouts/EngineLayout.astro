---
/**
 * Engine Layout
 * 
 * The smart middle layer that selects the correct engine
 * (Brand/D2C or Affiliate) based on environment variables.
 */
import BaseLayout from "./BaseLayout.astro";
import BrandEngine from "../components/features/BrandEngine.astro";
import AffiliateEngine from "../components/features/AffiliateEngine.astro";
import TrackingScripts from "../components/features/TrackingScripts.astro";

interface Props {
  title?: string;
  pageTitle?: string;
  description?: string;
  hideHeader?: boolean;
}

const { title, pageTitle, description, hideHeader = false } = Astro.props;
const isAffiliate = import.meta.env.PUBLIC_AFFILIATE === 'true';
---

<BaseLayout title={title} pageTitle={pageTitle} description={description} hideHeader={hideHeader}>
  {/* Inject tracking scripts into the head */}
  <TrackingScripts slot="head" />

  {/* Inject the correct Engine logic/scripts */}
  {isAffiliate ? <AffiliateEngine /> : <BrandEngine />}

  {/* Main Content Slot */}
  <slot />
</BaseLayout>
