---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/features/Navbar.astro";
import Footer from "../components/features/Footer.astro";
import Heading from "../components/primitives/Heading.astro";
import ProductCard from "../components/features/ProductCard.astro";
import ProductGrid from "../components/features/ProductGrid.astro";

// Fetch all products from the content collection
const allProducts = await getCollection("products");
---

<BaseLayout title="Shop All Jewelry | Zaviona">
  <Navbar />

  <div class="mx-auto max-w-7xl px-4 py-12 lg:px-8">
    {/* Page Header */}
    <div class="mb-8 border-b border-(--color-border-subtle) pb-6">
      <Heading as="h1" class="mb-2">All Jewelry</Heading>
      <p class="text-(--color-text-muted)">
        Discover our curated collection of handcrafted pieces
      </p>
    </div>

    {/* Product Grid */}
    <ProductGrid>
      {
        allProducts.map((product) => (
          <ProductCard
            id={product.slug}
            title={product.data.title}
            price={product.data.price}
            salePrice={product.data.salePrice}
            image={product.data.image}
            href={`/products/${product.slug}`}
            badges={product.data.badges}
            rating={product.data.rating}
          />
        ))
      }
    </ProductGrid>
  </div>

  <Footer />
</BaseLayout>
