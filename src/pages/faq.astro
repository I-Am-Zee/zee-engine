---
import BaseLayout from "../layouts/BaseLayout.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";

export const prerender = true;
---

<BaseLayout title="FAQ | Zaviona">
  <main class="mx-auto max-w-3xl px-4 py-24">
    <Heading as="h1" class="mb-12 text-center">Frequently Asked Questions</Heading>
    
    <div class="space-y-8">
      <div>
        <Heading as="h3" class="mb-2">Are your diamonds ethically sourced?</Heading>
        <Text variant="muted">Yes, all Zaviona diamonds are conflict-free and sourced following the Kimberley Process.</Text>
      </div>
      <div>
        <Heading as="h3" class="mb-2">Do you offer international shipping?</Heading>
        <Text variant="muted">Currently we ship within India and selected international markets. Please contact us for details.</Text>
      </div>
      <div>
        <Heading as="h3" class="mb-2">What is your return policy?</Heading>
        <Text variant="muted">We offer a 30-day return policy for unused items in their original packaging.</Text>
      </div>
    </div>
  </main>
</BaseLayout>
