---
export const prerender = false;
import { getEntry } from "astro:content";
import CheckoutLayout from "../../layouts/CheckoutLayout.astro";

import { getBrandSettings } from "../../scripts/utils/brand";

const publicToken = Astro.url.searchParams.get("publicToken");

// Guard: no token → back to home
if (!publicToken) {
  return Astro.redirect("/");
}

const razorpayKeyId = import.meta.env.PUBLIC_RAZORPAY_KEY_ID;
const siteUrl = Astro.url.origin;
const gateway = import.meta.env.PUBLIC_IMAGE_GATEWAY_URL || "";
import fs from "node:fs";
import path from "node:path";

const brandId = import.meta.env.PUBLIC_BRAND_ID;
if (!brandId) {
  throw new Error("PUBLIC_BRAND_ID is required for the checkout bridge.");
}

const brandSettings = await getBrandSettings();
const brandName = brandSettings.name;
const brandColor = brandSettings.primary_color || "#000000";

const checkoutPage = await getEntry("pages_content" as any, "checkout_razorpay");
if (!checkoutPage) {
  throw new Error("[Checkout Razorpay] Page content missing in 'pages_content/checkout_razorpay'.");
}
const hubData = checkoutPage.data;
const currencySymbol = "₹";

// Zee Engine Fallback Favicon (Base64) - Used only if brand favicon is missing
const fallbackFavicon = "data:image/svg+xml;base64,";

// Build-time check for local junctioned favicon
const localFaviconPath = path.join(process.cwd(), "public/images/assets/brand/favicon.svg");
const hasLocalFavicon = fs.existsSync(localFaviconPath);

// Dynamic Favicon Strategy: R2 Gateway (Production) -> Local Junction (Dev) -> Base64 (Fallback)
const faviconUrl = gateway 
  ? `${gateway}/${brandId}/assets/brand/favicon.svg` 
  : (hasLocalFavicon ? `${siteUrl}/images/assets/brand/favicon.svg` : fallbackFavicon);
---

<CheckoutLayout pageTitle={hubData.title}>
  <!-- Razorpay SDK injected into <head> via named slot -->
  <script is:inline slot="head" src="https://checkout.razorpay.com/v1/checkout.js"></script>

  <!-- ── Checkout Card ── -->
  <div class="w-full max-w-[460px] bg-(--color-surface) border border-(--color-border-subtle) rounded-xs overflow-hidden">
    <div class="h-[3px] bg-linear-to-r from-(--color-primary) to-(--color-accent)" aria-hidden="true"></div>

    <div class="p-10 pb-8 sm:px-6 sm:py-8">
      <p class="text-[0.6875rem] font-semibold tracking-[0.12em] uppercase text-(--color-accent) mb-2">Step 3 of 3</p>
      <h1 class="font-serif font-normal text-[1.75rem] tracking-tight text-(--color-primary) mb-1">{hubData.title}</h1>
      <p class="text-sm text-(--color-text-muted) mb-8 min-h-[1.25rem]" id="email-display">{hubData.subtitle_loading}</p>

      <!-- Amount — populated after session load -->
      <div id="amount-section" class="flex items-center justify-between bg-(--color-background) border border-(--color-border-subtle) rounded-xs p-5 px-6 mb-7 hidden" aria-live="polite">
        <div class="flex flex-col">
          <span class="text-[0.6875rem] font-semibold tracking-[0.1em] uppercase text-(--color-text-muted)">{hubData.amount_label}</span>
        </div>
        <div class="font-serif text-[2rem] font-normal text-(--color-primary) tracking-tight" id="amount-display" aria-label="Order total">{currencySymbol}0</div>
      </div>

      <!-- Pay CTA -->
      <button
        class="w-full px-8 py-3.5 font-sans text-[0.8125rem] font-semibold tracking-[0.1em] uppercase text-(--color-primary-foreground) bg-(--color-primary) border border-(--color-primary) rounded-xs cursor-pointer transition-all duration-200 hover:bg-transparent hover:text-(--color-primary) focus-glow disabled:opacity-50 disabled:cursor-not-allowed group"
        id="pay-button"
        disabled
        aria-label="Loading payment session"
      >
        <span class="inline-flex items-center justify-center gap-2.5" aria-hidden="true" id="pay-button-content">
          <span class="w-3.5 h-3.5 border-2 border-white/25 border-t-current rounded-full animate-spin group-hover:border-(--color-primary)/15"></span>
          {hubData.button_loading}
        </span>
      </button>

      <p class="mt-4 text-[0.8125rem] text-(--color-text-muted) text-center min-h-[1.25rem]" id="status" role="status" aria-live="polite"></p>
      <div class="mt-5 p-4 border-l-3 border-(--color-danger) bg-(--color-danger)/5 rounded-xs text-sm leading-relaxed text-(--color-danger) hidden" id="error" role="alert"></div>
    </div>

    <!-- Trust strip -->
    <div class="flex items-center justify-center gap-2.5 p-4 px-8 border-t border-(--color-border-subtle) bg-(--color-background) text-[0.6875rem] tracking-[0.06em] uppercase font-medium text-(--color-text-muted) sm:flex-wrap sm:gap-2 sm:px-5 sm:py-3.5" aria-label="Security information">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" class="text-(--color-accent) shrink-0" aria-hidden="true">
        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
      </svg>
      {hubData.trust_badge_ssl}
      <span class="w-[3px] h-[3px] rounded-full bg-(--color-border-subtle) shrink-0" aria-hidden="true"></span>
      {hubData.trust_badge_razorpay}
      <span class="w-[3px] h-[3px] rounded-full bg-(--color-border-subtle) shrink-0" aria-hidden="true"></span>
      {hubData.trust_badge_pci}
    </div>
  </div>

  <!-- ── Payment Logic ── -->
  <script define:vars={{ 
    publicToken, 
    razorpayKeyId, 
    siteUrl, 
    brandName, 
    brandColor,
    currencyCode: "INR",
    locale: "en-IN",
    hubData,
    faviconUrl
  }} is:inline>
    /** @type {object|null} */
    let paymentSession = null;

    // ── DOM refs ──
    const payButton     = document.getElementById("pay-button");
    const payContent    = document.getElementById("pay-button-content");
    const emailDisplay  = document.getElementById("email-display");
    const amountSection = document.getElementById("amount-section");
    const amountDisplay = document.getElementById("amount-display");
    const statusEl      = document.getElementById("status");
    const errorEl       = document.getElementById("error");

    // ── Helpers ──
    function showError(message, detail = "") {
      errorEl.textContent = detail ? `${message}: ${detail}` : message;
      errorEl.classList.remove("hidden");
    }

    function setStatus(message) {
      statusEl.textContent = message;
    }

    function formatCurrency(amount) {
      return new Intl.NumberFormat(locale, {
        style: "currency",
        currency: currencyCode,
        minimumFractionDigits: 0,
      }).format(amount);
    }

    function setButtonBusy(label) {
      payButton.disabled = true;
      payButton.setAttribute("aria-label", label);
      payContent.innerHTML = `<span class="w-3.5 h-3.5 border-2 border-white/25 border-t-current rounded-full animate-spin"></span>${label}`;
    }

    function setButtonReady(label) {
      payButton.disabled = false;
      payButton.setAttribute("aria-label", label);
      payContent.textContent = label;
    }

    // ── Step 1: Fetch Snipcart payment session ──
    async function fetchPaymentSession() {
      setStatus("Loading order details...");
      const params = new URLSearchParams({ publicToken });
      const url = `https://payment.snipcart.com/api/public/custom-payment-gateway/payment-session?${params}`;

      const response = await fetch(url);
      if (!response.ok) {
        throw new Error(`Session fetch failed (${response.status})`);
      }

      paymentSession = await response.json();

      // Populate UI
      emailDisplay.textContent = paymentSession.invoice.email || "Verified customer";
      amountDisplay.textContent = formatCurrency(paymentSession.invoice.amount);
      amountSection.classList.remove("hidden");
    }

    // ── Step 2: Open Razorpay Standard Checkout ──
    async function openRazorpay() {
      try {
        setStatus(hubData.status_opening);
        setButtonBusy("Initiating...");

        // Securely initiate Razorpay order on server
        const initRes = await fetch("/api/checkout/initiate", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            publicToken,
            paymentSessionId: paymentSession.id,
          }),
        });

        if (!initRes.ok) {
          const initErr = await initRes.json();
          throw new Error(initErr.error || "Failed to initiate secure order");
        }

        const { orderId, amount: amountInPaise, currency } = await initRes.json();

        const options = {
          key: razorpayKeyId,
          amount: amountInPaise,
          currency: currency,
          order_id: orderId, // CRITICAL: Locks the amount and enables signature verification
          name: brandName,
          description: `Order #${String(paymentSession.id).substring(0, 8).toUpperCase()}`,
          image: faviconUrl,
          prefill: {
            name:    paymentSession.invoice.billingAddress?.name || "",
            email:   paymentSession.invoice.email               || "",
            contact: "",
          },
          theme: { color: brandColor },
          modal: {
            ondismiss() {
              setStatus("Payment cancelled.");
              setButtonReady(hubData.button_ready);
            },
          },
          handler: async (response) => {
            await verifyPayment(response);
          },
        };

        const rzp = new Razorpay(options);
        rzp.on("payment.failed", (ev) => {
          showError("Payment failed", ev.error?.description || "Unknown error");
          setButtonReady("Try Again");
        });
        rzp.open();
      } catch (err) {
        console.error("[Razorpay] Initiation error:", err);
        showError("Security check failed", err.message);
        setButtonReady("Retry Checkout");
      }
    }

    // ── Step 3: Verify & confirm with Snipcart ──
    async function verifyPayment(razorpayResponse) {
      setButtonBusy("Verifying...");
      setStatus(hubData.status_verifying);

      const payload = {
        razorpay_payment_id: razorpayResponse.razorpay_payment_id,
        razorpay_order_id:   razorpayResponse.razorpay_order_id  || "",
        razorpay_signature:  razorpayResponse.razorpay_signature  || "",
        paymentSessionId: paymentSession.id,
        amount:   paymentSession.invoice.amount,
        currency: paymentSession.invoice.currency,
      };

      const res = await fetch("/api/checkout/verify", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const result = await res.json();

      if (result.success) {
        setStatus(hubData.status_confirmed);
        setButtonBusy("Redirecting...");
        const redirect = result.redirectUrl
          || paymentSession.paymentAuthorizationRedirectUrl
          || "/";
        window.location.href = redirect;
      } else {
        throw new Error(result.error || "Verification failed");
      }
    }

    // ── Boot ──
    async function init() {
      if (!razorpayKeyId) {
        showError(hubData.error_config);
        return;
      }
      try {
        await fetchPaymentSession();
        setButtonReady(hubData.button_ready);
        setStatus("");
        payButton.onclick = () => {
          setButtonBusy("Opening...");
          openRazorpay();
        };
      } catch (err) {
        showError(hubData.error_expired, err?.message);
        payButton.disabled = true;
        payButton.textContent = "Session Expired";
      }
    }

    init();
  </script>
</CheckoutLayout>
