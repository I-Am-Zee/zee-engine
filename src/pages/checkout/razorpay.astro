---
export const prerender = false;
import { getEntry } from "astro:content";

const publicToken = Astro.url.searchParams.get("publicToken");

// Guard: no token → back to home
if (!publicToken) {
  return Astro.redirect("/");
}

const razorpayKeyId = import.meta.env.PUBLIC_RAZORPAY_KEY_ID;
const siteUrl = Astro.url.origin;
const brandSettings = await getEntry("settings", "brand");
const ecommerceSettings = await getEntry("settings", "ecommerce");
const checkoutPage = await getEntry("page_checkout_razorpay", "checkout_razorpay");

// Hub Strategy: Fallbacks
const brandName = brandSettings?.data?.name || "Our Boutique";
const brandColor = brandSettings?.data?.primary_color || "#052b22";

const currencyCode = ecommerceSettings?.data?.currency_code || "INR";
const currencySymbol = ecommerceSettings?.data?.currency_symbol || "₹";
const locale = ecommerceSettings?.data?.locale || "en-IN";

const hubData = checkoutPage?.data || {
  title: "Payment",
  subtitle_loading: "Connecting securely…",
  amount_label: "Order Total",
  button_loading: "Loading…",
  button_ready: "Pay Now",
  status_opening: "Opening secure payment window…",
  status_verifying: "Confirming your payment…",
  status_confirmed: "✓ Payment confirmed! Redirecting…",
  error_expired: "Unable to load your order. The session may have expired.",
  error_config: "Configuration error — contact support",
  trust_badge_ssl: "256-bit SSL Encryption",
  trust_badge_razorpay: "Powered by Razorpay",
  trust_badge_pci: "PCI DSS Compliant",
};
---

<CheckoutLayout pageTitle={hubData.title}>
  <!-- Razorpay SDK injected into <head> via named slot -->
  <script slot="head" src="https://checkout.razorpay.com/v1/checkout.js"></script>

  <!-- ── Checkout Card ── -->
  <div class="checkout-card">
    <div class="card-accent" aria-hidden="true"></div>

    <div class="card-body">
      <p class="step-label">Step 3 of 3</p>
      <h1 class="card-title">{hubData.title}</h1>
      <p class="card-subtitle" id="email-display">{hubData.subtitle_loading}</p>

      <!-- Amount — populated after session load -->
      <div id="amount-section" class="amount-block hidden" aria-live="polite">
        <div class="amount-meta">
          <span class="amount-label">{hubData.amount_label}</span>
        </div>
        <div class="amount-value" id="amount-display" aria-label="Order total">{currencySymbol}0</div>
      </div>

      <!-- Pay CTA -->
      <button
        class="pay-button"
        id="pay-button"
        disabled
        aria-label="Loading payment session"
      >
        <span class="loader" aria-hidden="true">
          <span class="spinner"></span>
          {hubData.button_loading}
        </span>
      </button>

      <p class="status-text" id="status" role="status" aria-live="polite"></p>
      <div class="error-box hidden" id="error" role="alert"></div>
    </div>

    <!-- Trust strip -->
    <div class="trust-strip" aria-label="Security information">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
      </svg>
      {hubData.trust_badge_ssl}
      <span class="trust-dot" aria-hidden="true"></span>
      {hubData.trust_badge_razorpay}
      <span class="trust-dot" aria-hidden="true"></span>
      {hubData.trust_badge_pci}
    </div>
  </div>

  <!-- ── Payment Logic ── -->
  <script define:vars={{ 
    publicToken, 
    razorpayKeyId, 
    siteUrl, 
    brandName, 
    brandColor,
    currencyCode,
    locale,
    hubData
  }} is:inline>
    /** @type {object|null} */
    let paymentSession = null;

    // ── DOM refs ──
    const payButton     = document.getElementById("pay-button");
    const emailDisplay  = document.getElementById("email-display");
    const amountSection = document.getElementById("amount-section");
    const amountDisplay = document.getElementById("amount-display");
    const statusEl      = document.getElementById("status");
    const errorEl       = document.getElementById("error");

    // ── Helpers ──
    function showError(message, detail = "") {
      errorEl.textContent = detail ? `${message}: ${detail}` : message;
      errorEl.classList.remove("hidden");
    }

    function setStatus(message) {
      statusEl.textContent = message;
    }

    function formatCurrency(amount) {
      return new Intl.NumberFormat(locale, {
        style: "currency",
        currency: currencyCode,
        minimumFractionDigits: 0,
      }).format(amount);
    }

    function setButtonBusy(label) {
      payButton.disabled = true;
      payButton.setAttribute("aria-label", label);
      payButton.innerHTML = `<span class="loader" aria-hidden="true"><span class="spinner"></span>${label}</span>`;
    }

    function setButtonReady(label) {
      payButton.disabled = false;
      payButton.setAttribute("aria-label", label);
      payButton.textContent = label;
    }

    // ── Step 1: Fetch Snipcart payment session ──
    async function fetchPaymentSession() {
      setStatus("Loading order details...");
      const params = new URLSearchParams({ publicToken });
      const url = `https://payment.snipcart.com/api/public/custom-payment-gateway/payment-session?${params}`;

      const response = await fetch(url);
      if (!response.ok) {
        throw new Error(`Session fetch failed (${response.status})`);
      }

      paymentSession = await response.json();

      // Populate UI
      emailDisplay.textContent = paymentSession.invoice.email || "Verified customer";
      amountDisplay.textContent = formatCurrency(paymentSession.invoice.amount);
      amountSection.classList.remove("hidden");
    }

    // ── Step 2: Open Razorpay Standard Checkout ──
    function openRazorpay() {
      setStatus(hubData.status_opening);

      const amountInPaise = Math.round(paymentSession.invoice.amount * 100);

      const options = {
        key: razorpayKeyId,
        amount: amountInPaise,
        currency: currencyCode,
        name: brandName,
        description: `Order #${String(paymentSession.id).substring(0, 8).toUpperCase()}`,
        image: `${siteUrl}/favicon.svg`,
        prefill: {
          name:    paymentSession.invoice.billingAddress?.name || "",
          email:   paymentSession.invoice.email               || "",
          contact: "",
        },
        theme: { color: brandColor },
        modal: {
          ondismiss() {
            setStatus("Payment cancelled.");
            setButtonReady(hubData.button_ready);
          },
        },
        handler: async (response) => {
          await verifyPayment(response);
        },
      };

      const rzp = new Razorpay(options);
      rzp.on("payment.failed", (ev) => {
        showError("Payment failed", ev.error?.description || "Unknown error");
        setButtonReady("Try Again");
      });
      rzp.open();
    }

    // ── Step 3: Verify & confirm with Snipcart ──
    async function verifyPayment(razorpayResponse) {
      setButtonBusy("Verifying...");
      setStatus(hubData.status_verifying);

      const payload = {
        razorpay_payment_id: razorpayResponse.razorpay_payment_id,
        razorpay_order_id:   razorpayResponse.razorpay_order_id  || "",
        razorpay_signature:  razorpayResponse.razorpay_signature  || "",
        paymentSessionId: paymentSession.id,
        amount:   paymentSession.invoice.amount,
        currency: paymentSession.invoice.currency,
      };

      const res = await fetch("/api/checkout/verify", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const result = await res.json();

      if (result.success) {
        setStatus(hubData.status_confirmed);
        setButtonBusy("Redirecting...");
        const redirect = result.redirectUrl
          || paymentSession.paymentAuthorizationRedirectUrl
          || "/";
        window.location.href = redirect;
      } else {
        throw new Error(result.error || "Verification failed");
      }
    }

    // ── Boot ──
    async function init() {
      if (!razorpayKeyId) {
        showError(hubData.error_config);
        return;
      }
      try {
        await fetchPaymentSession();
        setButtonReady(hubData.button_ready);
        setStatus("");
        payButton.onclick = () => {
          setButtonBusy("Opening...");
          openRazorpay();
        };
      } catch (err) {
        showError(hubData.error_expired, err?.message);
        payButton.disabled = true;
        payButton.textContent = "Session Expired";
      }
    }

    init();
  </script>
</CheckoutLayout>

<style>
/* ── Card ── */
.checkout-card {
  width: 100%;
  max-width: 460px;
  background: var(--color-surface);
  border: 1px solid var(--color-border-subtle);
  border-radius: 2px;
  overflow: hidden;
}

.card-accent {
  height: 3px;
  background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-accent-brass) 100%);
}

.card-body {
  padding: 2.5rem 2.5rem 2rem;
}

/* ── Hierarchy ── */
.step-label {
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-accent-brass);
  margin-bottom: 0.5rem;
}

.card-title {
  font-family: var(--font-serif);
  font-weight: 400;
  font-size: 1.75rem;
  letter-spacing: 0.01em;
  color: var(--color-primary);
  margin-bottom: 0.25rem;
}

.card-subtitle {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  margin-bottom: 2rem;
  min-height: 1.25rem;
}

/* ── Amount block ── */
.amount-block {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-background);
  border: 1px solid var(--color-border-subtle);
  border-radius: 2px;
  padding: 1.25rem 1.5rem;
  margin-bottom: 1.75rem;
}

.amount-label {
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.amount-value {
  font-family: var(--font-serif);
  font-size: 2rem;
  font-weight: 400;
  color: var(--color-primary);
  letter-spacing: -0.01em;
}

/* ── CTA ── */
.pay-button {
  width: 100%;
  padding: 0.9375rem 2rem;
  font-family: var(--font-sans-serif);
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-primary-foreground);
  background: var(--color-primary);
  border: 1px solid var(--color-primary);
  border-radius: 2px;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, box-shadow 0.2s;
  outline: none;
}

.pay-button:hover:not(:disabled) {
  background: transparent;
  color: var(--color-primary);
}

.pay-button:focus-visible {
  box-shadow:
    0 0 0 2px var(--color-background),
    0 0 0 4px var(--color-accent-brass),
    0 0 12px var(--color-ring-glow);
}

.pay-button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Spinner */
.loader {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.625rem;
}

.spinner {
  width: 14px; height: 14px;
  border: 2px solid rgba(255,255,255,0.25);
  border-top-color: currentColor;
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
}

.pay-button:hover .spinner {
  border-color: rgba(5,43,34,0.15);
  border-top-color: var(--color-primary);
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ── Trust strip ── */
.trust-strip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.625rem;
  padding: 1rem 2rem;
  border-top: 1px solid var(--color-border-subtle);
  background: var(--color-background);
  font-size: 0.6875rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  font-weight: 500;
  color: var(--color-text-muted);
}

.trust-strip svg { color: var(--color-accent-brass); flex-shrink: 0; }

.trust-dot {
  width: 3px; height: 3px;
  border-radius: 50%;
  background: var(--color-border-subtle);
}

/* ── Status / Error ── */
.status-text {
  margin-top: 1rem;
  font-size: 0.8125rem;
  color: var(--color-text-muted);
  text-align: center;
  min-height: 1.25rem;
}

.error-box {
  margin-top: 1.25rem;
  padding: 1rem 1.25rem;
  border-left: 3px solid var(--color-accent-coral);
  background: rgba(230, 81, 66, 0.05);
  border-radius: 2px;
  font-size: 0.875rem;
  line-height: 1.6;
  color: var(--color-accent-coral);
}

.hidden { display: none !important; }

@media (max-width: 480px) {
  .card-body { padding: 2rem 1.5rem 1.5rem; }
  .amount-value { font-size: 1.625rem; }
  .trust-strip { flex-wrap: wrap; gap: 0.5rem; padding: 0.875rem 1.25rem; }
}
</style>
