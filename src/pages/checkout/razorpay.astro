---
/**
 * Razorpay Payment Page
 * 
 * Customer-facing payment page that:
 * 1. Receives publicToken from Snipcart redirect
 * 2. Fetches payment session details
 * 3. Creates Razorpay order
 * 4. Shows Razorpay checkout
 * 5. On success, verifies and confirms payment
 */

// This page needs to be server-rendered
export const prerender = false;

const publicToken = Astro.url.searchParams.get('publicToken');

// Redirect if no token
if (!publicToken) {
  return Astro.redirect('/');
}

// Get Razorpay key for client-side
const razorpayKeyId = import.meta.env.PUBLIC_RAZORPAY_KEY_ID;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || Astro.url.origin;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Complete Payment - Zaviona</title>
  
  <!-- Razorpay Checkout Script -->
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  
  <style>
    :root {
      --color-background: #0a0a0a;
      --color-surface: #141414;
      --color-text: #fafafa;
      --color-text-muted: #a1a1aa;
      --color-primary: #d4af37;
      --color-border: #27272a;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--color-background);
      color: var(--color-text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .container {
      max-width: 480px;
      width: 100%;
      padding: 2rem;
    }
    
    .card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 16px;
      padding: 2rem;
      text-align: center;
    }
    
    .logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      color: var(--color-primary);
      margin-bottom: 1.5rem;
    }
    
    .title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
    
    .subtitle {
      color: var(--color-text-muted);
      font-size: 0.875rem;
      margin-bottom: 2rem;
    }
    
    .amount {
      font-size: 2.5rem;
      font-weight: 700;
      color: var(--color-primary);
      margin-bottom: 0.5rem;
    }
    
    .currency {
      font-size: 1rem;
      color: var(--color-text-muted);
      margin-bottom: 2rem;
    }
    
    .pay-button {
      width: 100%;
      padding: 1rem 2rem;
      font-size: 1rem;
      font-weight: 600;
      color: #000;
      background: var(--color-primary);
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    
    .pay-button:hover {
      background: #e5c04b;
      transform: translateY(-1px);
    }
    
    .pay-button:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }
    
    .loader {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    .spinner {
      width: 20px;
      height: 20px;
      border: 2px solid transparent;
      border-top-color: currentColor;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    
    .error {
      background: #450a0a;
      border: 1px solid #7f1d1d;
      color: #fecaca;
      padding: 1rem;
      border-radius: 8px;
      margin-top: 1rem;
      font-size: 0.875rem;
    }
    
    .status {
      margin-top: 1rem;
      font-size: 0.875rem;
      color: var(--color-text-muted);
    }
    
    .hidden {
      display: none;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="logo">Zaviona</div>
      
      <h1 class="title">Complete Your Payment</h1>
      <p class="subtitle" id="email-display">Loading order details...</p>
      
      <div id="amount-section" class="hidden">
        <div class="amount" id="amount-display">₹0</div>
        <div class="currency">Indian Rupees (INR)</div>
      </div>
      
      <button class="pay-button" id="pay-button" disabled>
        <span class="loader">
          <span class="spinner"></span>
          Loading...
        </span>
      </button>
      
      <div class="status" id="status"></div>
      <div class="error hidden" id="error"></div>
    </div>
  </div>

  <script define:vars={{ publicToken, razorpayKeyId, siteUrl }}>
    // State
    let paymentSession = null;
    let razorpayOrder = null;
    
    // DOM Elements
    const payButton = document.getElementById('pay-button');
    const emailDisplay = document.getElementById('email-display');
    const amountSection = document.getElementById('amount-section');
    const amountDisplay = document.getElementById('amount-display');
    const statusEl = document.getElementById('status');
    const errorEl = document.getElementById('error');
    
    // Helper Functions
    function showError(message) {
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
    }
    
    function updateStatus(message) {
      statusEl.textContent = message;
    }
    
    function formatCurrency(amount, currency = 'INR') {
      return new Intl.NumberFormat('en-IN', { 
        style: 'currency', 
        currency: currency 
      }).format(amount);
    }
    
    // Step 1: Fetch payment session from Snipcart
    async function fetchPaymentSession() {
      updateStatus('Fetching order details...');
      
      try {
        const response = await fetch(
          `https://payment.snipcart.com/api/public/custom-payment-gateway/payment-session?publicToken=${publicToken}`
        );
        
        if (!response.ok) {
          throw new Error('Failed to fetch payment session');
        }
        
        paymentSession = await response.json();
        console.log('Payment session:', paymentSession);
        
        // Update UI
        emailDisplay.textContent = paymentSession.invoice.email;
        amountDisplay.textContent = formatCurrency(paymentSession.invoice.amount, paymentSession.invoice.currency);
        amountSection.classList.remove('hidden');
        
        return paymentSession;
      } catch (error) {
        console.error('Error fetching payment session:', error);
        showError('Failed to load order details. Please try again.');
        throw error;
      }
    }
    
    // Step 2: Open Razorpay checkout directly (no order creation needed)
    function openRazorpayCheckout() {
      updateStatus('Opening payment gateway...');
      
      // Calculate amount in paise for Razorpay
      // Note: We force INR currency because Razorpay only supports INR for Indian merchants
      // If Snipcart sends USD/CAD, we need to handle currency conversion separately
      const amountInPaise = Math.round(paymentSession.invoice.amount * 100);
      
      const options = {
        key: razorpayKeyId,
        amount: amountInPaise,
        currency: 'INR', // Force INR - Razorpay only supports INR for Indian merchants
        name: 'Zaviona',
        description: `Order #${paymentSession.id.substring(0, 8)}`,
        // order_id: razorpayOrder.orderId, // No longer needed
        prefill: {
          name: paymentSession.invoice.billingAddress?.name || '',
          email: paymentSession.invoice.email || '',
          contact: ''
        },
        theme: {
          color: '#d4af37'
        },
        handler: async function(response) {
          console.log('Razorpay success:', response);
          await verifyPayment(response);
        },
        modal: {
          ondismiss: function() {
            updateStatus('Payment cancelled. Click the button to try again.');
            payButton.disabled = false;
            payButton.innerHTML = 'Pay Now';
          }
        }
      };
      
      const rzp = new Razorpay(options);
      rzp.on('payment.failed', function(response) {
        console.error('Razorpay payment failed:', response.error);
        showError(`Payment failed: ${response.error.description}`);
        payButton.disabled = false;
        payButton.innerHTML = 'Try Again';
      });
      
      rzp.open();
    }
    
    // Step 3: Verify payment
    async function verifyPayment(razorpayResponse) {
      updateStatus('Verifying payment...');
      payButton.disabled = true;
      payButton.innerHTML = '<span class="loader"><span class="spinner"></span> Verifying...</span>';
      
      try {
        const response = await fetch(`${siteUrl}/api/checkout/verify`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            razorpay_payment_id: razorpayResponse.razorpay_payment_id,
            razorpay_order_id: razorpayResponse.razorpay_order_id || '', // Order ID might not be present for direct payments
            razorpay_signature: razorpayResponse.razorpay_signature || '', // Signature might not be present for direct payments
            paymentSessionId: paymentSession.id,
            amount: paymentSession.invoice.amount,
            currency: paymentSession.invoice.currency
          })
        });
        
        const result = await response.json();
        console.log('Verification result:', result);
        
        if (result.success) {
          updateStatus('Payment successful! Redirecting...');
          payButton.innerHTML = '✓ Payment Complete';
          
          // Redirect back to Snipcart confirmation
          if (result.redirectUrl) {
            window.location.href = result.redirectUrl;
          } else if (paymentSession.paymentAuthorizationRedirectUrl) {
            window.location.href = paymentSession.paymentAuthorizationRedirectUrl;
          } else {
            // Fallback: go to home
            setTimeout(() => {
              window.location.href = '/';
            }, 2000);
          }
        } else {
          throw new Error(result.error || 'Payment verification failed');
        }
      } catch (error) {
        console.error('Error verifying payment:', error);
        showError('Payment verification failed. Please contact support.');
        payButton.disabled = false;
        payButton.innerHTML = 'Try Again';
      }
    }
    
    // Initialize
    async function init() {
      try {
        await fetchPaymentSession();
        // await createRazorpayOrder(); // No longer needed
        
        // Enable pay button - NO ORDER CREATION NEEDED
        payButton.disabled = false;
        payButton.innerHTML = 'Pay Now';
        updateStatus('Ready to pay');
        
        // Set up click handler
        payButton.onclick = () => {
          payButton.disabled = true;
          payButton.innerHTML = '<span class="loader"><span class="spinner"></span> Opening checkout...</span>';
          openRazorpayCheckout();
        };
        
      } catch (error) {
        payButton.disabled = true;
        payButton.innerHTML = 'Error';
      }
    }
    
    // Start
    init();
  </script>
</body>
</html>
