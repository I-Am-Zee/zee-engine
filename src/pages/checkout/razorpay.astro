---
/**
 * Razorpay Payment Page
 *
 * Customer-facing payment page that:
 * 1. Receives publicToken from Snipcart redirect
 * 2. Fetches payment session details
 * 3. Creates Razorpay order
 * 4. Shows Razorpay checkout
 * 5. On success, verifies and confirms payment
 */

// This page needs to be server-rendered
export const prerender = false;

const publicToken = Astro.url.searchParams.get("publicToken");

// Redirect if no token
if (!publicToken) {
  return Astro.redirect("/");
}

// Get Razorpay key for client-side
const razorpayKeyId = import.meta.env.PUBLIC_RAZORPAY_KEY_ID;
const siteUrl = Astro.url.origin || import.meta.env.PUBLIC_SITE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Complete Payment - Zelia Vance</title>

    <!-- Razorpay Checkout Script -->
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap");

      :root {
        --color-background: #ffffff;
        --color-text: #171717;
        --color-text-muted: #737373;
        --color-border: #e5e5e5;
        --color-primary: #000000;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background: var(--color-background);
        color: var(--color-text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem;
        -webkit-font-smoothing: antialiased;
      }

      header {
        width: 100%;
        padding-top: 2rem;
        padding-bottom: 4rem;
        text-align: center;
      }

      .logo {
        font-size: 1.5rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-primary);
      }

      .container {
        max-width: 420px;
        width: 100%;
        margin: 0 auto;
        padding: 3rem 0;
      }

      .checkout-header {
        margin-bottom: 3rem;
        text-align: center;
      }

      .title {
        font-size: 1.125rem;
        font-weight: 400;
        color: var(--color-text);
        margin-bottom: 0.5rem;
      }

      .subtitle {
        color: var(--color-text-muted);
        font-size: 0.875rem;
        font-weight: 400;
      }

      .order-summary {
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        padding: 2rem 0;
        margin-bottom: 3rem;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .amount {
        font-size: 3rem;
        font-weight: 300;
        color: var(--color-text);
        margin-bottom: 0.25rem;
        letter-spacing: -0.02em;
      }

      .currency {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-text-muted);
      }

      .pay-button {
        width: 100%;
        padding: 1rem 2rem;
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #ffffff;
        background: var(--color-primary);
        border: 1px solid var(--color-primary);
        cursor: pointer;
        transition: all 0.2s ease;
      }

      .pay-button:hover:not(:disabled) {
        background: #ffffff;
        color: var(--color-primary);
      }

      .pay-button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .loader {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
      }

      .spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: currentColor;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }

      .pay-button:hover .spinner {
        border-color: rgba(0, 0, 0, 0.2);
        border-top-color: var(--color-primary);
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      .error {
        margin-top: 2rem;
        padding: 1rem;
        background: #fafafa;
        border-left: 2px solid #ef4444;
        color: #dc2626;
        font-size: 0.875rem;
        line-height: 1.5;
      }

      .status {
        margin-top: 1.5rem;
        font-size: 0.875rem;
        color: var(--color-text-muted);
        text-align: center;
      }

      .hidden { display: none; }
      
      .secure-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 2rem;
        font-size: 0.75rem;
        color: var(--color-text-muted);
      }
      .secure-badge svg {
        width: 14px;
        height: 14px;
        fill: currentColor;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="logo">Zelia Vance</div>
    </header>

    <div class="container">
      <div class="checkout-header">
        <h1 class="title">Secure Checkout</h1>
        <p class="subtitle" id="email-display">Preparing your connection...</p>
      </div>

      <div id="amount-section" class="order-summary hidden">
        <div class="amount" id="amount-display">₹0</div>
        <div class="currency">INR &bull; Secure Payment</div>
      </div>

      <button class="pay-button" id="pay-button" disabled>
        <span class="loader">
          <span class="spinner"></span>
          Loading Session
        </span>
      </button>

      <div class="secure-badge">
        <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
        Encrypted via Razorpay
      </div>

      <div class="status" id="status"></div>
      <div class="error hidden" id="error"></div>
    </div>

    <script define:vars={{ publicToken, razorpayKeyId, siteUrl }} is:inline>
      // State
      let paymentSession = null;
      let razorpayOrder = null;

      // DOM Elements
      const payButton = document.getElementById("pay-button");
      const emailDisplay = document.getElementById("email-display");
      const amountSection = document.getElementById("amount-section");
      const amountDisplay = document.getElementById("amount-display");
      const statusEl = document.getElementById("status");
      const errorEl = document.getElementById("error");

      // Helper Functions
      function showError(message, details = "") {
        errorEl.textContent = message + (details ? ": " + details : "");
        errorEl.classList.remove("hidden");
        console.error("Payment Error:", message, details);
      }

      function updateStatus(message) {
        console.log("Status update:", message);
        statusEl.textContent = message;
      }

      function formatCurrency(amount, currency = "INR") {
        return new Intl.NumberFormat("en-IN", {
          style: "currency",
          currency: currency,
        }).format(amount);
      }

      // Step 1: Fetch payment session from Snipcart
      async function fetchPaymentSession() {
        updateStatus("Fetching order details...");

        try {
          const params = new URLSearchParams({ publicToken });
          const url = `https://payment.snipcart.com/api/public/custom-payment-gateway/payment-session?${params.toString()}`;

          console.log("[Razorpay] Fetching session from:", url);

          const response = await fetch(url);

          if (!response.ok) {
            const errorText = await response.text();
            console.error("[Razorpay] Session fetch failed:", response.status, errorText);
            throw new Error(`Failed to fetch payment session: ${response.status}`);
          }

          paymentSession = await response.json();
          console.log("[Razorpay] Payment session loaded:", paymentSession);

          // Update UI
          emailDisplay.textContent = paymentSession.invoice.email;
          amountDisplay.textContent = formatCurrency(
            paymentSession.invoice.amount,
            paymentSession.invoice.currency
          );
          amountSection.classList.remove("hidden");

          return paymentSession;
        } catch (error) {
          console.error("[Razorpay] Error in fetchPaymentSession:", error);
          showError(
            "Failed to load order details. This usually happens if the payment session has expired or the token is invalid.",
            error.message
          );
          throw error;
        }
      }

      // Step 2: Open Razorpay checkout directly (no order creation needed)
      function openRazorpayCheckout() {
        updateStatus("Opening payment gateway...");

        // Calculate amount in paise for Razorpay
        // Note: We force INR currency because Razorpay only supports INR for Indian merchants
        // If Snipcart sends USD/CAD, we need to handle currency conversion separately
        const amountInPaise = Math.round(paymentSession.invoice.amount * 100);

        const options = {
          key: razorpayKeyId,
          amount: amountInPaise,
          currency: "INR", // Force INR - Razorpay only supports INR for Indian merchants
          name: "Zelia Vance",
          description: `Order #${paymentSession.id.substring(0, 8)}`,
          // order_id: razorpayOrder.orderId, // No longer needed
          prefill: {
            name: paymentSession.invoice.billingAddress?.name || "",
            email: paymentSession.invoice.email || "",
            contact: "",
          },
          theme: {
            color: "#d4af37",
          },
          handler: async function (response) {
            console.log("Razorpay success:", response);
            await verifyPayment(response);
          },
          modal: {
            ondismiss: function () {
              updateStatus("Payment cancelled. Click the button to try again.");
              payButton.disabled = false;
              payButton.innerHTML = "Pay Now";
            },
          },
        };

        const rzp = new Razorpay(options);
        rzp.on("payment.failed", function (response) {
          console.error("Razorpay payment failed:", response.error);
          showError(`Payment failed: ${response.error.description}`);
          payButton.disabled = false;
          payButton.innerHTML = "Try Again";
        });

        rzp.open();
      }

      // Step 3: Verify payment
      async function verifyPayment(razorpayResponse) {
        updateStatus("Verifying payment...");
        payButton.disabled = true;
        payButton.innerHTML =
          '<span class="loader"><span class="spinner"></span> Verifying...</span>';

        try {
          const payload = {
            razorpay_payment_id: razorpayResponse.razorpay_payment_id,
            razorpay_order_id: razorpayResponse.razorpay_order_id || "", // Order ID might not be present for direct payments
            razorpay_signature: razorpayResponse.razorpay_signature || "", // Signature might not be present for direct payments
            paymentSessionId: paymentSession.id,
            amount: paymentSession.invoice.amount,
            currency: paymentSession.invoice.currency,
          };

          console.log("Sending verification payload:", payload);

          const response = await fetch(`/api/checkout/verify`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          const result = await response.json();
          console.log("Verification result:", result);

          if (result.success) {
            updateStatus("Payment successful! Redirecting...");
            payButton.innerHTML = "✓ Payment Complete";

            // Redirect back to Snipcart confirmation
            if (result.redirectUrl) {
              window.location.href = result.redirectUrl;
            } else if (paymentSession.paymentAuthorizationRedirectUrl) {
              window.location.href = paymentSession.paymentAuthorizationRedirectUrl;
            } else {
              // Fallback: go to home
              setTimeout(() => {
                window.location.href = "/";
              }, 2000);
            }
          } else {
            throw new Error(result.error || "Payment verification failed");
          }
        } catch (error) {
          console.error("Error verifying payment:", error);
          showError("Payment verification failed. Please contact support.");
          payButton.disabled = false;
          payButton.innerHTML = "Try Again";
        }
      }

      // Initialize
      async function init() {
        console.log("Payment initialized with token:", publicToken ? "YES" : "NO");
        if (!razorpayKeyId) console.error("PUBLIC_RAZORPAY_KEY_ID is missing!");

        try {
          await fetchPaymentSession();
          // await createRazorpayOrder(); // No longer needed

          // Enable pay button - NO ORDER CREATION NEEDED
          payButton.disabled = false;
          payButton.innerHTML = "Pay Now";
          updateStatus("Ready to pay");

          // Set up click handler
          payButton.onclick = () => {
            payButton.disabled = true;
            payButton.innerHTML =
              '<span class="loader"><span class="spinner"></span> Opening checkout...</span>';
            openRazorpayCheckout();
          };
        } catch (error) {
          payButton.disabled = true;
          payButton.innerHTML = "Error";
        }
      }

      // Start
      init();
    </script>
  </body>
</html>
