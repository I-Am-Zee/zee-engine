---
/**
 * Stripe Payment Page
 * 
 * Customer-facing payment page for international customers
 * 1. Receives publicToken from Snipcart redirect
 * 2. Fetches payment session details
 * 3. Creates Stripe Payment Intent
 * 4. Shows Stripe Elements checkout
 * 5. On success, verifies and confirms payment
 * 
 * NOTE: This integration is ready but dormant until you:
 * 1. Add STRIPE_SECRET_KEY to environment variables
 * 2. Add PUBLIC_STRIPE_PUBLISHABLE_KEY to environment variables  
 * 3. Enable stripe gateway in src/lib/payments/config.ts
 */

// This page needs to be server-rendered
export const prerender = false;

const publicToken = Astro.url.searchParams.get('publicToken');

// Redirect if no token
if (!publicToken) {
  return Astro.redirect('/');
}

// Get Stripe key for client-side
const stripePublishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY;
const siteUrl = Astro.url.origin || import.meta.env.PUBLIC_SITE_URL;

// Check if Stripe is configured
const stripeConfigured = !!stripePublishableKey;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Complete Payment - Zaviona</title>
  
  {stripeConfigured && (
    <!-- Stripe.js -->
    <script src="https://js.stripe.com/v3/"></script>
  )}
  
  <style>
    :root {
      --color-background: #0a0a0a;
      --color-surface: #141414;
      --color-text: #fafafa;
      --color-text-muted: #a1a1aa;
      --color-primary: #d4af37;
      --color-border: #27272a;
      --color-error: #ef4444;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--color-background);
      color: var(--color-text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .container {
      max-width: 480px;
      width: 100%;
      padding: 2rem;
    }
    
    .card {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 16px;
      padding: 2rem;
    }
    
    .logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 500;
      text-align: center;
      margin-bottom: 2rem;
      color: var(--color-primary);
    }
    
    .status {
      text-align: center;
      margin-bottom: 1.5rem;
      color: var(--color-text-muted);
      font-size: 0.875rem;
    }
    
    .error {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.3);
      color: var(--color-error);
      padding: 1rem;
      border-radius: 8px;
      margin-bottom: 1rem;
      font-size: 0.875rem;
    }
    
    #payment-element {
      margin-bottom: 1.5rem;
    }
    
    .pay-button {
      width: 100%;
      padding: 1rem;
      background: var(--color-primary);
      color: black;
      border: none;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    
    .pay-button:hover:not(:disabled) {
      opacity: 0.9;
    }
    
    .pay-button:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    
    .spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(0, 0, 0, 0.1);
      border-top-color: currentColor;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }
    
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    
    .loader {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="logo">Zaviona</div>
      
      <div id="error-message" class="error" style="display: none;"></div>
      <div id="status-message" class="status">Loading payment details...</div>
      
      {!stripeConfigured ? (
        <div class="error">
          Stripe is not configured yet. Please add STRIPE_SECRET_KEY and PUBLIC_STRIPE_PUBLISHABLE_KEY to environment variables.
        </div>
      ) : (
        <>
          <form id="payment-form">
            <div id="payment-element"></div>
            <button type="submit" id="pay-button" class="pay-button cursor-pointer disabled:cursor-not-allowed" disabled>
              <span class="loader"><span class="spinner"></span> Preparing...</span>
            </button>
          </form>
        </>
      )}
    </div>
  </div>

  {stripeConfigured && (
    <script define:vars={{ publicToken, stripePublishableKey, siteUrl }} is:inline>
    // Initialize Stripe
    const stripe = Stripe(stripePublishableKey);
    
    // UI elements
    const form = document.getElementById('payment-form');
    const payButton = document.getElementById('pay-button');
    const statusMessage = document.getElementById('status-message');
    const errorMessage = document.getElementById('error-message');
    
    let elements;
    let paymentSession = null;
    let clientSecret = null;
    
    // Utility functions
    function updateStatus(message) {
      statusMessage.textContent = message;
      statusMessage.style.display = 'block';
    }
    
    function showError(message) {
      errorMessage.textContent = message;
      errorMessage.style.display = 'block';
      statusMessage.style.display = 'none';
    }
    
    function hideError() {
      errorMessage.style.display = 'none';
    }
    
    // Step 1: Fetch payment session from Snipcart
    async function fetchPaymentSession() {
      try {
        updateStatus('Loading order details...');
        
        const response = await fetch(
          `https://payment.snipcart.com/api/public/custom-payment-gateway/payment-session?publicToken=${publicToken}`
        );
        
        if (!response.ok) {
          throw new Error('Failed to fetch payment session');
        }
        
        paymentSession = await response.json();
        console.log('[stripe] Payment session loaded:', paymentSession);
        
        return paymentSession;
      } catch (error) {
        console.error('[stripe] Error fetching payment session:', error);
        showError('Failed to load order details. Please try again.');
        throw error;
      }
    }
    
    // Step 2: Create Stripe Payment Intent
    async function createPaymentIntent() {
      try {
        updateStatus('Preparing payment gateway...');
        
        const response = await fetch(`${siteUrl}/api/checkout/stripe-create-intent`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            paymentSessionId: paymentSession.id,
            amount: paymentSession.invoice.amount,
            currency: paymentSession.invoice.currency,
            email: paymentSession.invoice.email,
          })
        });
        
        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.error || 'Failed to create payment intent');
        }
        
        const result = await response.json();
        clientSecret = result.clientSecret;
        console.log('[stripe] Payment intent created');
        
        return clientSecret;
      } catch (error) {
        console.error('[stripe] Error creating payment intent:', error);
        showError(error.message);
        throw error;
      }
    }
    
    // Step 3: Initialize Stripe Elements
    async function initializeStripeElements() {
      elements = stripe.elements({ clientSecret });
      
      const paymentElement = elements.create('payment');
      paymentElement.mount('#payment-element');
      
      payButton.disabled = false;
      payButton.innerHTML = 'Pay Now';
      updateStatus('Enter your payment details');
    }
    
    // Step 4: Handle form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      payButton.disabled = true;
      payButton.innerHTML = '<span class="loader"><span class="spinner"></span> Processing...</span>';
      hideError();
      updateStatus('Processing payment...');
      
      const { error } = await stripe.confirmPayment({
        elements,
        confirmParams: {
          return_url: `${siteUrl}/checkout/stripe-success?publicToken=${publicToken}`,
        },
      });
      
      if (error) {
        console.error('[stripe] Payment failed:', error);
        showError(error.message);
        payButton.disabled = false;
        payButton.innerHTML = 'Try Again';
        updateStatus('');
      }
    });
    
    // Initialize
    async function init() {
      try {
        await fetchPaymentSession();
        await createPaymentIntent();
        await initializeStripeElements();
      } catch (error) {
        payButton.disabled = true;
        payButton.innerHTML = 'Error';
      }
    }
    
    init();
    </script>
  )}
</body>
</html>
