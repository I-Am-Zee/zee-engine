---
/**
 * Stripe Payment Page
 * 
 * Customer-facing payment page for international customers
 * 1. Receives publicToken from Snipcart redirect
 * 2. Fetches payment session details
 * 3. Creates Stripe Payment Intent
 * 4. Shows Stripe Elements checkout
 * 5. On success, verifies and confirms payment
 * 
 * NOTE: This integration is ready but dormant until you:
 * 1. Add STRIPE_SECRET_KEY to environment variables
 * 2. Add PUBLIC_STRIPE_PUBLISHABLE_KEY to environment variables  
 * 3. Enable stripe gateway in src/lib/payments/config.ts
 */

// This page needs to be server-rendered
export const prerender = false;
import { getEntry } from "astro:content";
import CheckoutLayout from "../../layouts/CheckoutLayout.astro";

const publicToken = Astro.url.searchParams.get('publicToken');

// Redirect if no token
if (!publicToken) {
  return Astro.redirect('/');
}

// Get Stripe key for client-side
const stripePublishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY;
const siteUrl = Astro.url.origin || import.meta.env.PUBLIC_SITE_URL;

// Check if Stripe is configured
const stripeConfigured = !!stripePublishableKey;

const brandSettings = await getEntry("settings", "brand");
const brandName = brandSettings?.data?.name || "Our Boutique";
---

<CheckoutLayout pageTitle="Secure Checkout">
  {stripeConfigured && (
    <script slot="head" src="https://js.stripe.com/v3/"></script>
  )}

  <div class="w-full max-w-[480px]">
    <div class="bg-(--color-surface) border border-(--color-border-subtle) rounded-[4px] p-10">
      <div class="font-serif text-[2rem] text-(--color-primary) text-center mb-8">{brandName}</div>
      
      <div id="error-message" class="bg-(--color-accent-coral)/5 border border-(--color-accent-coral)/20 text-(--color-accent-coral) p-4 rounded-[4px] mb-6 text-sm" style="display: none;"></div>
      <div id="status-message" class="text-center mb-6 text-(--color-text-muted) text-sm">Loading payment details...</div>
      
      {!stripeConfigured ? (
        <div class="bg-(--color-accent-coral)/5 border border-(--color-accent-coral)/20 text-(--color-accent-coral) p-4 rounded-[4px] mb-6 text-sm">
          Stripe is not configured yet. Please add settings to environment variables.
        </div>
      ) : (
        <form id="payment-form">
          <div id="payment-element"></div>
          <button type="submit" id="pay-button" class="w-full p-4 bg-(--color-primary) text-(--color-primary-foreground) border-none rounded-[4px] font-semibold cursor-pointer uppercase tracking-[0.1em] mt-6 disabled:opacity-50 disabled:cursor-not-allowed group">
            <span id="pay-button-content" class="flex items-center justify-center gap-3">
              <span class="inline-block w-3.5 h-3.5 border-2 border-white/20 border-t-white rounded-full animate-spin"></span> Preparing...
            </span>
          </button>
        </form>
      )}
    </div>
  </div>

  {stripeConfigured && (
    <script define:vars={{ publicToken, stripePublishableKey, siteUrl }} is:inline>
    const stripe = Stripe(stripePublishableKey);
    const form = document.getElementById('payment-form');
    const payButton = document.getElementById('pay-button');
    const payContent = document.getElementById('pay-button-content');
    const statusMessage = document.getElementById('status-message');
    const errorMessage = document.getElementById('error-message');
    
    let elements, paymentSession, clientSecret;
    
    function updateStatus(message) {
      statusMessage.textContent = message;
      statusMessage.style.display = 'block';
    }
    
    function showError(message) {
      errorMessage.textContent = message;
      errorMessage.style.display = 'block';
      statusMessage.style.display = 'none';
    }
    
    async function fetchPaymentSession() {
      const response = await fetch(`https://payment.snipcart.com/api/public/custom-payment-gateway/payment-session?publicToken=${publicToken}`);
      paymentSession = await response.json();
      return paymentSession;
    }
    
    async function createPaymentIntent() {
      const response = await fetch(`${siteUrl}/api/checkout/stripe-create-intent`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          paymentSessionId: paymentSession.id,
          amount: paymentSession.invoice.amount,
          currency: paymentSession.invoice.currency,
          email: paymentSession.invoice.email,
        })
      });
      const result = await response.json();
      clientSecret = result.clientSecret;
      return clientSecret;
    }
    
    async function init() {
      try {
        await fetchPaymentSession();
        await createPaymentIntent();
        elements = stripe.elements({ clientSecret });
        const paymentElement = elements.create('payment');
        paymentElement.mount('#payment-element');
        payButton.disabled = false;
        payContent.innerHTML = 'Pay Now';
        updateStatus('Enter your payment details');
      } catch (error) {
        showError('Setup failed');
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      payButton.disabled = true;
      payContent.innerHTML = '<span class="inline-block w-3.5 h-3.5 border-2 border-white/20 border-t-white rounded-full animate-spin"></span> Processing...';
      const { error } = await stripe.confirmPayment({
        elements,
        confirmParams: {
          return_url: `${siteUrl}/checkout/stripe-success?publicToken=${publicToken}`,
        },
      });
      if (error) {
        showError(error.message);
        payButton.disabled = false;
        payContent.innerHTML = 'Pay Now';
      }
    });
    
    init();
    </script>
  )}
</CheckoutLayout>
