---
/**
 * Stripe Payment Success Page
 * 
 * Customer is redirected here after successful Stripe payment
 * Verifies payment and notifies Snipcart
 */

export const prerender = false;
import { getEntry } from "astro:content";
import CheckoutLayout from "../../layouts/CheckoutLayout.astro";

const publicToken = Astro.url.searchParams.get('publicToken');
const paymentIntentId = Astro.url.searchParams.get('payment_intent');

const siteUrl = import.meta.env.DEPLOY_PRIME_URL || import.meta.env.PUBLIC_SITE_URL || Astro.url.origin;

const brandSettings = await getEntry("settings", "brand");
if (!brandSettings) {
  throw new Error("[Stripe Success] 'settings/brand' not found.");
}
const brandName = brandSettings.data.name;
---

<CheckoutLayout pageTitle="Order Confirmed">
  <div class="w-full max-w-[480px]">
    <div class="bg-(--color-surface) border border-(--color-border-subtle) rounded-[4px] p-12 px-8 text-center">
      <div class="font-serif text-[2rem] text-(--color-primary) mb-8">{brandName}</div>
      
      <svg class="w-16 h-16 mx-auto mb-6 text-(--color-accent-emerald)" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      
      <h1 class="text-2xl mb-2 font-serif">Payment Successful!</h1>
      <p class="text-(--color-text-muted) text-sm" id="status">
        <span class="inline-block w-3.5 h-3.5 border-2 border-black/10 border-t-(--color-primary) rounded-full animate-spin"></span> Confirming your order...
      </p>
    </div>
  </div>

  <script define:vars={{ publicToken, paymentIntentId, siteUrl }} is:inline>
    async function verifyAndConfirm() {
      try {
        const response = await fetch(`https://payment.snipcart.com/api/public/custom-payment-gateway/payment?publicToken=${publicToken}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ state: 'processed', transactionId: paymentIntentId })
        });
        const result = await response.json();
        if (result.returnUrl) {
          window.location.href = result.returnUrl;
        } else {
          document.getElementById('status').innerHTML = '✓ Order confirmed! Redirecting...';
          setTimeout(() => window.location.href = '/', 2000);
        }
      } catch (error) {
        document.getElementById('status').textContent = 'Error confirming order. Reference: ' + paymentIntentId;
      }
    }
    verifyAndConfirm();
  </script>
</CheckoutLayout>
