---
/**
 * Stripe Payment Success Page
 * 
 * Customer is redirected here after successful Stripe payment
 * Verifies payment and notifies Snipcart
 */

export const prerender = false;

const publicToken = Astro.url.searchParams.get('publicToken');
const paymentIntentId = Astro.url.searchParams.get('payment_intent');
const paymentIntentClientSecret = Astro.url.searchParams.get('payment_intent_client_secret');

const siteUrl = import.meta.env.DEPLOY_PRIME_URL || import.meta.env.PUBLIC_SITE_URL || Astro.url.origin;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Successful - Zaviona</title>
  
  <style>
    :root {
      --color-background: #0a0a0a;
      --color-surface: #141414;
      --color-text: #fafafa;
      --color-text-muted: #a1a1aa;
      --color-primary: #d4af37;
      --color-success: #10b981;
    }
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--color-background);
      color: var(--color-text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .container {
      max-width: 480px;
      width: 100%;
      padding: 2rem;
      text-align: center;
    }
    
    .card {
      background: var(--color-surface);
      border: 1px solid #27272a;
      border-radius: 16px;
      padding: 2rem;
    }
    
    .logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      color: var(--color-primary);
      margin-bottom: 2rem;
    }
    
    .success-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 1.5rem;
      color: var(--color-success);
    }
    
    h1 {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }
    
    .status {
      color: var(--color-text-muted);
      font-size: 0.875rem;
    }
    
    .spinner {
      display: inline-block;
      width: 20px;
      height: 20px;
      border: 2px solid rgba(255, 255, 255, 0.1);
      border-top-color: var(--color-primary);
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }
    
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <div class="logo">Zaviona</div>
      
      <svg class="success-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      
      <h1>Payment Successful!</h1>
      <p class="status" id="status">
        <span class="spinner"></span> Confirming your order...
      </p>
    </div>
  </div>

  <script define:vars={{ publicToken, paymentIntentId, siteUrl }}>
    async function verifyAndConfirm() {
      try {
        // Notify Snipcart of successful payment
        const response = await fetch(
          `https://payment.snipcart.com/api/public/custom-payment-gateway/payment?publicToken=${publicToken}`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              state: 'processed',
              transactionId: paymentIntentId,
            })
          }
        );
        
        if (!response.ok) {
          throw new Error('Failed to confirm payment with Snipcart');
        }
        
        const result = await response.json();
        console.log('[stripe-success] Payment confirmed');
        
        // Redirect to confirmation page
        if (result.returnUrl) {
          window.location.href = result.returnUrl;
        } else {
          document.getElementById('status').innerHTML = '✓ Order confirmed! Redirecting...';
          setTimeout(() => window.location.href = '/', 2000);
        }
        
      } catch (error) {
        console.error('[stripe-success] Error:', error);
        document.getElementById('status').textContent = 'Error confirming order. Please contact support with reference: ' + paymentIntentId;
      }
    }
    
    verifyAndConfirm();
  </script>
</body>
</html>
