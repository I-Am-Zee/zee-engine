---
import BaseLayout from "../layouts/BaseLayout.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";

export const prerender = true;
---

<BaseLayout title="About Us | Zaviona">
  <main class="mx-auto max-w-3xl px-4 py-24 text-center">
    <Heading as="h1" class="mb-6">About Zaviona</Heading>
    <Text variant="lead" color="muted" class="mb-8">
      Zaviona is a luxury jewelry brand dedicated to ethically sourced diamonds and timeless craftsmanship. 
      Our mission is to bring brilliance and elegance to your most cherished moments.
    </Text>
    <Text variant="paragraph" color="muted">
      We are currently refining our story. Full page coming soon.
    </Text>
  </main>
</BaseLayout>
