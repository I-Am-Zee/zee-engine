---
import { getCollection } from 'astro:content';
import EngineLayout from '../../layouts/EngineLayout.astro';
import Heading from '../../components/primitives/Heading.astro';
import Text from '../../components/primitives/Text.astro';
import Image from '../../components/primitives/Image.astro';
import Button from '../../components/primitives/Button.astro';
import Icon from '../../components/primitives/Icon.astro';

import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import EditorialHero from '../../components/ui/EditorialHero.astro';

export async function getStaticPaths() {
  const brandPages = await getCollection('brand');
  return brandPages
    .filter(page => !page.data.isDraft)
    .map(page => {
      // Defensively strip extensions if they exist in the ID
      const slug = page.id.replace(/\.(json|yaml|yml)$/, '');
      return {
        params: { slug },
        props: { page },
      };
    });
}

export const prerender = true;

const { page } = Astro.props;
const { hero, sections = [], title } = page.data;
const hasHeroImage = !!(hero?.image);

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Brand", current: false },
  { label: title, current: true },
];

const alignmentMap: Record<string, string> = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right',
};
---

<EngineLayout pageTitle={title}>
  <Breadcrumbs items={breadcrumbItems} />

  <article class="relative overflow-hidden bg-(--color-background)">
    
    <EditorialHero 
      title={hero?.heading || title}
      image={hero?.image}
      description={hero?.text}
      eyebrow={title}
    />

    {/* ── STORY BODY (LUXURY MAGAZINE FLOW) ── */}
    <div class={`mx-auto px-4 lg:px-8 py-12 md:py-20 ${hasHeroImage ? 'max-w-7xl' : 'max-w-4xl'}`}>
      {sections.map((section: any) => {
        const { layout, alignment = 'left', stack = [], image } = section;
        
        const isImageLeft = layout === 'image-left';
        const isImageRight = layout === 'image-right';
        const isNoImage = layout === 'no-image';
        const alignmentClass = alignmentMap[alignment] || 'text-left';
        const imageRatio = image?.shape === 'square' ? 'square' : 'portrait';

        return (
          <section 
            class={`relative py-12 md:py-20 clear-both ${alignmentClass}`}
            data-layout={layout}
          >
            
            {/* ── MAGAZINE IMAGE (FLOAT) ── */}
            {(isImageLeft || isImageRight) && image?.url && (
              <div class={`hidden md:block w-full md:w-[35%] mb-8 ${isImageLeft ? 'md:float-left md:mr-16' : 'md:float-right md:ml-16'}`}>
                <div class="overflow-hidden rounded-sm shadow-2xl">
                  <Image src={image.url} alt={image.alt || "Story visual"} ratio={imageRatio} class="w-full" />
                </div>
                {image.caption && (
                  <Text variant="caption" color="muted" class="mt-4 italic block text-center">
                    {image.caption}
                  </Text>
                )}
              </div>
            )}

            {/* ── CONTENT STACK (FLOWS AROUND FLOAT) ── */}
            <div class="content-flow leading-relaxed clear-both md:clear-none">
              {stack.map((item: any, blockIndex: number) => {
                const { discriminant, value } = item;
                
                // --- UNIFORM RHYTHM LOGIC ---
                const prevItem = blockIndex > 0 ? stack[blockIndex - 1] : null;
                const isHeading = discriminant === 'heading';
                const isPrevEyebrow = prevItem?.discriminant === 'text' && prevItem?.value?.type === 'eyebrow';

                let spacingClass = '';
                if (blockIndex > 0) {
                  if (isHeading && isPrevEyebrow) {
                    spacingClass = 'mt-2 md:mt-4'; // Magnetize Eyebrow to Heading
                  } else {
                    spacingClass = 'mt-8'; // Uniform Editorial Rhythm
                  }
                }
                
                // Mobile Image Injection Logic (Choreographer)
                const targetOffset = Number(image?.mobileOffset || 0);
                const showImageHere = !isNoImage && image?.url && blockIndex === targetOffset;

                return (
                  <>
                    {showImageHere && (
                      <div class="block md:hidden w-full mb-12 mt-4 pt-8">
                        <div class="overflow-hidden rounded-sm shadow-2xl">
                          <Image 
                            src={image.url} 
                            alt={image.alt || "Story visual"} 
                            ratio={imageRatio} 
                            class="w-full max-h-[70vh]"
                          />
                        </div>
                        {image.caption && (
                          <Text variant="caption" color="muted" class="mt-4 italic block text-center">
                            {image.caption}
                          </Text>
                        )}
                      </div>
                    )}

                    {discriminant === 'heading' && (
                      <div class={spacingClass}>
                        <Heading 
                          as={value.type as any} 
                          italic={value.italic}
                          class="text-balance"
                        >
                          {value.content}
                        </Heading>
                      </div>
                    )}
                    {discriminant === 'text' && (() => {
                      const isQuote = value.type === 'quote';
                      return (
                        <div class={`
                          ${spacingClass} 
                          overflow-hidden
                          ${isQuote ? 'px-8 md:px-17' : ''}
                          ${isQuote && isNoImage && alignment === 'center' ? 'flex justify-center' : ''}
                        `}>
                          <Text 
                            variant={value.type as any} 
                            italic={value.italic}
                            class={`${isQuote && isNoImage ? 'max-w-3xl mx-auto' : 'max-w-none'}`}
                          >
                            {value.content}
                          </Text>
                        </div>
                      );
                    })()}
                    {discriminant === 'button' && (() => {
                      const isModal = value.action_type === 'modal';

                      return (
                        <div class={`${spacingClass} ${alignment === 'center' ? 'flex justify-center' : ''}`}>
                          {isModal ? (
                            <div
                              x-data="{ open: false }"
                              x-effect="document.body.style.overflow = open ? 'hidden' : ''"
                            >
                              {/* Trigger Button */}
                              <Button
                                type="primary"
                                class="w-full sm:w-auto"
                                @click="open = true"
                              >
                                {value.label}
                              </Button>

                              {/* Modal Overlay — click backdrop to close */}
                              <div
                                x-show="open"
                                x-cloak
                                @click="open = false"
                                @keydown.escape.window="open = false"
                                class="fixed inset-0 z-[var(--z-modal)] flex items-end sm:items-center justify-center bg-black/60 backdrop-blur-sm"
                                style="display: none;"
                              >
                                {/* Modal Panel — stop click propagation so panel clicks don't close */}
                                <div
                                  class="relative w-full h-[95svh] sm:h-[85vh] sm:w-[90vw] sm:max-w-2xl sm:rounded-xl bg-(--color-surface) flex flex-col shadow-2xl overflow-hidden"
                                  @click.stop
                                >
                                  {/* Close Button */}
                                  <button
                                    @click="open = false"
                                    class="absolute top-4 right-4 z-10 p-2 rounded-full bg-(--color-surface-muted) hover:bg-(--color-border-subtle) transition-colors cursor-pointer"
                                    aria-label="Close"
                                  >
                                    <Icon name="PhX" class="h-5 w-5 text-(--color-text-muted)" />
                                  </button>

                                  {/* Scrollable Tally iframe — modal scrolls, not the page */}
                                  <div class="flex-1 overflow-y-auto overscroll-contain pt-12">
                                    <iframe
                                      src={`https://tally.so/embed/${value.embed_url}?transparentBackground=1&hideTitle=1&alignLeft=1`}
                                      width="100%"
                                      style="min-height: 560px; border: none; display: block;"
                                      title={value.label}
                                      loading="lazy"
                                    ></iframe>
                                  </div>
                                </div>
                              </div>
                            </div>
                          ) : (
                            <Button as="a" type="primary" class="w-full sm:w-auto" href={value.url}>
                              {value.label}
                            </Button>
                          )}
                        </div>
                      );
                    })()}
                  </>
                );
              })}

              {/* Handle case where image is appended to the end of the mobile stack */}
              {!isNoImage && image?.url && Number(image?.mobileOffset || 0) >= stack.length && (
                <div class="block md:hidden w-full mb-12 mt-12 pt-8">
                  <div class="overflow-hidden rounded-sm shadow-2xl">
                    <Image 
                      src={image.url} 
                      alt={image.alt || "Story visual"} 
                      ratio={imageRatio} 
                      class="w-full max-h-[70vh]"
                    />
                  </div>
                  {image.caption && (
                    <Text variant="caption" color="muted" class="mt-4 italic block text-center">
                      {image.caption}
                    </Text>
                  )}
                </div>
              )}
            </div>

            {/* Clear floats for the next section */}
            <div class="clear-both" />
          </section>
        )
      })}
    </div>

  </article>
</EngineLayout>
