---
import { getEntry } from "astro:content";
import EngineLayout from "../../layouts/EngineLayout.astro";
import NewsletterConfirmForm from "../../components/features/NewsletterConfirmForm.astro";

export const prerender = false;

// Load Page content (Hub Strategy)
// Corrected: newsletter_confirm is an entry in 'pages_content' collection
const confirmPage = await getEntry('pages_content', 'newsletter_confirm');
const hubData = confirmPage?.data || {
  title: "Stay in the Loop",
  description: "Join our inner circle for rare arrivals, seasonal pieces, and the occasional exclusives."
};

const email = Astro.url.searchParams.get("email") || "";
---

<EngineLayout
  pageTitle={hubData.title}
  description={hubData.description}
>
  <NewsletterConfirmForm 
    email={email} 
    headingLocked={hubData.heading_locked}
    headingOpen={hubData.heading_open}
    descriptionLocked={hubData.description_locked}
    descriptionOpen={hubData.description_open}
    emailPlaceholder={hubData.email_placeholder}
    emailError={hubData.email_error}
    submitLabel={hubData.submit_label}
    footerNote={hubData.footer_note}
  />
</EngineLayout>
