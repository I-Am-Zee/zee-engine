---
export const prerender = false;

import EngineLayout from "../../layouts/EngineLayout.astro";
import NewsletterConfirmForm from "../../components/features/NewsletterConfirmForm.astro";

const email = Astro.url.searchParams.get("email") || "";
---

<EngineLayout
  title="Stay in the Loop | Zelia Vance"
  description="Join the Zelia Vance inner circle for rare arrivals, seasonal pieces, and the occasional exclusive."
>
  <NewsletterConfirmForm email={email} />
</EngineLayout>
