---
import { getEntry } from "astro:content";
import EngineLayout from "../../layouts/EngineLayout.astro";
import NewsletterPageCard from "../../components/ui/NewsletterPageCard.astro";
import Button from "../../components/primitives/Button.astro";
import Text from "../../components/primitives/Text.astro";

// Load Page content (Hub Strategy)
const successPage = await getEntry('page_newsletter_success', 'newsletter_success');
const hubData = successPage?.data || {
  title: "You're in the Loop",
  description: "Welcome to our inner circle.",
  heading: "You're in the loop.",
  message_primary: "From this moment forward, you'll be among the first to hear about new arrivals, seasonal pieces, and things we quietly reserve for people who've been here since the beginning.",
  message_secondary: "We write rarely. When we do, it means something.",
  cta_label: "Continue Exploring",
  cta_link: "/collections",
  unsubscribe_note: "You can unsubscribe at any time from any email we send."
};
---

<EngineLayout
  pageTitle={hubData.title}
  description={hubData.description}
>
  <NewsletterPageCard
    heading={hubData.heading}
    emblem
  >
    <Text variant="caption" color="muted" class="mb-3 block leading-relaxed">
      {hubData.message_primary}
    </Text>

    <Text variant="caption" color="muted" italic class="mb-10 block opacity-80">
      {hubData.message_secondary}
    </Text>

    <Button as="a" href={hubData.cta_link} type="primary" size="lg" class="w-full uppercase tracking-widest text-xs!">
      {hubData.cta_label}
    </Button>

    <Text variant="metadata" class="mt-8 block opacity-60">
      {hubData.unsubscribe_note}
    </Text>
  </NewsletterPageCard>
</EngineLayout>
