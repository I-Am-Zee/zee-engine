---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NewsletterPageCard from "../../components/ui/NewsletterPageCard.astro";
import Button from "../../components/primitives/Button.astro";
import Text from "../../components/primitives/Text.astro";
---

<BaseLayout
  title="You're in the Loop | Zelia Vance"
  description="Welcome to the Zelia Vance inner circle."
>
  <NewsletterPageCard
    heading="You're in the loop."
    emblem
  >
    <Text variant="caption" color="muted" class="mb-3 block leading-relaxed">
      From this moment forward, you'll be among the first to hear about
      new arrivals, seasonal pieces, and things we quietly reserve for
      people who've been here since the beginning.
    </Text>

    <Text variant="caption" color="muted" italic class="mb-10 block opacity-80">
      We write rarely. When we do, it means something.
    </Text>

    <Button as="a" href="/collections" type="primary" size="lg" class="w-full uppercase tracking-widest text-xs!">
      Continue Exploring
    </Button>

    <Text variant="metadata" class="mt-8 block opacity-60">
      You can unsubscribe at any time from any email we send.
    </Text>
  </NewsletterPageCard>
</BaseLayout>
