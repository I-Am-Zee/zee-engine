---
import { getCollection, getEntry, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

import EngineLayout from "../../layouts/EngineLayout.astro";
import Heading from "../../components/primitives/Heading.astro";
import Text from "../../components/primitives/Text.astro";
import Badge from "../../components/primitives/Badge.astro";

import PriceTag from "../../components/ui/PriceTag.astro";
import RatingStars from "../../components/ui/RatingStars.astro";
import OptionSelector from "../../components/ui/OptionSelector.astro";
import QuantitySelector from "../../components/ui/QuantitySelector.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import CompleteTheLook from "../../components/features/CompleteTheLook.astro";
import RelatedProducts from "../../components/features/RelatedProducts.astro";
import ProductGallery from "../../components/features/ProductGallery.astro";
import WishlistButton from "../../components/features/WishlistButton.astro";
import AddToCartButton from "../../components/ui/AddToCartButton.astro";
import { sortBadgesByHierarchy, getBadgeIntent } from "../../scripts/utils/badges";

// Pre-render at build time (required in server mode)
export const prerender = true;

// Generate static paths for all products
export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

interface Props {
  product: CollectionEntry<"products">;
}

const { product } = Astro.props;
const { Content } = await render(product);

// Use gallery if available, fallback to single image
const galleryImages =
  product.data.gallery && product.data.gallery.length > 0
    ? product.data.gallery
    : [product.data.image];

// Check if product is "Coming Soon" (publishDate in future)
const now = new Date();
const publishDate = product.data.publishDate ? new Date(product.data.publishDate) : null;
const isComingSoon = publishDate && publishDate > now;

// Auto-add "Coming Soon" badge if publish date is in future
const badges = [...(product.data.badges || [])];
if (isComingSoon && !badges.includes("Coming Soon")) {
  badges.unshift("Coming Soon");
}

// Sort badges by hierarchy (Urgency → Prestige → Attributes → State)
const sortedBadges = sortBadgesByHierarchy(badges);

// ── Smart Page Controller Logic (Cross-Sell) ──────────────────────
const allProductsForCrossSell = await getCollection("products");
const crossSellHeader = await getEntry("section_headers", "pdp-related");

const crossSellProducts = allProductsForCrossSell
  .filter((p) => p.id !== product.id)
  .filter((p) => p.data.category === product.data.category)
  .slice(0, 4);

const crossSellTitle = crossSellHeader?.data?.title || "You May Also Like";
const crossSellSubtitle = crossSellHeader?.data?.subtitle || "Selected specifically to complement your style";
---

<EngineLayout pageTitle={product.data.title}>
  <div x-data={`{ 
    showStickyCart: false,
    error: '',
    errorTimer: null,
    validateAdd(e) {
      const btn = e.currentTarget;
      for(let i=1; i<=3; i++) {
        const customName = btn.dataset['itemCustom' + i + 'Name'];
        if(customName) {
          const sel = document.querySelector('.product-variant-selector[data-variant-name="' + customName + '"]');
          if(sel && !sel.value) {
            this.error = 'Please select a ' + customName + ' to add to cart.';
            e.preventDefault();
            e.stopImmediatePropagation();
            
            // Final 3: Self-destruct timer (matches SideDrawer)
            if(this.errorTimer) clearTimeout(this.errorTimer);
            this.errorTimer = setTimeout(() => this.error = '', 4000);

            if (window.innerWidth < 1024) window.scrollTo({ top: document.querySelector('.product-actions-row').offsetTop - 150, behavior: 'smooth' });
            return;
          } else if(sel && sel.value) {
            btn.dataset['itemCustom' + i + 'Value'] = sel.value;
          }
        }
      }
      this.error = '';
      if(this.errorTimer) clearTimeout(this.errorTimer);
    }
  }`} 
  @scroll.window="showStickyCart = window.scrollY > 500 && (document.documentElement.scrollHeight - window.scrollY - window.innerHeight) > 800"
  @change="if($event.target.closest('fieldset')) { error = ''; if(errorTimer) clearTimeout(errorTimer); }"
  >
    <div class="mx-auto max-w-7xl px-4 py-8 lg:px-8">
      {/* Breadcrumbs */}
      <div class="mt-4 mb-8">
        <Breadcrumbs
          items={[
            { label: "Home", href: "/" },
            { label: "Shop", href: "/shop" },
            { label: product.data.title, href: "#" },
          ]}
        />
      </div>
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-12">
      {/* Left Column - Gallery (Sticky on Desktop) */}
      <div class="lg:sticky lg:top-24 lg:col-span-7 lg:self-start">
        <ProductGallery images={galleryImages} alt={product.data.title} />
      </div>

      {/* Right Column - Product Info */}
      <div class="lg:col-span-5 lg:pl-12">
        {/* Header Zone: Badges, Title, Price, Urgency */}
        <div class="mb-8">
          {/* Badges */}
          {
            badges.length > 0 && (
              <div class="mb-4 flex flex-wrap gap-2">
                {sortedBadges.map((badge) => (
                  <Badge intent={getBadgeIntent(badge)} size="sm">
                    {badge}
                  </Badge>
                ))}
              </div>
            )
          }

          {/* Title */}
          <Heading as="h1" class="mb-4">
            {product.data.title}
          </Heading>

          {/* Price + Urgency Row */}
          <div class="mb-4 flex items-center gap-4">
            <PriceTag price={product.data.price} salePrice={product.data.salePrice} />
          </div>

          {/* Rating */}
          {
            product.data.rating && product.data.rating > 0 && (
              <div class="flex items-center gap-2">
                <RatingStars rating={product.data.rating} />
                <Text variant="metadata">({product.data.rating.toFixed(1)} out of 5)</Text>
              </div>
            )
          }
        </div>

        {/* Description Zone */}
        <div class="my-8">
          <Text variant="paragraph">
            {product.data.description}
          </Text>
        </div>

        {/* Options Zone - Object-based Variant Slots */}
        {
          (product.data.variant_1 || product.data.variant_2 || product.data.variant_3) && (
            <div class="mt-4 space-y-4">
              {product.data.variant_1?.name && product.data.variant_1?.values && (
                <OptionSelector
                  legend={product.data.variant_1.name}
                  options={product.data.variant_1.values.split(",").map((v) => v.trim())}
                  name={product.data.variant_1.name}
                />
              )}
              {product.data.variant_2?.name && product.data.variant_2?.values && (
                <OptionSelector
                  legend={product.data.variant_2.name}
                  options={product.data.variant_2.values.split(",").map((v) => v.trim())}
                  name={product.data.variant_2.name}
                />
              )}
              {product.data.variant_3?.name && product.data.variant_3?.values && (
                <OptionSelector
                  legend={product.data.variant_3.name}
                  options={product.data.variant_3.values.split(",").map((v) => v.trim())}
                  name={product.data.variant_3.name}
                />
              )}
            </div>
          )
        }

        {/* Action Zone: Quantity + Add to Cart */}
        <div class="mt-10 space-y-6">
          {/* Coming Soon Countdown */}
          {
            isComingSoon && publishDate && (
              <div class="rounded-lg border border-(--color-accent-amber)/20 bg-(--color-accent-amber)/10 p-4 text-center">
                <Text variant="label" class="mb-1 text-amber-600">
                  Dropping Soon
                </Text>
                <div
                  class="text-lg font-semibold text-amber-700"
                  id="countdown"
                  data-release={publishDate.toISOString()}
                >
                  {publishDate.toLocaleDateString("en-IN", {
                    weekday: "long",
                    month: "long",
                    day: "numeric",
                  })}
                </div>
              </div>
            )
          }

          {/* Quantity Selector */}
          {
            !isComingSoon && (
              <div class="flex items-center gap-3">
                <Text variant="label">
                  {" "}
                  Quantity:{" "}
                </Text>
                <QuantitySelector initial={1} min={1} max={10} />
              </div>
            )
          }

          <template x-if="error">
            <div x-show="error" x-transition x-cloak class="mt-6 bg-accent-coral/10 border border-accent-coral/20 text-accent-coral px-4 py-2.5 rounded-lg text-sm font-semibold flex items-center justify-center shadow-sm">
              <span x-text="error"></span>
            </div>
          </template>

          <div class="product-actions-row flex flex-col gap-4 sm:flex-row sm:items-stretch mt-6">
            {/* Add to Cart Button - Snipcart */}
            <AddToCartButton
              product={product}
              size="lg"
              class="w-full sm:flex-1 whitespace-nowrap h-13"
              disabled={isComingSoon ?? false}
              @click="validateAdd($event)"
            >
              {isComingSoon ? "Coming Soon" : "Add to Cart"}
            </AddToCartButton>

            {/* Wishlist Button - Uses global store */}
            <WishlistButton productId={product.id} variant="with-label" size="lg" class="h-13" />
          </div>
        </div>

        {/* Divider */}
        <hr class="my-12 border-(--color-border-subtle)" />

        {/* Details Zone: The Story (Markdown Content) */}
        <div class="product-story prose prose-zelia max-w-none">
          <Content />
        </div>
      </div>
    </div>

    {/* Complete the Look (Related Products) */}
    {
      product.data.related_products && product.data.related_products.length > 0 && (
        <CompleteTheLook
          productSlugs={product.data.related_products}
          currentProduct={{
            id: product.id,
            title: product.data.title,
            price: product.data.price,
            salePrice: product.data.salePrice,
            image: product.data.image,
          }}
        />
      )
    }

    {/* You May Also Like (Algorithmic Recommendations) */}
    <RelatedProducts 
      title={crossSellTitle}
      subtitle={crossSellSubtitle}
      products={crossSellProducts}
    />
  </div>

    {/* Sticky Mobile Add to Cart Bar */}
    <div
      x-show="showStickyCart"
      x-transition:enter="transition ease-out duration-300 transform"
      x-transition:enter-start="translate-y-full opacity-0"
      x-transition:enter-end="translate-y-0 opacity-100"
      x-transition:leave="transition ease-in duration-200 transform"
      x-transition:leave-start="translate-y-0 opacity-100"
      x-transition:leave-end="translate-y-full opacity-0"
      class="fixed right-0 bottom-0 left-0 border-t border-(--color-border-subtle) bg-white/95 p-4 backdrop-blur-sm lg:hidden shadow-[0_-4px_20px_rgba(0,0,0,0.05)] z-50"
      x-cloak
    >
      <div class="mx-auto flex max-w-lg items-center gap-3">
        <div class="flex-1 min-w-0">
          <Text variant="paragraph" weight="semibold" class="truncate block">{product.data.title}</Text>
          <PriceTag price={product.data.price} salePrice={product.data.salePrice} />
        </div>
        <AddToCartButton
          product={product}
          size="md"
          disabled={isComingSoon ?? false}
          class="shrink-0"
          @click="validateAdd($event)"
        >
          {isComingSoon ? "Soon" : "Add"}
        </AddToCartButton>
      </div>
    </div>
  </div>
</EngineLayout>

<style>
  /* Enhanced Prose styling for product story */
  .product-story {
    color: var(--color-text-main);
  }

  /* Use :global() to target elements inside the injected Markdown content */
  .product-story :global(h1),
  .product-story :global(h2),
  .product-story :global(h3),
  .product-story :global(h4),
  .product-story :global(h5),
  .product-story :global(h6) {
    font-family: var(--font-serif);
    color: var(--color-text-main);
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .product-story :global(h2) {
    font-size: 1.5rem;
  }

  .product-story :global(h3) {
    font-size: 1.25rem;
  }

  /* Generous paragraph spacing */
  .product-story :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .product-story :global(strong) {
    font-weight: 600;
    color: var(--color-text-main);
  }

  /* Well-spaced, visually appealing bullets */
  .product-story :global(ul) {
    list-style: disc;
    margin-left: 1.5rem;
    margin-bottom: 2rem;
    margin-top: 1rem;
  }

  .product-story :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.7;
    padding-left: 0.5rem;
  }

  /* Custom bullet styling for luxury feel */
  .product-story :global(ul li::marker) {
    color: var(--color-text-muted);
  }

  /* Ordered lists */
  .product-story :global(ol) {
    list-style: decimal;
    margin-left: 1.5rem;
    margin-bottom: 2rem;
    margin-top: 1rem;
  }

  .product-story :global(ol li) {
    margin-bottom: 0.75rem;
    line-height: 1.7;
    padding-left: 0.5rem;
  }

  /* Removed padding for sticky mobile bar as it now auto-hides at footer */
</style>
