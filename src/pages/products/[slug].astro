---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Heading from "../../components/primitives/Heading.astro";
import Text from "../../components/primitives/Text.astro";
import Badge from "../../components/primitives/Badge.astro";
import Button from "../../components/primitives/Button.astro";
import PriceTag from "../../components/ui/PriceTag.astro";
import RatingStars from "../../components/ui/RatingStars.astro";
import OptionSelector from "../../components/ui/OptionSelector.astro";
import QuantitySelector from "../../components/ui/QuantitySelector.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import UrgencyBadge from "../../components/ui/UrgencyBadge.astro";
import CompleteTheLook from "../../components/ui/CompleteTheLook.astro";
import RelatedProducts from "../../components/features/RelatedProducts.astro";
import ProductGallery from "../../components/features/ProductGallery.astro";
import Navbar from "../../components/features/Navbar.astro";
import Footer from "../../components/features/Footer.astro";
import WishlistButton from "../../components/features/WishlistButton.astro";
import AddToCartButton from "../../components/ui/AddToCartButton.astro";
import { sortBadgesByHierarchy, getBadgeIntent } from "../../scripts/utils/badges";

// Pre-render at build time (required in server mode)
export const prerender = true;

// Generate static paths for all products
export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

interface Props {
  product: CollectionEntry<"products">;
}

const { product } = Astro.props;
const { Content } = await product.render();

// Use gallery if available, fallback to single image
const galleryImages =
  product.data.gallery && product.data.gallery.length > 0
    ? product.data.gallery
    : [product.data.image];

// Check if product is "Coming Soon" (release_date in future)
const now = new Date();
const releaseDate = product.data.release_date ? new Date(product.data.release_date) : null;
const isComingSoon = releaseDate && releaseDate > now;

// Auto-add "Coming Soon" badge if release date is in future
const badges = [...(product.data.badges || [])];
if (isComingSoon && !badges.includes("Coming Soon")) {
  badges.unshift("Coming Soon");
}

// Sort badges by hierarchy (Urgency → Prestige → Attributes → State)
const sortedBadges = sortBadgesByHierarchy(badges);
---

<BaseLayout title={`${product.data.title} | Zaviona`}>
  <Navbar />

  <div class="mx-auto max-w-7xl px-4 py-8 lg:px-8">
    {/* Breadcrumbs */}
    <div class="mt-4 mb-8">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Shop", href: "/shop" },
          { label: product.data.title, href: "#" },
        ]}
      />
    </div>

    {/* Main Grid - Sticky Split Layout */}
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-12">
      {/* Left Column - Gallery (Sticky on Desktop) */}
      <div class="lg:sticky lg:top-24 lg:col-span-7 lg:self-start">
        <ProductGallery images={galleryImages} alt={product.data.title} />
      </div>

      {/* Right Column - Product Info */}
      <div class="lg:col-span-5 lg:pl-12">
        {/* Header Zone: Badges, Title, Price, Urgency */}
        <div class="mb-8">
          {/* Badges */}
          {badges.length > 0 && (
            <div class="mb-4 flex flex-wrap gap-2">
              {sortedBadges.map((badge) => (
                <Badge intent={getBadgeIntent(badge)} size="sm">
                  {badge}
                </Badge>
              ))}
            </div>
          )}

          {/* Title */}
          <Heading as="h1" class="mb-4">
            {product.data.title}
          </Heading>

          {/* Price + Urgency Row */}
          <div class="flex items-center gap-4 mb-4">
            <PriceTag price={product.data.price} salePrice={product.data.salePrice} />
            {product.data.urgency_tag && !isComingSoon && (
              <UrgencyBadge label={product.data.urgency_tag} />
            )}
          </div>

          {/* Rating */}
          {product.data.rating && product.data.rating > 0 && (
            <div class="flex items-center gap-2">
              <RatingStars rating={product.data.rating} />
              <Text variant="caption">({product.data.rating.toFixed(1)} out of 5)</Text>
            </div>
          )}
        </div>

        {/* Description Zone */}
        <div class="my-8">
          <Text class="leading-relaxed text-(--color-text-main)">
            {product.data.description}
          </Text>
        </div>

        {/* Options Zone - Object-based Variant Slots */}
        {(product.data.variant_1 || product.data.variant_2 || product.data.variant_3) && (
          <div class="space-y-6">
            {product.data.variant_1?.name && product.data.variant_1?.values && (
              <OptionSelector
                legend={product.data.variant_1.name}
                options={product.data.variant_1.values.split(",").map(v => v.trim())}
                name={product.data.variant_1.name.toLowerCase().replace(/\s+/g, "-")}
              />
            )}
            {product.data.variant_2?.name && product.data.variant_2?.values && (
              <OptionSelector
                legend={product.data.variant_2.name}
                options={product.data.variant_2.values.split(",").map(v => v.trim())}
                name={product.data.variant_2.name.toLowerCase().replace(/\s+/g, "-")}
              />
            )}
            {product.data.variant_3?.name && product.data.variant_3?.values && (
              <OptionSelector
                legend={product.data.variant_3.name}
                options={product.data.variant_3.values.split(",").map(v => v.trim())}
                name={product.data.variant_3.name.toLowerCase().replace(/\s+/g, "-")}
              />
            )}
          </div>
        )}

        {/* Action Zone: Quantity + Add to Cart */}
        <div class="mt-10 space-y-6">
          {/* Coming Soon Countdown */}
          {isComingSoon && releaseDate && (
            <div class="p-4 rounded-lg bg-(--color-accent-amber)/10 border border-(--color-accent-amber)/20 text-center">
              <Text variant="caption" class="text-amber-600 font-medium mb-1">
                Dropping Soon
              </Text>
              <div class="text-lg font-semibold text-amber-700" id="countdown" data-release={releaseDate.toISOString()}>
                {releaseDate.toLocaleDateString("en-IN", { 
                  weekday: "long", 
                  month: "long", 
                  day: "numeric" 
                })}
              </div>
            </div>
          )}

          {/* Quantity Selector */}
          {!isComingSoon && (
            <div class="flex items-center gap-3">
              <Text variant="caption" class="font-medium"> Quantity: </Text>
              <QuantitySelector initial={1} min={1} max={10} />
            </div>
          )}

          <div class="flex flex-col gap-4 md:flex-row md:items-center">
            {/* Add to Cart Button - Snipcart */}
            <AddToCartButton 
              product={product} 
              size="lg" 
              class="w-full md:flex-1"
              disabled={isComingSoon ?? false}
            >
              {isComingSoon ? "Coming Soon" : "Add to Cart"}
            </AddToCartButton>

            {/* Wishlist Button - Uses global store */}
            <WishlistButton productId={product.slug} variant="with-label" size="lg" />
          </div>
        </div>

        {/* Divider */}
        <hr class="my-12 border-(--color-border-subtle)" />

        {/* Details Zone: The Story (Markdown Content) */}
        <div class="product-story prose prose-slate max-w-none">
          <Content />
        </div>
      </div>
    </div>

    {/* Complete the Look (Related Products) */}
    {product.data.related_products && product.data.related_products.length > 0 && (
      <CompleteTheLook 
        productSlugs={product.data.related_products}
        currentProduct={{
          id: product.slug,
          title: product.data.title,
          price: product.data.price,
          salePrice: product.data.salePrice,
          image: product.data.image,
        }}
      />
    )}

    {/* You May Also Like (Algorithmic Recommendations) */}
    <RelatedProducts currentProduct={product} />
  </div>

  {/* Sticky Mobile Add to Cart Bar */}
  <div class="fixed bottom-0 left-0 right-0 z-50 p-4 bg-white/95 backdrop-blur-sm border-t border-(--color-border-subtle) lg:hidden">
    <div class="flex items-center gap-3 max-w-lg mx-auto">
      <div class="flex-1">
        <Text variant="caption" class="font-semibold truncate">{product.data.title}</Text>
        <PriceTag price={product.data.price} salePrice={product.data.salePrice} />
      </div>
      <AddToCartButton 
        product={product} 
        size="md" 
        disabled={isComingSoon ?? false}
        class="shrink-0"
      >
        {isComingSoon ? "Soon" : "Add"}
      </AddToCartButton>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
  /* Enhanced Prose styling for product story */
  .product-story {
    color: var(--color-text-main);
  }

  /* Use :global() to target elements inside the injected Markdown content */
  .product-story :global(h1),
  .product-story :global(h2),
  .product-story :global(h3),
  .product-story :global(h4),
  .product-story :global(h5),
  .product-story :global(h6) {
    font-family: var(--font-serif);
    color: var(--color-text-main);
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .product-story :global(h2) {
    font-size: 1.5rem;
  }

  .product-story :global(h3) {
    font-size: 1.25rem;
  }

  /* Generous paragraph spacing */
  .product-story :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .product-story :global(strong) {
    font-weight: 600;
    color: var(--color-text-main);
  }

  /* Well-spaced, visually appealing bullets */
  .product-story :global(ul) {
    list-style: disc;
    margin-left: 1.5rem;
    margin-bottom: 2rem;
    margin-top: 1rem;
  }

  .product-story :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.7;
    padding-left: 0.5rem;
  }

  /* Custom bullet styling for luxury feel */
  .product-story :global(ul li::marker) {
    color: var(--color-text-muted);
  }

  /* Ordered lists */
  .product-story :global(ol) {
    list-style: decimal;
    margin-left: 1.5rem;
    margin-bottom: 2rem;
    margin-top: 1rem;
  }

  .product-story :global(ol li) {
    margin-bottom: 0.75rem;
    line-height: 1.7;
    padding-left: 0.5rem;
  }

  /* Add padding to account for sticky mobile bar */
  @media (max-width: 1023px) {
    :global(body) {
      padding-bottom: 80px;
    }
  }
</style>
