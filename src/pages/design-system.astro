---
import BaseLayout from "../layouts/BaseLayout.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";
import Button from "../components/primitives/Button.astro";
import Link from "../components/primitives/Link.astro";
import Icon from "../components/primitives/Icon.astro";
import Image from "../components/primitives/Image.astro";
import Badge from "../components/primitives/Badge.astro";
import Input from "../components/primitives/Input.astro";

// UI Molecules
import PriceTag from "../components/ui/PriceTag.astro";
import QuantitySelector from "../components/ui/QuantitySelector.astro";
import SearchInput from "../components/ui/SearchInput.astro";
import RatingStars from "../components/ui/RatingStars.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import FormField from "../components/ui/FormField.astro";
import Alert from "../components/ui/Alert.astro";
import MenuToggle from "../components/ui/MenuToggle.astro";
import Pagination from "../components/ui/Pagination.astro";
import OptionSelector from "../components/ui/OptionSelector.astro";
import EmptyState from "../components/ui/EmptyState.astro";

// Organisms (Features)
import Footer from "../components/features/Footer.astro";
import ProductCard from "../components/features/ProductCard.astro";
import ProductGrid from "../components/features/ProductGrid.astro";
---

<BaseLayout title="Design System Kitchen Sink | Zaviona">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <!-- Page Header -->
    <div class="mb-12 border-b border-[var(--color-border-subtle)] pb-8">
      <Heading as="h1" class="mb-4">Design System Kitchen Sink</Heading>
      <Text variant="lead">
        A comprehensive showcase of all primitive components in the Zaviona e-commerce design
        system, built with Astro, TailwindCSS, and atomic design principles.
      </Text>
    </div>

    <!-- Typography Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Typography</Heading>

      <div class="space-y-6">
        <div>
          <Text variant="caption" class="mb-3 uppercase">Headings (Fraunces Font)</Text>
          <div class="space-y-4 rounded-lg bg-[var(--color-surface)] p-6">
            <Heading as="h1">Heading 1 - The Quick Brown Fox</Heading>
            <Heading as="h2">Heading 2 - The Quick Brown Fox</Heading>
            <Heading as="h3">Heading 3 - The Quick Brown Fox</Heading>
            <Heading as="h4">Heading 4 - The Quick Brown Fox</Heading>
            <Heading as="h5">Heading 5 - The Quick Brown Fox</Heading>
            <Heading as="h6">Heading 6 - The Quick Brown Fox</Heading>
          </div>
        </div>

        <div>
          <Text variant="caption" class="mb-3 uppercase">Text Variants (Plus Jakarta Sans)</Text>
          <div class="space-y-4 rounded-lg bg-[var(--color-surface)] p-6">
            <div>
              <Text variant="caption" class="mb-1">Lead Paragraph:</Text>
              <Text variant="lead">
                This is a lead paragraph with larger text, perfect for introducing sections or
                highlighting important content.
              </Text>
            </div>
            <div>
              <Text variant="caption" class="mb-1">Default Paragraph:</Text>
              <Text>
                This is default body text using Plus Jakarta Sans. It provides excellent readability
                for e-commerce content, product descriptions, and general website copy.
              </Text>
            </div>
            <div>
              <Text variant="caption">
                This is caption text, smaller and muted, ideal for timestamps, metadata, or
                supplementary information.
              </Text>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Buttons Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Buttons</Heading>

      <div class="space-y-8">
        <!-- Button Types -->
        {
          ["primary", "secondary", "neutral", "ghost"].map((type) => (
            <div>
              <Text variant="caption" class="mb-3 uppercase">
                {type} Buttons
              </Text>
              <div class="flex flex-wrap items-center gap-4 rounded-lg bg-[var(--color-surface)] p-6">
                {["sm", "md", "lg"].map((size) => (
                  <>
                    <Button type={type as any} size={size as any}>
                      {size.toUpperCase()} Button
                    </Button>
                    <Button type={type as any} size={size as any} variant="icon-left">
                      <Icon name="PhCheck" />
                      With Icon
                    </Button>
                    <Button type={type as any} size={size as any} variant="icon-right">
                      Next
                      <Icon name="PhCaretDown" />
                    </Button>
                    <Button type={type as any} size={size as any} variant="icon-only">
                      <Icon name="PhShoppingCart" />
                    </Button>
                  </>
                ))}
              </div>
            </div>
          ))
        }

        <!-- Disabled State -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Disabled State</Text>
          <div class="flex flex-wrap gap-4 rounded-lg bg-[var(--color-surface)] p-6">
            <Button disabled>Disabled Primary</Button>
            <Button type="secondary" disabled>Disabled Secondary</Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Links Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Links</Heading>
      <div class="space-y-4 rounded-lg bg-[var(--color-surface)] p-6">
        <Text>
          This paragraph contains a <Link href="#" variant="plain">plain inline link</Link> that inherits
          the font size of its parent and transitions smoothly on hover.
        </Text>
        <Text>
          This paragraph contains an{" "}
          <Link href="#" variant="underline">underlined inline link</Link> with skip-ink decoration for
          better readability.
        </Text>
      </div>
    </section>

    <!-- Icons Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Icons</Heading>
      <div class="space-y-4">
        <div>
          <Text variant="caption" class="mb-3 uppercase">Icon Examples</Text>
          <div class="flex flex-wrap items-center gap-6 rounded-lg bg-[var(--color-surface)] p-6">
            <div class="flex items-center gap-2">
              <Icon name="PhMagnifyingGlass" />
              <Text>Search</Text>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="PhShoppingCart" />
              <Text>Cart</Text>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="PhCheck" />
              <Text>Check</Text>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="PhCaretDown" />
              <Text>Chevron</Text>
            </div>
          </div>
        </div>
        <div>
          <Text variant="caption" class="mb-3 uppercase">Icon Sizes (inherits from text size)</Text>
          <div class="space-y-3 rounded-lg bg-[var(--color-surface)] p-6">
            <p class="flex items-center gap-2 font-sans text-sm text-[var(--color-text-main)]">
              <Icon name="PhShoppingCart" /> Small text with icon
            </p>
            <p class="flex items-center gap-2 font-sans text-base text-[var(--color-text-main)]">
              <Icon name="PhShoppingCart" /> Base text with icon
            </p>
            <p class="flex items-center gap-2 font-sans text-lg text-[var(--color-text-main)]">
              <Icon name="PhShoppingCart" /> Large text with icon
            </p>
            <p class="flex items-center gap-2 font-sans text-2xl text-[var(--color-text-main)]">
              <Icon name="PhShoppingCart" /> 2XL text with icon
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Images Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Images</Heading>
      <Text variant="caption" class="mb-3 uppercase">Aspect Ratios</Text>
      <div class="grid gap-6 sm:grid-cols-3">
        <div>
          <Image
            src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400"
            alt="Product demo - Portrait"
            ratio="portrait"
          />
          <Text variant="caption" class="mt-2 text-center">Portrait (4:5)</Text>
        </div>
        <div>
          <Image
            src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400"
            alt="Product demo - Square"
            ratio="square"
          />
          <Text variant="caption" class="mt-2 text-center">Square (1:1)</Text>
        </div>
        <div>
          <Image
            src="https://images.unsplash.com/photo-1491553895911-0055eca6402d?w=400"
            alt="Product demo - Landscape"
            ratio="landscape"
          />
          <Text variant="caption" class="mt-2 text-center">Landscape (16:9)</Text>
        </div>
      </div>
    </section>

    <!-- Badges Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Badges</Heading>
      <div class="space-y-4">
        <div>
          <Text variant="caption" class="mb-3 uppercase">Small Badges (for cart counts)</Text>
          <div class="flex flex-wrap items-center gap-3 rounded-lg bg-[var(--color-surface)] p-6">
            <Badge size="sm" intent="surface">New</Badge>
            <Badge size="sm" intent="primary">Sale</Badge>
            <Badge size="sm" intent="accent">Hot</Badge>
            <Badge size="sm" intent="outline">3</Badge>
          </div>
        </div>
        <div>
          <Text variant="caption" class="mb-3 uppercase">Medium Badges (for product labels)</Text>
          <div class="flex flex-wrap items-center gap-3 rounded-lg bg-[var(--color-surface)] p-6">
            <Badge size="md" intent="surface">In Stock</Badge>
            <Badge size="md" intent="primary">Bestseller</Badge>
            <Badge size="md" intent="accent">Limited</Badge>
            <Badge size="md" intent="outline">Featured</Badge>
          </div>
        </div>
      </div>
    </section>

    <!-- Inputs Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Inputs</Heading>
      <div class="space-y-4">
        <div>
          <Text variant="caption" class="mb-3 uppercase">Normal State</Text>
          <div class="space-y-3 rounded-lg bg-[var(--color-surface)] p-6">
            <Input type="text" placeholder="Enter your name" />
            <Input type="email" placeholder="Enter your email" />
            <Input type="password" placeholder="Enter your password" />
          </div>
        </div>
        <div>
          <Text variant="caption" class="mb-3 uppercase">Error State</Text>
          <div class="space-y-3 rounded-lg bg-[var(--color-surface)] p-6">
            <Input type="email" placeholder="invalid@email" error={true} />
            <Text variant="caption" class="text-red-500">Please enter a valid email address</Text>
          </div>
        </div>
      </div>
    </section>

    <!-- Color System Reference -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Color System (Greyscale)</Heading>
      <div class="space-y-6">
        <div>
          <Text variant="caption" class="mb-3 uppercase">Brand Actions</Text>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-lg border border-[var(--color-border-subtle)] p-4">
              <div class="mb-2 h-16 rounded bg-[var(--color-primary)]"></div>
              <Text variant="caption">Primary (#0f172a)</Text>
            </div>
            <div class="rounded-lg border border-[var(--color-border-subtle)] p-4">
              <div class="mb-2 h-16 rounded bg-[var(--color-secondary)]"></div>
              <Text variant="caption">Secondary (#e2e8f0)</Text>
            </div>
            <div class="rounded-lg border border-[var(--color-border-subtle)] p-4">
              <div class="mb-2 h-16 rounded bg-[var(--color-ghost-hover)]"></div>
              <Text variant="caption">Ghost Hover (#f1f5f9)</Text>
            </div>
          </div>
        </div>
        <div>
          <Text variant="caption" class="mb-3 uppercase">Surfaces</Text>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-lg border border-[var(--color-border-subtle)] p-4">
              <div class="mb-2 h-16 rounded border bg-[var(--color-background)]"></div>
              <Text variant="caption">Background (#ffffff)</Text>
            </div>
            <div class="rounded-lg border border-[var(--color-border-subtle)] p-4">
              <div class="mb-2 h-16 rounded bg-[var(--color-surface)]"></div>
              <Text variant="caption">Surface (#f8fafc)</Text>
            </div>
            <div class="rounded-lg border border-[var(--color-border-subtle)] p-4">
              <div class="mb-2 h-16 rounded bg-[var(--color-surface-muted)]"></div>
              <Text variant="caption">Surface Muted (#f1f5f9)</Text>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Molecules (UI) Section -->
    <section class="mb-16">
      <div class="mb-6 border-b border-[var(--color-border-subtle)] pb-4">
        <Heading as="h2" class="mb-2">Molecules (UI)</Heading>
        <Text variant="caption">
          Composed components built using Primitives. These follow the headless pattern where logic
          lives in TypeScript and UI binds to it.
        </Text>
      </div>

      <div class="space-y-8">
        <!-- PriceTag -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">PriceTag</Text>
          <div class="flex flex-wrap items-center gap-8 rounded-lg bg-[var(--color-surface)] p-6">
            <div>
              <Text variant="caption" class="mb-2">Regular Price:</Text>
              <PriceTag price={2500} />
            </div>
            <div>
              <Text variant="caption" class="mb-2">Sale Price (20% off):</Text>
              <PriceTag price={2500} salePrice={2000} />
            </div>
            <div>
              <Text variant="caption" class="mb-2">Big Discount (50% off):</Text>
              <PriceTag price={5000} salePrice={2500} />
            </div>
          </div>
        </div>

        <!-- QuantitySelector -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">QuantitySelector (Headless)</Text>
          <div class="flex flex-wrap items-center gap-8 rounded-lg bg-[var(--color-surface)] p-6">
            <div>
              <Text variant="caption" class="mb-2">Default (1-99):</Text>
              <QuantitySelector />
            </div>
            <div>
              <Text variant="caption" class="mb-2">Custom Range (1-5):</Text>
              <QuantitySelector min={1} max={5} initial={3} />
            </div>
          </div>
        </div>

        <!-- SearchInput -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">SearchInput</Text>
          <div class="max-w-md rounded-lg bg-[var(--color-surface)] p-6">
            <SearchInput placeholder="Search products..." />
          </div>
        </div>

        <!-- RatingStars -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">RatingStars</Text>
          <div class="flex flex-wrap items-center gap-6 rounded-lg bg-[var(--color-surface)] p-6">
            <div class="flex items-center gap-2">
              <RatingStars rating={5} />
              <Text variant="caption">5.0</Text>
            </div>
            <div class="flex items-center gap-2">
              <RatingStars rating={4} />
              <Text variant="caption">4.0</Text>
            </div>
            <div class="flex items-center gap-2">
              <RatingStars rating={3.5} />
              <Text variant="caption">3.5</Text>
            </div>
            <div class="flex items-center gap-2">
              <RatingStars rating={2} />
              <Text variant="caption">2.0</Text>
            </div>
            <div class="flex items-center gap-2">
              <RatingStars rating={0} />
              <Text variant="caption">0.0</Text>
            </div>
          </div>
        </div>

        <!-- Breadcrumbs -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Breadcrumbs</Text>
          <div class="rounded-lg bg-[var(--color-surface)] p-6">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Products", href: "/products" },
                { label: "Accessories", href: "/products/accessories" },
                { label: "Watch" },
              ]}
            />
          </div>
        </div>

        <!-- FormField -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">FormField</Text>
          <div class="grid gap-6 rounded-lg bg-[var(--color-surface)] p-6 sm:grid-cols-2">
            <FormField label="Email Address" name="email" placeholder="you@example.com" />
            <FormField
              label="Password"
              name="password"
              type="password"
              placeholder="Enter password"
              error="Password must be at least 8 characters"
            />
          </div>
        </div>

        <!-- Alert -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Alert</Text>
          <div class="space-y-4 rounded-lg bg-[var(--color-surface)] p-6">
            <Alert intent="info" title="Information">
              <Text as="span" variant="caption"
                >Your order has been received and is being processed.</Text
              >
            </Alert>
            <Alert intent="warning" title="Warning">
              <Text as="span" variant="caption">Only 3 items left in stock!</Text>
            </Alert>
            <Alert intent="success" title="Success">
              <Text as="span" variant="caption"
                >Your payment was successful. Thank you for your order!</Text
              >
            </Alert>
          </div>
        </div>

        <!-- MenuToggle -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">MenuToggle (Headless)</Text>
          <div class="rounded-lg bg-[var(--color-surface)] p-6">
            <MenuToggle label="Navigation menu">
              <div
                class="w-48 rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-background)] p-2 shadow-lg"
              >
                <a
                  href="#"
                  class="block rounded px-3 py-2 text-sm hover:bg-[var(--color-ghost-hover)]"
                  >Dashboard</a
                >
                <a
                  href="#"
                  class="block rounded px-3 py-2 text-sm hover:bg-[var(--color-ghost-hover)]"
                  >Products</a
                >
                <a
                  href="#"
                  class="block rounded px-3 py-2 text-sm hover:bg-[var(--color-ghost-hover)]"
                  >Orders</a
                >
                <a
                  href="#"
                  class="block rounded px-3 py-2 text-sm hover:bg-[var(--color-ghost-hover)]"
                  >Settings</a
                >
              </div>
            </MenuToggle>
            <Text variant="caption" class="mt-2"
              >Click the hamburger icon to toggle the dropdown menu.</Text
            >
          </div>
        </div>

        <!-- Pagination -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Pagination</Text>
          <div class="space-y-4 rounded-lg bg-[var(--color-surface)] p-6">
            <div>
              <Text variant="caption" class="mb-2">Few Pages:</Text>
              <Pagination currentPage={2} totalPages={5} />
            </div>
            <div>
              <Text variant="caption" class="mb-2">Many Pages (with ellipsis):</Text>
              <Pagination currentPage={5} totalPages={20} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- User Choices & States Section -->
    <section class="mb-16">
      <div class="mb-6 border-b border-[var(--color-border-subtle)] pb-4">
        <Heading as="h2" class="mb-2">User Choices & States</Heading>
        <Text variant="caption">
          Components for handling user selections and empty/error states.
        </Text>
      </div>

      <div class="space-y-8">
        <!-- OptionSelector -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">OptionSelector (Variant Picker)</Text>
          <div class="grid gap-8 rounded-lg bg-[var(--color-surface)] p-6 sm:grid-cols-2">
            <OptionSelector
              legend="Ring Size"
              options={["6", "7", "8", "9"]}
              name="ring_size"
              selected="7"
            />
            <OptionSelector
              legend="Material"
              options={["Gold", "Silver", "Rose Gold"]}
              name="material"
            />
          </div>
          <Text variant="caption" class="mt-2">
            Click to select an option. Uses Alpine.js for state management.
          </Text>
        </div>

        <!-- EmptyState -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">EmptyState (Sad Paths)</Text>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            <div
              class="rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-background)]"
            >
              <EmptyState
                icon="PhBag"
                heading="Your Cart is Empty"
                description="Looks like you haven't added anything yet. Start shopping to fill your bag!"
                action={{ label: "Start Shopping", href: "/shop" }}
              />
            </div>
            <div
              class="rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-background)]"
            >
              <EmptyState
                icon="PhMagnifyingGlass"
                heading="No Results Found"
                description="We couldn't find any products matching your search. Try different keywords."
              />
            </div>
            <div
              class="rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-background)]"
            >
              <EmptyState
                icon="PhHeart"
                heading="Save Your Favorites"
                description="Items you love will appear here. Start adding to your wishlist!"
                action={{ label: "Explore Collection", href: "/collection" }}
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Organisms Section -->
    <section class="mb-16">
      <div class="mb-6 border-b border-[var(--color-border-subtle)] pb-4">
        <Heading as="h2" class="mb-2">Organisms (Features)</Heading>
        <Text variant="caption">
          Complex, reusable features composed of multiple molecules. These are major site sections.
        </Text>
      </div>

      <div class="space-y-8">
        <!-- Footer Demo -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Footer</Text>
          <Text variant="caption" class="mb-4">
            4-column responsive footer with brand info, navigation, support links, and newsletter
            signup.
          </Text>
          <div class="-mx-4 overflow-hidden rounded-lg border border-[var(--color-border-subtle)]">
            <Footer />
          </div>
        </div>

        <!-- Navbar Note -->
        <div class="rounded-lg bg-[var(--color-surface)] p-6">
          <Text variant="caption" class="mb-2 uppercase">Navbar</Text>
          <Alert intent="info" title="Navbar Component Ready">
            <Text as="span" variant="caption">
              The Navbar component is implemented at `src/components/features/Navbar.astro`. It
              includes desktop navigation with dropdowns and a mobile slide-over drawer with
              exclusive accordion menu. Cannot be embedded here due to fixed positioning.
            </Text>
          </Alert>
        </div>
      </div>
    </section>

    <!-- Shop Components Section -->
    <section class="mb-16">
      <div class="mb-6 border-b border-[var(--color-border-subtle)] pb-4">
        <Heading as="h2" class="mb-2">Shop Components</Heading>
        <Text variant="caption">
          Product display components for the shopping experience. Test cases include products with
          various states.
        </Text>
      </div>

      <div class="space-y-8">
        <!-- ProductCard Examples -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">ProductCard States</Text>
          <Text variant="caption" class="mb-6">
            Cards feature image zoom on hover, wishlist toggle (click heart), conditional rating
            display, and responsive badges.
          </Text>

          <ProductGrid>
            <!-- Test Case A: Sale + Badge + Rating -->
            <ProductCard
              title="Celestial Moon Necklace"
              price={3500}
              salePrice={2800}
              image="https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=400&h=500&fit=crop"
              href="/shop/celestial-moon-necklace"
              badges={["New", "Sale"]}
              rating={4.8}
            />

            <!-- Test Case B: Standard (no rating, no badges) -->
            <ProductCard
              title="Minimalist Gold Ring"
              price={2200}
              image="https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=400&h=500&fit=crop"
              href="/shop/minimalist-gold-ring"
            />

            <!-- With Sale Price only -->
            <ProductCard
              title="Vintage Pearl Earrings"
              price={4200}
              salePrice={3500}
              image="https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=400&h=500&fit=crop"
              href="/shop/vintage-pearl-earrings"
              rating={4.5}
            />

            <!-- With Badge only -->
            <ProductCard
              title="Diamond Stud Earrings"
              price={5800}
              image="https://images.unsplash.com/photo-1617038220319-276d3cfab638?w=400&h=500&fit=crop"
              href="/shop/diamond-stud-earrings"
              badges={["Bestseller"]}
              rating={4.9}
            />

            <!-- New product (no rating yet) -->
            <ProductCard
              title="Delicate Chain Bracelet"
              price={1800}
              image="https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=400&h=500&fit=crop"
              href="/shop/delicate-chain-bracelet"
