---
import BaseLayout from "../layouts/BaseLayout.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";
import Button from "../components/primitives/Button.astro";
import Link from "../components/primitives/Link.astro";
import Icon from "../components/primitives/Icon.astro";
import Image from "../components/primitives/Image.astro";
import Badge from "../components/primitives/Badge.astro";
import Input from "../components/primitives/Input.astro";

// UI Molecules
import PriceTag from "../components/ui/PriceTag.astro";
import QuantitySelector from "../components/ui/QuantitySelector.astro";
import SearchInput from "../components/ui/SearchInput.astro";
import RatingStars from "../components/ui/RatingStars.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import FormField from "../components/ui/FormField.astro";
import Alert from "../components/ui/Alert.astro";
import MenuToggle from "../components/ui/MenuToggle.astro";
import Pagination from "../components/ui/Pagination.astro";
import OptionSelector from "../components/ui/OptionSelector.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import CopyButton from "../components/ui/CopyButton.astro";
import GlassProductCard from "../components/ui/GlassProductCard.astro";

// Organisms (Features)
import Footer from "../components/features/Footer.astro";
import ProductGrid from "../components/features/ProductGrid.astro";
---

<BaseLayout title="Design System Kitchen Sink | Zelia Vance">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <!-- Page Header -->
    <div class="mb-12 border-b border-(--color-border-subtle) pb-8">
      <Heading as="h1" class="mb-4">Design System Kitchen Sink</Heading>
      <Text variant="lead">
        A comprehensive showcase of all primitive components in the Zelia Vance e-commerce design
        system, built with Astro, TailwindCSS, and atomic design principles.
      </Text>
    </div>

    <!-- Typography Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Typography</Heading>

      <div class="space-y-6">
        <div>
          <Text variant="label" class="mb-3">Headings (Fraunces Font)</Text>
          <div class="space-y-4 rounded-lg bg-(--color-surface) p-6">
            <Heading as="h1">Heading 1 - The Quick Brown Fox</Heading>
            <Heading as="h2">Heading 2 - The Quick Brown Fox</Heading>
            <Heading as="h3">Heading 3 - The Quick Brown Fox</Heading>
            <Heading as="h4">Heading 4 - The Quick Brown Fox</Heading>
            <Heading as="h5">Heading 5 - The Quick Brown Fox</Heading>
            <Heading as="h6">Heading 6 - The Quick Brown Fox</Heading>
          </div>
        </div>

        <div>
          <Text variant="label" class="mb-3">Intent-Based Text Primitives (Plus Jakarta Sans)</Text>
          <div class="grid gap-6 rounded-lg bg-surface p-6 md:grid-cols-2 lg:grid-cols-3">
            <div class="space-y-4 rounded-lg border border-border-subtle p-6">
              <Text variant="eyebrow" class="mb-1">Editorial Intent</Text>
              <Text variant="lead">Lead Paragraph</Text>
              <Text variant="paragraph">
                Standard paragraph text with refined leading and spacing for optimal readability.
              </Text>
            </div>
            
            <div class="space-y-4 rounded-lg border border-border-subtle p-6">
              <Text variant="label" class="mb-1">UI Elements</Text>
              <div class="flex flex-col gap-2">
                <Text variant="metadata">Order #12345 • Shipped 2 days ago</Text>
                <Text variant="muted">Secondary information in a muted tone.</Text>
                <div class="flex gap-2">
                  <Text variant="tag">New Arrival</Text>
                  <Text variant="tag">Bestseller</Text>
                </div>
              </div>
            </div>

            <div class="space-y-4 rounded-lg border border-border-subtle p-6">
              <Text variant="label" class="mb-1">Technical & Commerce</Text>
              <div class="flex flex-col gap-2">
                <Text variant="code">const price = 2500;</Text>
                <div class="flex items-center gap-2">
                  <Text variant="price">₹2,500</Text>
                  <Text variant="price_sale">₹3,000</Text>
                </div>
              </div>
            </div>

            <div class="col-span-full space-y-4 rounded-lg border border-border-subtle p-6">
              <Text variant="label" class="mb-1">Specialized Content</Text>
              <div class="grid gap-6 md:grid-cols-2">
                <Text variant="quote">
                  "Luxury is in each detail, from the ethically sourced gems to the polished brass finishes."
                </Text>
                <Text variant="callout">
                  Limited Time Offer: Get a complimentary jewelry cleaning kit with every order over ₹5,000.
                </Text>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Buttons Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Buttons</Heading>

      <div class="space-y-8">
        <!-- Grouped by Size -->
        {
          (["sm", "md", "lg"] as const).map((size) => (
            <div>
              <Text variant="caption" class="mb-3 uppercase">
                {size === "sm" ? "Small" : size === "md" ? "Medium" : "Large"} Buttons
              </Text>
              <div class="grid grid-cols-1 gap-6 rounded-xl bg-surface p-8 sm:grid-cols-2 lg:grid-cols-4">
                {(["primary", "secondary", "neutral", "ghost"] as const).map((type) => (
                  <div class="flex flex-col gap-4">
                    <Text variant="caption" color="muted" class="text-[10px] uppercase tracking-wider">{type}</Text>
                    <div class="flex flex-wrap items-center gap-3">
                      <Button type={type} size={size}>
                        Button
                      </Button>
                      <Button type={type} size={size} variant="icon-left">
                        <Icon name="PhCheck" />
                        Left
                      </Button>
                      <Button type={type} size={size} variant="icon-right">
                        Right
                        <Icon name="PhArrowRight" />
                      </Button>
                      <Button type={type} size={size} variant="icon-only">
                        <Icon name="PhHeart" />
                      </Button>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))
        }

        <!-- Disabled State -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Disabled State</Text>
          <div class="flex flex-wrap gap-4 rounded-lg bg-(--color-surface) p-6">
            <Button disabled>Disabled Primary</Button>
            <Button type="secondary" disabled>Disabled Secondary</Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Links Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Links</Heading>
      <div class="space-y-4 rounded-lg bg-(--color-surface) p-6">
        <Text>
          This paragraph contains a <Link href="#" variant="plain">plain inline link</Link> that inherits
          the font size of its parent and transitions smoothly on hover.
        </Text>
        <Text>
          This paragraph contains an{" "}
          <Link href="https://google.com" variant="underline">external link</Link> that
          automatically adds security attributes (<code class="text-xs">target="_blank"</code>).
        </Text>
      </div>
    </section>

    <!-- Icons Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Icons</Heading>
      <div class="space-y-4">
        <div>
          <Text variant="caption" class="mb-3 uppercase">Icon Examples</Text>
          <div class="flex flex-wrap items-center gap-6 rounded-lg bg-(--color-surface) p-6">
            <div class="flex items-center gap-2">
              <Icon name="PhMagnifyingGlass" />
              <Text>Search</Text>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="PhShoppingCart" />
              <Text>Cart</Text>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="PhCheck" />
              <Text>Check</Text>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="PhCaretDown" />
              <Text>Chevron</Text>
            </div>
          </div>
        </div>
        <div>
          <Text variant="caption" class="mb-3 uppercase">Icon Sizes (inherits from text size)</Text>
          <div class="space-y-3 rounded-lg bg-(--color-surface) p-6">
            <p class="flex items-center gap-2 font-sans text-sm text-(--color-text-main)">
              <Icon name="PhShoppingCart" /> Small text with icon
            </p>
            <p class="flex items-center gap-2 font-sans text-base text-(--color-text-main)">
              <Icon name="PhShoppingCart" /> Base text with icon
            </p>
            <p class="flex items-center gap-2 font-sans text-lg text-(--color-text-main)">
              <Icon name="PhShoppingCart" /> Large text with icon
            </p>
            <p class="flex items-center gap-2 font-sans text-2xl text-(--color-text-main)">
              <Icon name="PhShoppingCart" /> 2XL text with icon
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Images Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Images</Heading>
      <Text variant="caption" class="mb-3 uppercase">Aspect Ratios</Text>
      <div class="grid gap-6 sm:grid-cols-3">
        <div>
          <Image
            src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400"
            alt="Product demo - Portrait"
            ratio="portrait"
            width={400}
            height={500}
          />
          <Text variant="caption" class="mt-2 text-center">Optimized Portrait (4:5)</Text>
        </div>
        <div>
          <Image
            src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400"
            alt="Product demo - Square"
            ratio="square"
            width={400}
            height={400}
          />
          <Text variant="caption" class="mt-2 text-center">Optimized Square (1:1)</Text>
        </div>
        <div>
          <Image
            src="https://images.unsplash.com/photo-1491553895911-0055eca6402d?w=400"
            alt="Product demo - Landscape"
            ratio="landscape"
            width={400}
            height={225}
          />
          <Text variant="caption" class="mt-2 text-center text-text-muted">Optimized Landscape (16:9)</Text>
        </div>
      </div>
    </section>

    <!-- Badges Section - Royal Conservatory System -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Badge System - 4-Tier Hierarchy</Heading>
      <Text variant="body" class="mb-6 text-text-muted">
        Badges are centralized in <code class="rounded bg-surface px-2 py-1 text-sm">badges.ts</code>
        and automatically sort by hierarchy: Urgency → Prestige → Attributes → State.
      </Text>

      <div class="space-y-8">
        <!-- Tier 1: Urgency (Coral) -->
        <div>
          <div class="mb-3 flex items-center gap-3">
            <Text variant="caption" class="uppercase">Tier 1: Urgency</Text>
            <Badge size="sm" intent="coral">Spiced Coral</Badge>
          </div>
          <Text variant="caption" class="mb-3 text-text-muted">
            Conversion drivers - FOMO & price consciousness. 85% opacity background with white text ensures visibility on ANY product image.
          </Text>
          <div class="flex flex-wrap items-center gap-3 rounded-lg bg-surface p-6">
            <Badge size="sm" intent="coral">Sale</Badge>
            <Badge size="sm" intent="coral">20% OFF</Badge>
            <Badge size="sm" intent="coral">Last Chance</Badge>
            <Badge size="sm" intent="coral">Flash Deal</Badge>
          </div>
        </div>

        <!-- Tier 2: Prestige (Brass) -->
        <div>
          <div class="mb-3 flex items-center gap-3">
            <Text variant="caption" class="uppercase">Tier 2: Prestige</Text>
            <Badge size="sm" intent="brass">Polished Brass</Badge>
          </div>
          <Text variant="caption" class="mb-3 text-text-muted">
            Premium positioning - luxury, novelty, social proof. 85% opacity + backdrop-blur for glassmorphism effect.
          </Text>
          <div class="flex flex-wrap items-center gap-3 rounded-lg bg-surface p-6">
            <Badge size="sm" intent="brass">New</Badge>
            <Badge size="sm" intent="brass">Bestseller</Badge>
            <Badge size="sm" intent="brass">Limited Edition</Badge>
            <Badge size="sm" intent="brass">Restocked</Badge>
            <Badge size="sm" intent="brass">Staff Pick</Badge>
            <Badge size="sm" intent="brass">Exclusive</Badge>
          </div>
        </div>

        <!-- Tier 3: Attributes (Surface) -->
        <div>
          <div class="mb-3 flex items-center gap-3">
            <Text variant="caption" class="uppercase">Tier 3: Attributes</Text>
            <Badge size="sm" intent="surface">Informational</Badge>
          </div>
          <Text variant="caption" class="mb-3 text-text-muted">
            Product features - USPs & specifications
          </Text>
          <div class="flex flex-wrap items-center gap-3 rounded-lg bg-surface p-6">
            <Badge size="sm" intent="surface">Waterproof</Badge>
            <Badge size="sm" intent="surface">PVD Gold</Badge>
            <Badge size="sm" intent="surface">Gift Set</Badge>
            <Badge size="sm" intent="surface">Pre-Order</Badge>
            <Badge size="sm" intent="surface">Engravable</Badge>
          </div>
        </div>

        <!-- Tier 4: State (Outline) -->
        <div>
          <div class="mb-3 flex items-center gap-3">
            <Text variant="caption" class="uppercase">Tier 4: State</Text>
            <Badge size="sm" intent="outline">Low Hierarchy</Badge>
          </div>
          <Text variant="caption" class="mb-3 text-text-muted">
            Availability status - logistics
          </Text>
          <div class="flex flex-wrap items-center gap-3 rounded-lg bg-surface p-6">
            <Badge size="sm" intent="outline">Coming Soon</Badge>
            <Badge size="sm" intent="outline">Sold Out</Badge>
          </div>
        </div>

        <!-- Badge Size Variants -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Size Variants</Text>
          <div class="flex flex-wrap items-center gap-4 rounded-lg bg-surface p-6">
            <Badge size="sm" intent="coral">Small Badge</Badge>
            <Badge size="md" intent="brass">Medium Badge</Badge>
          </div>
        </div>

        <!-- Dark Background Test -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Visibility on Dark Background</Text>
          <div class="flex flex-wrap items-center gap-3 rounded-lg bg-primary p-6">
            <Badge size="sm" intent="coral">Sale</Badge>
            <Badge size="sm" intent="brass">Bestseller</Badge>
            <Badge size="sm" intent="surface">Waterproof</Badge>
            <Badge size="sm" intent="outline">Coming Soon</Badge>
          </div>
        </div>
      </div>
    </section>

    <!-- Inputs Section -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Inputs</Heading>
      <div class="space-y-4">
        <div>
          <Text variant="caption" class="mb-3 uppercase">Normal State</Text>
          <div class="space-y-3 rounded-lg bg-surface p-6">
            <Input id="example-name" type="text" placeholder="Enter your name" />
            <Input id="example-email" type="email" placeholder="Enter your email" />
            <Input id="example-password" type="password" placeholder="Enter your password" />
          </div>
        </div>
        <div>
          <Text variant="caption" class="mb-3 uppercase">Error State</Text>
          <div class="space-y-3 rounded-lg bg-surface p-6">
            <Input id="example-error" type="email" placeholder="invalid@email" error={true} />
            <Text variant="caption" class="text-red-500">Please enter a valid email address</Text>
          </div>
        </div>
      </div>
    </section>

    <!-- UI Moleclues Continued -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">UI Molecules (Refined)</Heading>
      <div class="space-y-8">
        <!-- CopyButton -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">CopyButton (Composed with Button primitive)</Text>
          <div class="flex flex-wrap items-center gap-8 rounded-lg bg-surface p-6">
            <CopyButton text="ZELIA20" label="Copy" successLabel="Copied!" />
          </div>
        </div>
      </div>
    </section>


    <!-- Color System Reference -->
    <section class="mb-16">
      <Heading as="h2" class="mb-6">Color System (Greyscale)</Heading>
      <div class="space-y-6">
        <div>
          <Text variant="caption" class="mb-3 uppercase">Brand Actions</Text>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-lg border border-(--color-border-subtle) p-4">
              <div class="mb-2 h-16 rounded bg-(--color-primary)"></div>
              <Text variant="caption">Primary (#0f172a)</Text>
            </div>
            <div class="rounded-lg border border-(--color-border-subtle) p-4">
              <div class="mb-2 h-16 rounded bg-(--color-secondary)"></div>
              <Text variant="caption">Secondary (#e2e8f0)</Text>
            </div>
            <div class="rounded-lg border border-(--color-border-subtle) p-4">
              <div class="mb-2 h-16 rounded bg-(--color-ghost-hover)"></div>
              <Text variant="caption">Ghost Hover (#f1f5f9)</Text>
            </div>
          </div>
        </div>
        <div>
          <Text variant="caption" class="mb-3 uppercase">Surfaces</Text>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-lg border border-(--color-border-subtle) p-4">
              <div class="mb-2 h-16 rounded border bg-background"></div>
              <Text variant="caption">Background (#ffffff)</Text>
            </div>
            <div class="rounded-lg border border-(--color-border-subtle) p-4">
              <div class="mb-2 h-16 rounded bg-(--color-surface)"></div>
              <Text variant="caption">Surface (#f8fafc)</Text>
            </div>
            <div class="rounded-lg border border-(--color-border-subtle) p-4">
              <div class="mb-2 h-16 rounded bg-(--color-surface-muted)"></div>
              <Text variant="caption">Surface Muted (#f1f5f9)</Text>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Molecules (UI) Section -->
    <section class="mb-16">
      <div class="mb-6 border-b border-(--color-border-subtle) pb-4">
        <Heading as="h2" class="mb-2">Molecules (UI)</Heading>
        <Text variant="caption">
          Composed components built using Primitives. These follow the headless pattern where logic
          lives in TypeScript and UI binds to it.
        </Text>
      </div>

      <div class="space-y-8">
        <!-- PriceTag -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">PriceTag</Text>
          <div class="flex flex-wrap items-center gap-8 rounded-lg bg-(--color-surface) p-6">
            <div>
              <Text variant="caption" class="mb-2">Regular Price:</Text>
              <PriceTag price={2500} />
            </div>
            <div>
              <Text variant="caption" class="mb-2">Sale Price (20% off):</Text>
              <PriceTag price={2500} salePrice={2000} />
            </div>
            <div>
              <Text variant="caption" class="mb-2">Big Discount (50% off):</Text>
              <PriceTag price={5000} salePrice={2500} />
            </div>
          </div>
        </div>

        <!-- QuantitySelector -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">QuantitySelector (Headless)</Text>
          <div class="flex flex-wrap items-center gap-8 rounded-lg bg-(--color-surface) p-6">
            <div>
              <Text variant="caption" class="mb-2">Default (1-99):</Text>
              <QuantitySelector />
            </div>
            <div>
              <Text variant="caption" class="mb-2">Custom Range (1-5):</Text>
              <QuantitySelector min={1} max={5} initial={3} />
            </div>
          </div>
        </div>

        <!-- SearchInput -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">SearchInput</Text>
          <div class="max-w-md rounded-lg bg-(--color-surface) p-6">
            <SearchInput placeholder="Search products..." />
          </div>
        </div>

        <!-- RatingStars -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">RatingStars</Text>
          <div class="flex flex-wrap items-center gap-6 rounded-lg bg-(--color-surface) p-6">
            <div class="flex items-center gap-2">
              <RatingStars rating={5} />
              <Text variant="caption">5.0</Text>
            </div>
            <div class="flex items-center gap-2">
              <RatingStars rating={4} />
              <Text variant="caption">4.0</Text>
            </div>
            <div class="flex items-center gap-2">
              <RatingStars rating={3.5} />
              <Text variant="caption">3.5</Text>
            </div>
            <div class="flex items-center gap-2">
              <RatingStars rating={2} />
              <Text variant="caption">2.0</Text>
            </div>
            <div class="flex items-center gap-2">
              <RatingStars rating={0} />
              <Text variant="caption">0.0</Text>
            </div>
          </div>
        </div>

        <!-- Breadcrumbs -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Breadcrumbs</Text>
          <div class="rounded-lg bg-(--color-surface) p-6">
            <Breadcrumbs
              items={[
                { label: "Home", href: "/" },
                { label: "Products", href: "/products" },
                { label: "Accessories", href: "/products/accessories" },
                { label: "Watch" },
              ]}
            />
          </div>
        </div>

        <!-- FormField -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">FormField</Text>
          <div class="grid gap-6 rounded-lg bg-(--color-surface) p-6 sm:grid-cols-2">
            <FormField label="Email Address" name="email" placeholder="you@example.com" />
            <FormField
              label="Password"
              name="password"
              type="password"
              placeholder="Enter password"
              error="Password must be at least 8 characters"
            />
          </div>
        </div>

        <!-- Alert -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Alert</Text>
          <div class="space-y-4 rounded-lg bg-(--color-surface) p-6">
            <Alert intent="info" title="Information">
              <Text as="span" variant="caption"
                >Your order has been received and is being processed.</Text
              >
            </Alert>
            <Alert intent="warning" title="Warning">
              <Text as="span" variant="caption">Only 3 items left in stock!</Text>
            </Alert>
            <Alert intent="success" title="Success">
              <Text as="span" variant="caption"
                >Your payment was successful. Thank you for your order!</Text
              >
            </Alert>
          </div>
        </div>

        <!-- MenuToggle -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">MenuToggle (Headless)</Text>
          <div class="rounded-lg bg-(--color-surface) p-6">
            <MenuToggle label="Navigation menu">
              <div
                class="w-48 rounded-lg border border-(--color-border-subtle) bg-background p-2 shadow-lg"
              >
                <a
                  href="#"
                  class="block rounded px-3 py-2 text-sm hover:bg-(--color-ghost-hover)"
                  >Dashboard</a
                >
                <a
                  href="#"
                  class="block rounded px-3 py-2 text-sm hover:bg-(--color-ghost-hover)"
                  >Products</a
                >
                <a
                  href="#"
                  class="block rounded px-3 py-2 text-sm hover:bg-(--color-ghost-hover)"
                  >Orders</a
                >
                <a
                  href="#"
                  class="block rounded px-3 py-2 text-sm hover:bg-(--color-ghost-hover)"
                  >Settings</a
                >
              </div>
            </MenuToggle>
            <Text variant="caption" class="mt-2"
              >Click the hamburger icon to toggle the dropdown menu.</Text
            >
          </div>
        </div>

        <!-- Pagination -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Pagination</Text>
          <div class="space-y-4 rounded-lg bg-(--color-surface) p-6">
            <div>
              <Text variant="caption" class="mb-2">Few Pages:</Text>
              <Pagination currentPage={2} totalPages={5} baseUrl="#" />
            </div>
            <div>
              <Text variant="caption" class="mb-2">Many Pages (with ellipsis):</Text>
              <Pagination currentPage={5} totalPages={20} baseUrl="#" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- User Choices & States Section -->
    <section class="mb-16">
      <div class="mb-6 border-b border-(--color-border-subtle) pb-4">
        <Heading as="h2" class="mb-2">User Choices & States</Heading>
        <Text variant="caption">
          Components for handling user selections and empty/error states.
        </Text>
      </div>

      <div class="space-y-8">
        <!-- OptionSelector -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">OptionSelector (Variant Picker)</Text>
          <div class="grid gap-8 rounded-lg bg-(--color-surface) p-6 sm:grid-cols-2">
            <OptionSelector
              legend="Ring Size"
              options={["6", "7", "8", "9"]}
              name="ring_size"
              selected="7"
            />
            <OptionSelector
              legend="Material"
              options={["Gold", "Silver", "Rose Gold"]}
              name="material"
            />
          </div>
          <Text variant="caption" class="mt-2">
            Click to select an option. Uses Alpine.js for state management.
          </Text>
        </div>

        <!-- EmptyState -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">EmptyState (Sad Paths)</Text>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            <div
              class="rounded-lg border border-(--color-border-subtle) bg-background"
            >
              <EmptyState
                icon="PhBag"
                heading="Your Cart is Empty"
                description="Looks like you haven't added anything yet. Start shopping to fill your bag!"
                action={{ label: "Start Shopping", href: "/shop" }}
              />
            </div>
            <div
              class="rounded-lg border border-(--color-border-subtle) bg-background"
            >
              <EmptyState
                icon="PhMagnifyingGlass"
                heading="No Results Found"
                description="We couldn't find any products matching your search. Try different keywords."
              />
            </div>
            <div
              class="rounded-lg border border-(--color-border-subtle) bg-background"
            >
              <EmptyState
                icon="PhHeart"
                heading="Save Your Favorites"
                description="Items you love will appear here. Start adding to your wishlist!"
                action={{ label: "Explore Collection", href: "/collection" }}
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Organisms Section -->
    <section class="mb-16">
      <div class="mb-6 border-b border-(--color-border-subtle) pb-4">
        <Heading as="h2" class="mb-2">Organisms (Features)</Heading>
        <Text variant="caption">
          Complex, reusable features composed of multiple molecules. These are major site sections.
        </Text>
      </div>

      <div class="space-y-8">
        <!-- Footer Demo -->
        <div>
          <Text variant="caption" class="mb-3 uppercase">Footer</Text>
          <Text variant="caption" class="mb-4">
            4-column responsive footer with brand info, navigation, support links, and newsletter
            signup.
          </Text>
          <div class="-mx-4 overflow-hidden rounded-lg border border-(--color-border-subtle)">
            <Footer />
          </div>
        </div>

        <!-- Navbar Note -->
        <div class="rounded-lg bg-(--color-surface) p-6">
          <Text variant="caption" class="mb-2 uppercase">Navbar</Text>
          <Alert intent="info" title="Navbar Component Ready">
            <Text as="span" variant="caption">
              The Navbar component is implemented at `src/components/features/Navbar.astro`. It
              includes desktop navigation with dropdowns and a mobile slide-over drawer with
              exclusive accordion menu. Cannot be embedded here due to fixed positioning.
            </Text>
          </Alert>
        </div>
      </div>
    </section>

    <!-- Shop Components Section -->
    <section class="mb-16">
      <div class="mb-6 border-b border-(--color-border-subtle) pb-4">
        <Heading as="h2" class="mb-2">Shop Components</Heading>
        <Text variant="caption">
          Product display components for the shopping experience. Test cases include products with
          various states.
        </Text>
      </div>

      <div class="space-y-8">

      </div>
    </section>

    <!-- Glass Product Card Section -->
    <section class="mb-16">
      <div class="mb-6 border-b border-(--color-border-subtle) pb-4">
        <Heading as="h2" class="mb-2">Glass Product Card</Heading>
        <Text variant="caption">
          Premium Glassmorphism card — a UI Molecule. Hover on desktop to see the Quick Shop
          button animate up. On mobile a persistent cart icon sits in the price row.
        </Text>
      </div>

      {/* Cards sit on a warm-toned image backdrop so the glass effect is visible */}
      <div
        class="relative overflow-hidden rounded-xl"
        style="background-image: url('https://images.unsplash.com/photo-1617500603321-ece5f30d8f16?w=1400&auto=format&fit=crop&q=80'); background-size: cover; background-position: center;"
      >
        {/* Subtle dark veil over image for contrast */}
        <div class="absolute inset-0 bg-primary/30 backdrop-blur-[2px] rounded-xl" />

        <div class="relative z-10 grid grid-cols-1 sm:grid-cols-3 gap-6 p-8">

          {/* Variant 1: Standard — one badge, no rating, no sale */}
          <div>
            <Text variant="eyebrow" class="mb-3 text-white">Standard</Text>
            <GlassProductCard
              image="https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=600&h=750&fit=crop"
              title="Celestial Moon Necklace"
              price={3500}
              badges={["bestseller"]}
              href="/shop/celestial-moon-necklace"
            />
          </div>

          {/* Variant 2: Sale — original price shown, rating visible */}
          <div>
            <Text variant="eyebrow" class="mb-3 text-white">Sale + Rating</Text>
            <GlassProductCard
              image="https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?w=600&h=750&fit=crop"
              title="Vintage Pearl Earrings"
              price={4200}
              salePrice={2800}
              badges={["sale", "new"]}
              href="/shop/vintage-pearl-earrings"
            />
          </div>

          {/* Variant 3: Long Title — tests truncation, no badges */}
          <div>
            <Text variant="eyebrow" class="mb-3 text-white">Long Title (truncation)</Text>
            <GlassProductCard
              image="https://images.unsplash.com/photo-1602173574767-37ac01994b2a?w=600&h=900&fit=crop"
              title="Handcrafted Rose Gold & Diamond-Studded Mangalsutra Bangle Set"
              price={5800}
              badges={["limited-edition", "pvd-gold"]}
              href="/shop/rose-gold-mangalsutra-bangle-set"
            />
          </div>

        </div>
      </div>

      {/* Notes panel */}
      <div class="mt-4 rounded-lg bg-surface p-5 space-y-1.5">
        <Text variant="eyebrow" class="mb-2">Implementation Notes</Text>
        <Text variant="caption" color="muted">• Component: <code class="rounded bg-surface-muted px-1.5 py-0.5 text-xs font-mono">src/components/ui/GlassProductCard.astro</code> (UI Molecule — no scripts/behavior imports)</Text>
        <Text variant="caption" color="muted">• Hover a card on desktop: glass panel expands upward, Quick Shop fades in with a 75ms delay</Text>
        <Text variant="caption" color="muted">• On mobile (&lt;md): Quick Shop is hidden; a shopping bag icon links to the PDP</Text>
        <Text variant="caption" color="muted">• Wishlist heart uses <code class="rounded bg-surface-muted px-1.5 py-0.5 text-xs font-mono">$store.wishlist</code> — same Alpine.js store as ProductCard</Text>
        <Text variant="caption" color="muted">• Quick Shop dispatches <code class="rounded bg-surface-muted px-1.5 py-0.5 text-xs font-mono">zeliavance:quick-shop</code> event for any Feature to catch</Text>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mt-16 border-t border-(--color-border-subtle) pt-8 text-center">
      <Text variant="caption">
        Design System for Zelia Vance E-commerce | Built with Astro, TailwindCSS & Atomic Design
      </Text>
    </footer>
  </div>
</BaseLayout>
