---
import { getCollection, getEntry } from "astro:content";
import EngineLayout from "../../layouts/EngineLayout.astro";
import SmartProductGrid from "../../components/features/SmartProductGrid.astro";
import Pagination from "../../components/ui/Pagination.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import Section from "../../components/primitives/Section.astro";
import type { Page, PaginateFunction } from "astro";

// Pre-render at build time (required in server mode)
export const prerender = true;

import { sortProductsByHierarchy } from "../../scripts/utils/product-sort";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allProducts = await getCollection("products");
  const sortedProducts = await sortProductsByHierarchy(allProducts);
  return paginate(sortedProducts, { pageSize: 12 });
}

interface Props {
  page: Page<any>;
}

const { page } = Astro.props;
const products = page.data;
import PageHeader from "../../components/ui/PageHeader.astro";

const shopHeader = await getEntry('page_headers', 'shop-all');
const data = shopHeader?.data || { 
  title: "All Jewelry", 
  subtitle: "Discover our curated collection of handcrafted pieces",
  align: "left"
};
---

<EngineLayout pageTitle="Shop All Jewelry">

  <Section as="main" variant="standard">
    <div class="mb-8">
      <PageHeader 
        title={data.title} 
        subtitle={data.subtitle}
        align={data.align || "left"}
      />
    </div>

    <SmartProductGrid products={products} />

    {/* Pagination - shown when more than 12 products */}
    {
      page.lastPage > 1 && (
        <div class="mt-16">
          <Pagination currentPage={page.currentPage} totalPages={page.lastPage} baseUrl="/shop" />
        </div>
      )
    }
  </Section>
</EngineLayout>

