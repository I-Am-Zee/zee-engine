---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/features/Navbar.astro";
import Footer from "../../components/features/Footer.astro";
import Heading from "../../components/primitives/Heading.astro";
import Text from "../../components/primitives/Text.astro";
import GlassProductCard from "../../components/ui/GlassProductCard.astro";
import ProductGrid from "../../components/features/ProductGrid.astro";
import FilterSortBar from "../../components/ui/FilterSortBar.astro";
import Pagination from "../../components/ui/Pagination.astro";
import type { Page, PaginateFunction } from "astro";

// Pre-render at build time (required in server mode)
export const prerender = true;

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allProducts = await getCollection("products");
  return paginate(allProducts, { pageSize: 12 });
}

interface Props {
  page: Page<any>;
}

const { page } = Astro.props;
const products = page.data;
---

<BaseLayout title="Shop All Jewelry | Zelia Vance">

  <div class="mx-auto max-w-7xl px-4 py-16 md:py-24 lg:px-8" x-data="productSorter">
    {/* Page Header */}
    <div class="mb-8 max-[425px]:text-center">
      <Heading as="h1" class="mb-2">All Jewelry</Heading>
      <Text class="text-text-muted">Discover our curated collection of handcrafted pieces</Text>
    </div>

    {/* Filter/Sort Bar */}
    <FilterSortBar productCount={page.total} />

    {/* Product Grid with Alpine.js sorting */}
    <div id="product-grid">
      <ProductGrid>
        {
          products.map((product, index) => (
            <div
              class="product-item"
              data-index={index}
              data-price={product.data.salePrice || product.data.price}
              data-original-price={product.data.price}
              data-sale-price={product.data.salePrice || ""}
              data-name={product.data.title}
              data-rating={product.data.rating || 0}
              data-publish-date={
                product.data.publishDate ? new Date(product.data.publishDate).getTime() : 0
              }
              data-discount={
                product.data.salePrice
                  ? Math.round((1 - product.data.salePrice / product.data.price) * 100)
                  : 0
              }
            >
              <GlassProductCard product={product} />
            </div>
          ))
        }
      </ProductGrid>
    </div>

    {/* Pagination - shown when more than 12 products */}
    {
      page.lastPage > 1 && (
        <Pagination currentPage={page.currentPage} totalPages={page.lastPage} baseUrl="/shop" />
      )
    }
  </div>

  </div>
</BaseLayout>

<script>
  // @ts-ignore
  function initSorter() {
    if (!window.Alpine) return;
    
    // @ts-ignore
    const Alpine = window.Alpine;

    Alpine.data("productSorter", () => ({
      sortBy: "default",

      sort(criteria: string) {
        this.sortBy = criteria;
        const grid = document.querySelector("[data-product-grid]");
        if (!grid) return;

        const items = Array.from(grid.querySelectorAll(".product-item")) as HTMLElement[];

        items.sort((a, b) => {
          const aPrice = parseFloat(a.dataset.price || "0");
          const bPrice = parseFloat(b.dataset.price || "0");
          const aName = a.dataset.name || "";
          const bName = b.dataset.name || "";
          const aRating = parseFloat(a.dataset.rating || "0");
          const bRating = parseFloat(b.dataset.rating || "0");
          const aDate = parseInt(a.dataset.publishDate || "0");
          const bDate = parseInt(b.dataset.publishDate || "0");
          const aDiscount = parseFloat(a.dataset.discount || "0");
          const bDiscount = parseFloat(b.dataset.discount || "0");
          const aIndex = parseInt(a.dataset.index || "0");
          const bIndex = parseInt(b.dataset.index || "0");

          switch (criteria) {
            case "price-asc":
              return aPrice - bPrice;
            case "price-desc":
              return bPrice - aPrice;
            case "name-asc":
              return aName.localeCompare(bName);
            case "name-desc":
              return bName.localeCompare(aName);
            case "rating-desc":
              return bRating - aRating;
            case "date-desc":
              return bDate - aDate;
            case "discount-desc":
              return bDiscount - aDiscount;
            case "default":
              return aIndex - bIndex;
            default:
              return 0;
          }
        });

        items.forEach((item) => grid.appendChild(item));
      },
    }));
  }

  document.addEventListener("alpine:init", initSorter);
  document.addEventListener("astro:page-load", initSorter);
</script>
