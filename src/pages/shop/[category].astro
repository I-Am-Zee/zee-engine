---
/**
 * Dynamic Category Page with Auto-detected Categories and Pagination
 * Displays products filtered by category with sorting options
 */

import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/features/Navbar.astro";
import Footer from "../../components/features/Footer.astro";
import Heading from "../../components/primitives/Heading.astro";
import Text from "../../components/primitives/Text.astro";
import ProductCard from "../../components/features/ProductCard.astro";
import ProductGrid from "../../components/features/ProductGrid.astro";
import FilterSortBar from "../../components/ui/FilterSortBar.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import Pagination from "../../components/ui/Pagination.astro";

// Category display info - add new categories here as needed
const CATEGORY_INFO: Record<string, { name: string; description: string }> = {
  rings: {
    name: "Rings",
    description:
      "Discover our collection of exquisite rings, from engagement diamonds to everyday elegance.",
  },
  necklaces: {
    name: "Necklaces",
    description:
      "Explore our curated selection of necklaces, from delicate pendants to statement pieces.",
  },
  earrings: {
    name: "Earrings",
    description: "Find the perfect pair of earrings to complement any occasion.",
  },
  bracelets: {
    name: "Bracelets",
    description: "Adorn your wrist with our stunning bracelet collection.",
  },
  gifts: {
    name: "Gifts",
    description: "Thoughtfully curated gift sets for life's special moments.",
  },
};

// Products per page for pagination
const PRODUCTS_PER_PAGE = 12;

// Pre-render at build time (required in server mode)
export const prerender = true;

export async function getStaticPaths() {
  const allProducts = await getCollection("products");

  // Auto-detect categories from products - no hardcoded list needed!
  const categoriesSet = new Set<string>();
  allProducts.forEach((product) => {
    categoriesSet.add(product.data.category);
  });
  const categories = Array.from(categoriesSet);

  // Category display info fallback for auto-detected categories
  const categoryInfo: Record<string, { name: string; description: string }> = {
    rings: {
      name: "Rings",
      description:
        "Discover our collection of exquisite rings, from engagement diamonds to everyday elegance.",
    },
    necklaces: {
      name: "Necklaces",
      description:
        "Explore our curated selection of necklaces, from delicate pendants to statement pieces.",
    },
    earrings: {
      name: "Earrings",
      description: "Find the perfect pair of earrings to complement any occasion.",
    },
    bracelets: {
      name: "Bracelets",
      description: "Adorn your wrist with our stunning bracelet collection.",
    },
    gifts: {
      name: "Gifts",
      description: "Thoughtfully curated gift sets for life's special moments.",
    },
  };

  return categories.map((category) => {
    const categoryProducts = allProducts.filter((product) => product.data.category === category);
    // Default fallback for new categories
    const info = categoryInfo[category] || {
      name: category.charAt(0).toUpperCase() + category.slice(1),
      description: `Browse our ${category} collection.`,
    };
    return {
      params: { category },
      props: {
        products: categoryProducts,
        categoryName: info.name,
        categoryDescription: info.description,
      },
    };
  });
}

interface Props {
  products: Awaited<ReturnType<typeof getCollection<"products">>>;
  categoryName: string;
  categoryDescription: string;
}

const { category } = Astro.params;
const { products, categoryName, categoryDescription } = Astro.props;

// Pagination info (client-side pagination handled by Alpine.js)
const totalPages = Math.ceil(products.length / PRODUCTS_PER_PAGE);
---

<BaseLayout title={`${categoryName} | Zaviona`}>
  <Navbar />

  <div
    class="mx-auto max-w-7xl px-4 py-12 lg:px-8"
    x-data={`productSorter(${JSON.stringify(
      products.map((p) => ({
        slug: p.slug,
        price: p.data.salePrice || p.data.price,
        originalPrice: p.data.price,
        salePrice: p.data.salePrice,
        name: p.data.title,
        rating: p.data.rating || 0,
        publishDate: p.data.publishDate ? new Date(p.data.publishDate).getTime() : 0,
        discount: p.data.salePrice ? Math.round((1 - p.data.salePrice / p.data.price) * 100) : 0,
      }))
    )})`}
  >
    {/* Breadcrumbs */}
    <div class="mb-6">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Shop", href: "/shop" },
          { label: categoryName },
        ]}
      />
    </div>

    {/* Page Header */}
    <div class="mb-8">
      <Heading as="h1" class="mb-2">{categoryName}</Heading>
      <Text class="text-(--color-text-muted)">{categoryDescription}</Text>
    </div>

    {
      products.length > 0 ? (
        <>
          {/* Filter/Sort Bar */}
          <FilterSortBar productCount={products.length} categoryName={categoryName.toLowerCase()} />

          {/* Product Grid with Alpine.js sorting */}
          <div id="product-grid">
            <ProductGrid>
              {products.map((product, index) => (
                <div
                  class="product-item"
                  data-index={index}
                  data-slug={product.slug}
                  data-price={product.data.salePrice || product.data.price}
                  data-original-price={product.data.price}
                  data-sale-price={product.data.salePrice || ""}
                  data-name={product.data.title}
                  data-rating={product.data.rating || 0}
                  data-publish-date={
                    product.data.publishDate ? new Date(product.data.publishDate).getTime() : 0
                  }
                  data-discount={
                    product.data.salePrice
                      ? Math.round((1 - product.data.salePrice / product.data.price) * 100)
                      : 0
                  }
                >
                  <ProductCard
                    id={product.slug}
                    title={product.data.title}
                    price={product.data.price}
                    salePrice={product.data.salePrice}
                    image={product.data.image}
                    href={`/products/${product.slug}`}
                    badges={product.data.badges}
                    rating={product.data.rating}
                  />
                </div>
              ))}
            </ProductGrid>
          </div>

          {/* Pagination */}
          {totalPages > 1 && (
            <Pagination currentPage={1} totalPages={totalPages} baseUrl={`/shop/${category}`} />
          )}
        </>
      ) : (
        <EmptyState
          icon="PhMagnifyingGlass"
          heading={`No ${categoryName} Found`}
          description={`We don't have any ${categoryName.toLowerCase()} in our collection yet. Check back soon!`}
          action={{ label: "View All Products", href: "/shop" }}
        />
      )
    }
  </div>

  <Footer />
</BaseLayout>

<script>
  // @ts-ignore
  document.addEventListener("alpine:init", () => {
    // @ts-ignore
    const Alpine = window.Alpine;

    Alpine.data("productSorter", () => ({
      sortBy: "default",

      sort(criteria: string) {
        this.sortBy = criteria;
        const grid = document.querySelector("[data-product-grid]");
        if (!grid) return;

        const items = Array.from(grid.querySelectorAll(".product-item")) as HTMLElement[];

        items.sort((a, b) => {
          const aPrice = parseFloat(a.dataset.price || "0");
          const bPrice = parseFloat(b.dataset.price || "0");
          const aName = a.dataset.name || "";
          const bName = b.dataset.name || "";
          const aRating = parseFloat(a.dataset.rating || "0");
          const bRating = parseFloat(b.dataset.rating || "0");
          const aDate = parseInt(a.dataset.publishDate || "0");
          const bDate = parseInt(b.dataset.publishDate || "0");
          const aDiscount = parseFloat(a.dataset.discount || "0");
          const bDiscount = parseFloat(b.dataset.discount || "0");
          const aIndex = parseInt(a.dataset.index || "0");
          const bIndex = parseInt(b.dataset.index || "0");

          switch (criteria) {
            case "price-asc":
              return aPrice - bPrice;
            case "price-desc":
              return bPrice - aPrice;
            case "name-asc":
              return aName.localeCompare(bName);
            case "name-desc":
              return bName.localeCompare(aName);
            case "rating-desc":
              return bRating - aRating;
            case "date-desc":
              return bDate - aDate;
            case "discount-desc":
              return bDiscount - aDiscount;
            case "default":
              return aIndex - bIndex;
            default:
              return 0;
          }
        });

        items.forEach((item) => grid.appendChild(item));
      },
    }));
  });
</script>
