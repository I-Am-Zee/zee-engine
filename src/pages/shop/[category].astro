---
/**
 * Dynamic Category Page with Auto-detected Categories and Pagination
 * Displays products filtered by category with sorting options
 */

import { getCollection, getEntry } from "astro:content";
import EngineLayout from "../../layouts/EngineLayout.astro";
import Heading from "../../components/primitives/Heading.astro";
import Text from "../../components/primitives/Text.astro";
import GlassProductCard from "../../components/ui/GlassProductCard.astro";
import ProductGrid from "../../components/features/ProductGrid.astro";
import FilterSortBar from "../../components/ui/FilterSortBar.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import Pagination from "../../components/ui/Pagination.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import RelatedProducts from "../../components/features/RelatedProducts.astro";
import ComingSoon from "../../components/ui/ComingSoon.astro";
import EmptyState from "../../components/ui/EmptyState.astro";


import { slugify } from "../../scripts/utils/slugify";

// Products per page for pagination
const PRODUCTS_PER_PAGE = 12;

// Pre-render at build time (required in server mode)
export const prerender = true;

export async function getStaticPaths() {
  const allProducts = await getCollection("products");
  const taxonomy = await getEntry("settings", "taxonomy");
  const categories = (taxonomy?.data as any)?.categories || [];
  
  let gridData;
  try {
    gridData = await getEntry("collections_grid", "data");
  } catch (e) {
    console.warn("Collections grid data not found.");
  }
  const cards = (gridData?.data as any)?.cards || [];

  return categories.map((categoryLabel: string) => {
    const categorySlug = slugify(categoryLabel);
    
    // Find matching CMS record
    const match = cards.find((c: any) => c.slug === categorySlug && c.type === 'category');
    const isComingSoon = match?.is_coming_soon === true;
    
    // Find products, OR force empty if coming soon
    const categoryProducts = isComingSoon ? [] : allProducts.filter(
      (product) => product.data.category?.toLowerCase() === categoryLabel.toLowerCase()
    );

    return {
      params: { category: categorySlug },
      props: {
        products: categoryProducts,
        categoryLabel,
        categoryDescription: match?.description || "",
        isComingSoon
      },
    };
  });
}

interface Props {
  products: Awaited<ReturnType<typeof getCollection<"products">>>;
  categoryLabel: string;
  categoryDescription: string;
  isComingSoon: boolean;
}

const { category } = Astro.params;
const { products, categoryLabel, categoryDescription, isComingSoon } = Astro.props;

// Pagination info (client-side pagination handled by Alpine.js)
const totalPages = Math.ceil(products.length / PRODUCTS_PER_PAGE);

// ── Smart Page Controller Logic (Cross-Sell) ──────────────────────
const allProducts = await getCollection("products");
const crossSellHeader = await getEntry("section_headers", "category-related");

const crossSellProducts = allProducts
  .filter((p) => p.data.category?.toLowerCase() !== categoryLabel.toLowerCase())
  .sort(() => 0.5 - Math.random())
  .slice(0, 4);

const crossSellTitle = crossSellHeader?.data?.title || "Pair With Your Selection";
const crossSellSubtitle = crossSellHeader?.data?.subtitle || "Discover stunning pieces that elevate these styles";
---

<EngineLayout pageTitle={categoryLabel}>

  <div
    class="mx-auto max-w-7xl px-4 py-12 lg:px-8"
    x-data="productSorter"
  >
    {/* Breadcrumbs */}
    <div class="mb-6">
      <Breadcrumbs
        items={[
          { label: "Home", href: "/" },
          { label: "Shop", href: "/shop" },
          { label: categoryLabel },
        ]}
      />
    </div>

    {/* Page Header */}
    <PageHeader 
      title={categoryLabel} 
      subtitle={categoryDescription} 
      align="left"
      class="mb-8"
    />


    {
      isComingSoon ? (
        <ComingSoon categoryName={categoryLabel} />
      ) : products.length > 0 ? (
        <>
          {/* Filter/Sort Bar */}
          <FilterSortBar productCount={products.length} categoryName={categoryLabel.toLowerCase()} />

          {/* Product Grid with Alpine.js sorting */}
          <div id="product-grid">
            <ProductGrid>
              {products.map((product, index) => (
                <div
                  class="product-item"
                  data-index={index}
                  data-id={product.id}
                  data-price={product.data.salePrice || product.data.price}
                  data-original-price={product.data.price}
                  data-sale-price={product.data.salePrice || ""}
                  data-name={product.data.title}
                  data-rating={product.data.rating || 0}
                  data-publish-date={
                    product.data.publishDate ? new Date(product.data.publishDate).getTime() : 0
                  }
                  data-discount={
                    product.data.salePrice
                      ? Math.round((1 - product.data.salePrice / product.data.price) * 100)
                      : 0
                  }
                >
                  <GlassProductCard product={product} />
                </div>
              ))}
            </ProductGrid>
          </div>

          {/* Pagination */}
          {totalPages > 1 && (
            <Pagination currentPage={1} totalPages={totalPages} baseUrl={`/shop/${category}`} />
          )}
        </>
      ) : (
        <EmptyState
          icon="shopping-bag"
          heading="No products found"
          description={`We couldn't find any products in the ${categoryLabel} category.`}
          action={{ label: "Back to Shop", href: "/shop" }}
        />
      )
    }

    {/* Algorithmic Cross-Sell */}
    <div class="-mx-4 sm:mx-0 lg:-mx-8 mt-16">
      <RelatedProducts 
        title={crossSellTitle}
        subtitle={crossSellSubtitle}
        products={crossSellProducts}
      />
    </div>

  </div>
</EngineLayout>

<script>
  // @ts-ignore
  function initSorter() {
    if (!window.Alpine) return;
    window.Alpine.data("productSorter", () => ({
      sortBy: "default",
      sort(criteria) {
        this.sortBy = criteria;
        const grid = document.querySelector("#product-grid");
        if (!grid) return;

        const items = Array.from(grid.querySelectorAll(".product-item"));

        items.sort((a, b) => {
          // @ts-ignore
          const aPrice = parseFloat(a.dataset.price || "0");
          // @ts-ignore
          const bPrice = parseFloat(b.dataset.price || "0");
          // @ts-ignore
          const aName = a.dataset.name || "";
          // @ts-ignore
          const bName = b.dataset.name || "";
          // @ts-ignore
          const aRating = parseFloat(a.dataset.rating || "0");
          // @ts-ignore
          const bRating = parseFloat(b.dataset.rating || "0");
          // @ts-ignore
          const aDate = parseInt(a.dataset.publishDate || "0");
          // @ts-ignore
          const bDate = parseInt(b.dataset.publishDate || "0");
          // @ts-ignore
          const aDiscount = parseFloat(a.dataset.discount || "0");
          // @ts-ignore
          const bDiscount = parseFloat(b.dataset.discount || "0");
          // @ts-ignore
          const aIndex = parseInt(a.dataset.index || "0");
          // @ts-ignore
          const bIndex = parseInt(b.dataset.index || "0");

          switch (criteria) {
            case "price-asc": return aPrice - bPrice;
            case "price-desc": return bPrice - aPrice;
            case "name-asc": return aName.localeCompare(bName);
            case "name-desc": return bName.localeCompare(aName);
            case "rating-desc": return bRating - aRating;
            case "date-desc": return bDate - aDate;
            case "discount-desc": return bDiscount - aDiscount;
            case "default": return aIndex - bIndex;
            default: return 0;
          }
        });

        items.forEach((item) => grid.appendChild(item));
      },
    }));
  }

  document.addEventListener("alpine:init", initSorter);
  document.addEventListener("astro:page-load", initSorter);
</script>
