---
import { getCollection, getEntry } from "astro:content";
import EngineLayout from "../../layouts/EngineLayout.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import FilterSortBar from "../../components/ui/FilterSortBar.astro";
import BlogCard from "../../components/ui/BlogCard.astro";
import BlogCategoryFilter from "../../components/ui/BlogCategoryFilter.astro";
import Pagination from "../../components/ui/Pagination.astro";
import Text from "../../components/primitives/Text.astro";
import Section from "../../components/primitives/Section.astro";
import Icon from "../../components/primitives/Icon.astro";
import type { Page, PaginateFunction } from "astro";

export const prerender = true;

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const allPosts = await getCollection("blog", ({ data }) => {
    return data.isDraft !== true;
  });

  // Default sort: latest first
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  );

  return paginate(sortedPosts, { pageSize: 8 });
}

interface Props {
  page: Page<any>;
}

const { page } = Astro.props;
const posts = page.data;

// Pre-fetch all authors for performance
const authorsEntry = await getEntry('authors', 'authors');
const authorsList = authorsEntry?.data || [];

// Identify featured post (first post on page 1)
const isFirstPage = page.currentPage === 1;
const featuredPost = isFirstPage ? posts[0] : null;
const remainingPosts = isFirstPage ? posts.slice(1) : posts;

// Load Page Header content
const headerEntry = await getEntry('page_headers', 'blog-index');
const headerData = headerEntry?.data || {
  heading: "The Journal",
  description: "Stories, style guides, and care tips.",
  labels: {
    filterHeading: "Filter By Category",
    allStories: "All Stories",
    showAll: "Show All Stories",
    noResults: "No articles found.",
    itemsFound: "found",
    showingFiltered: "Showing"
  }
};

// Default sort for FilterSortBar
const methodsEntry = await getEntry("settings", "sorting-methods");
const defaultSort = methodsEntry?.data?.blog?.default_sort || 'latest';
---

<EngineLayout pageTitle={headerData.heading}>
  <main x-data={`blogDiscovery('${defaultSort}')`}>
    {/* Section 1: Header & Featured */}
    <Section as="div" variant="standard" class="pt-8! pb-0!">
      <PageHeader 
        title={headerData.heading} 
        subtitle={headerData.description}
        align="left"
        class="mb-12"
      />

      {isFirstPage && featuredPost && (
        <div class="mb-20">
          <BlogCard 
            post={featuredPost} 
            variant="horizontal" 
            authorData={authorsList.find((a: any) => a.name === featuredPost.data.author) || authorsList[0]}
            class="shadow-xl! md:min-h-[400px]"
          />
        </div>
      )}
    </Section>

    {/* Section 2: Full-Bleed Sticky Filter Shelf */}
    <Section 
      as="div" 
      variant="full" 
      class="sticky top-[64px] z-40 bg-navbar-glass"
    >
      <div class="max-w-7xl mx-auto px-4 lg:px-8">
        <FilterSortBar 
          productCount={page.total} 
          itemLabel="articles" 
          context="blog" 
        />
      </div>
    </Section>

    {/* Section 3: Sidebar & Grid */}
    <Section variant="standard" class="pt-8!">
      <div class="flex flex-col lg:flex-row gap-12">
        {/* Category Sidebar */}
        <BlogCategoryFilter 
          class="lg:w-64 shrink-0" 
          labels={headerData.labels}
        />

        {/* Main Grid */}
        <div class="flex-1">
          <div 
            class="grid gap-8 md:grid-cols-1" 
            x-ref="blogGrid"
          >
            {remainingPosts.map((post) => (
              <div
                class="blog-item transition-all duration-500"
                x-show={`shouldShow('${JSON.stringify(post.data.tags || [])}', '${post.data.category}')`}
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-4"
                x-transition:enter-end="opacity-100 translate-y-0"
                data-tags={JSON.stringify(post.data.tags || [])}
                data-category={post.data.category}
                data-date={post.data.publishDate.toISOString()}
                data-name={post.data.title}
                x-cloak
              >
                <BlogCard 
                  post={post} 
                  variant="horizontal" 
                  authorData={authorsList.find((a: any) => a.name === post.data.author) || authorsList[0]}
                />
              </div>
            ))}
          </div>

          {/* Empty State */}
          <div x-show="selectedCategories.length > 0 && filteredCount === 0" class="py-20 text-center" x-cloak>
            <div class="mb-6 opacity-10 flex justify-center">
              <Icon name="PhMagnifyingGlass" size="4rem" weight="thin" />
            </div>
            <Text variant="body" class="text-text-muted mb-4">
              {headerData.labels.noResults}
            </Text>
            <button 
              type="button"
              @click="clearFilters()" 
              class="group cursor-pointer inline-flex items-center gap-2"
            >
              <Text variant="metadata" class="text-accent-brass border-b border-accent-brass/30 pb-0.5 group-hover:text-primary group-hover:border-primary transition-colors">
                {headerData.labels.showAll}
              </Text>
              <Icon name="PhArrowCounterClockwise" class="h-3 w-3 text-accent-brass group-hover:text-primary transition-colors" />
            </button>
          </div>

          {/* Pagination */}
          {page.lastPage > 1 && (
            <div x-show="isAllSelected()" class="mt-16" x-cloak>
              <Pagination 
                currentPage={page.currentPage} 
                totalPages={page.lastPage}
                baseUrl="/blog"
              />
            </div>
          )}
        </div>
      </div>
    </Section>
  </main>
</EngineLayout>
