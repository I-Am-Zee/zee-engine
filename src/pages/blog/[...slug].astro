---
import { getCollection, getEntry, render } from "astro:content";
import EngineLayout from "../../layouts/EngineLayout.astro";
import Heading from "../../components/primitives/Heading.astro";
import Text from "../../components/primitives/Text.astro";
import Image from "../../components/primitives/Image.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";

import EditorialHero from "../../components/ui/EditorialHero.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.[^/.]+$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, excerpt, publishDate, author, image, tags } = post.data;
const { Content } = await render(post);

// Fetch author data for bio
const authorEntry = await getEntry('authors', author);
const authorData = authorEntry?.data;

const formattedDate = new Intl.DateTimeFormat('en-IN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(publishDate);

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Journal", href: "/blog" },
  { label: title, href: `/blog/${post.id.replace(/\.[^/.]+$/, "")}`, current: true },
];
---

<EngineLayout pageTitle={title}>
  <Breadcrumbs items={breadcrumbItems} />

  {/* Cinematic Hero */}
  <EditorialHero
    title={title}
    image={image}
    description={excerpt}
    eyebrow={post.data.category}
    metadata={[formattedDate, authorData?.name || author]}
  />

  <article class="mx-auto max-w-3xl px-4 py-16 md:py-24 lg:px-8">
    {/* Content */}
    <div class="prose prose-zelia prose-lg max-w-none 
                prose-headings:font-heading prose-headings:font-bold prose-headings:tracking-tight
                prose-p:leading-relaxed prose-p:text-(--color-text-main)/90
                prose-a:text-(--color-primary) prose-a:no-underline hover:prose-a:underline
                prose-strong:text-(--color-text-main) prose-strong:font-bold
                prose-blockquote:border-l-primary prose-blockquote:bg-(--color-surface) prose-blockquote:py-2 prose-blockquote:px-8 prose-blockquote:rounded-r-xl prose-blockquote:italic
                prose-img:rounded-2xl prose-img:shadow-lg">
      <Content />
    </div>

    {/* Footer Tags */}
    {tags && tags.length > 0 && (
      <div class="mt-16 pt-8 border-t border-(--color-border-subtle)/30 flex flex-wrap gap-2">
        {tags.map(tag => (
          <span class="px-4 py-2 bg-(--color-surface) rounded-full text-xs font-medium text-(--color-text-muted) border border-(--color-border-subtle)/50 hover:border-(--color-primary)/30 transition-colors cursor-default">
            #{tag}
          </span>
        ))}
      </div>
    )}

    {/* Author Bio */}
    {authorData && (
      <div class="mt-16 rounded-3xl bg-(--color-surface) p-8 border border-(--color-border-subtle)/30 flex flex-col sm:flex-row items-center gap-6">
        <div class="h-20 w-20 shrink-0 rounded-full bg-(--color-primary)/10 overflow-hidden flex items-center justify-center text-(--color-primary) font-bold text-2xl border border-(--color-primary)/20">
          {authorData.avatar ? (
            <Image src={authorData.avatar} alt={authorData.name} class="w-full h-full object-cover" />
          ) : (
            authorData.name.charAt(0)
          )}
        </div>
        <div class="text-center sm:text-left">
          <Text variant="small" color="muted" class="mb-1 uppercase tracking-widest font-bold">Written By</Text>
          <Heading as="h4" class="mb-2">{authorData.name}</Heading>
          <Text variant="paragraph" color="muted" class="text-sm">
            {authorData.bio || `Curating the latest stories and style guides for our journal.`}
          </Text>
        </div>
      </div>
    )}
  </article>
</EngineLayout>
