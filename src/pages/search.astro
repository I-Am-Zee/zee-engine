---
// Pre-render at build time
export const prerender = true;

import { getCollection, getEntry } from "astro:content";
import EngineLayout from "../layouts/EngineLayout.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";
import Section from "../components/primitives/Section.astro";
import Input from "../components/primitives/Input.astro";
import Icon from "../components/primitives/Icon.astro";
import FilterChip from "../components/primitives/FilterChip.astro";
import GlassProductCard from "../components/ui/GlassProductCard.astro";
import BlogCard from "../components/ui/BlogCard.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";

// Load content and settings
const allProducts = await getCollection("products");
const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.isDraft !== true : true;
});

const uiSearch = await getEntry("settings", "ui_search");

const labels = uiSearch?.data || {
  title: "Search",
  description: "Discover our products and stories.",
  placeholder: "Search...",
  filters: { all: "Everything", product: "Jewellery", blog: "Stories" }
};

const emptyState = uiSearch?.data?.empty_states || {
  initial: { heading: "Start typing to search...", subtext: "Search our catalog." },
  no_results: { heading: "Nothing found", description: "Try different keywords.", cta_label: "View All", cta_link: "/shop" }
};

// UI Labels are now hardcoded for structural consistency
const uiLabels = {
  resultsFound: "Found",
  resultsSuffix: "results"
};

// Flatten products for Fuse — serializable plain objects only
const searchableProducts = allProducts.map(p => ({
  type: "product",
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags || [],
  category: p.data.category,
  slug: p.id,
}));

const searchablePosts = allPosts.map(p => ({
  type: "blog",
  title: p.data.title,
  description: p.data.excerpt,
  tags: p.data.tags || [],
  category: p.data.category,
  slug: p.id.replace(/\.[^/.]+$/, ""),
}));

const allSearchable = [...searchablePosts, ...searchableProducts];

// Pre-fetch all authors for BlogCard optimization
const allAuthors = await getCollection('authors');
const authorsMap = Object.fromEntries(allAuthors.map(a => [a.id, a.data]));
const defaultAuthor = allAuthors[0]?.data;

// Helper to find author by slug safely
const findAuthor = (slug: string) => {
  return authorsMap[slug] ?? defaultAuthor;
};

const readMoreLabel = uiSearch?.data?.labels?.readMore || "Read";

// Serialise filters for the inline script
const filterLabels = labels.filters;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: labels.title, current: true },
];
---

<EngineLayout pageTitle={labels.title}>

  <Section variant="hero" x-data="searchApp" class="!pt-12 min-h-[80vh]">

    {/* ── Hero Search Bar ─────────────────────────────────── */}
    <div class="mb-12 text-center max-w-3xl mx-auto">
      <Heading as="h1" class="mb-4 uppercase tracking-widest">{labels.title}</Heading>
      <Text variant="paragraph" color="muted" class="mb-10 text-lg opacity-80">{labels.description}</Text>

      {/* Atomic Input — uses upgraded Input primitive with icon support */}
      <div class="relative group">
        <Input
          id="search-input"
          type="search"
          x-model="query"
          @input.debounce.300ms="performSearch()"
          placeholder={labels.placeholder}
          icon="PhMagnifyingGlass"
          autocomplete="off"
          class="py-5! pl-14! text-lg shadow-xs focus:shadow-xl transition-shadow duration-500"
        />
        
        {/* Loading indicator (visual only for now as Fuse is instant) */}
        <div x-show="query.length >= 2 && totalCount === 0" class="absolute right-4 top-1/2 -translate-y-1/2 opacity-20" x-cloak>
          <Icon name="PhCircleNotch" class="h-5 w-5 animate-spin" />
        </div>
      </div>

      {/* Result count — only show when actively searching */}
      <div x-show="query.length >= 2" class="mt-6 h-6" x-transition x-cloak>
        <Text variant="metadata" color="muted" class="tracking-widest">
          {uiLabels.resultsFound}&nbsp;<span class="font-bold text-(--color-text-main)" x-text="totalCount"></span>&nbsp;{uiLabels.resultsSuffix}
        </Text>
      </div>
    </div>

    {/* ── Content-Type Chips ──────────────────────────────── */}
    <div x-show="query.length >= 2" x-transition class="mb-16 flex items-center justify-center gap-3 flex-wrap" x-cloak>
      <FilterChip
        label={labels.filters.all}
        isActive="activeType === 'all'"
        onClick="setType('all')"
      />
      <FilterChip
        label={labels.filters.product}
        isActive="activeType === 'product'"
        onClick="setType('product')"
      />
      <FilterChip
        label={labels.filters.blog}
        isActive="activeType === 'blog'"
        onClick="setType('blog')"
      />
    </div>

    {/* ── Initial State (shown when query is too short) ────── */}
    <div x-show="query.length < 2" class="py-20 text-center" x-transition x-cloak>
      <div class="mb-8 opacity-5 flex justify-center scale-150">
        <Icon name="PhMagnifyingGlass" size="5rem" weight="thin" class="text-(--color-text-muted)" />
      </div>
      <Heading as="h3" color="muted" class="font-light tracking-tight">{emptyState.initial.heading}</Heading>
      <Text variant="paragraph" color="muted" class="mt-2 opacity-60">{emptyState.initial.subtext}</Text>
    </div>

    {/* ── Results Container ────────────────────────────────── */}
    <div id="search-results" x-show="query.length >= 2" x-cloak>

      {/* No results */}
      <div x-show="totalCount === 0" class="py-16" x-transition x-cloak>
        <EmptyState
          icon="PhMagnifyingGlass"
          heading={emptyState.no_results.heading}
          description={emptyState.no_results.description || "Try different keywords or check your spelling."}
          action={{ label: emptyState.no_results.cta_label, href: emptyState.no_results.cta_link }}
        />
      </div>

      {/* Product results section */}
      <div x-show="(activeType === 'all' || activeType === 'product') && matchingProductSlugs.length > 0" x-transition x-cloak>
        <div x-show="activeType === 'all'" class="mb-10 flex items-center gap-4" x-cloak>
          <div class="h-px flex-1 bg-linear-to-r from-transparent to-(--color-border-subtle)"></div>
          <div class="flex items-center gap-2 px-4">
            <Icon name="PhDiamond" class="h-4 w-4 text-(--color-primary) opacity-50" />
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-(--color-text-main) opacity-80">{labels.filters.product}</span>
          </div>
          <div class="h-px flex-1 bg-linear-to-l from-transparent to-(--color-border-subtle)"></div>
        </div>
        
        <div class="grid gap-6 sm:gap-8 grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {allProducts.map((product) => (
            <div 
              x-show={`matchingProductSlugs.includes('${product.id}')`} 
              x-transition:enter="transition ease-out duration-300"
              x-transition:enter-start="opacity-0 scale-95"
              x-transition:enter-end="opacity-100 scale-100"
              x-cloak
            >
              <GlassProductCard product={product} />
            </div>
          ))}
        </div>
      </div>

      {/* Blog results section */}
      <div
        x-show="(activeType === 'all' || activeType === 'blog') && matchingPostSlugs.length > 0"
        :class="(activeType === 'all' && matchingProductSlugs.length > 0) ? 'mt-24' : ''"
        x-transition
        x-cloak
      >
        <div x-show="activeType === 'all'" class="mb-10 flex items-center gap-4" x-cloak>
          <div class="h-px flex-1 bg-linear-to-r from-transparent to-(--color-border-subtle)"></div>
          <div class="flex items-center gap-2 px-4">
            <Icon name="PhBookOpenText" class="h-4 w-4 text-(--color-primary) opacity-50" />
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-(--color-text-main) opacity-80">{labels.filters.blog}</span>
          </div>
          <div class="h-px flex-1 bg-linear-to-l from-transparent to-(--color-border-subtle)"></div>
        </div>

        <div class="grid gap-8 grid-cols-1 md:grid-cols-2">
          {allPosts.map((post) => (
            <div
              x-show={`matchingPostSlugs.includes('${post.id.replace(/\.[^/.]+$/, "")}')`}
              x-transition:enter="transition ease-out duration-300"
              x-transition:enter-start="opacity-0 translate-y-4"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-cloak
            >
              <BlogCard 
                post={post} 
                variant="horizontal" 
                authorData={findAuthor(post.data.author)}
                readMoreLabel={readMoreLabel}
                class="h-full"
              />
            </div>
          ))}
        </div>
      </div>
    </div>

  </Section>
</EngineLayout>

<script is:inline define:vars={{ allSearchable, filterLabels }}>
  document.addEventListener("alpine:init", () => {
    window.Alpine.data("searchApp", () => ({
      query: "",
      activeType: "all",
      matchingProductSlugs: [],
      matchingPostSlugs: [],
      _fuse: null,

      get totalCount() {
        const countProducts = this.activeType === "all" || this.activeType === "product";
        const countBlog = this.activeType === "all" || this.activeType === "blog";
        return (countProducts ? this.matchingProductSlugs.length : 0) +
               (countBlog ? this.matchingPostSlugs.length : 0);
      },

      _getFuse() {
        if (!this._fuse) {
          this._fuse = new Fuse(allSearchable, {
            keys: [
              { name: "title", weight: 0.7 },
              { name: "description", weight: 0.3 },
              { name: "tags", weight: 0.5 },
              { name: "category", weight: 0.4 }
            ],
            threshold: 0.3,
            location: 0,
            distance: 100,
            includeScore: true,
          });
        }
        return this._fuse;
      },

      setType(type) {
        this.activeType = type;
      },

      performSearch() {
        const q = this.query.trim();
        if (q.length < 2) {
          this.matchingProductSlugs = [];
          this.matchingPostSlugs = [];
          return;
        }

        const results = this._getFuse().search(q);

        this.matchingProductSlugs = results
          .filter((r) => r.item.type === "product")
          .map((r) => r.item.slug);

        this.matchingPostSlugs = results
          .filter((r) => r.item.type === "blog")
          .map((r) => r.item.slug);
      },
    }));
  });
</script>

<script>
  // Load Fuse.js into global scope for the inline script
  import Fuse from "fuse.js";
  (window as any).Fuse = Fuse;
</script>
