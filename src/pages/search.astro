---
// Pre-render at build time
export const prerender = true;

import { getCollection, getEntry } from "astro:content";
import EngineLayout from "../layouts/EngineLayout.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";
import Section from "../components/primitives/Section.astro";
import Input from "../components/primitives/Input.astro";
import Icon from "../components/primitives/Icon.astro";
import FilterChip from "../components/primitives/FilterChip.astro";
import GlassProductCard from "../components/ui/GlassProductCard.astro";
import BlogCard from "../components/ui/BlogCard.astro";
import EmptyState from "../components/ui/EmptyState.astro";

// Load content and settings
const allProducts = await getCollection("products");
const allPosts = await getCollection("blog", ({ data }) => !data.isDraft);
const searchSettings = await getEntry("settings", "search");
const labels = searchSettings?.data || {
  title: "Search",
  description: "Discover our world.",
  placeholder: "Search...",
  initialState: { heading: "Start typing...", subtext: "" },
  labels: { resultsFound: "Found", resultsIn: "in", nothingFound: "Nothing found", nothingFoundSub: "", viewAllAction: "View Shop" },
  filters: { all: "All", product: "Jewellery", blog: "Stories" }
};

// Flatten products for Fuse — serializable plain objects only
const searchableProducts = allProducts.map(p => ({
  type: "product",
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags || [],
  category: p.data.category,
  slug: p.id,
}));

// Flatten blog posts for Fuse — serializable plain objects only
const searchablePosts = allPosts.map(p => ({
  type: "blog",
  title: p.data.title,
  description: p.data.excerpt,
  tags: p.data.tags || [],
  category: p.data.category,
  slug: p.id.replace(/\.[^/.]+$/, ""),
}));

const allSearchable = [...searchableProducts, ...searchablePosts];

// Serialise labels.filters for the inline script
const filterLabels = labels.filters;
---

<EngineLayout pageTitle={labels.title}>
  <Section variant="hero" x-data="searchApp">

    {/* ── Hero Search Bar ─────────────────────────────────── */}
    <div class="mb-10 text-center">
      <Heading as="h1" class="mb-2 uppercase tracking-wider">{labels.title}</Heading>
      <Text variant="paragraph" color="muted" class="mb-8">{labels.description}</Text>

      {/* Atomic Input — uses upgraded Input primitive with icon support */}
      <div class="mx-auto max-w-2xl">
        <Input
          id="search-input"
          type="search"
          x-model="query"
          @input.debounce.300ms="performSearch()"
          placeholder={labels.placeholder}
          icon="PhMagnifyingGlass"
          autocomplete="off"
        />
      </div>

      {/* Result count — only show when actively searching */}
      <div x-show="query.length >= 2" class="mt-3 min-h-[1.5rem]" x-cloak>
        <Text variant="metadata" color="muted">
          {labels.labels.resultsFound}&nbsp;<span class="font-bold text-(--color-text-main)" x-text="totalCount"></span>&nbsp;results
        </Text>
      </div>
    </div>

    {/* ── Content-Type Chips ──────────────────────────────── */}
    <div class="mb-10 flex items-center justify-center gap-3 flex-wrap">
      <FilterChip
        label={labels.filters.all}
        isActive="activeType === 'all'"
        onClick="setType('all')"
      />
      <FilterChip
        label={labels.filters.product}
        isActive="activeType === 'product'"
        onClick="setType('product')"
      />
      <FilterChip
        label={labels.filters.blog}
        isActive="activeType === 'blog'"
        onClick="setType('blog')"
      />
    </div>

    {/* ── Initial State (shown when query is too short) ────── */}
    <div x-show="query.length < 2" class="py-20 text-center" x-cloak>
      <div class="mb-8 opacity-20 flex justify-center">
        <Icon name="PhMagnifyingGlass" size="5rem" weight="thin" class="text-text-muted" />
      </div>
      <Heading as="h3" color="muted">{labels.initialState.heading}</Heading>
      <Text variant="paragraph" color="muted" class="mt-2">{labels.initialState.subtext}</Text>
    </div>

    {/* ── Results Container ────────────────────────────────── */}
    <div id="search-results" x-show="query.length >= 2" x-cloak>

      {/* No results */}
      <div x-show="totalCount === 0" class="py-16">
        <EmptyState
          icon="PhMagnifyingGlass"
          heading={labels.labels.nothingFound}
          description={labels.labels.nothingFoundSub}
          action={{ label: labels.labels.viewAllAction, href: "/shop" }}
        />
      </div>

      {/* Product results section */}
      <div x-show="(activeType === 'all' || activeType === 'product') && matchingProductSlugs.length > 0">
        <div x-show="activeType === 'all'" class="mb-6 flex items-center gap-3">
          <Icon name="PhDiamond" class="h-4 w-4 text-(--color-primary) shrink-0" />
          <span class="text-xs font-bold uppercase tracking-widest text-(--color-text-main)">{labels.filters.product}</span>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>
        <div class="grid gap-6 grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {allProducts.map((product) => (
            <div x-show={`matchingProductSlugs.includes('${product.id}')`} x-cloak>
              <GlassProductCard product={product} />
            </div>
          ))}
        </div>
      </div>

      {/* Blog results section */}
      <div
        x-show="(activeType === 'all' || activeType === 'blog') && matchingPostSlugs.length > 0"
        :class="(activeType === 'all' && matchingProductSlugs.length > 0) ? 'mt-14' : ''"
      >
        <div x-show="activeType === 'all'" class="mb-6 flex items-center gap-3">
          <Icon name="PhBookOpenText" class="h-4 w-4 text-(--color-primary) shrink-0" />
          <span class="text-xs font-bold uppercase tracking-widest text-(--color-text-main)">{labels.filters.blog}</span>
          <div class="flex-1 h-px bg-(--color-border-subtle)"></div>
        </div>
        <div class="grid gap-6 grid-cols-1 md:grid-cols-2">
          {allPosts.map((post) => (
            <div
              x-show={`matchingPostSlugs.includes('${post.id.replace(/\.[^/.]+$/, "")}')`}
              x-cloak
            >
              <BlogCard post={post} variant="vertical" />
            </div>
          ))}
        </div>
      </div>
    </div>

  </Section>
</EngineLayout>

<script is:inline define:vars={{ allSearchable, filterLabels }}>
  document.addEventListener("alpine:init", () => {
    window.Alpine.data("searchApp", () => ({
      query: "",
      activeType: "all",
      matchingProductSlugs: [],
      matchingPostSlugs: [],
      _fuse: null,

      get totalCount() {
        const countProducts = this.activeType === "all" || this.activeType === "product";
        const countBlog = this.activeType === "all" || this.activeType === "blog";
        return (countProducts ? this.matchingProductSlugs.length : 0) +
               (countBlog ? this.matchingPostSlugs.length : 0);
      },

      _getFuse() {
        if (!this._fuse) {
          this._fuse = new Fuse(allSearchable, {
            keys: ["title", "description", "tags", "category"],
            threshold: 0.35,
            includeScore: true,
          });
        }
        return this._fuse;
      },

      setType(type) {
        this.activeType = type;
      },

      performSearch() {
        if (this.query.length < 2) {
          this.matchingProductSlugs = [];
          this.matchingPostSlugs = [];
          return;
        }

        const results = this._getFuse().search(this.query);

        this.matchingProductSlugs = results
          .filter((r) => r.item.type === "product")
          .map((r) => r.item.slug);

        this.matchingPostSlugs = results
          .filter((r) => r.item.type === "blog")
          .map((r) => r.item.slug);
      },
    }));
  });
</script>

<script>
  // Load Fuse.js into global scope for the inline script
  import Fuse from "fuse.js";
  (window as any).Fuse = Fuse;
</script>

<style>
  [x-cloak] { display: none !important; }
</style>
