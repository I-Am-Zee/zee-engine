---
import { getCollection, getEntry } from "astro:content";
import EngineLayout from "../layouts/EngineLayout.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";
import Button from "../components/primitives/Button.astro";
import Image from "../components/primitives/Image.astro";
import GlassProductCard from "../components/ui/GlassProductCard.astro";
import CollectionCard from "../components/ui/CollectionCard.astro";
import ProductCarousel from "../components/features/ProductCarousel.astro";

import LookbookCarousel from "../components/features/LookbookCarousel.astro";
import TrustSection from "../components/ui/TrustSection.astro";
import Carousel from "../components/ui/Carousel.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import NewsletterWidget from "../components/features/NewsletterWidget.astro";

// Load Hero Content (Brand Aware)
const homeHeroEntry = await getEntry("pages_content", "home");
const trustEntry = await getEntry("pages_content", "trust_section");
const trustData = trustEntry?.data || { main_heading: "Quality Assured", hero_image: "/images/identity/trust-hero.webp", markers: [] };
const homeHero = homeHeroEntry?.data || {
  title: "The Permanent Glow.",
  subtitle: "Designed for the woman who lives without borders.",
  cta_label_primary: "Shop Now",
  cta_link_primary: "/shop",
  cta_label_secondary: "View Lookbooks",
  cta_link_secondary: "/lookbooks",
  image: "/images/brand-shots/HeroCheck.jpg"
};

// Load Section Headers (Hub Strategy)
const categoriesHeader = await getEntry("section_headers", "home-categories");
const featuredHeader = await getEntry("section_headers", "home-featured");

const catData = categoriesHeader?.data || { 
  title: "Heading Level 2", 
  subtitle: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
  button_mode: "link",
  action_label: "Action Link",
  link_url: "/collections"
};

const featData = featuredHeader?.data || { 
  title: "Heading Level 2", 
  subtitle: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
  button_mode: "link",
  action_label: "Action Link",
  link_url: "/shop"
};


// Pre-render at build time
export const prerender = true;

const allProducts = await getCollection("products");
const featuredProducts = allProducts.slice(0, 8);

const categories = [
  { name: "Rings", href: "/shop/rings", image: "/images/products/1605100804763-247f67b3557e.jpg" },
  { name: "Necklaces", href: "/shop/necklaces", image: "/images/products/1599643478518-a784e5dc4c8f.jpg" },
  { name: "Earrings", href: "/shop/earrings", image: "/images/products/1535632066927-ab7c9ab60908.jpg" },
  { name: "Bracelets", href: "/shop/bracelets", image: "/images/products/1602173574767-37ac01994b2a.jpg" },
  { name: "Engagement", href: "/shop/rings", image: "/images/products/1605100804763-247f67b3557e.jpg" },
  { name: "Timepieces", href: "/shop/watches", image: "/images/products/1599643478518-a784e5dc4c8f.jpg" },
  { name: "Fine Jewels", href: "/shop/necklaces", image: "/images/products/1535632066927-ab7c9ab60908.jpg" },
].map(cat => ({
  ...cat,
  itemCount: allProducts.filter(p => p.data.category === cat.name.toLowerCase()).length
}));
---

<EngineLayout >
  <main>
    {/* Hero Section */}
    <section class="relative h-[90vh] overflow-hidden bg-white">
      <div class="absolute inset-0 z-0 opacity-60">
        <Image 
          src={homeHero.image} 
          alt="Luxury Jewelry Hero" 
          class="h-full w-full object-cover object-center brightness-110 opacity-90"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="absolute inset-0 z-0 bg-linear-to-b from-white/70 via-white/30 to-white/90"></div>
      
      <div class="relative z-10 mx-auto flex h-full max-w-7xl flex-col items-center justify-center px-4 text-center">
        <Heading as="h1" color="main" class="mb-6" set:html={homeHero.title} />
        <Text variant="lead" color="main" class="mb-10 max-w-2xl opacity-90">
          {homeHero.subtitle}
        </Text>
        <div class="flex flex-col sm:flex-row justify-center gap-4 w-full px-8 md:px-0">
          <Button as="a" href={homeHero.cta_link_primary} size="lg" type="primary" class="w-full sm:w-auto text-center justify-center">
            {homeHero.cta_label_primary}
          </Button>
          <Button as="a" href={homeHero.cta_link_secondary} size="lg" type="ghost" class="w-full sm:w-auto text-center justify-center text-black! bg-white/40! hover:bg-white/60!">
            {homeHero.cta_label_secondary}
          </Button>
        </div>
      </div>
    </section>

    {/* Categories Section */}
    <section class="bg-background py-16 md:py-24 px-4 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <SectionHeader 
          title={catData.title} 
          subtitle={catData.subtitle}
          align="left"
        >
          <Fragment slot="action">
            {catData.button_mode === 'link' && (
              <Button as="a" href={catData.link_url} type="ghost" class="font-bold uppercase tracking-[0.2em] text-[10px]">
                {catData.action_label} &rarr;
              </Button>
            )}
          </Fragment>
        </SectionHeader>
        
        <Carousel 
          options={{ perPage: 4, perMove: 1, gap: 24, type: 'loop', pagination: true, breakpoints: { 1024: { perPage: 3, gap: 24 }, 768: { perPage: 2, padding: { left: '1rem', right: '2rem' }, gap: 16 }, 640: { perPage: 1, padding: { left: '1rem', right: '5rem' }, gap: 16 } } }}
          class="w-[calc(100%+2rem)] -mx-4 md:w-full md:mx-0 pb-16"
          trackClass="py-4"
        >
          {categories.map((category) => (
            <li class="splide__slide h-auto py-4">
              <CollectionCard 
                title={category.name}
                href={category.href}
                image={category.image}
                itemCount={category.itemCount}
              />
            </li>
          ))}
        </Carousel>
      </div>
    </section>

    {/* Featured Products */}
    <section class="bg-surface py-16 md:py-24 px-4 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <SectionHeader 
          title={featData.title} 
          subtitle={featData.subtitle}
          align="left"
        >
          <Fragment slot="action">
            {featData.button_mode === 'link' && (
              <Button as="a" href={featData.link_url} type="ghost" class="font-bold uppercase tracking-[0.2em] text-[10px]">
                {featData.action_label} &rarr;
              </Button>
            )}
          </Fragment>
        </SectionHeader>
        
        <ProductCarousel products={featuredProducts} columns={4} />
      </div>
    </section>

    {/* Lookbook Carousel Feature */}
    <LookbookCarousel />

    {/* Trust Section */}
    <TrustSection main_heading={trustData.main_heading} hero_image={trustData.hero_image} markers={trustData.markers} />

  </main>
</EngineLayout>


