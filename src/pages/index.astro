---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/features/Navbar.astro";
import Footer from "../components/features/Footer.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";
import Button from "../primitives/Button.astro";
import ProductCard from "../components/features/ProductCard.astro";
import ProductGrid from "../components/features/ProductGrid.astro";

// Pre-render at build time
export const prerender = true;

const allProducts = await getCollection("products");
const featuredProducts = allProducts.slice(0, 4);

const categories = [
  { name: "Rings", href: "/shop/rings", image: "/images/products/1605100804763-247f67b3557e.jpg" },
  { name: "Necklaces", href: "/shop/necklaces", image: "/images/products/1599643478518-a784e5dc4c8f.jpg" },
  { name: "Earrings", href: "/shop/earrings", image: "/images/products/1535632066927-ab7c9ab60908.jpg" },
  { name: "Bracelets", href: "/shop/bracelets", image: "/images/products/1602173574767-37ac01994b2a.jpg" },
];
---

<BaseLayout title="Zaviona | Luxury Jewelry & Timeless Elegance">
  <Navbar />

  <main>
    {/* Hero Section */}
    <section class="relative h-[90vh] overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img 
          src="/images/products/1605100804763-247f67b3557e.jpg" 
          alt="Luxury Jewelry Hero" 
          class="h-full w-full object-cover object-center brightness-50"
        />
      </div>
      <div class="relative z-10 mx-auto flex h-full max-w-7xl flex-col items-center justify-center px-4 text-center">
        <Heading as="h1" class="mb-6 text-5xl font-bold tracking-tight text-white md:text-7xl">
          Timeless Elegance, <br /> Forged in Brilliance
        </Heading>
        <Text class="mb-10 max-w-2xl text-xl text-gray-200">
          Discover our curated collection of ethically sourced diamond jewelry, crafted to celebrate your most precious moments.
        </Text>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/shop">
            <Button size="lg" class="bg-white text-black hover:bg-gray-100">
              Shop Collection
            </Button>
          </a>
          <a href="/collections">
            <Button size="lg" type="outline" class="border-white text-white hover:bg-white/10">
              View Collections
            </Button>
          </a>
        </div>
      </div>
    </section>

    {/* Categories Section */}
    <section class="bg-(--color-background) py-24 px-4 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 text-center">
          <Heading as="h2" class="mb-4 text-3xl font-bold md:text-4xl">Shop by Category</Heading>
          <Text class="mx-auto max-w-2xl text-(--color-text-muted)">
            Explore our diverse ranges of jewelry, each piece designed with luxury and sophistication in mind.
          </Text>
        </div>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {categories.map((category) => (
            <a href={category.href} class="group relative overflow-hidden rounded-2xl shadow-sm transition-transform hover:-translate-y-1">
              <div class="aspect-[4/5] overflow-hidden">
                <img 
                  src={category.image} 
                  alt={category.name} 
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
                />
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
              <div class="absolute bottom-6 left-6 text-white">
                <Heading as="h3" class="text-xl font-bold">{category.name}</Heading>
                <Text class="text-sm opacity-80">Explore Collection &rarr;</Text>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* Featured Products */}
    <section class="bg-(--color-surface) py-24 px-4 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 flex flex-col items-center justify-between gap-4 md:flex-row">
          <div>
            <Heading as="h2" class="text-3xl font-bold md:text-4xl">Featured Pieces</Heading>
            <Text class="mt-2 text-(--color-text-muted)">Hand-selected favorites from our latest season.</Text>
          </div>
          <a href="/shop">
            <Button type="ghost" class="text-(--color-primary) font-semibold uppercase tracking-widest text-xs">
              View All Products &rarr;
            </Button>
          </a>
        </div>
        <ProductGrid>
          {featuredProducts.map((product) => (
            <ProductCard
              id={product.slug}
              title={product.data.title}
              price={product.data.price}
              salePrice={product.data.salePrice}
              image={product.data.image}
              href={`/products/${product.slug}`}
              badges={product.data.badges}
              rating={product.data.rating}
            />
          ))}
        </ProductGrid>
      </div>
    </section>

    {/* Trust Section */}
    <section class="border-y border-(--color-border-subtle) bg-(--color-background) py-16">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <div class="grid grid-cols-1 gap-12 text-center sm:grid-cols-3">
          <div class="flex flex-col items-center">
            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-(--color-primary-subtle)/10 text-(--color-primary)">
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            </div>
            <Heading as="h4" class="mb-2 text-lg font-bold">Ethically Sourced</Heading>
            <Text class="text-sm text-(--color-text-muted)">Every diamond is conflict-free and responsibly sourced.</Text>
          </div>
          <div class="flex flex-col items-center">
            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-(--color-primary-subtle)/10 text-(--color-primary)">
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
              </svg>
            </div>
            <Heading as="h4" class="mb-2 text-lg font-bold">Luxury Packaging</Heading>
            <Text class="text-sm text-(--color-text-muted)">Our signature gift wrap is included with every order.</Text>
          </div>
          <div class="flex flex-col items-center">
            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-(--color-primary-subtle)/10 text-(--color-primary)">
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <Heading as="h4" class="mb-2 text-lg font-bold">Lifetime Warranty</Heading>
            <Text class="text-sm text-(--color-text-muted)">We stand behind our craftsmanship for a lifetime.</Text>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

