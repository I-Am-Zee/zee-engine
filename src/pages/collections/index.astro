---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/features/Navbar.astro";
import Footer from "../../components/features/Footer.astro";
import Heading from "../../components/primitives/Heading.astro";
import Text from "../../components/primitives/Text.astro";
import { getCollection } from "astro:content";

const allProducts = await getCollection("products");

const collections = [
  {
    title: "Rings",
    description: "Explore our stunning collection of rings.",
    image: "https://images.unsplash.com/photo-1605100804763-247f67b3557e?w=800&q=80",
    href: "/shop/rings",
    type: "category",
    slug: "rings"
  },
  {
    title: "Earrings",
    description: "Perfect for any occasion.",
    image: "https://images.unsplash.com/photo-1617038220319-276d3cfab638?w=800&q=80",
    href: "/shop/earrings",
    type: "category",
    slug: "earrings"
  },
  {
    title: "Necklaces",
    description: "Timeless pieces to complete your look.",
    image: "https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=800&q=80",
    href: "/shop/necklaces",
    type: "category",
    slug: "necklaces"
  },
  {
    title: "Bracelets",
    description: "Elegant wristwear for every style.",
    image: "https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=800&q=80",
    href: "/shop/bracelets",
    type: "category",
    slug: "bracelets"
  },
  {
    title: "Waterproof Collection",
    description: "Shower-proof, swim-proof jewelry that never tarnishes.",
    image: "https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=800&q=80",
    href: "/collections/waterproof",
    type: "tag",
    slug: "waterproof"
  },
  {
    title: "Luxury Statement",
    description: "Make an impression with our premium, high-end pieces.",
    image: "https://images.unsplash.com/photo-1602173574767-37ac01994b2a?w=800&q=80",
    href: "/collections/luxury",
    type: "tag",
    slug: "luxury"
  },
  {
    title: "Everyday Essentials",
    description: "The foundations of your jewelry box, designed for daily wear.",
    image: "https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=800&q=80",
    href: "/collections/everyday",
    type: "tag",
    slug: "everyday"
  },
  {
    title: "Gift Sets",
    description: "Curated sets for your loved ones, ready for any celebration.",
    image: "https://images.unsplash.com/photo-1549492423-400259a2e574?w=800&q=80",
    href: "/shop/gifts",
    type: "category",
    slug: "gifts"
  }
].map(collection => {
  const count = allProducts.filter(p => {
    if (collection.type === "category") {
      return p.data.category === collection.slug;
    } else {
      return p.data.tags?.includes(collection.slug);
    }
  }).length;
  
  return {
    ...collection,
    count: `${count} ${count === 1 ? 'Product' : 'Products'}`
  };
});
---

<BaseLayout title="Explore Collections | Zaviona">
  <Navbar />

  <main class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <Heading as="h1" class="mb-4">Our Collections</Heading>
      <Text class="mx-auto max-w-2xl text-text-muted">
        Discover our curated selections of jewelry, from daily essentials to luxury statement pieces.
        Each collection is crafted with precision and passion.
      </Text>
    </div>

    <div class="grid grid-cols-1 gap-y-10 gap-x-6 sm:grid-cols-2 lg:grid-cols-3 xl:gap-x-8">
      {collections.map((collection) => (
        <a href={collection.href} class="group relative flex flex-col overflow-hidden rounded-2xl border border-border-subtle transition-all hover:shadow-xl hover:-translate-y-1">
          <div class="aspect-h-12 aspect-w-16 bg-gray-200 sm:aspect-none sm:h-96">
            <img
              src={collection.image}
              alt={collection.title}
              class="h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-110"
            />
          </div>
          <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/30 to-transparent flex flex-col justify-end p-6">
            <Text class="text-xs font-semibold uppercase tracking-wider text-white/70 mb-1">{collection.count}</Text>
            <Heading as="h3" class="font-bold text-white mb-2">{collection.title}</Heading>
            <Text class="text-sm text-white/90 line-clamp-2 md:opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              {collection.description}
            </Text>
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>
