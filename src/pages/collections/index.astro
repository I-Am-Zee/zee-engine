---
import EngineLayout from "../../layouts/EngineLayout.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import CollectionCard from "../../components/ui/CollectionCard.astro";
import { getCollection, getEntry } from "astro:content";

const allProducts = await getCollection("products");

const gridEntry = await getEntry("collections_grid", "data");
const hubEntry = await getEntry("page_headers", "collection-index");

const hubData = hubEntry?.data || {
  title: "Our Collections",
  subtitle: "Explore our curated ranges, each with its own story.",
  align: "center"
};

const collections = ((gridEntry?.data as any)?.cards || []).map((card: any) => {
  return {
    title: card.title,
    description: card.description,
    image: card.image,
    href: card.type === "category" ? `/shop/${card.slug}` : `/collections/${card.slug}`,
    type: card.type,
    slug: card.slug
  };
}).map((collection: any) => {
  const count = allProducts.filter(p => {
    // Robust normalization: Strip all spaces and hyphens for comparison
    const normalize = (s: string) => s?.toLowerCase().replace(/[\s-]/g, "") || "";
    const targetSlug = normalize(collection.slug);

    if (collection.type === "category") {
      return normalize(p.data.category) === targetSlug;
    } else {
      return p.data.tags?.some(tag => normalize(tag) === targetSlug);
    }
  }).length;
  
  return {
    ...collection,
    count: `${count} ${count === 1 ? 'Product' : 'Products'}`
  };
});
---

<EngineLayout pageTitle="Explore Collections">

  <main class="mx-auto max-w-7xl px-4 py-16 md:py-24 sm:px-6 lg:px-8">
    <PageHeader 
      title={hubData.title}
      subtitle={hubData.subtitle}
      align={hubData.align || "center"}
      class="mb-16"
    />

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 md:gap-8">
      {collections.map((collection: any) => (
        <CollectionCard 
          title={collection.title}
          href={collection.href}
          image={collection.image}
          description={collection.description}
          itemCount={collection.count}
        />
      ))}
    </div>
  </main>

</EngineLayout>

