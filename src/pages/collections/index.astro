---
import EngineLayout from "../../layouts/EngineLayout.astro";
import Heading from "../../components/primitives/Heading.astro";
import Text from "../../components/primitives/Text.astro";
import CollectionCard from "../../components/ui/CollectionCard.astro";
import { getCollection, getEntry } from "astro:content";

const allProducts = await getCollection("products");

const brandId = import.meta.env.PUBLIC_BRAND_ID || "zelia-vance";

// Use proper error handling in case the singleton hasn't been created yet
let gridData;
try {
  gridData = await getEntry("settings", "collections-grid");
} catch (e) {
  console.warn("Collections grid data not found, please configure it in Keystatic.");
const collections = ((gridData?.data as any)?.cards || []).map((card: any) => {
  return {
    title: card.title,
    description: card.description,
    image: card.image,
    href: card.href,
    type: card.type,
    slug: card.slug
  };
}).map((collection: any) => {
  const count = allProducts.filter(p => {
    if (collection.type === "category") {
      return p.data.category === collection.slug;
    } else {
      return p.data.tags?.includes(collection.slug);
    }
  }).length;
  
  return {
    ...collection,
    count: `${count} ${count === 1 ? 'Product' : 'Products'}`
  };
});
---

<EngineLayout title="Explore Collections | Zelia Vance">

  <main class="mx-auto max-w-7xl px-4 py-16 md:py-24 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <Heading as="h1" class="mb-4">Our Collections</Heading>
      <Text class="mx-auto max-w-2xl text-text-muted">
        Discover our curated selections of jewelry, from daily essentials to luxury statement pieces.
        Each collection is crafted with precision and passion.
      </Text>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 md:gap-8">
      {collections.map((collection) => (
        <CollectionCard 
          title={collection.title}
          href={collection.href}
          image={collection.image}
          description={collection.description}
          itemCount={collection.count}
        />
      ))}
    </div>
  </main>

</EngineLayout>

