---
import { getCollection, getEntry } from "astro:content";
import EngineLayout from "../../layouts/EngineLayout.astro";
import Heading from "../../components/primitives/Heading.astro";
import GlassProductCard from "../../components/ui/GlassProductCard.astro";
import ProductGrid from "../../components/features/ProductGrid.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import FilterSortBar from "../../components/ui/FilterSortBar.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import Pagination from "../../components/ui/Pagination.astro";
import RelatedProducts from "../../components/features/RelatedProducts.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import ComingSoon from "../../components/ui/ComingSoon.astro";

// Pre-render at build time (required in server mode)
export const prerender = true;

export async function getStaticPaths() {
  const allProducts = await getCollection("products");

  let gridData;
  try {
    gridData = await getEntry("collections_grid", "data");
  } catch (e) {
    console.warn("Collections grid data not found.");
  }
  const cards = (gridData?.data as any)?.cards || [];

  // Extract all unique tags
  const tags = [...new Set(allProducts.flatMap((p) => p.data.tags || []))];

  return tags.map((tag) => {
    // Find matching CMS record
    const match = cards.find((c: any) => c.slug === tag && c.type === 'tag');
    const isComingSoon = match?.is_coming_soon === true;

    // Find products or force empty
    const filteredProducts = isComingSoon ? [] : allProducts.filter((p) => p.data.tags?.includes(tag));
    
    return {
      params: { tag },
      props: { 
        products: filteredProducts, 
        tagName: tag,
        categoryDescription: match?.description || "",
        isComingSoon
      },
    };
  });
}

const { tag } = Astro.params;
const { products, tagName, categoryDescription, isComingSoon } = Astro.props;

// Formatting tag for display (e.g., "pvd-coated" -> "PVD Coated")
const formattedTagName = tagName
  .split("-")
  .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
  .join(" ");

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Collections", href: "/collections" },
  { label: formattedTagName, active: true },
];

const PRODUCTS_PER_PAGE = 12;
const totalPages = Math.ceil(products.length / PRODUCTS_PER_PAGE);
const currentPage = 1;

// ── Smart Page Controller Logic (Cross-Sell) ──────────────────────
const allProductsForCrossSell = await getCollection("products");
const crossSellHeader = await getEntry("section_headers", "collection-related");

const crossSellProducts = allProductsForCrossSell
  .filter((p) => !p.data.tags?.includes(tagName))
  .sort(() => 0.5 - Math.random())
  .slice(0, 4);

const crossSellTitle = crossSellHeader?.data?.title || "Style Pairings";
const crossSellSubtitle = crossSellHeader?.data?.subtitle || "Discover curated pieces that complement this collection";
---

<EngineLayout pageTitle={`${formattedTagName} Collection`}>

  <div class="mx-auto max-w-7xl px-4 py-8 lg:px-8" x-data="productSorter">
    <Breadcrumbs items={breadcrumbItems} />

    <div class="mt-6 mb-8">
      <PageHeader 
        title={`${formattedTagName} Collection`}
        subtitle={categoryDescription} 
        align="left"
      />
    </div>

    {
      isComingSoon ? (
        <ComingSoon categoryName={formattedTagName} />
      ) : products.length > 0 ? (
        <>
          <FilterSortBar productCount={products.length} categoryName={formattedTagName} />

          <div id="product-grid">
            <ProductGrid>
              {products.map((product, index) => (
                <div
                  class="product-item"
                  data-index={index}
                  data-slug={product.slug}
                  data-price={product.data.salePrice || product.data.price}
                  data-original-price={product.data.price}
                  data-sale-price={product.data.salePrice || ""}
                  data-name={product.data.title}
                  data-rating={product.data.rating || 0}
                  data-publish-date={
                    product.data.publishDate ? new Date(product.data.publishDate).getTime() : 0
                  }
                  data-discount={
                    product.data.salePrice
                      ? Math.round((1 - product.data.salePrice / product.data.price) * 100)
                      : 0
                  }
                >
                  <GlassProductCard product={product} />
                </div>
              ))}
            </ProductGrid>
          </div>

          {totalPages > 1 && (
            <Pagination
              currentPage={currentPage}
              totalPages={totalPages}
              baseUrl={`/collections/${tag}`}
            />
          )}
        </>
      ) : (
        <EmptyState
          icon="shopping-bag"
          heading="No products found"
          description={`We couldn't find any products in the ${formattedTagName} collection.`}
          action={{ label: "Back to Shop", href: "/shop" }}
        />
      )
    }
    
    {/* Expand Your Look Algorithm */}
    <div class="-mx-4 sm:mx-0 lg:-mx-8 mt-16">
      <RelatedProducts 
        title={crossSellTitle}
        subtitle={crossSellSubtitle}
        products={crossSellProducts}
      />
    </div>
  </div>

</EngineLayout>

<script>
  // @ts-ignore
  function initSorter() {
    if (!window.Alpine) return;
    window.Alpine.data("productSorter", () => ({
      sortOrder: "featured",
      get sortedProducts() {
        const products = Array.from(document.querySelectorAll('.product-item')); // Changed from .product-card to .product-item
        const sortContainer = document.getElementById('product-grid'); // Changed from product-grid-container to product-grid
        
        if (!sortContainer) return;

        products.sort((a, b) => {
          const aIndex = parseInt(a.getAttribute('data-index') || "0");
          const bIndex = parseInt(b.getAttribute('data-index') || "0");
          return aIndex - bIndex;
        });

        // Clear existing children and append sorted ones
        while (sortContainer.firstChild) {
          sortContainer.removeChild(sortContainer.firstChild);
        }
        products.forEach(p => sortContainer.appendChild(p));
        return products; // Return sorted products for reactivity if needed
      },

      // Retaining the original sort method logic for compatibility with FilterSortBar
      sortBy: "default",
      sort(criteria) {
        this.sortBy = criteria;
        const grid = document.querySelector("#product-grid"); // Use ID selector
        if (!grid) return;

        const items = Array.from(grid.querySelectorAll(".product-item"));

        items.sort((a, b) => {
          const aPrice = parseFloat(a.dataset.price || "0");
          const bPrice = parseFloat(b.dataset.price || "0");
          const aName = a.dataset.name || "";
          const bName = b.dataset.name || "";
          const aRating = parseFloat(a.dataset.rating || "0");
          const bRating = parseFloat(b.dataset.rating || "0");
          const aDate = parseInt(a.dataset.publishDate || "0");
          const bDate = parseInt(b.dataset.publishDate || "0");
          const aDiscount = parseFloat(a.dataset.discount || "0");
          const bDiscount = parseFloat(b.dataset.discount || "0");
          const aIndex = parseInt(a.dataset.index || "0");
          const bIndex = parseInt(b.dataset.index || "0");

          switch (criteria) {
            case "price-asc":
              return aPrice - bPrice;
            case "price-desc":
              return bPrice - aPrice;
            case "name-asc":
              return aName.localeCompare(bName);
            case "name-desc":
              return bName.localeCompare(aName);
            case "rating-desc":
              return bRating - aRating;
            case "date-desc":
              return bDate - aDate;
            case "discount-desc":
              return bDiscount - aDiscount;
            case "default":
              return aIndex - bIndex;
            default:
              return 0;
          }
        });

        items.forEach((item) => grid.appendChild(item));
      },
    }));
  }

  document.addEventListener("alpine:init", initSorter);
  document.addEventListener("astro:page-load", initSorter);
</script>
