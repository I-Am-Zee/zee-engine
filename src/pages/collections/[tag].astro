---
import { getCollection, getEntry } from "astro:content";
import EngineLayout from "../../layouts/EngineLayout.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import Pagination from "../../components/ui/Pagination.astro";
import RelatedProducts from "../../components/features/RelatedProducts.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import ComingSoon from "../../components/ui/ComingSoon.astro";
import SmartProductGrid from "../../components/features/SmartProductGrid.astro";

// Pre-render at build time (required in server mode)
export const prerender = true;

export async function getStaticPaths() {
  const allProducts = await getCollection("products");
  const comingSoonEntry = await getEntry("component_hub", "coming_soon");
  const comingSoonData = comingSoonEntry?.data;

  let gridData;
  try {
    gridData = await getEntry("collections_grid", "data");
  } catch (e) {
    console.warn("Collections grid data not found.");
  }
  const cards = (gridData?.data as any)?.cards || [];

  // Extract all unique tags
  const tags = [...new Set(allProducts.flatMap((p) => p.data.tags || []))];

  return tags.map((tag) => {
    // Find matching CMS record
    const match = cards.find((c: any) => c.slug === tag && c.type === 'tag');
    const isComingSoon = match?.is_coming_soon === true;

    // Find products or force empty
    const filteredProducts = isComingSoon ? [] : allProducts.filter((p) => p.data.tags?.includes(tag));
    
    return {
      params: { tag },
      props: { 
        products: filteredProducts, 
        tagName: tag,
        categoryDescription: match?.description || "",
        isComingSoon,
        comingSoonData
      },
    };
  });
}

const { tag } = Astro.params;
const { products, tagName, categoryDescription, isComingSoon, comingSoonData } = Astro.props;

// Formatting tag for display (e.g., "pvd-coated" -> "PVD Coated")
const formattedTagName = tagName
  .split("-")
  .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
  .join(" ");

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Collections", href: "/collections" },
  { label: formattedTagName, active: true },
];

const PRODUCTS_PER_PAGE = 12;
const totalPages = Math.ceil(products.length / PRODUCTS_PER_PAGE);
const currentPage = 1;

// ── Smart Page Controller Logic (Cross-Sell) ──────────────────────
const allProductsForCrossSell = await getCollection("products");
const crossSellHeader = await getEntry("section_headers", "collection-related");

const crossSellProducts = allProductsForCrossSell
  .filter((p) => !p.data.tags?.includes(tagName))
  .sort(() => 0.5 - Math.random())
  .slice(0, 4);

const crossSellTitle = crossSellHeader?.data?.title || "Style Pairings";
const crossSellSubtitle = crossSellHeader?.data?.subtitle || "Discover curated pieces that complement this collection";
---

<EngineLayout pageTitle={`${formattedTagName} Collection`}>

  <div class="mx-auto max-w-7xl px-4 py-8 lg:px-8">
    <Breadcrumbs items={breadcrumbItems} />

    <div class="mt-6 mb-8">
      <PageHeader 
        title={`${formattedTagName} Collection`}
        subtitle={categoryDescription} 
        align="left"
      />
    </div>

    {
      isComingSoon ? (
        <ComingSoon categoryName={formattedTagName} {...comingSoonData} />
      ) : products.length > 0 ? (
        <>
          <SmartProductGrid products={products} categoryName={formattedTagName} />

          {totalPages > 1 && (
            <Pagination
              currentPage={currentPage}
              totalPages={totalPages}
              baseUrl={`/collections/${tag}`}
            />
          )}
        </>
      ) : (
        <EmptyState
          icon="shopping-bag"
          heading="No products found"
          description={`We couldn't find any products in the ${formattedTagName} collection.`}
          action={{ label: "Back to Shop", href: "/shop" }}
        />
      )
    }
    
    {/* Expand Your Look Algorithm */}
    <div class="-mx-4 sm:mx-0 lg:-mx-8 mt-16">
      <RelatedProducts 
        title={crossSellTitle}
        subtitle={crossSellSubtitle}
        products={crossSellProducts}
      />
    </div>
  </div>

</EngineLayout>
