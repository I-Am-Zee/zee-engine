---
import { getCollection, type CollectionEntry } from "astro:content";
import { mapProduct } from "../../config/ecommerce";
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Heading from '../../components/primitives/Heading.astro';
import Text from '../../components/primitives/Text.astro';
import Icon from '../../components/primitives/Icon.astro';
import Button from '../../components/primitives/Button.astro';
import GlassProductCard from '../../components/ui/GlassProductCard.astro';
import ProductGrid from '../../components/features/ProductGrid.astro';
import BuySetButton from '../../components/features/BuySetButton.astro';
import Image from '../../components/primitives/Image.astro';
import CompleteTheLook from '../../components/ui/CompleteTheLook.astro';
import Carousel from '../../components/ui/Carousel.astro';
import ProductCarousel from '../../components/features/ProductCarousel.astro';
import CollectionCard from '../../components/ui/CollectionCard.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';

export const getStaticPaths = (async () => {
  const lookbooks = await getCollection('lookbooks');
  return lookbooks.map((lookbook) => ({
    params: { slug: lookbook.slug },
    props: { lookbook },
  }));
}) satisfies GetStaticPaths;

const { lookbook } = Astro.props;
const { title, description, hero_image, products: productSlugs } = lookbook.data;
const { Content } = await lookbook.render();

// Fetch full product data
const allProducts = await getCollection('products');
const allLookbooks = await getCollection('lookbooks');
const relatedLookbooks = allLookbooks.filter((lb) => lb.slug !== lookbook.slug);

// Filter only valid products that exist in the collection
const products = (productSlugs || [])
  .map((slug) => allProducts.find((p) => p.slug === slug))
  .filter((p): p is NonNullable<typeof p> => !!p);

// Transform for BuySetButton - Flatten to clean objects for client-side serialization
const productsForButton = products.map(p => mapProduct(p));

// SEO
const pageTitle = `${title} | Shop the Look | Zelia Vance`;
const pageDescription = description || 'Discover our curated jewelry collection';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Breadcrumbs -->
  <nav class="bg-surface border-b border-border-subtle py-3">
    <div class="mx-auto max-w-7xl px-4 lg:px-8">
      <ol class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-text-muted">
        <li><a href="/" class="hover:text-text-main transition-colors">Home</a></li>
        <li class="opacity-30">/</li>
        <li><a href="/lookbooks" class="hover:text-text-main transition-colors">Lookbooks</a></li>
        <li class="opacity-30">/</li>
        <li class="text-text-main truncate max-w-37.5 md:max-w-none">{title}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero Image Section -->
  <div class="relative w-full h-[60vh] md:h-[80vh] bg-black overflow-hidden">
    <Image
      src={hero_image}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover brightness-50"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-linear-to-t from-black via-black/20 to-transparent" />
    
    <!-- Title Overlay -->
    <div class="absolute bottom-0 left-0 right-0 p-8 md:p-20 text-white">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <Text variant="caption" class="text-accent-brass font-bold uppercase tracking-[0.3em] mb-4">Editorial Spotlight</Text>
        <Heading as="h1" class="mb-6 text-white">
          {title}
        </Heading>
        {description && (
          <p class="text-lg md:text-2xl max-w-2xl font-light italic leading-relaxed text-gray-200 opacity-90 border-l-2 border-accent-brass/50 pl-6 py-2">
            "{description}"
          </p>
        )}
      </div>
    </div>
  </div>

  <!-- Editorial Gallery -->
  {lookbook.data.gallery && lookbook.data.gallery.length > 0 && (
    <section class="bg-surface py-12 md:py-16 px-4">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <SectionHeader title="Editorial Gallery" subtitle="A closer look at the intricate details and design language." />
        <Carousel 
          options={{ perPage: 3, gap: 24, type: lookbook.data.gallery.length > 3 ? 'loop' : 'slide', pagination: true, autoplay: lookbook.data.gallery.length > 3, interval: 4000, pauseOnHover: true, breakpoints: { 1024: { perPage: 2 }, 768: { perPage: 2, padding: { left: '1rem', right: '2rem' } }, 640: { perPage: 1, padding: { left: '1rem', right: '5rem' }, gap: 16 } } }} 
          class="w-[calc(100%+2rem)] -mx-4 md:w-full md:mx-0 pb-8"
          trackClass="py-4"
          showArrows={lookbook.data.gallery.length > 3}
        >
          {lookbook.data.gallery.map((img) => (
            <li class="splide__slide flex justify-center items-center h-auto">
              <div class="aspect-4/5 w-full max-w-sm md:max-w-md lg:max-w-lg rounded-2xl overflow-hidden cursor-zoom-in active:scale-[0.98] transition-all">
                <Image 
                  src={img} 
                  alt={`${title} Editorial Detail`} 
                  class="w-full h-full object-cover transition-transform duration-1000 hover:scale-[1.03]"
                  @click={`$dispatch('open-lightbox', { src: '${img}', alt: '${title} Editorial Detail' })`}
                />
              </div>
            </li>
          ))}
        </Carousel>
      </div>
    </section>
  )}

  <!-- Products Section -->
  {products.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 lg:px-8 py-12 md:py-16" id="products">
      <SectionHeader 
        title="Shop the Ensemble" 
        subtitle="Our senior stylists have curated these pieces specifically for their complementary silhouettes and materials." 
      />

      <ProductCarousel products={products} columns={3} class="mb-16" />

      <!-- Buy Complete Look Button -->
      <div class="bg-white/50 backdrop-blur-sm relative overflow-hidden rounded-3xl p-6 md:p-20 border border-border-subtle/50 max-w-5xl mx-auto text-center shadow-sm">
        <div class="absolute top-0 right-0 p-8 opacity-5">
          <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        </div>
        
        <Heading as="h3" class="mb-4">The Master Set</Heading>
        <Text class="mb-8 md:mb-10 block text-text-muted max-w-2xl mx-auto leading-relaxed text-sm md:text-base">
          Acquire the complete curation with a single click. Every piece is guaranteed to complement each other perfectly.
        </Text>
        <div class="flex justify-center flex-col items-center gap-4 md:gap-6">
          <BuySetButton 
            products={productsForButton} 
            label="Acquire Set"
            class="w-full max-w-md"
          />
          <Text variant="caption" class="text-accent-brass font-bold animate-pulse text-[10px] md:text-xs">✨ Exclusive Bundle Pricing Applied</Text>
        </div>
      </div>
    </section>
  )}

  <!-- Story Content -->
  <section class="bg-background py-12 md:py-16 border-y border-border-subtle relative">
    <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/silk-weave.png');"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto">
        <SectionHeader title="The Narrative" />
        <div class="prose prose-zelia max-w-3xl mx-auto">
          <Content />
        </div>
      </div>
    </div>
  </section>

  <!-- Related Lookbooks (Recommendation) -->
  <section class="mx-auto max-w-7xl px-4 lg:px-8 py-12 md:py-16">
     <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between mb-8 md:mb-12 max-[425px]:items-center max-[425px]:text-center">
       <div>
         <Heading as="h2">Continue Exploring</Heading>
         <Text variant="caption" class="mt-2 block uppercase tracking-widest text-accent-brass font-bold">More Editorial Stories</Text>
       </div>
       <a href="/lookbooks" class="group flex items-center gap-2 text-xs uppercase tracking-widest font-black hover:text-accent-brass transition-all">
         All Stories <span class="group-hover:translate-x-2 transition-transform">&rarr;</span>
       </a>
     </div>
     
     <Carousel 
        options={{ perPage: 3, gap: 32, type: relatedLookbooks.length > 3 ? 'loop' : 'slide', pagination: true, breakpoints: { 1024: { perPage: 2 }, 768: { perPage: 2, padding: { left: '1rem', right: '2rem' } }, 640: { perPage: 1, padding: { left: '1rem', right: '5rem' }, gap: 16 } } }} 
        class="w-[calc(100%+2rem)] -mx-4 md:w-full md:mx-0 pb-16 related-carousel"
        trackClass="py-4"
        showArrows={relatedLookbooks.length > 3}
      >
        {relatedLookbooks.map(lb => (
          <li class="splide__slide flex justify-center h-auto">
            <a href={`/lookbooks/${lb.slug}`} class="group block relative w-full max-w-sm md:max-w-md lg:max-w-lg aspect-4/5 overflow-hidden rounded-3xl bg-black focus-glow">
              <Image src={lb.data.hero_image} alt={lb.data.title} class="absolute inset-0 w-full h-full object-cover opacity-70 transition-transform duration-1000 group-hover:scale-[1.05]" />
              <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-black/10"></div>
              <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-8">
                <Text variant="caption" class="text-accent-brass mb-3 uppercase tracking-widest block font-bold drop-shadow-md">Editorial Story</Text>
                <Heading as="h3" class="text-white font-serif tracking-tight text-3xl md:text-4xl mb-6 drop-shadow-lg">{lb.data.title}</Heading>
                <div class="h-0.5 w-12 bg-white/50 mx-auto group-hover:w-24 group-hover:bg-accent-brass transition-all duration-500"></div>
              </div>
            </a>
          </li>
        ))}
     </Carousel>
  </section>

  <!-- Sticky Mobile CTA -->
  <div 
    x-data="{ show: false }"
    @scroll.window="show = window.scrollY > 800 && (document.documentElement.scrollHeight - window.scrollY - window.innerHeight) > 800"
    x-show="show"
    x-transition:enter="transition ease-out duration-300 transform"
    x-transition:enter-start="translate-y-full"
    x-transition:enter-end="translate-y-0"
    x-transition:leave="transition ease-in duration-200 transform"
    x-transition:leave-start="translate-y-0"
    x-transition:leave-end="translate-y-full"
    class="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-md border-t border-border-subtle p-4 md:hidden shadow-[0_-10px_30px_rgba(0,0,0,0.1)] z-[50]"
    x-cloak
  >
    <div class="container mx-auto">
      <Button
        type="primary"
        size="lg"
        @click={`$dispatch('zeliavance:master-set', { products: ${JSON.stringify(productsForButton)} })`}
        class="w-full py-4 uppercase tracking-[0.2em] text-xs font-bold shadow-md shadow-primary/10 hover:shadow-lg hover:shadow-primary/20 transition-all duration-300"
      >
        <Icon name="PhShoppingBagOpen" size={20} weight="bold" />
        <span>Acquire Set (₹{productsForButton.reduce((sum, p) => sum + (p.salePrice || p.price || 0), 0).toLocaleString("en-IN")})</span>
      </Button>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .prose p {
    margin-bottom: 2rem;
  }
  .quote-marks {
    position: relative;
  }
  [x-cloak] { display: none !important; }
</style>
