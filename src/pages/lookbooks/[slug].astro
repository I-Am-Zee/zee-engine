---
import { getCollection, getEntry, render } from "astro:content";

import { mapProduct } from "../../config/ecommerce";
import type { GetStaticPaths } from 'astro';
import EngineLayout from '../../layouts/EngineLayout.astro';
import Heading from '../../components/primitives/Heading.astro';
import Text from '../../components/primitives/Text.astro';
import Button from '../../components/primitives/Button.astro';
import Icon from '../../components/primitives/Icon.astro';
import BuySetButton from '../../components/features/BuySetButton.astro';

import GalleryCarousel from '../../components/features/GalleryCarousel.astro';
import ProductCarousel from '../../components/features/ProductCarousel.astro';
import RelatedLookbooksCarousel from '../../components/features/RelatedLookbooksCarousel.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import EditorialHero from '../../components/ui/EditorialHero.astro';
import MdxImage from "../../components/ui/MdxImage.astro";
import BrandVariable from "../../components/features/BrandVariable.astro";

export const getStaticPaths = (async () => {
  const lookbooks = await getCollection('lookbooks');
  return lookbooks.map((lookbook) => ({
    params: { slug: lookbook.id },
    props: { lookbook },
  }));
}) satisfies GetStaticPaths;


const { lookbook } = Astro.props;
const { title, description, hero: hero_image, products: productSlugs } = lookbook.data;
const { Content } = await render(lookbook);

// Fetch full product data
const allProducts = await getCollection('products');
const allLookbooks = await getCollection('lookbooks');
const relatedLookbooks = allLookbooks.filter((lb) => lb.id !== lookbook.id);

// Filter only valid products that exist in the collection
const products = (productSlugs || [])
  .map((slug) => allProducts.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => !!p);


// Transform for BuySetButton - Flatten to clean objects for client-side serialization
const productsForButton = products.map(p => mapProduct(p));

// SEO
const pageTitle = `${title} | Shop the Look`;
const pageDescription = description || 'Discover our curated jewelry collection';

// Load Section Headers & Global Messaging (Hub Strategy)
const galleryHub = await getEntry('section_headers', 'lookbook-gallery');
const productsHub = await getEntry('section_headers', 'lookbook-products');
const exploreHub = await getEntry('section_headers', 'lookbook-explore');
const lookbookSettings = await getEntry('settings', 'lookbook_settings');
const isAffiliate = import.meta.env.PUBLIC_AFFILIATE === "true";

const galleryData = galleryHub?.data || { title: "Editorial Gallery", subtitle: "A closer look at the intricate details and design language." };
const productsData = productsHub?.data || { 
  title: "Shop the Ensemble", 
  subtitle: "Our senior stylists have curated these pieces specifically for their complementary silhouettes and materials.",
  action_label: "Acquire Set"
};
const exploreData = exploreHub?.data || { title: "Continue Exploring", subtitle: "More Editorial Stories" };

const storyTitle = lookbookSettings?.data?.narrative_heading || "The Narrative";

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Lookbooks", href: "/lookbooks" },
  { label: title, current: true },
];
---

<EngineLayout pageTitle={pageTitle} description={pageDescription}>
  <Breadcrumbs items={breadcrumbItems} />

  {/* Cinematic Hero */}
  <EditorialHero
    title={title}
    image={hero_image} 
    description={description} 
    eyebrow="Editorial Spotlight" 
  />

  {/* Editorial Gallery */}
  {lookbook.data.gallery && lookbook.data.gallery.length > 0 && (
    <section class="bg-(--color-surface) py-12 md:py-16">
      <div class="mx-auto max-w-7xl px-4 lg:px-8">
        <SectionHeader title={galleryData.title} subtitle={galleryData.subtitle} />
        <GalleryCarousel images={lookbook.data.gallery} title={title} />
      </div>
    </section>
  )}

  {/* Products Section */}
  {products.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 lg:px-8 py-12 md:py-16" id="products">
      <SectionHeader 
        title={productsData.title} 
        subtitle={productsData.subtitle} 
      />

      <ProductCarousel products={products} columns={3} class={isAffiliate ? "mb-8" : "mb-16"} />

      {!isAffiliate && (
        <div class="bg-white/50 backdrop-blur-sm relative overflow-hidden rounded-3xl p-6 md:p-20 border border-(--color-border-subtle)/50 max-w-5xl mx-auto text-center shadow-xs">
          <div class="absolute top-0 right-0 p-8 opacity-5">
            <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          </div>
          
          <Heading as="h3" class="mb-4">The Master Set</Heading>
          <Text class="mb-8 md:mb-10 block text-(--color-text-muted) max-w-2xl mx-auto leading-relaxed text-sm md:text-base">
            Acquire the complete curation with a single click. Every piece is guaranteed to complement each other perfectly.
          </Text>
          <div class="flex justify-center flex-col items-center gap-4 md:gap-6">
            <BuySetButton 
              products={productsForButton} 
              label={productsData.action_label}
              class="w-full max-w-md"
            />
            <Text variant="caption" class="text-(--color-accent) font-bold animate-pulse text-[10px] md:text-xs">{lookbookSettings?.data?.bundle_pricing_label || "✨ Exclusive Bundle Pricing Applied"}</Text>
          </div>
        </div>
      )}
    </section>
  )}

  {/* Story Content */}
  <section class="bg-(--color-background) py-12 md:py-16 border-y border-(--color-border-subtle) relative">
    <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/silk-weave.png');"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto">
        <SectionHeader title={storyTitle} />
        <div class="prose max-w-3xl mx-auto">
          <Content components={{ img: MdxImage, ContactMark: BrandVariable, ContactToken: BrandVariable }} />
        </div>
      </div>
    </div>
  </section>

  {/* Related Lookbooks (Recommendation) */}
  <section class="mx-auto max-w-7xl py-12 md:py-16 px-4 lg:px-8 overflow-hidden">
     <SectionHeader 
       title={exploreData.title} 
       subtitle={exploreData.subtitle}
       align="left"
       actionLabel={exploreData.button_mode === 'link' ? exploreData.action_label : undefined}
       linkUrl={exploreData.button_mode === 'link' ? exploreData.link_url : undefined}
     />
     
     <RelatedLookbooksCarousel lookbooks={relatedLookbooks} />
  </section>

  {!isAffiliate && (
    <div 
      x-data="{ show: false }"
      @scroll.window="show = window.scrollY > 800 && (document.documentElement.scrollHeight - window.scrollY - window.innerHeight) > 800"
      x-show="show"
      x-transition:enter="transition ease-out duration-300 transform"
      x-transition:enter-start="translate-y-full"
      x-transition:enter-end="translate-y-0"
      x-transition:leave="transition ease-in duration-200 transform"
      x-transition:leave-start="translate-y-0"
      x-transition:leave-end="translate-y-full"
      class="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-md border-t border-(--color-border-subtle) p-4 md:hidden shadow-[0_-10px_30px_rgba(0,0,0,0.1)] z-50"
      x-cloak
    >
      <div class="container mx-auto">
        <Button
          type="primary"
          size="lg"
          @click={`$dispatch('engine:master-set', { products: ${JSON.stringify(productsForButton)} })`}
          class="w-full py-4 uppercase tracking-[0.2em] text-xs font-bold shadow-md shadow-primary/10 hover:shadow-lg hover:shadow-primary/20 transition-all duration-300"
        >
          <Icon name="PhShoppingBagOpen" size={20} weight="bold" />
          <span>Acquire Set (₹{productsForButton.reduce((sum, p) => sum + (p.salePrice || p.price || 0), 0).toLocaleString("en-IN")})</span>
        </Button>
      </div>
    </div>
  )}
</EngineLayout>
