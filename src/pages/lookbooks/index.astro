---
/**
 * Lookbooks Index Page
 * 
 * Gallery view of all lookbooks for SEO and lifestyle storytelling.
 * Target keywords: "Diwali jewelry ideas", "wedding necklace sets", etc.
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Heading from '../../components/primitives/Heading.astro';
import CollectionCard from '../../components/ui/CollectionCard.astro';

// Get all lookbooks
const lookbooks = await getCollection('lookbooks');

const title = 'Shop the Look | Curated Jewelry Collections | Zelia Vance';
const description = 'Explore our curated jewelry collections. From Diwali party glam to wedding elegance, find the perfect set to complete your look.';
---

<EngineLayout title={title} description={description}>
  <div class="mx-auto max-w-7xl px-4 py-16 md:py-24 lg:px-8">
    <!-- Header -->
    <SectionHeader 
      title="Shop the Look" 
      subtitle="Curated jewelry collections for every occasion. From intimate gatherings to grand celebrations, find your perfect ensemble." 
      align="center"
    />

    <!-- Lookbooks Grid -->
    {lookbooks.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 max-w-7xl mx-auto">
        {lookbooks.map((lookbook) => (
          <CollectionCard
            title={lookbook.data.title}
            href={`/lookbooks/${lookbook.id}`}
            image={lookbook.data.hero_image}
            description={lookbook.data.description}
            itemCount={lookbook.data.products?.length}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500 text-lg">No lookbooks available yet. Check back soon!</p>
      </div>
    )}
  </div>
</EngineLayout>
