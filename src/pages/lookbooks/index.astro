---
import { getCollection, getEntry } from 'astro:content';
import EngineLayout from '../../layouts/EngineLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import CollectionCard from '../../components/ui/CollectionCard.astro';

// Get all lookbooks
const lookbooks = await getCollection('lookbooks');

// Load Page Header (Hub Strategy)
const header = await getEntry('page_headers', 'lookbook-index');
const hubData = header?.data || {
  title: "Shop the Look",
  subtitle: "Curated jewelry collections for every occasion. From intimate gatherings to grand celebrations, find your perfect ensemble.",
  align: "center"
};

const title = hubData.title;
const description = hubData.subtitle;
---

<EngineLayout pageTitle={title} description={description}>
  <div class="mx-auto max-w-7xl px-4 py-16 md:py-24 lg:px-8">
    <!-- Header -->
    <PageHeader 
      title={hubData.title} 
      subtitle={hubData.subtitle} 
      align={hubData.align || "center"}
    />

    <!-- Lookbooks Grid -->
    {lookbooks.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 max-w-7xl mx-auto">
        {lookbooks.map((lookbook) => (
          <CollectionCard
            title={lookbook.data.title}
            href={`/lookbooks/${lookbook.id}`}
            image={lookbook.data.hero}
            description={lookbook.data.description}
            itemCount={lookbook.data.products?.length}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-(--color-text-muted) text-lg">No lookbooks available yet. Check back soon!</p>
      </div>
    )}
  </div>
</EngineLayout>
