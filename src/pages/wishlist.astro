---
/**
 * Wishlist Page - Display user's saved products
 * Uses global Alpine.store('wishlist') for state
 */

// Pre-render at build time (required in server mode)
export const prerender = true;

import { getCollection, getEntry } from "astro:content";
import EngineLayout from "../layouts/EngineLayout.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";
import Button from "../components/primitives/Button.astro";
import Icon from "../components/primitives/Icon.astro";
import GlassProductCard from "../components/ui/GlassProductCard.astro";
import ProductGrid from "../components/features/ProductGrid.astro";
import EmptyState from "../components/ui/EmptyState.astro";

// Fetch all products - filtering will happen client-side with Alpine
const allProducts = await getCollection("products");

// Fetch Empty State Content (Centralized Strategy)
const uiWishlist = await getEntry("settings", "ui_wishlist");
const emptyState = uiWishlist?.data?.empty_states || {
  heading: "Your Wishlist is Empty",
  description: "Save your favorite pieces to view them later. Start exploring our collection!",
  cta_label: "Explore Collection",
  cta_link: "/shop"
};
---

<EngineLayout pageTitle="My Wishlist">

  <div class="mx-auto max-w-7xl px-4 py-12 lg:px-8" x-data="{ isLoaded: false }" x-init="setTimeout(() => isLoaded = true, 150)">
    {/* Page Header */}
    <div class="mb-8 border-b border-(--color-border-subtle) pb-6">
      <Heading as="h1" class="mb-2 text-(--color-text-main) font-serif">My Wishlist</Heading>
      <Text variant="paragraph" color="muted">
        <span x-text="$store.wishlist.count" class="font-bold text-(--color-text-main)">0</span> saved items
      </Text>
    </div>

    {/* Content Area - Min-height prevents footer jumping during Alpine initialization */}
    <div class="min-h-[60vh] flex flex-col relative">
      
      {/* Loading State - Solid background prevents ghosting/mixing with content */}
      <div 
        x-show="!isLoaded" 
        class="absolute inset-0 flex items-center justify-center bg-(--color-background) z-20"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        x-cloak
      >
        <div class="flex flex-col items-center gap-4">
          <Icon name="PhCircleNotch" class="h-10 w-10 animate-spin text-(--color-accent)" />
          <Text variant="caption" class="tracking-widest uppercase opacity-50">Loading Collection</Text>
        </div>
      </div>

      {/* Actual Content - Fades in once Alpine is ready */}
      <div 
        x-show="isLoaded" 
        x-cloak
        x-transition:enter="transition ease-out duration-500 delay-100"
        x-transition:enter-start="opacity-0 translate-y-4"
        x-transition:enter-end="opacity-100 translate-y-0"
        class="flex-1 flex flex-col"
      >
        {/* Empty State - shown when no items */}
        <div x-show="$store.wishlist.count === 0" class="flex-1 flex flex-col justify-center" x-cloak>
          <EmptyState
            icon="PhHeart"
            heading={emptyState.heading}
            description={emptyState.description}
            action={{ label: emptyState.cta_label, href: emptyState.cta_link }}
          />
        </div>

        {/* Wishlist Grid - shown when there are items */}
        <div x-show="$store.wishlist.count > 0" class="flex-1" x-cloak>
          <ProductGrid>
            {
              allProducts.map((product) => (
                <div x-show={`$store.wishlist.has('${product.id}')`} x-cloak>
                  <GlassProductCard product={product} />
                </div>
              ))
            }
          </ProductGrid>

          {/* Clear All Button */}
          <div class="mt-12 flex justify-center border-t border-(--color-border-subtle) pt-12">
            <Button
              type="ghost"
              @click="if(confirm('Clear all saved items?')) { $store.wishlist.items = []; $store.wishlist.save(); }"
              class="text-(--color-danger) hover:text-(--color-danger)/80"
            >
              <Icon name="PhTrash" class="mr-2 h-4 w-4" />
              Clear Wishlist
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>

</EngineLayout>
