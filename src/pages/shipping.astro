---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/features/Navbar.astro";
import Footer from "../components/features/Footer.astro";
import Heading from "../components/primitives/Heading.astro";
import Text from "../components/primitives/Text.astro";

export const prerender = true;
---

<BaseLayout title="Shipping & Returns | Zaviona">
  <Navbar />
  <main class="mx-auto max-w-3xl px-4 py-24 text-center">
    <Heading as="h1" class="mb-6 text-4xl font-bold">Shipping & Returns</Heading>
    <Text class="mb-8 text-lg text-(--color-text-muted)">
      We offer secure, insured shipping on all orders. Returns are accepted within 30 days.
    </Text>
    <Text class="text-(--color-text-muted)">
      Full policy details are being updated. Please contact support for immediate questions.
    </Text>
  </main>
  <Footer />
</BaseLayout>
