---
import { getCollection, render } from 'astro:content';
import EngineLayout from '../../layouts/EngineLayout.astro';
import Heading from '../../components/primitives/Heading.astro';
import Text from '../../components/primitives/Text.astro';
import Section from '../../components/primitives/Section.astro';
import Breadcrumbs from '../../components/ui/Breadcrumbs.astro';
import MdxImage from '../../components/ui/MdxImage.astro';
import BrandVariable from '../../components/features/BrandVariable.astro';

export async function getStaticPaths() {
  const legalPages = await getCollection('legal');
  // Only generate paths for non-draft pages
  return legalPages
    .filter(page => !page.data.isDraft)
    .map(page => ({
      params: { slug: page.id },
      props: { page },
    }));
}

const { page } = Astro.props;
const { Content } = await render(page);

export const prerender = true;

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Legal", current: false }, // Text only for category level if no landing page
  { label: page.data.title, current: true },
];
---

<EngineLayout pageTitle={page.data.title}>
  <Breadcrumbs items={breadcrumbItems} />

  <Section as="article" py="py-16 md:py-32" containerClass="max-w-4xl">
    <div class="text-center mb-16 md:mb-24">
      <Text variant="eyebrow" class="text-(--color-accent) mb-4 block">Legal Center</Text>
      <Heading as="h1" class="mb-6">{page.data.title}</Heading>
      {page.data.description && (
        <Text variant="lead" color="muted" class="max-w-2xl mx-auto">
          {page.data.description}
        </Text>
      )}
      {page.data.lastUpdated && (
        <Text variant="caption" color="muted" class="mt-4 block italic">
          Last Updated: {page.data.lastUpdated.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}
        </Text>
      )}
    </div>

    <div class="prose mx-auto max-w-none">
      <Content components={{ img: MdxImage, ContactMark: BrandVariable, ContactToken: BrandVariable }} />
    </div>
  </Section>
</EngineLayout>
: MdxImage }} />
    </div>
  </Section>
</EngineLayout>
