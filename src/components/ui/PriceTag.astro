---
import Text from "../primitives/Text.astro";
import Badge from "../primitives/Badge.astro";
import { formatCurrency, calculateDiscount } from "../../scripts/utils/currency";

interface Props {
  price?: number;
  salePrice?: number;
  affiliateLinks?: any[]; // For affiliate mode
  variant?: "standard" | "compact";
  showPrefix?: boolean; // e.g. "Approx. ₹500"
  class?: string;
}

const { 
  price = 0, 
  salePrice, 
  affiliateLinks = [], 
  variant = "standard", 
  showPrefix = false,
  class: className 
} = Astro.props;

const isAffiliate = import.meta.env.PUBLIC_AFFILIATE === "true";

// SSR Initial state
const ssrHasSale = salePrice !== undefined && salePrice < price;
const discountPercent = calculateDiscount(price, salePrice || 0);
---

<div 
  class:list={["flex items-baseline gap-2 flex-wrap", className]}
  x-data="{}"
>
  {/* Standard Mode (D2C) */}
  {!isAffiliate && (
    <div class="flex items-baseline gap-2 flex-wrap">
      <Text 
        as="span" 
        variant="price" 
      >
        {formatCurrency(salePrice || price)}
      </Text>
      
      {ssrHasSale && (
        <Text 
          as="span" 
          variant="price_sale" 
        >
          {formatCurrency(price)}
        </Text>
      )}
    </div>
  )}

  {/* Affiliate Mode (Dynamic Region-Based) */}
  {isAffiliate && (
    <div class="flex items-baseline gap-2 flex-wrap">
      <Text 
        as="span" 
        variant="price" 
        x-text={`${showPrefix ? "'Approx. ' + " : ""}$store.region.format($store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.salePrice || $store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.price || ${price})`}
      >
        {showPrefix && "Approx. "}{formatCurrency(salePrice || price)}
      </Text>
      
      <Text 
        as="span" 
        variant="price_sale" 
        class:list={[!ssrHasSale && "hidden"]} 
        x-show={`$store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.salePrice !== undefined && $store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.salePrice < $store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.price`} 
        x-cloak
        x-text={`$store.region.format($store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.price)`}
      >
        {formatCurrency(price)}
      </Text>
    </div>
  )}
</div>
