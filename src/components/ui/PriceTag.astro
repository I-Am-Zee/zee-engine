---
import Text from "../primitives/Text.astro";
import Badge from "../primitives/Badge.astro";
import { formatCurrency, calculateDiscount } from "../../scripts/utils/currency";

interface Props {
  price?: number;
  salePrice?: number;
  currency?: string;
  variant?: "default" | "compact";
  class?: string;
  affiliateLinks?: any[];
  showPrefix?: boolean;
}

const {
  price = 0,
  salePrice,
  currency, // Handled automatically or bypassed
  variant = "default",
  class: className,
  affiliateLinks,
  showPrefix = false,
  ...rest
} = Astro.props;

const isAffiliate = Boolean(affiliateLinks && affiliateLinks.length > 0);
const primaryLink = isAffiliate ? affiliateLinks![0] : null;

// Determine SSR Initial State
let ssrHasSale = salePrice !== undefined && salePrice < price;
let ssrActivePrice = ssrHasSale ? salePrice! : price;
let ssrOriginalPrice = price;
let ssrCurrency = currency || "INR";
let ssrLocale = "en-IN";

if (isAffiliate && primaryLink) {
  ssrHasSale = primaryLink.salePrice !== undefined && primaryLink.salePrice < primaryLink.price;
  ssrActivePrice = ssrHasSale ? primaryLink.salePrice : primaryLink.price;
  ssrOriginalPrice = primaryLink.price;
  ssrCurrency = primaryLink.currency || "INR";
  ssrLocale = ssrCurrency === 'INR' ? 'en-IN' : 'en-US';
}

const isAffiliateMode = import.meta.env.PUBLIC_AFFILIATE === "true";
const prefix = (isAffiliateMode && showPrefix) ? "Approx. " : "";

const displayPriceStr = prefix + formatCurrency(ssrActivePrice, ssrCurrency, ssrLocale);
const salePriceStr = ssrHasSale ? formatCurrency(ssrOriginalPrice, ssrCurrency, ssrLocale) : null;
const discountPercent = ssrHasSale ? calculateDiscount(ssrOriginalPrice, ssrActivePrice) : 0;
---

<div class:list={["flex gap-2 flex-wrap items-center", className]} {...rest} x-data={isAffiliate ? `{ links: ${JSON.stringify(affiliateLinks)} }` : "{}"}>
  <div class="flex items-baseline gap-2">
    {/* Active Price */}
    <Text as="span" variant={variant === "compact" ? "caption" : "price"} weight={variant === "compact" ? "bold" : "bold"} class={variant === "compact" ? "text-sm tracking-tight" : ""}>
      {isAffiliate ? (
        <span x-text={`'${prefix}' + $store.region.format($store.region.getActiveLink(links)?.salePrice || $store.region.getActiveLink(links)?.price || ${price})`}>{displayPriceStr}</span>
      ) : (
        <>{displayPriceStr}</>
      )}
    </Text>

    {/* Original Price (Strikethrough) */}
    {isAffiliate ? (
      <Text as="span" variant="price_sale" class={variant === "compact" ? "text-[10px] md:text-px" : ""} x-show={`$store.region.getActiveLink(links)?.salePrice !== undefined && $store.region.getActiveLink(links)?.salePrice < $store.region.getActiveLink(links)?.price`} style={ssrHasSale ? "" : "display: none;"} x-cloak>
        <span x-text={`$store.region.format($store.region.getActiveLink(links)?.price || 0)`}>{salePriceStr}</span>
      </Text>
    ) : (
      ssrHasSale && salePriceStr && (
        <Text as="span" variant="price_sale" class={variant === "compact" ? "text-[10px] md:text-px" : ""}>
          {salePriceStr}
        </Text>
      )
    )}
  </div>

  {/* Discount Badge */}
  {isAffiliate ? (
    <Badge intent="coral" size="xs" x-show={`$store.region.getActiveLink(links)?.salePrice !== undefined && $store.region.getActiveLink(links)?.salePrice < $store.region.getActiveLink(links)?.price`} style={ssrHasSale ? "" : "display: none;"} x-cloak>
      <span x-text={`Math.round((($store.region.getActiveLink(links)?.price - $store.region.getActiveLink(links)?.salePrice) / $store.region.getActiveLink(links)?.price) * 100)`}>{discountPercent}</span>% OFF
    </Badge>
  ) : (
    ssrHasSale && discountPercent > 0 && (
      <Badge intent="coral" size="xs">
        {discountPercent}% OFF
      </Badge>
    )
  )}
</div>
