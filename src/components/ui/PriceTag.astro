---
import Text from "../primitives/Text.astro";
import Badge from "../primitives/Badge.astro";
import { formatCurrency, calculateDiscount } from "../../scripts/utils/currency";

interface Props {
  price?: number;
  salePrice?: number;
  affiliateLinks?: any[]; // For affiliate mode
  variant?: "standard" | "compact";
  showPrefix?: boolean; // e.g. "Approx. ₹500"
  class?: string;
}

const { 
  price = 0, 
  salePrice, 
  affiliateLinks = [], 
  variant = "standard", 
  showPrefix = false,
  class: className 
} = Astro.props;

const isAffiliate = import.meta.env.PUBLIC_AFFILIATE === "true";
const links = affiliateLinks || [];

// SSR Initial state
const ssrHasSale = salePrice !== undefined && salePrice < price;
const discountPercent = calculateDiscount(price, salePrice);
---

<div 
  class:list={["flex items-baseline gap-2 flex-wrap", className]}
  x-data="{}"
>
  {/* Standard Mode (D2C) */}
  {!isAffiliate && (
    <div class="flex items-baseline gap-2 flex-wrap">
      <Text 
        as="span" 
        variant="price_main" 
        class={variant === "compact" ? "text-base md:text-lg" : ""}
      >
        {formatCurrency(salePrice || price)}
      </Text>
      
      {ssrHasSale && (
        <Text 
          as="span" 
          variant="price_sale" 
          class={variant === "compact" ? "text-[10px] md:text-px" : ""}
        >
          {formatCurrency(price)}
        </Text>
      )}
    </div>
  )}

  {/* Affiliate Mode (Dynamic Region-Based) */}
  {isAffiliate && (
    <div class="flex items-baseline gap-2 flex-wrap">
      <Text 
        as="span" 
        variant="price_main" 
        class={variant === "compact" ? "text-base md:text-lg" : ""}
        x-text={`${showPrefix ? "'Approx. ' + " : ""}$store.region.format($store.region.getActiveLink(links)?.salePrice || $store.region.getActiveLink(links)?.price || ${price})`}
      >
        {showPrefix && "Approx. "}{formatCurrency(salePrice || price)}
      </Text>
      
      <Text 
        as="span" 
        variant="price_sale" 
        class:list={[variant === "compact" ? "text-[10px] md:text-px" : "", !ssrHasSale && "hidden"]} 
        x-show={`$store.region.getActiveLink(links)?.salePrice !== undefined && $store.region.getActiveLink(links)?.salePrice < $store.region.getActiveLink(links)?.price`} 
        x-cloak
        x-text={`$store.region.format($store.region.getActiveLink(links)?.price)`}
      >
        {formatCurrency(price)}
      </Text>
    </div>
  )}

  {/* Discount Badge */}
  {isAffiliate ? (
    <Badge 
      intent="coral" 
      size="xs" 
      class:list={[!ssrHasSale && "hidden"]}
      x-show={`$store.region.getActiveLink(links)?.salePrice !== undefined && $store.region.getActiveLink(links)?.salePrice < $store.region.getActiveLink(links)?.price`} 
      x-cloak
    >
      <span x-text={`Math.round((($store.region.getActiveLink(links)?.price - $store.region.getActiveLink(links)?.salePrice) / $store.region.getActiveLink(links)?.price) * 100)`}>{discountPercent}</span>% OFF
    </Badge>
  ) : (
    ssrHasSale && discountPercent > 0 && (
      <Badge intent="coral" size="xs">
        {discountPercent}% OFF
      </Badge>
    )
  )}
</div>
