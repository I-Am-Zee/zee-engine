---
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  min?: number;
  max?: number;
  initial?: number;
  class?: string;
}

const { min = 1, max = 99, initial = 1, class: className, ...rest } = Astro.props;
---

<div
  class:list={["inline-flex items-center gap-1", className]}
  x-data={`{ count: ${initial}, min: ${min}, max: ${max}, increment() { if(this.count < this.max) this.count++ }, decrement() { if(this.count > this.min) this.count-- } }`}
  {...rest}
>
  <Button
    type="neutral"
    variant="icon-only"
    size="sm"
    x-on:click="decrement()"
    x-bind:disabled="count <= min"
  >
    <Icon name="PhMinus" />
  </Button>

  <input
    type="text"
    aria-label="Quantity"
    readonly
    x-bind:value="count"
    class="h-8 w-12 bg-transparent text-sm font-medium text-text-main text-center focus:outline-none"
  />

  <Button
    type="neutral"
    variant="icon-only"
    size="sm"
    x-on:click="increment()"
    x-bind:disabled="count >= max"
  >
    <Icon name="PhPlus" />
  </Button>
</div>
