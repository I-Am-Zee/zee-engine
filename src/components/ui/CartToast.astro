---
/**
 * CartToast - UI Molecule
 * 
 * Toast notification that appears when a product is added to cart.
 * Uses Alpine.js for state management and auto-dismissal.
 * Follows Zaviona design system aesthetics.
 * 
 * @component Molecule (ui/)
 * @uses Alpine.js for reactivity
 */

import Text from "../primitives/Text.astro";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  autoDismissMs?: number;
}

const { autoDismissMs = 4000 } = Astro.props;
---

<!-- Cart Toast Container - Fixed position at top-right -->
<div
  id="cart-toast"
  data-auto-dismiss-ms={autoDismissMs}
  x-data="{ 
    visible: false, 
    productName: '', 
    productPrice: 0, 
    productImage: '',
    dismissTimeout: null,
    autoDismissMs: 4000,
    registered: false,
    init() {
      this.autoDismissMs = parseInt(this.$el.dataset.autoDismissMs) || 4000;
      
      const showToast = (item) => {
        this.productName = item.name || item.title || 'Product added';
        this.productPrice = item.price || 0;
        this.productImage = item.image || '/placeholder.jpg';
        if (this.dismissTimeout) clearTimeout(this.dismissTimeout);
        this.visible = true;
        this.dismissTimeout = setTimeout(() => { this.visible = false; }, this.autoDismissMs);
      };
      
      // Register only once using a flag
      if (!this.registered) {
        this.registered = true;
        
        // Wait for Snipcart to be ready
        const registerEvents = () => {
          if (window.Snipcart && window.Snipcart.events) {
            window.Snipcart.events.on('item.added', showToast);
          }
        };
        
        document.addEventListener('snipcart.ready', registerEvents);
        
        // Also try if Snipcart is already ready
        if (window.Snipcart && window.Snipcart.events) {
          registerEvents();
        }
        
        // Listen for internal dispatch from custom flows (like SideDrawer Quick Shop)
        document.addEventListener('zaviona:show-toast', (e) => {
          if (e.detail) showToast(e.detail);
        });
      }
    },
    formatPrice(price) {
      return new Intl.NumberFormat('en-IN', {
        style: 'currency', currency: 'INR', maximumFractionDigits: 0
      }).format(price || 0);
    }
  }"
  x-show="visible"
  x-cloak
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0 translate-x-full"
  x-transition:enter-end="opacity-100 translate-x-0"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100 translate-x-0"
  x-transition:leave-end="opacity-0 translate-x-full"
  class="fixed top-20 right-4 z-[9999] w-80 max-w-[calc(100vw-2rem)]"
  role="alert"
  aria-live="polite"
>
  <div class="overflow-hidden rounded-lg border border-(--color-border-subtle) bg-(--color-surface) shadow-xl">
    <!-- Success Header -->
    <div class="flex items-center gap-2 border-b border-(--color-border-subtle) bg-(--color-surface) px-4 py-2.5">
      <Icon name="PhCheckCircle" class="text-emerald-600" size={16} weight="fill" />
      <Text as="span" variant="paragraph" weight="medium">Added to Cart</Text>
      
      <!-- Dismiss Button -->
      <button
        @click="visible = false"
        class="ml-auto rounded p-1 text-(--color-text-muted) transition-colors hover:bg-(--color-ghost-hover) hover:text-(--color-text-main) cursor-pointer disabled:cursor-not-allowed"
        aria-label="Dismiss"
      >
        <Icon name="PhX" size={16} />
      </button>
    </div>
    
    <!-- Product Info -->
    <div class="flex items-center gap-3 bg-(--color-background) p-4">
      <div class="h-14 w-14 shrink-0 overflow-hidden rounded bg-(--color-surface) border border-(--color-border-subtle)">
        <img
          :src="productImage || '/placeholder.jpg'"
          alt="Product"
          class="h-full w-full object-cover"
        />
      </div>
      
      <div class="min-w-0 flex-1">
        <Text variant="paragraph" weight="medium" class="truncate" x-text="productName"></Text>
        <Text variant="caption" color="muted" class="mt-0.5" x-text="formatPrice(productPrice)"></Text>
      </div>
    </div>
    
    <!-- Actions -->
    <div class="flex gap-2 border-t border-(--color-border-subtle) bg-(--color-surface) p-3">
      <Button
        type="ghost"
        size="sm"
        @click="visible = false"
        class="flex-1 border border-(--color-border-subtle)"
      >
        <Text variant="label" color="inherit">Continue</Text>
      </Button>
      <Button
        type="primary"
        size="sm"
        @click="visible = false; Snipcart.api.theme.cart.open()"
        class="flex-1"
      >
        <Text variant="label" color="inherit">View Cart</Text>
      </Button>
    </div>
  </div>
</div>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
