---
import { getEntry } from "astro:content";
import Text from "../primitives/Text.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  class?: string;
  productCount: number;
  itemLabel?: string;
  context?: 'products' | 'blog';
  sortOptions?: { label: string; value: string }[];
  categoryName?: string;
}

const { class: className, productCount, itemLabel, context = 'products', sortOptions: manualOptions } = Astro.props;

// Default labels mapping for CMS-driven values
const SORT_LABELS: Record<string, string> = {
  'featured': 'Sort by: Featured',
  'latest': 'Latest',
  'oldest': 'Oldest',
  'price-asc': 'Price: Low to High',
  'price-desc': 'Price: High to Low',
  'name-asc': 'Name: A to Z',
  'name-desc': 'Name: Z to A',
  'rating-desc': 'Rating: High to Low',
  'on-sale': 'On Sale'
};

// Fetch global settings from specialized singletons
const methodsEntry = await getEntry("settings", "sorting-methods");
const methodsData = methodsEntry?.data;

// Get enabled sorts based on context
const contextSettings = context === 'blog' ? methodsData?.blog : methodsData?.products;
const enabledSorts = contextSettings?.enabled_sorts || [];

const finalSortOptions = manualOptions || enabledSorts.map((val: string) => ({
  label: SORT_LABELS[val] || val,
  value: val
}));
---

<div
  class:list={[
    "flex flex-row items-center justify-between gap-4 border-b border-border-subtle/40",
    context === 'blog' ? "py-4" : "pb-4 mb-6",
    className
  ]}
>
<!-- Count Display -->
  <Text variant="metadata" class="text-text-muted">
    {/* Reactive Count for Blog (when filteredCount is available in scope) */}
    {context === 'blog' ? (
      <span x-cloak>
        <span x-show="selectedCategories.length > 0" x-text={`\`\${filteredCount} ${itemLabel || 'articles'} found\``}></span>
        <span x-show="selectedCategories.length === 0">{`${productCount} ${itemLabel || "articles"}`}</span>
      </span>
    ) : (
      /* Static Count for Products */
      `${productCount} ${itemLabel || "products"}`
    )}
  </Text>

  <!-- Sort Dropdown -->
  <div class="relative">
    <label for="sort-select" class="sr-only">Sort items</label>
    <select
      id="sort-select"
      x-model="sortBy"
      @change="sort()"
      class="appearance-none rounded-md border border-(--color-border-subtle) bg-background py-2 pr-10 pl-4 text-sm text-text-main transition-colors hover:border-primary focus:border-primary focus-glow outline-none cursor-pointer"
    >
      {finalSortOptions.map((opt: any) => (
        <option value={opt.value}>{opt.label}</option>
      ))}
    </select>
    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
      <Icon name="PhCaretDown" class="h-4 w-4 text-text-muted" />
    </div>
  </div>
</div>
