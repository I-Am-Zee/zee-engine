---
/**
 * UpsellDrawer Component
 * 
 * A slide-out side drawer that triggers after an item is added to the cart.
 * Displays matching/related products with size selection and quick-add functionality.
 */

import { getCollection, getEntry } from "astro:content";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
import FreeShippingNudge from "../features/FreeShippingNudge.astro";

// Get Global Settings
const settings = await getEntry("settings", "site");
const threshold = settings?.data?.free_shipping_threshold || 3000;
---

<div
  x-data="upsellDrawer"
  x-show="isOpen"
  x-cloak
  @keydown.escape.window="close()"
  class="fixed inset-0 z-9999 overflow-hidden"
  aria-labelledby="upsell-drawer-title"
  role="dialog"
  aria-modal="true"
>
  <!-- Background backdrop -->
  <div 
    x-show="isOpen"
    x-transition:enter="ease-in-out duration-500"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="ease-in-out duration-500"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="close()"
    class="absolute inset-0 bg-black/40 transition-opacity"
  ></div>

  <div class="fixed inset-y-0 right-0 flex max-w-full pl-10">
    <div 
      x-show="isOpen"
      x-transition:enter="transform transition ease-in-out duration-500 sm:duration-700"
      x-transition:enter-start="translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transform transition ease-in-out duration-500 sm:duration-700"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="translate-x-full"
      class="w-screen max-w-md"
    >
      <div class="flex h-full flex-col overflow-y-scroll bg-white shadow-2xl">
        <!-- Header -->
        <div class="px-6 py-6 sm:px-8 border-b border-gray-100">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green-100 text-green-600">
                <Icon name="PhCheck" size={24} weight="bold" />
              </div>
              <Heading as="h2" id="upsell-drawer-title">Added to Cart!</Heading>
            </div>
            <button @click="close()" class="text-gray-400 hover:text-gray-500 transition-colors">
              <Icon name="PhX" size={24} />
            </button>
          </div>

          <!-- Main Item Summary -->
          <div class="mt-6 flex items-center gap-4 bg-gray-50 p-3 rounded-lg border border-gray-100" x-show="mainItem">
            <template x-if="mainItem?.image">
              <img :src="mainItem.image" :alt="mainItem.name" class="h-16 w-16 rounded object-cover" />
            </template>
            <div class="flex-1 min-w-0">
              <Text variant="caption" class="font-bold truncate" x-text="mainItem?.name"></Text>
              <div class="flex gap-2 text-xs text-gray-500 mt-1">
                 <template x-for="option in mainItem?.options" :key="option.name">
                    <span x-text="option.name + ': ' + option.value"></span>
                 </template>
              </div>
            </div>
          </div>
        </div>

        <!-- Body: Perfect Pairings -->
        <div class="flex-1 px-6 py-8 sm:px-8">
          {/* Dynamic Free Shipping Nudge */}
          <div class="mb-8">
            <FreeShippingNudge threshold={threshold} />
          </div>

          <div class="mb-6">
            <Text class="font-bold text-gray-900 mb-1">Make it a Set & Save</Text>
            <div class="h-px w-full bg-gray-100 my-4"></div>
          </div>

          <div class="space-y-8">
            <template x-for="(item, index) in relatedProducts" :key="item.id">
              <div class="group relative flex gap-6 pb-2">
                <!-- Checkbox (Top Right) -->
                <div class="absolute right-0 top-0">
                  <input 
                    type="checkbox" 
                    :id="'upsell-' + item.id"
                    x-model="selectedItems"
                    :value="item.id"
                    class="h-5 w-5 rounded border-gray-300 text-black focus:ring-black cursor-pointer"
                  />
                </div>

                <!-- Product Image -->
                <div class="h-24 w-24 shrink-0 overflow-hidden rounded-md border border-gray-100">
                   <a :href="'/products/' + item.id" @click="close()">
                     <img :src="item.image" :alt="item.title" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-300" />
                   </a>
                </div>

                <!-- Product Info -->
                <div class="flex flex-1 flex-col">
                  <div>
                    <div class="flex justify-between text-base font-medium text-gray-900">
                      <h3>
                        <a :href="'/products/' + item.id" @click="close()" class="hover:underline" x-text="item.title"></a>
                      </h3>
                    </div>
                    <div class="mt-1 flex items-center gap-2">
                       <span x-show="item.salePrice && Number(item.salePrice) < Number(item.price)" class="text-xs text-gray-400 line-through" x-text="'₹' + Number(item.price).toLocaleString('en-IN')"></span>
                       <span class="text-sm font-semibold text-gray-900" x-text="'₹' + (Number(item.salePrice) || Number(item.price)).toLocaleString('en-IN')"></span>
                    </div>
                  </div>

                  <!-- Variant Selectors (Flexible for up to 3 slots) -->
                  <div class="mt-4 space-y-4">
                    <template x-for="v in [item.variant_1, item.variant_2, item.variant_3].filter(slot => slot && slot.values)" :key="v.name">
                      <div>
                        <Text variant="caption" class="text-xs uppercase tracking-wider text-gray-400 mb-2" x-text="'Select ' + v.name"></Text>
                        <div class="flex flex-wrap gap-2">
                          <template x-for="val in (v.values || '').split(',').map(v => v.trim()).filter(v => v !== '')" :key="val">
                            <button
                              @click="selectOption(item.id, v.name, val)"
                              class="inline-flex h-8 min-w-8 items-center justify-center rounded border px-2 text-xs font-medium transition-all"
                              :class="selections[item.id]?.[v.name] === val ? 'border-black bg-black text-white' : 'border-gray-200 bg-white text-gray-700 hover:border-gray-400'"
                              x-text="val"
                            ></button>
                          </template>
                        </div>
                      </div>
                    </template>
                  </div>
                </div>
              </div>
            </template>
          </div>
        </div>

        <!-- Footer (Sticky) -->
        <div class="border-t border-gray-200 px-6 py-8 sm:px-8 bg-gray-50/50">
          <!-- Validation Message -->
          <div x-show="errorMessage" x-text="errorMessage" class="mb-4 text-xs text-red-600 bg-red-50 p-2 rounded border border-red-100" x-transition></div>

          <button 
            @click="addSelected()"
            :disabled="selectedItems.length === 0 || isSubmitting"
            class="flex w-full items-center justify-center rounded-md border border-transparent bg-black px-6 py-4 text-base font-medium text-white shadow-sm hover:bg-gray-800 disabled:bg-gray-300 disabled:cursor-not-allowed transition-all"
          >
            <span x-show="!isSubmitting">Add Selected to Cart (₹<span x-text="totalPrice.toLocaleString('en-IN')"></span>)</span>
            <span x-show="isSubmitting" class="flex items-center gap-2">
              <svg class="animate-spin h-5 w-5 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
              Adding...
            </span>
          </button>
          
          <div class="mt-6 flex justify-center text-center text-sm text-gray-500">
            <button @click="proceedToCheckout()" class="font-medium text-gray-600 hover:text-black hover:underline transition-all">
              No thanks, proceed to checkout &rarr;
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  // Robust event bridge: Store pending events if Alpine isn't ready
  (function() {
    window._zaviona_pending_upsell = null;
    document.addEventListener('zaviona:item-added', (e) => {
      window._zaviona_pending_upsell = e.detail;
      // Also try to trigger potential global listeners
      window.dispatchEvent(new CustomEvent('upsell-ready', { detail: e.detail }));
    });
  })();

  document.addEventListener('alpine:init', () => {
    Alpine.data('upsellDrawer', () => ({
      isOpen: false,
      isSubmitting: false,
      errorMessage: '',
      mainItem: null,
      relatedProducts: [],
      selectedItems: [], // List of IDs
      selections: {}, // ID -> Selected Size
      
      init() {
        // Handle pending event if it happened before init
        if (window._zaviona_pending_upsell) {
           setTimeout(() => {
             this.handleItemAdded(window._zaviona_pending_upsell);
             window._zaviona_pending_upsell = null;
           }, 100);
        }

        document.addEventListener('zaviona:item-added', (e) => {
          this.handleItemAdded(e.detail);
        });
      },

      handleItemAdded(item) {
        console.log('[Upsell] Opening drawer for:', item.name);
        this.mainItem = item;
        this.relatedProducts = window.ZAVIONA_UPSELL_CONTEXT || [];
        this.selectedItems = [];
        this.selections = {};
        this.errorMessage = '';
        this.isOpen = true; // Use nextTick if needed, but this should be fine
      },

      close() {
        this.isOpen = false;
      },

      selectOption(itemId, variantName, val) {
        if (!this.selections[itemId]) this.selections[itemId] = {};
        this.selections[itemId][variantName] = val;
        this.errorMessage = '';
        if (!this.selectedItems.includes(itemId)) {
          this.selectedItems.push(itemId);
        }
      },

      get totalPrice() {
        return this.relatedProducts
          .filter(item => this.selectedItems.includes(item.id))
          .reduce((sum, item) => sum + (Number(item.salePrice) || Number(item.price)), 0);
      },

      async addSelected() {
        if (this.selectedItems.length === 0) return;
        
        // Validation: Ensure all variants are selected for all checked items
        let missingSelection = null;
        for (const id of this.selectedItems) {
            const item = this.relatedProducts.find(p => p.id === id);
            if (!item) continue;
            
            const variants = [item.variant_1, item.variant_2, item.variant_3].filter(v => v?.values);
            const missing = variants.find(v => !this.selections[id]?.[v.name]);
            if (missing) {
                missingSelection = { item, variant: missing };
                break;
            }
        }

        if (missingSelection) {
          const title = missingSelection.item.title || missingSelection.item.name || 'Selected item';
          this.errorMessage = `Please select ${missingSelection.variant.name} for "${title}"`;
          return;
        }

        this.isSubmitting = true;
        this.errorMessage = '';

        const itemsToAdd = this.relatedProducts
          .filter(item => this.selectedItems.includes(item.id))
          .map(item => {
            const customFields = [];
            
            // Flexible Variant Mapping: Match what Snipcart expects via API to ensure proper validation & display
            [item.variant_1, item.variant_2, item.variant_3].forEach((v) => {
              if (v?.name && v?.values && this.selections[item.id]?.[v.name]) {
                const options = v.values.split(',').map(val => val.trim());
                customFields.push({
                  name: v.name,
                  value: this.selections[item.id][v.name],
                  // Robust options format for Snipcart API
                  options: options.join('|'),
                  // Ensure Snipcart knows this is a multiple-choice field
                  type: 'dropdown',
                  required: !v.is_checkbox
                });
              }
            });
            
            return {
              id: item.id,
              name: item.title,
              price: Number(item.salePrice) || Number(item.price),
              description: item.description || '', // Ensure description is synced
              url: item.url || (`/products/${item.id}`),
              // Ensure consistent absolute URL for images
              image: (item.image && (item.image.startsWith('http') || item.image.startsWith('//'))) 
                ? item.image 
                : window.location.origin + (item.image?.startsWith('/') ? item.image : '/' + (item.image || '')),
              quantity: 1,
              customFields: customFields
            };
          });

        console.log('[Upsell] Sending individually with variants:', itemsToAdd);

        try {
          for (const item of itemsToAdd) {
             console.log('[Upsell] Adding item:', item.id, item.url, item.customFields);
             await Snipcart.api.cart.items.add(item);
          }
          this.close();
          // Open cart after successful additions
          setTimeout(() => {
            Snipcart.api.theme.cart.open();
          }, 500);
        } catch (error) {
          console.error('Failed to add upsells. Error:', error);
          this.errorMessage = 'Failed to add items to cart. Please check your connection.';
        } finally {
          this.isSubmitting = false;
        }
      },

      proceedToCheckout() {
        this.close();
        Snipcart.api.theme.cart.open();
      }
    }));
  });
</script>

<style is:global>
  [x-cloak] { display: none !important; }
</style>
