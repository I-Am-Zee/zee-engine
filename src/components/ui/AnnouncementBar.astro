---
/**
 * AnnouncementBar - UI Molecule
 *
 * Top-of-page marketing banner controlled from CMS.
 * Reads from site.yml settings.
 *
 * @component Molecule (ui/)
 */

import { getEntry } from "astro:content";
import Icon from "../primitives/Icon.astro";
import Text from "../primitives/Text.astro";

// Get settings from CMS
const settings = await getEntry("settings", "site");
const threshold = settings?.data?.free_shipping_threshold || 3000;
const announcement = settings?.data?.announcement_bar;

// Dynamic text: Replace {{threshold}} placeholder
let displayText = announcement?.text || "";
if (displayText.includes("{{threshold}}")) {
  displayText = displayText.replace("{{threshold}}", threshold.toLocaleString('en-IN'));
}

// Don't render if not enabled or no text
const show = announcement?.enabled && announcement?.text;
---

{
  show && (
    <div
      class:list={[
        "relative flex items-center justify-center gap-2 px-6 sm:px-8 py-2.5 text-center",
        announcement.bg_color || "bg-surface border-b border-border-subtle",
        announcement.text_color || "text-text-main",
      ]}
    >
      {announcement.link ? (
        <a
          href={announcement.link}
          class="flex items-center gap-2 hover:underline underline-offset-2"
        >
          <Text variant="caption" weight="medium" color="inherit">{displayText}</Text>
          <Icon name="PhArrowRight" size={14} />
        </a>
      ) : (
        <Text variant="caption" weight="medium" color="inherit">{displayText}</Text>
      )}
    </div>
  )
}
