---
/**
 * AnnouncementBar - UI Molecule
 * Supports Airy Cream theme.
 */

import Icon from "../primitives/Icon.astro";
import Text from "../primitives/Text.astro";

interface Props {
  announcement: any;
  threshold: number;
}

const { announcement, threshold = 3000 } = Astro.props;

let displayText = announcement?.text || "";
if (displayText.includes("{{threshold}}")) {
  displayText = displayText.replace("{{threshold}}", threshold.toLocaleString('en-IN'));
}

const show = announcement?.enabled && announcement?.text;
---

{
  show && (
    <div
      class={`relative flex items-center justify-center gap-2 px-6 sm:px-8 py-2.5 text-center ${announcement.bg_color || "bg-(--color-surface-muted) border-b border-(--color-border-subtle)"} ${announcement.text_color || "text-(--color-text-main)"}`}
    >
      {announcement.link ? (
        <a
          href={announcement.link}
          class="flex items-center gap-2 hover:underline underline-offset-2 text-inherit"
        >
          <Text variant="caption" weight="medium" color="inherit">{displayText}</Text>
          <Icon name="PhArrowRight" size={14} />
        </a>
      ) : (
        <Text variant="caption" weight="medium" color="inherit">{displayText}</Text>
      )}
    </div>
  )
}
