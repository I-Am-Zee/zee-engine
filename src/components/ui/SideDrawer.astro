---
/**
 * SideDrawer Component
 *
 * A multi-purpose slide-out side drawer that handles:
 * 1. Post-purchase Upsells (upsell mode)
 * 2. Single-item Quick Shop (quick-shop mode)
 * 3. Multi-item Lookbook Bundles (master-set mode)
 */

interface Props {
  threshold: number;
}

const { threshold = 3000 } = Astro.props;

import { getEntry } from "astro:content";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Icon from "../primitives/Icon.astro";
import Button from "../primitives/Button.astro";
import Image from "../primitives/Image.astro";
import FreeShippingNudge from "../features/FreeShippingNudge.astro";
import DrawerProductCard from "./DrawerProductCard.astro";

// Fetch default HSN from legal-taxonomy settings
const legalTaxonomyEntry = await getEntry("settings", "legal-taxonomy");
const hsnCode = legalTaxonomyEntry?.data?.tax_classes?.[0]?.hsn || "0000";
---

<div
  id="engine-side-drawer"
  x-data="sideDrawer"
  data-hsn={hsnCode}
  x-show="isOpen"
  x-effect="document.body.style.overflow = isOpen ? 'hidden' : ''"
  x-cloak
  @keydown.escape.window="close()"
  class="fixed inset-0 flex items-center justify-end overflow-hidden z-200"
  aria-labelledby="side-drawer-title"
  role="dialog"
  aria-modal="true"
>
  <!-- Background backdrop -->
  <div
    x-show="isOpen"
    x-transition:enter="ease-in-out duration-500"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="ease-in-out duration-500"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="close()"
    class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity"
    x-cloak
  >
  </div>

  <div class="fixed inset-y-0 right-0 flex max-w-full pl-6 sm:pl-10">
    <div
      x-show="isOpen"
      x-transition:enter="transform-gpu transition-transform ease-out duration-500"
      x-transition:enter-start="translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transform-gpu transition-transform ease-in duration-400"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="translate-x-full"
      class="w-full max-w-md will-change-transform"
      x-cloak
    >
      <div class="bg-surface lg:bg-background flex h-full flex-col overflow-hidden shadow-2xl">
        <!-- Header -->
        <div class="border-border-subtle bg-surface/50 border-b px-5 py-6 sm:px-8">
          <div class="mb-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <template x-if="mode === 'upsell'">
                <div
                  class="bg-(--color-success)/10 text-(--color-success) flex h-10 w-10 items-center justify-center rounded-full"
                >
                  <Icon name="PhCheck" size={24} weight="bold" />
                </div>
              </template>
              <Heading as="h2" id="side-drawer-title" x-text="headerTitle" />
            </div>
            <Button
              type="ghost"
              variant="icon-only"
              size="md"
              @click="close()"
              class="-mr-2"
              aria-label="Close"
            >
              <Icon name="PhX" size={24} />
            </Button>
          </div>

          <!-- Main Item Summary (Only for upsell) -->
          <template x-if="mode === 'upsell' && mainItem">
            <div
              class="bg-background border-border-subtle mt-6 flex items-center gap-4 rounded-xl border p-3 shadow-xs"
            >
              <Image
                src=""
                :src="mainItem.image"
                alt=""
                :alt="mainItem.name"
                class="h-16 w-16 rounded-lg object-cover"
                ratio="auto"
                sizes="64px"
                widths={[200, 400]}
              />
              <div class="min-w-0 flex-1">
                <Text variant="paragraph" weight="bold" class="truncate" x-text="mainItem.name" />
                <div class="mt-1 flex flex-wrap gap-2">
                  <template x-for="option in mainItem.options" :key="option.name">
                    <Text
                      variant="metadata"
                      weight="bold"
                      x-text="option.name + ': ' + option.value"
                    />
                  </template>
                </div>
              </div>
            </div>
          </template>
        </div>

        <!-- Body: Product List -->
        <div class="flex-1 overflow-y-auto px-4 py-8 sm:px-8">
          {/* Dynamic Free Shipping Nudge */}
          <div class="mb-10">
            <FreeShippingNudge threshold={threshold} />
          </div>

          <div class="mb-8">
            <Text variant="paragraph" weight="bold" x-text="subHeading" />
            <div class="bg-(--color-accent) mt-2 h-1 w-12"></div>
          </div>

          <div class="space-y-6">
            <template x-for="(item, index) in products" :key="item.id">
              <DrawerProductCard />
            </template>
          </div>
        </div>

        <!-- Footer (Sticky) -->
        <div class="border-border-subtle bg-surface/80 border-t px-5 py-8 backdrop-blur-md sm:px-8">
          <!-- Validation Message -->
          <div
            x-show="typeof validationError !== 'undefined' && validationError"
            class="bg-(--color-danger)/10 border border-(--color-danger)/20 mb-5 rounded-lg p-3"
            x-transition
            x-cloak
          >
            <Text
              id="side-drawer-error-text"
              variant="label"
              color="coral"
              x-text="typeof validationError !== 'undefined' ? validationError : ''"
            />
          </div>

          <Button
            type="primary"
            @click="submit()"
            :disabled="((mode === 'master-set' || mode === 'upsell') && selectedItems.length === 0) || isSubmitting"
            class="w-full py-5 text-base tracking-widest uppercase shadow-xl"
          >
            <span x-show="!isSubmitting" x-cloak>
              <Text variant="label" color="inherit" x-text="submitButtonText" />
            </span>
            <span x-show="isSubmitting" class="flex items-center gap-2" x-cloak>
              <Icon name="PhCircleNotch" class="animate-spin" size={20} />
              <Text variant="label" color="inherit">Processing...</Text>
            </span>
          </Button>

          <div class="mt-6 flex justify-center text-center">
            <button
              @click="close()"
              class="focus-glow cursor-pointer rounded p-2 disabled:cursor-not-allowed"
            >
              <Text variant="eyebrow" color="muted" class="hover:text-primary transition-colors"
                >Continue Shopping</Text
              >
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Placeholder to satisfy Astro component indexing
</script>
