---
/**
 * SideDrawer Component
 * 
 * A multi-purpose slide-out side drawer that handles:
 * 1. Post-purchase Upsells (upsell mode)
 * 2. Single-item Quick Shop (quick-shop mode)
 * 3. Multi-item Lookbook Bundles (master-set mode)
 */

import { getEntry } from "astro:content";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Icon from "../primitives/Icon.astro";
import FreeShippingNudge from "../features/FreeShippingNudge.astro";

// Get Global Settings
const settings = await getEntry("settings", "site");
const threshold = settings?.data?.free_shipping_threshold || 3000;
---

<div
  x-data="sideDrawer"
  x-show="isOpen"
  x-cloak
  @keydown.escape.window="close()"
  class="fixed inset-0 z-9999 overflow-hidden"
  aria-labelledby="side-drawer-title"
  role="dialog"
  aria-modal="true"
>
  <!-- Background backdrop -->
  <div 
    x-show="isOpen"
    x-transition:enter="ease-in-out duration-500"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="ease-in-out duration-500"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="close()"
    class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity"
  ></div>

  <div class="fixed inset-y-0 right-0 flex max-w-full pl-10">
    <div 
      x-show="isOpen"
      x-transition:enter="transform transition ease-in-out duration-500 sm:duration-700"
      x-transition:enter-start="translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transform transition ease-in-out duration-500 sm:duration-700"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="translate-x-full"
      class="w-screen max-w-md"
    >
      <div class="flex h-full flex-col overflow-y-scroll bg-white shadow-2xl">
        <!-- Header -->
        <div class="px-6 py-6 sm:px-8 border-b border-gray-100 bg-gray-50/50">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <template x-if="mode === 'upsell'">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green-100 text-green-600">
                  <Icon name="PhCheck" size={24} weight="bold" />
                </div>
              </template>
              <Heading as="h2" id="side-drawer-title" x-text="headerTitle"></Heading>
            </div>
            <button @click="close()" class="p-2 -mr-2 text-gray-400 hover:text-black transition-colors focus-glow rounded-full">
              <Icon name="PhX" size={24} />
            </button>
          </div>

          <!-- Main Item Summary (Only for upsell) -->
          <template x-if="mode === 'upsell' && mainItem">
            <div class="mt-6 flex items-center gap-4 bg-white p-3 rounded-xl border border-gray-100 shadow-sm">
              <img :src="mainItem.image" :alt="mainItem.name" class="h-16 w-16 rounded-lg object-cover" />
              <div class="flex-1 min-w-0">
                <Text variant="paragraph" weight="bold" class="truncate" x-text="mainItem.name"></Text>
                <div class="mt-1">
                   <template x-for="option in mainItem.options" :key="option.name">
                      <Text variant="metadata" weight="bold" x-text="option.name + ': ' + option.value"></Text>
                   </template>
                </div>
              </div>
            </div>
          </template>
        </div>

        <!-- Body: Product List -->
        <div class="flex-1 px-6 py-8 sm:px-8">
          {/* Dynamic Free Shipping Nudge */}
          <div class="mb-10">
            <FreeShippingNudge threshold={threshold} />
          </div>

          <div class="mb-8">
            <Text variant="paragraph" weight="bold" x-text="subHeading"></Text>
            <div class="h-1 w-12 bg-accent-brass mt-2"></div>
          </div>

          <div class="space-y-10">
            <template x-for="(item, index) in products" :key="item.id">
              <div class="group relative flex gap-6 pb-2 border-b border-gray-50 last:border-0">
                <!-- Checkbox (for Master Set and Upsell mode) -->
                <template x-if="mode === 'master-set' || mode === 'upsell'">
                  <div class="absolute right-0 top-0">
                    <input 
                      type="checkbox" 
                      :id="'drawer-' + item.id"
                      x-model="selectedItems"
                      :value="item.id"
                      class="h-5 w-5 rounded border-gray-300 text-primary focus-glow cursor-pointer"
                    />
                  </div>
                </template>

                <!-- Product Image -->
                <div class="h-28 w-28 shrink-0 overflow-hidden rounded-xl border border-gray-100 bg-gray-50">
                   <a :href="'/products/' + item.id" @click="close()" class="focus-glow block h-full">
                     <img :src="item.image" :alt="item.title" class="h-full w-full object-cover object-center group-hover:scale-110 transition-transform duration-700" />
                   </a>
                </div>

                <!-- Product Info -->
                <div class="flex flex-1 flex-col">
                  <div>
                    <div class="flex justify-between">
                      <Heading as="h3">
                        <a :href="'/products/' + item.id" @click="close()" class="hover:text-accent-brass transition-colors focus-glow rounded" x-text="item.title"></a>
                      </Heading>
                    </div>
                    <div class="mt-2 flex items-center gap-2">
                       <template x-if="item.salePrice && Number(item.salePrice) < Number(item.price)">
                         <Text variant="metadata" color="muted" class="line-through font-medium" x-text="'₹' + Number(item.price).toLocaleString('en-IN')"></Text>
                       </template>
                       <Text variant="paragraph" weight="bold" color="main" x-text="'₹' + (Number(item.salePrice) || Number(item.price)).toLocaleString('en-IN')"></Text>
                    </div>
                  </div>

                  <!-- Variant Selectors (Flexible for up to 3 slots) -->
                  <div class="mt-6 space-y-5">
                    <template x-for="v in [item.variant_1, item.variant_2, item.variant_3].filter(slot => slot && slot.values)" :key="v.name">
                      <div>
                        <div class="flex justify-between items-center mb-2">
                          <Text variant="eyebrow" x-text="v.name"></Text>
                          <template x-if="selections[item.id]?.[v.name]">
                            <Text variant="eyebrow" x-text="selections[item.id][v.name]"></Text>
                          </template>
                        </div>
                        <div class="flex flex-wrap gap-2">
                          <template x-for="val in (v.values || '').split(',').map(v => v.trim()).filter(v => v !== '')" :key="val">
                            <button
                              @click="selectOption(item.id, v.name, val)"
                              class="inline-flex h-9 min-w-9 items-center justify-center rounded border px-3 transition-all focus-glow"
                              :class="selections[item.id]?.[v.name] === val ? 'border-primary bg-primary text-text-inverse' : 'border-gray-200 bg-white text-gray-700 hover:border-accent-brass hover:text-accent-brass hover:bg-surface'"
                            >
                              <Text variant="label" color="inherit" x-text="val"></Text>
                            </button>
                          </template>
                        </div>
                      </div>
                    </template>
                  </div>
                </div>
              </div>
            </template>
          </div>
        </div>

        <!-- Footer (Sticky) -->
        <div class="border-t border-gray-100 px-6 py-8 sm:px-8 bg-gray-50/80 backdrop-blur-xs">
          <!-- Validation Message -->
          <div x-show="errorMessage" x-text="errorMessage" class="mb-5 bg-red-50 p-3 rounded-lg border border-red-100" x-transition>
            <Text variant="label" class="text-red-600" x-text="errorMessage"></Text>
          </div>

          <button 
            @click="submit()"
            :disabled="(mode === 'master-set' && selectedItems.length === 0) || isSubmitting"
            class="flex w-full items-center justify-center rounded-lg border border-transparent bg-primary text-text-inverse px-6 py-5 shadow-xl hover:bg-black hover:scale-[1.02] disabled:bg-gray-300 disabled:scale-100 disabled:cursor-not-allowed transition-all active:scale-95 focus-glow outline-none"
          >
            <span x-show="!isSubmitting">
              <Text variant="label" color="inherit" x-text="submitButtonText"></Text>
            </span>
            <span x-show="isSubmitting" class="flex items-center gap-2">
              <svg class="animate-spin h-5 w-5 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
              <Text variant="label" color="inherit">Processing...</Text>
            </span>
          </button>
          
          <div class="mt-6 flex justify-center text-center">
            <button @click="close()" class="focus-glow p-2">
              <Text variant="eyebrow" color="muted" class="hover:text-primary transition-colors">Continue Shopping</Text>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener('alpine:init', () => {
    Alpine.data('sideDrawer', () => ({
      isOpen: false,
      isSubmitting: false,
      mode: 'upsell', // upsell, quick-shop, master-set
      errorMessage: '',
      mainItem: null, // For upsell mode (the item just added)
      products: [], // Related or selected products
      selectedItems: [], // IDs of checked items
      selections: {}, // ItemID -> { VariantName -> Value }
      
      init() {
        // Listen for all entry points
        document.addEventListener('zaviona:item-added', (e) => this.openUpsell(e.detail));
        document.addEventListener('zaviona:quick-shop', (e) => this.openQuickShop(e.detail));
        document.addEventListener('zaviona:master-set', (e) => this.openMasterSet(e.detail));
      },

      openUpsell(item) {
        console.log('[SideDrawer] Mode: Upsell', item);
        this.mode = 'upsell';
        this.mainItem = item;
        this.products = window.ZAVIONA_UPSELL_CONTEXT || [];
        this.resetInternalState();
        this.isOpen = true;
      },

      openQuickShop(product) {
        console.log('[SideDrawer] Mode: Quick Shop', product);
        this.mode = 'quick-shop';
        this.mainItem = null;
        this.products = [product];
        this.resetInternalState();
        this.selectedItems = [product.id]; // Always selected in this mode
        this.isOpen = true;
      },

      openMasterSet(bundle) {
        console.log('[SideDrawer] Mode: Master Set', bundle);
        this.mode = 'master-set';
        this.mainItem = null;
        this.products = bundle.products;
        this.resetInternalState();
        // Pre-select all items by default for the "Complete the Look" feel
        this.selectedItems = this.products.map(p => p.id);
        this.isOpen = true;
      },

      resetInternalState() {
        this.selections = {};
        this.errorMessage = '';
        this.isSubmitting = false;
        // Pre-fill first available options as defaults
        this.products.forEach(p => {
          this.selections[p.id] = {};
          [p.variant_1, p.variant_2, p.variant_3].forEach(v => {
            if (v?.values) {
              const firstVal = v.values.split(',')[0].trim();
              this.selections[p.id][v.name] = firstVal;
            }
          });
        });
      },

      close() {
        this.isOpen = false;
      },

      get headerTitle() {
        if (this.mode === 'upsell') return 'Added to Cart!';
        if (this.mode === 'quick-shop') return 'Quick Shop';
        return 'Complete the Look';
      },

      get subHeading() {
        if (this.mode === 'upsell') return 'Style it With';
        if (this.mode === 'quick-shop') return 'Select Your Style';
        return 'The Editorial Ensemble';
      },

      get submitButtonText() {
        if (this.mode === 'upsell') return 'Add Pairings (₹' + this.totalPrice.toLocaleString('en-IN') + ')';
        if (this.mode === 'quick-shop') return 'Add to Cart';
        return 'Acquire Complete Look (₹' + this.totalPrice.toLocaleString('en-IN') + ')';
      },

      get totalPrice() {
        const activeProducts = this.mode === 'master-set' 
          ? this.products.filter(p => this.selectedItems.includes(p.id))
          : this.products;
          
        return activeProducts.reduce((sum, p) => sum + (Number(p.salePrice) || Number(p.price)), 0);
      },

      selectOption(itemId, variantName, val) {
        if (!this.selections[itemId]) this.selections[itemId] = {};
        this.selections[itemId][variantName] = val;
        this.errorMessage = '';
      },

      async submit() {
        const itemsToAdd = this.products.filter(p => this.mode !== 'master-set' || this.selectedItems.includes(p.id));
        
        if (itemsToAdd.length === 0) return;

        // Validation
        let missingSelection = null;
        for (const item of itemsToAdd) {
          const variants = [item.variant_1, item.variant_2, item.variant_3].filter(v => v?.values);
          const missing = variants.find(v => !this.selections[item.id]?.[v.name]);
          if (missing) {
            missingSelection = { item, variant: missing };
            break;
          }
        }

        if (missingSelection) {
          this.errorMessage = `Please select ${missingSelection.variant.name} for "${missingSelection.item.title}"`;
          return;
        }

        this.isSubmitting = true;
        
        try {
          const payload = itemsToAdd.map(item => {
            const customFields = [];
            [item.variant_1, item.variant_2, item.variant_3].forEach(v => {
              if (v?.name && this.selections[item.id][v.name]) {
                customFields.push({
                  name: v.name,
                  value: this.selections[item.id][v.name],
                  type: 'dropdown',
                  options: v.values.split(',').map(v => v.trim()).join('|')
                });
              }
            });

            return {
              id: item.id,
              name: item.title,
              price: Number(item.salePrice) || Number(item.price),
              url: `/products/${item.id}`,
              image: item.image,
              quantity: 1,
              customFields
            };
          });

          for (const item of payload) {
            await Snipcart.api.cart.items.add(item);
            
            // Dispatch toast for Quick Shop or explicit sets
            if (this.mode === 'quick-shop' || this.mode === 'master-set') {
              document.dispatchEvent(new CustomEvent('zaviona:show-toast', { detail: item }));
            }
          }
          
          this.close();
        } catch (e) {
          console.error(e);
          this.errorMessage = 'Addition failed. Please check connection.';
        } finally {
          this.isSubmitting = false;
        }
      }
    }));
  });
</script>

<style is:global>
  [x-cloak] { display: none !important; }
</style>
