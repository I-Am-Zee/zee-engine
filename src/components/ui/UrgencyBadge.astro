---
/**
 * UrgencyBadge - UI Molecule
 *
 * Displays scarcity/urgency labels with pulsing animation.
 * Uses Spiced Coral accent from The Royal Conservatory palette.
 *
 * @component Molecule (ui/)
 */

interface Props {
  label: string;
  class?: string;
}

const { label, class: className } = Astro.props;
---

<div
  class:list={[
    "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold tracking-wide",
    "bg-(--color-accent-coral)/10 text-(--color-accent-coral) border border-(--color-accent-coral)/20",
    className,
  ]}
>
  <span class="relative flex h-2 w-2">
    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-(--color-accent-coral) opacity-60"></span>
    <span class="relative inline-flex h-2 w-2 rounded-full bg-(--color-accent-coral)"></span>
  </span>
  <span>{label}</span>
</div>
