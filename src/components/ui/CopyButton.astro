---
import Button from "../primitives/Button.astro";
import Text from "../primitives/Text.astro";

interface Props {
  text: string;
  label?: string;
  successLabel?: string;
  class?: string;
}

const { text, label = "Copy", successLabel = "Copied!", class: className } = Astro.props;
---

<div
  x-data={`{
    copied: false,
    text: '${text}',
    copy() {
      navigator.clipboard.writeText(this.text).then(() => {
        this.copied = true;
        setTimeout(() => this.copied = false, 2000);
      });
    }
  }`}
  @click="copy()"
  class={className}
>
  <Button
    type="ghost"
    size="sm"
    class="transition-colors duration-200"
    :class="copied ? 'text-green-600' : 'text-text-muted hover:text-text-main'"
  >
    <Text variant="label" color="inherit" x-text={`copied ? '${successLabel}' : '${label}'`}></Text>
  </Button>
</div>
