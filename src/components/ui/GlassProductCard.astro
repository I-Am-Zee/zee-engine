---
/**
 * GlassProductCard - UI Molecule (Glassmorphism - Luxury v8 Final)
 *
 * - 2:3 portrait aspect ratio
 * - Layer 1: Static blurred base image (color match)
 * - Layer 2: Crisp product image, top 80%
 * - Layer 3: Glass info panel, bottom 22%
 * - Zero transforms on badge stack or panel (fully static)
 */

import Badge from "../primitives/Badge.astro";
import Heading from "../primitives/Heading.astro";
import Icon from "../primitives/Icon.astro";
import PriceTag from "./PriceTag.astro";
import { sortBadgesByHierarchy, getBadgeIntent } from "../../scripts/utils/badges";

interface Props {
  id?: string;
  image: string;
  title: string;
  price: number;
  salePrice?: number;
  href: string;
  badges?: string[];
  variant_1?: any;
  variant_2?: any;
  variant_3?: any;
  class?: string;
}

const {
  id = "",
  image,
  title,
  price,
  salePrice,
  href,
  badges = [],
  variant_1 = "",
  variant_2 = "",
  variant_3 = "",
  class: className,
  ...rest
} = Astro.props;

const sortedBadges = sortBadgesByHierarchy(badges);

const hasSale = salePrice !== undefined && salePrice < price;
const priceTagProps = hasSale
  ? { price: price, salePrice: salePrice }
  : { price: price };
---

<article
  class:list={[
    "relative flex flex-col overflow-hidden rounded-2xl group aspect-2/3",
    "cursor-pointer select-none bg-surface-muted border border-white/10",
    "transition-shadow duration-700 hover:shadow-[0_24px_60px_rgba(0,0,0,0.20)] hover:border-white/20",
    className,
  ]}
  x-data="glassCard()"
  data-key={href}
  data-id={id}
  data-title={title}
  data-price={salePrice ? String(salePrice) : String(price)}
  data-image={image}
  data-v1={variant_1}
  data-v2={variant_2}
  data-v3={variant_3}
  {...rest}
>
  {/* LAYER 1: Static color-matched blurred base. No hover animation. */}
  <div class="absolute inset-0 z-0 pointer-events-none">
    <img
      src={image}
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover blur-2xl scale-[1.3] opacity-30"
    />
  </div>

  {/* FULL CARD CLICKABLE SURFACE */}
  <a
    href={href}
    class="absolute inset-0 z-10 focus-glow rounded-2xl"
    aria-label={"View " + title}
    tabindex="0"
  ></a>

  {/* LAYER 2: Crisp product image (Flex-1 fills all space above the glass panel) */}
  <div class="relative flex-1 block overflow-hidden z-5 pointer-events-none">
    <img
      src={image}
      alt={title}
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
    />
    {/* Deeper bottom vignette for guaranteed text contrast */}
    <div class="absolute inset-x-0 bottom-0 h-1/3 bg-linear-to-t from-black/50 via-black/10 to-transparent"></div>
  </div>

  {/* TOP-LEFT: Badge stack. Fully static - no transforms on hover. */}
  {sortedBadges.length > 0 && (
    <div class="pointer-events-none absolute top-3 left-3 sm:top-4 sm:left-4 z-30 flex flex-col gap-1.5 sm:gap-2">
      {sortedBadges.map((badge) => (
        <Badge intent={getBadgeIntent(badge)} size="xs">
          {badge}
        </Badge>
      ))}
    </div>
  )}

  {/*
    TOP-RIGHT: Action buttons.
    - isolate: prevents z-index compositing glitches
    - transition-[transform,...]: prevents layout-jitter from transition-all
    - transform-gpu: hardware-accelerated scale, eliminates pixel jitter on hover
  */}
  <div class="absolute top-3 right-3 sm:top-4 sm:right-4 z-30 flex flex-col gap-1.5 sm:gap-2 isolate">
    <button
      class="flex items-center justify-center w-9 h-9 rounded-full isolate
             bg-white/10 backdrop-blur-xl border border-white/25 text-white shadow-sm
             hover:bg-white hover:text-red-500 hover:scale-110
             transition-[transform,background-color,color] duration-300 ease-out transform-gpu
             focus-glow"
      x-on:click.prevent="toggleWishlist()"
      x-bind:class="wishlisted ? 'text-red-500 bg-white!' : 'text-white'"
      aria-label="Toggle wishlist"
    >
      <Icon name="PhHeart" size={17} weight="regular" class="block shrink-0" x-show="!wishlisted" />
      <Icon name="PhHeart" size={17} weight="fill"    class="block shrink-0" x-show="wishlisted" x-cloak />
    </button>

    <button
      class="flex items-center justify-center w-9 h-9 rounded-full isolate
             bg-white/10 backdrop-blur-xl border border-white/25 text-white shadow-sm
             hover:bg-white hover:text-primary hover:scale-110
             transition-[transform,background-color,color] duration-300 ease-out transform-gpu
             focus-glow"
      x-on:click.stop="quickShop()"
      aria-label={"Quick shop " + title}
    >
      <Icon name="PhShoppingBagOpen" size={17} weight="regular" class="block shrink-0" />
    </button>
  </div>

  {/*
    GLASS INFO PANEL
    True glass: backdrop-blur-3xl is the primary visual driver.
    bg-linear-to-br gradient mimics real glass catching light at an angle.
    Flex layout seamlessly anchors this to the bottom without percentage overlap bugs.
  */}
  <div
    class="relative z-20 shrink-0 w-full pointer-events-none
           flex flex-col justify-center gap-1 sm:gap-1.5 px-3 py-3 sm:px-4 sm:py-4 md:px-5 md:py-5
           backdrop-blur-3xl bg-linear-to-br from-white/8 via-white/5 to-white/2
           border-t border-white/15 rounded-b-2xl"
  >
    <Heading
      as="h3"
      color="inverse"
      class="line-clamp-1 tracking-tight leading-normal font-semibold drop-shadow-md"
      style="font-size: clamp(1rem, 2.5vw, 1.15rem);"
    >
      {title}
    </Heading>

    <div class="flex items-center justify-between">
      <PriceTag
        {...priceTagProps}
        variant="compact"
        class="text-white brightness-110 drop-shadow-sm"
      />
    </div>
  </div>
</article>

<script>
  document.addEventListener("alpine:init", () => {
    (window as any).Alpine.data("glassCard", () => ({
      get wishlisted(): boolean {
        const key = (this as any).$el?.dataset?.key ?? "";
        return (window as any).Alpine?.store("wishlist")?.has(key) ?? false;
      },
      toggleWishlist(): void {
        const key = (this as any).$el?.dataset?.key ?? "";
        (window as any).Alpine?.store("wishlist")?.toggle(key);
      },
      quickShop(): void {
        const self = this as any;
        const el: HTMLElement = self.$el;
        self.$dispatch("zaviona:quick-shop", {
          id: el.dataset.id,
          title: el.dataset.title,
          price: Number(el.dataset.price),
          image: el.dataset.image,
          variants: {
            variant_1: el.dataset.v1,
            variant_2: el.dataset.v2,
            variant_3: el.dataset.v3
          }
        });
      },
    }));
  });
</script>

<style>
  [x-cloak] { display: none !important; }
</style>
