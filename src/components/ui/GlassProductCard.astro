---
/**
 * GlassProductCard - UI Molecule (Glassmorphism - Luxury v8 Final)
 *
 * - 2:3 portrait aspect ratio
 * - Layer 1: Static blurred base image (color match)
 * - Layer 2: Crisp product image, top 80%
 * - Layer 3: Glass info panel, bottom 22%
 * - Zero transforms on badge stack or panel (fully static)
 */

import Badge from "../primitives/Badge.astro";
import Heading from "../primitives/Heading.astro";
import Icon from "../primitives/Icon.astro";
import Image from "../primitives/Image.astro";
import PriceTag from "./PriceTag.astro";
import { sortBadgesByHierarchy, getBadgeIntent } from "../../scripts/utils/badges";
import { mapProduct } from "../../config/ecommerce";
import { calculateDiscount } from "../../scripts/utils/currency";
import type { CollectionEntry } from "astro:content";

const isAffiliate = import.meta.env.PUBLIC_AFFILIATE === "true";

interface Props {
  product?: CollectionEntry<"products">; // Raw product entry (optional for backward compatibility)
  id?: string;
  title?: string;
  price?: number;
  salePrice?: number;
  image?: string;
  href?: string;
  badges?: string[];
  class?: string;
  [key: string]: any;
}

const {
  product,
  id: manualId,
  title: manualTitle,
  price: manualPrice,
  salePrice: manualSalePrice,
  image: manualImage,
  href: manualHref,
  badges: manualBadges,
  class: className,
  ...rest
} = Astro.props;

// Use mapping for consistent data access
// prioritize raw product data, fallback to manual props
const p = product ? mapProduct(product) : {
  id: manualId || "",
  title: manualTitle || "",
  price: manualPrice || 0,
  salePrice: manualSalePrice,
  image: manualImage || "",
};

const title = p.title;
const price = p.price;
const salePrice = p.salePrice;
const image = p.image;
const href = manualHref || `/products/${p.id}`;
const id = p.id;
const badges = manualBadges || (product?.data?.badges) || [];

const discountPercent = salePrice && salePrice < price ? calculateDiscount(price, salePrice) : 0;
const hasSale = discountPercent > 0;

// Filter out 'Sale' badge if we are showing the percentage
const filteredBadges = badges.filter(b => b.toLowerCase() !== 'sale');
const sortedBadges = sortBadgesByHierarchy(filteredBadges);

const affiliateLinks = p.affiliate_links;
---

<article
  class:list={[
    "relative flex flex-col overflow-hidden rounded-2xl group aspect-2/3",
    "cursor-pointer select-none bg-(--color-surface-muted) border border-(--color-border-subtle)/40",
    "shadow-xs transition-all duration-300 ease-out",
    "hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] hover:border-(--color-border-subtle)/80",
    className,
  ]}
  x-data
  {...rest}
>
  {/* LAYER 1: Static color-matched blurred base. No hover animation. */}
  <div class="absolute inset-0 z-0 pointer-events-none">
    <Image
      src={image}
      alt=""
      aria-hidden="true"
      class="w-full h-full object-cover blur-2xl scale-[1.3] opacity-30 group-hover:opacity-50 transition-opacity duration-500"
    />
    {/* Text Protection Scrim: Deepens the base behind the glass panel for extreme light images, but now using a LIGHT theme scrim for dark text */}
    <div class="absolute inset-0 bg-linear-to-t from-white/70 via-white/30 to-transparent"></div>
  </div>

  {/* FULL CARD CLICKABLE SURFACE */}
  <a
    href={href}
    class="absolute inset-0 z-10 focus-glow rounded-2xl"
    aria-label={"View " + title}
    tabindex="0"
  ></a>

  {/* LAYER 2: Crisp product image (Flex-1 fills all space above the glass panel) */}
  <div class="relative flex-1 block overflow-hidden z-[5] pointer-events-none">
    <Image
      src={image}
      alt={title}
      loading="lazy"
      sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover motion-soft group-hover:scale-[1.04]"
    />
  </div>

  {/* TOP-LEFT: Badge stack. Fully static - no transforms on hover. */}
  <div class="pointer-events-none absolute top-3 left-3 sm:top-4 sm:left-4 z-30 flex flex-col gap-1.5 sm:gap-2">
    {/* Discount Badge (Affiliate - Dynamic) */}
    {isAffiliate ? (
      <Badge 
        intent="danger" 
        size="xs" 
        class:list={[!hasSale && "hidden"]}
        x-show={`$store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.salePrice !== undefined && $store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.salePrice < $store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.price`} 
        x-cloak
      >
        <span x-text={`Math.round((($store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.price - $store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.salePrice) / $store.region.getActiveLink(${JSON.stringify(affiliateLinks)})?.price) * 100)`}>{discountPercent}</span>% OFF
      </Badge>
    ) : (
      hasSale && (
        <Badge intent="danger" size="xs">
          {discountPercent}% OFF
        </Badge>
      )
    )}

    {/* Static Badges (Filtered) */}
    {sortedBadges.map((badge) => (
      <Badge intent={getBadgeIntent(badge)} size="xs">
        {badge}
      </Badge>
    ))}
  </div>

  {/* Protective radial scrim for icon contrast on light backgrounds */}
  <div class="absolute top-0 right-0 w-32 h-32 bg-[radial-gradient(ellipse_at_top_right,var(--tw-gradient-stops))] from-black/20 via-black/0 to-transparent z-20 pointer-events-none rounded-tr-2xl"></div>
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300
              bg-[radial-gradient(ellipse_at_top_right,var(--tw-gradient-stops))] from-white/20 via-transparent to-transparent"></div>

  {/*
    TOP-RIGHT: Action buttons.
  */}
  <div class="absolute top-3 right-3 sm:top-4 sm:right-4 z-30 flex flex-col gap-1.5 sm:gap-2 isolate
              lg:opacity-0 lg:translate-x-2 lg:group-hover:opacity-100 lg:group-hover:translate-x-0 transition-all duration-300">
    <button
      class="flex items-center justify-center w-[clamp(2rem,6vw,2.25rem)] h-[clamp(2rem,6vw,2.25rem)] rounded-full isolate
             bg-white/50 backdrop-blur-3xl border border-white/60 shadow-md
             transition-all duration-300 ease-out transform-gpu
             hover:bg-white hover:text-(--color-primary) hover:shadow-lg hover:scale-110
             focus-glow cursor-pointer disabled:cursor-not-allowed group relative"
      x-data={`{ id: '${id}' }`}
      x-on:click.prevent="$store.wishlist.toggle(id)"
      x-bind:class="$store.wishlist.has(id) ? 'text-(--color-danger)! bg-white! border-transparent!' : ''"
      aria-label="Toggle wishlist"
    >
      <Icon name="PhHeart" class="absolute shrink-0 transition-colors w-[45%] h-[45%]" x-show="!$store.wishlist.has(id)" />
      <Icon name="PhHeart" weight="fill"    class="absolute shrink-0 text-(--color-danger)! transition-colors w-[45%] h-[45%]" x-show="$store.wishlist.has(id)" x-cloak />
    </button>

    <button
      class="flex items-center justify-center w-[clamp(2rem,6vw,2.25rem)] h-[clamp(2rem,6vw,2.25rem)] rounded-full isolate relative
             bg-white/50 backdrop-blur-3xl border border-white/60 text-(--color-text-main) shadow-md delay-75
             transition-all duration-300 ease-out transform-gpu
             hover:bg-white hover:text-(--color-primary) hover:shadow-lg hover:scale-110
             focus-glow cursor-pointer disabled:cursor-not-allowed"
      x-on:click.prevent.stop={isAffiliate ? `$dispatch('engine:affiliate-quick-view', ${JSON.stringify(p)})` : `$dispatch('engine:quick-shop', ${JSON.stringify(p)})`}
      aria-label={"Quick shop " + title}
    >
      <Icon name="PhShoppingBagOpen" class="absolute shrink-0 w-[45%] h-[45%]" />
    </button>
  </div>

  {/*
    GLASS INFO PANEL
    True glass: backdrop-blur-3xl is the primary visual driver.
    bg-linear-to-br gradient mimics real glass catching light at an angle.
    Flex layout seamlessly anchors this to the bottom without percentage overlap bugs.
  */}
  <div
    class="relative z-20 shrink-0 w-full pointer-events-none
           flex flex-col justify-center gap-1 sm:gap-1.5 px-3 py-3 sm:px-4 sm:py-4 md:px-5 md:py-5
           backdrop-blur-3xl bg-linear-to-br from-white/40 via-white/20 to-white/10 group-hover:from-white/60 group-hover:via-white/30 transition-all duration-500
           border-t border-white/30 rounded-b-2xl"
  >
    <Heading
      as="h3"
      color="main"
      class="line-clamp-1 tracking-tight leading-normal font-semibold text-[clamp(1rem,2.5vw,1.15rem)]"
    >
      {title}
    </Heading>

    <div class="flex items-center justify-between">
      <PriceTag
        price={price}
        salePrice={salePrice}
        affiliateLinks={isAffiliate ? affiliateLinks : undefined}
        variant="compact"
      />
    </div>
  </div>
</article>
