---
import Link from "../primitives/Link.astro";
import Icon from "../primitives/Icon.astro";
import Text from "../primitives/Text.astro";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className, ...rest } = Astro.props;
---

<nav class:list={["flex items-center gap-2 text-sm", className]} aria-label="Breadcrumb" {...rest}>
  <ol class="inline-flex items-center gap-1">
    {
      items.map((item, index) => (
        <li class="inline-flex items-center gap-1">
          {index > 0 && <Icon name="PhCaretRight" class="text-text-muted" />}
          {item.href && index < items.length - 1 ? (
            <Link href={item.href} variant="plain" class="text-text-muted hover:text-text-main">
              {item.label}
            </Link>
          ) : (
            <Text as="span" variant="caption" color="main">
              {item.label}
            </Text>
          )}
        </li>
      ))
    }
  </ol>
</nav>
