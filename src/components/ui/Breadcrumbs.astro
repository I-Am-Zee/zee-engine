---
import Link from "../primitives/Link.astro";
import Text from "../primitives/Text.astro";
import Section from "../primitives/Section.astro";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className, ...rest } = Astro.props;
---

<Section 
  as="nav" 
  variant="standard" 
  py="py-0"
  class={`bg-(--color-surface) border-b border-(--color-border-subtle)/30 ${className || ""}`}
  containerClass="py-4"
  aria-label="Breadcrumb" 
  {...rest}
>
  <ol class="flex items-center gap-x-2 whitespace-nowrap overflow-x-auto scrollbar-hide snap-x snap-mandatory [mask-image:linear-gradient(to_right,black_90%,transparent_100%)] pr-12">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-2 shrink-0 snap-start">
          {index > 0 && (
            <Text variant="metadata" color="muted" class="opacity-30 select-none leading-normal! translate-y-[1.5px]">
              /
            </Text>
          )}
          {item.href && index < items.length - 1 ? (
            <Link 
              href={item.href} 
              variant="plain" 
              class="text-(--color-text-muted)! hover:text-(--color-text-main)! transition-colors duration-200 shrink-0 no-underline! flex items-center h-6"
            >
              <Text as="span" variant="metadata" weight="semibold" color="inherit" class="leading-normal!">
                {item.label}
              </Text>
            </Link>
          ) : index < items.length - 1 ? (
            <div class="flex items-center h-6 shrink-0 translate-y-[1.5px]">
              <Text variant="metadata" color="muted" weight="medium" class="leading-normal!">
                {item.label}
              </Text>
            </div>
          ) : (
            <div class="flex items-center h-6 shrink-0 translate-y-[1.5px]">
              <Text variant="metadata" color="main" weight="bold" class="leading-normal!">
                {item.label}
              </Text>
            </div>
          )}
        </li>
      ))
    }
  </ol>
</Section>
