---
/**
 * BlogCard - UI Molecule
 *
 * Premium editorial card for blog posts.
 * variant="featured" — three responsive layouts matching editorial mockup:
 *   mobile  (<640px)  : portrait tall, full-bleed image, content overlaid
 *   tablet  (640-1024): stacked split — image top, light content below
 *   desktop (>1024px) : wide cinematic, full-bleed image, content overlaid
 *
 * variant="horizontal" | "vertical" — standard card variants.
 */
import type { CollectionEntry } from "astro:content";
import Image from "../primitives/Image.astro";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Badge from "../primitives/Badge.astro";
import Icon from "../primitives/Icon.astro";
import { calculateReadTime } from "../../scripts/utils/reading-time";

interface Props {
  post: CollectionEntry<"blog">;
  authorData?: {
    name: string;
    avatar?: string;
    bio?: string;
  };
  readMoreLabel?: string;
  variant?: "horizontal" | "vertical" | "featured";
  class?: string;
}

const {
  post,
  authorData,
  readMoreLabel = "Read",
  variant = "horizontal",
  class: className
} = Astro.props;

const { title, excerpt, publishDate, image, author: authorName, category } = post.data;

const readTime = calculateReadTime(post.body || "");

const formattedDate = new Intl.DateTimeFormat('en-IN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
}).format(publishDate);

const postUrl = `/blog/${post.id.replace(/\.[^/.]+$/, "")}`;
const isFeatured = variant === "featured";
const isHorizontal = variant === "horizontal";
---

{isFeatured ? (
  /* ─────────────────────────────────────────────────────────────
     FEATURED VARIANT
     - Mobile  : portrait, image fills card, text overlaid
     - Tablet  : stacked (image top, light content below)
     - Desktop : wide cinematic, image fills card, text overlaid
  ───────────────────────────────────────────────────────────── */
  <article
    class:list={[
      "group relative overflow-hidden rounded-2xl motion-soft bg-(--color-surface)",
      "shadow-xs hover:shadow-sm hover:-translate-y-1",
      "border border-(--color-border-subtle)/40 group-hover:border-(--color-border-subtle)/80",
      /* Responsive Layout: 
         Mobile/Tablet: Portrait Overlay (full width)
         Desktop (lg): Cinematic Billboard with Floating Glass Panel
      */
      "h-[80svh] min-h-[520px] max-h-[800px]",
      "lg:h-[58vh] lg:min-h-[560px] lg:max-h-[680px]",
      className
    ]}
  >
    {/* Clickable surface */}
    <a href={postUrl} class="absolute inset-0 z-30 focus-glow rounded-2xl" aria-label={`Read: ${title}`}></a>

    {/* ── IMAGE LAYER ──────────────────────────────────────────
        Fills entire card.
    ──────────────────────────────────────────────────────── */}
    <div class="overflow-hidden z-0 absolute inset-0">
      <Image
        src={image}
        alt={title}
        class="h-full w-full object-cover motion-soft group-hover:scale-[1.03]"
      />

      {/* Subtle top-down scrim */}
      <div class="absolute inset-0 bg-linear-to-b from-black/20 via-transparent to-transparent" />
      
      {/* Desktop side scrim — helps blend the floating panel if the image is too busy on the left */}
      <div class="absolute inset-y-0 left-0 w-1/3 bg-linear-to-r from-black/20 to-transparent hidden lg:block" />

      {/* Top Left Category Badge */}
      {category && (
        <div class="absolute top-6 left-6 z-10 lg:top-10 lg:left-10">
          <Badge intent="accent" size="xs" class="shadow-sm">
            {category}
          </Badge>
        </div>
      )}
    </div>

    {/* ── OVERLAY CONTENT (Floating Glass Panel Concept) ────────
        Bottom-anchored for mobile/tablet.
        Floating bottom-left panel for desktop (lg).
    ──────────────────────────────────────────────────────── */}
    <div class="absolute inset-0 z-10 flex flex-col justify-end lg:p-10">
      {/* 
          Glass content block:
          - Mobile/Tablet: Full width at bottom
          - Desktop (lg): Floating card, max-width, rounded, offset
      */}
      <div
        class:list={[
          "motion-soft bg-black/40 backdrop-blur-lg",
          "p-6 pb-8 md:p-10 md:pb-12",
          "lg:max-w-2xl lg:rounded-3xl lg:border lg:border-white/10 lg:shadow-2xl",
          "translate-y-1.5 group-hover:translate-y-0"
        ]}
      >
        {/* Eyebrow: Featured Story */}
        <div class="mb-4">
          <Text variant="eyebrow" color="inverse" class="opacity-90">
            Featured Story
          </Text>
        </div>

        <Heading
          as="h2"
          size="h3"
          color="inverse"
          class="mb-4 drop-shadow-sm leading-tight lg:text-3xl"
        >
          {title}
        </Heading>

        <Text
          variant="paragraph"
          color="inverse"
          class="mb-8 opacity-80 line-clamp-3 md:line-clamp-none"
        >
          {excerpt}
        </Text>

        {/* Full width divider below title and excerpt */}
        <div class="h-px w-full bg-white/20 mb-8" />

        {/* Author row */}
        <div class="flex items-center gap-4">
          <div class="h-11 w-11 shrink-0 overflow-hidden rounded-full border border-white/40 shadow-sm bg-white/10">
            <Image
              src={authorData?.avatar || "/images/authors/placeholder.jpg"}
              alt={authorData?.name || authorName}
              class="h-full w-full object-cover"
            />
          </div>
          <div class="flex flex-col">
            <Text variant="label" weight="semibold" color="inverse" class="mb-1 text-base">
              {authorData?.name || authorName}
            </Text>
            <div class="flex items-center gap-2">
              <Text variant="metadata" color="inverse" class="opacity-70">
                {readTime}
              </Text>
              <Text variant="metadata" color="inverse" class="opacity-40 select-none">·</Text>
              <Text variant="metadata" color="inverse" class="opacity-70">
                {formattedDate}
              </Text>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* ── TABLET CONTENT (DEPRECATED) ──────────────────────────
        Hidden across all breakpoints as overlay look is unified.
    ──────────────────────────────────────────────────────── */}
    <div class="hidden flex-col p-7 pb-8">

      <Heading
        as="h2"
        size="h2"
        class="mb-5 leading-[1.2] line-clamp-3 group-hover:text-(--color-primary) transition-colors duration-500"
      >
        {title}
      </Heading>

      {/* Metadata row: WORDS BY · Date · Read time */}
      <div class="flex items-center gap-2 flex-wrap mt-auto pt-5 border-t border-(--color-border-subtle)/30">
        <Text variant="metadata" color="muted" class="tracking-[0.2em] opacity-60">
          Words by
        </Text>
        <div class="flex items-center gap-2">
          <div class="h-6 w-6 shrink-0 overflow-hidden rounded-full border border-(--color-border-subtle)">
            <Image
              src={authorData?.avatar || "/images/authors/placeholder.jpg"}
              alt={authorData?.name || authorName}
              class="h-full w-full object-cover"
            />
          </div>
          <Text variant="label" weight="semibold" class="text-xs">
            {authorData?.name || authorName}
          </Text>
        </div>
        <Text variant="metadata" color="muted" class="opacity-40 select-none">·</Text>
        <Text variant="metadata" color="muted" class="tracking-[0.12em] opacity-60">
          {formattedDate}
        </Text>
        <Text variant="metadata" color="muted" class="opacity-40 select-none">·</Text>
        <div class="flex items-center gap-1 text-(--color-text-muted) opacity-60">
          <Icon name="PhClock" class="h-3 w-3 shrink-0" />
          <Text variant="metadata" class="tracking-[0.12em]">
            {readTime}
          </Text>
        </div>
      </div>
    </div>

  </article>

) : (
  /* ─────────────────────────────────────────────────────────────
     STANDARD VARIANTS: horizontal | vertical
  ───────────────────────────────────────────────────────────── */
  <article
    class:list={[
      "group relative flex motion-soft",
      "bg-(--color-surface) rounded-2xl h-full",
      "shadow-xs hover:shadow-sm hover:-translate-y-1",
      className
    ]}
  >
    {/* Clickable surface */}
    <a href={postUrl} class="absolute inset-0 z-30 focus-glow rounded-2xl" aria-label={`Read more about ${title}`}></a>

    {/* Layout wrapper */}
    <div
      class:list={[
        "relative z-10 flex-1 flex rounded-2xl overflow-hidden motion-soft",
        "border border-(--color-border-subtle)/40 group-hover:border-(--color-border-subtle)/80",
        isHorizontal ? "flex-col md:flex-row" : "flex-col"
      ]}
    >

      {/* 1. IMAGE SECTION */}
      <div
        class:list={[
          "relative overflow-hidden shrink-0 bg-(--color-surface-muted) self-stretch",
          isHorizontal
            ? "w-full md:w-[42%] rounded-t-2xl md:rounded-l-2xl md:rounded-tr-none min-h-[220px] md:aspect-[16/10]"
            : "w-full aspect-[16/10] rounded-t-2xl"
        ]}
      >
        <div class="absolute inset-0 z-10 pointer-events-none bg-linear-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
        <div class="absolute inset-0">
          <Image src={image} alt={title} class="h-full w-full object-cover motion-soft group-hover:scale-[1.04]" />
        </div>

        {category && (
          <div
            class:list={[
              "absolute z-10 top-4 left-4 sm:top-5 sm:left-5",
              isHorizontal ? "md:hidden" : ""
            ]}
          >
            <Badge intent="surface" size="xs" class="shadow-xs backdrop-blur-md font-bold">{category}</Badge>
          </div>
        )}

        <div class="absolute bottom-5 right-5 z-20 translate-y-4 opacity-0 transition-all duration-500 ease-out group-hover:translate-y-0 group-hover:opacity-100 hidden md:block">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-(--color-background) text-(--color-primary) shadow-sm border border-(--color-background)/50">
            <Icon name="PhArrowRight" class="h-5 w-5" />
          </div>
        </div>
      </div>

      {/* 2. CONTENT SECTION */}
      <div
        class:list={[
          "flex flex-1 flex-col p-5 sm:p-7 lg:p-10",
          isHorizontal ? "rounded-b-2xl md:rounded-r-2xl md:rounded-bl-none" : "rounded-b-2xl"
        ]}
      >
        <div class="flex items-center justify-between mb-4">
          {isHorizontal && category && (
            <div class="hidden md:block">
              <Badge intent="surface" size="xs" class="bg-(--color-surface-muted) border-(--color-border-subtle)/50 font-bold">{category}</Badge>
            </div>
          )}
          <Text variant="metadata" color="muted" class="opacity-60">
            {formattedDate}
          </Text>
        </div>

        <Heading as="h3" size={isHorizontal ? "h3" : "h4"} class="mb-4 transition-colors duration-500 group-hover:text-(--color-primary) leading-tight line-clamp-2">
          {title}
        </Heading>

        <Text
          variant="paragraph"
          color="muted"
          class:list={[
            "mb-8 text-sm leading-relaxed max-w-prose opacity-80 group-hover:opacity-100 transition-opacity",
            isHorizontal ? "line-clamp-3" : "line-clamp-2"
          ]}
        >
          {excerpt}
        </Text>

        {/* Footer: author + read time */}
        <div class="mt-auto flex items-center justify-between pt-6 border-t border-(--color-border-subtle)/30">
          <div class="flex items-center gap-3">
            {/* Avatar — static, no hover scale */}
            <div class="h-9 w-9 shrink-0 overflow-hidden rounded-full border border-(--color-border-subtle) bg-(--color-surface-muted) ring-2 ring-white ring-offset-2 ring-offset-(--color-surface-muted)/10 shadow-xs">
              <Image
                src={authorData?.avatar || "/images/authors/placeholder.jpg"}
                alt={authorData?.name || authorName}
                class="h-full w-full object-cover"
              />
            </div>
            <div class="flex flex-col">
              <Text variant="label" weight="semibold" color="main" class="text-xs leading-none mb-1">
                {authorData?.name || authorName}
              </Text>
              <Text variant="metadata" class="text-[9px] opacity-50 uppercase tracking-wider">{readTime}</Text>
            </div>
          </div>

          <div class="md:hidden flex items-center gap-1 text-(--color-primary)">
            <Text variant="label" weight="bold" class="text-[10px] uppercase tracking-widest">{readMoreLabel}</Text>
            <Icon name="PhArrowRight" class="h-3 w-3" />
          </div>
        </div>
      </div>

    </div>
  </article>
)}
