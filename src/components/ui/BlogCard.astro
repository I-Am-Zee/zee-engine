---
/**
 * BlogCard - UI Molecule
 * 
 * Premium card for blog posts.
 * Consistent with GlassProductCard design system.
 */
import Image from "../primitives/Image.astro";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Icon from "../primitives/Icon.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  class?: string;
}

const { post, class: className } = Astro.props;
const { title, excerpt, publishDate, image, author } = post.data;

const formattedDate = new Intl.DateTimeFormat('en-IN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(publishDate);
---

<article class:list={["group relative flex flex-col overflow-hidden rounded-2xl bg-surface border border-border-subtle/50 transition-all duration-500 hover:shadow-xl hover:border-border-subtle hover:-translate-y-1", className]}>
  {/* Link Wrapper */}
  <a href={`/blog/${post.id.replace(/\.[^/.]+$/, "")}`} class="absolute inset-0 z-20" aria-label={`Read more about ${title}`}></a>

  {/* Image Container */}
  <div class="relative aspect-video overflow-hidden">
    <Image 
      src={image} 
      alt={title}
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-linear-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  </div>

  {/* Content Container */}
  <div class="flex flex-1 flex-col p-6 sm:p-8">
    {/* Meta */}
    <div class="mb-4 flex items-center gap-4 text-xs font-medium tracking-wider uppercase text-text-muted">
      <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      <span class="h-1 w-1 rounded-full bg-border-subtle"></span>
      <span>{author}</span>
    </div>

    {/* Title */}
    <Heading as="h3" size="h4" class="mb-3 line-clamp-2 transition-colors group-hover:text-primary">
      {title}
    </Heading>

    {/* Excerpt */}
    <Text variant="paragraph" color="muted" class="mb-6 line-clamp-2">
      {excerpt}
    </Text>

    {/* Read More Link (Visual Only) */}
    <div class="mt-auto flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-text-main group-hover:text-primary transition-colors">
      <span>Read Article</span>
      <Icon name="PhArrowRight" size={14} class="transition-transform duration-300 group-hover:translate-x-1" />
    </div>
  </div>
</article>
