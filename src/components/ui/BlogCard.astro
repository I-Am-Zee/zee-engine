---
/**
 * BlogCard - UI Molecule
 * 
 * Premium editorial card for blog posts.
 * Consistent with GlassProductCard design system.
 */
import type { CollectionEntry } from "astro:content";
import Image from "../primitives/Image.astro";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Badge from "../primitives/Badge.astro";
import Icon from "../primitives/Icon.astro";
import { calculateReadTime } from "../../scripts/utils/reading-time";

interface Props {
  post: CollectionEntry<"blog">;
  authorData?: {
    name: string;
    avatar?: string;
    bio?: string;
  };
  readMoreLabel?: string;
  variant?: "horizontal" | "vertical";
  class?: string;
}

const { 
  post, 
  authorData, 
  readMoreLabel = "Read",
  variant = "horizontal", 
  class: className 
} = Astro.props;

const { title, excerpt, publishDate, image, author: authorName, category } = post.data;

const readTime = calculateReadTime(post.body || "");

const formattedDate = new Intl.DateTimeFormat('en-IN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
}).format(publishDate);

const postUrl = `/blog/${post.id.replace(/\.[^/.]+$/, "")}`;
const isHorizontal = variant === "horizontal";
---

<article 
  class:list={[
    "group relative flex motion-soft",
    "bg-surface rounded-2xl h-full",
    "shadow-xs",
    "hover:shadow-[0_8px_30px_rgba(0,0,0,0.08)] hover:-translate-y-1",
    className
  ]}
>
  {/* The clickable surface MUST be top-level to cover everything */}
  <a href={postUrl} class="absolute inset-0 z-30 focus-glow rounded-2xl" aria-label={`Read more about ${title}`}></a>
 
  {/* CONTENT LAYER - Unified layout wrapper */}
  <div class:list={[
    "relative z-10 flex-1 flex rounded-2xl overflow-hidden motion-soft",
    "border border-(--color-border-subtle)/40",
    "group-hover:border-(--color-border-subtle)/80",
    isHorizontal ? "flex-col md:flex-row" : "flex-col"
  ]}>
    
    {/* 1. IMAGE SECTION */}
    <div class:list={[
      "relative overflow-hidden shrink-0 bg-surface-muted self-stretch",
      isHorizontal 
        ? "w-full md:w-[45%] rounded-t-2xl md:rounded-l-2xl md:rounded-tr-none min-h-[280px]" 
        : "w-full aspect-[16/10] rounded-t-2xl"
    ]}>
      {/* Subtle overlay to enhance image contrast on light modes */}
      <div class="absolute inset-0 z-10 pointer-events-none bg-linear-to-t from-black/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      
      <div class="absolute inset-0">
        <Image 
          src={image} 
          alt={title}
          class="h-full w-full object-cover motion-soft group-hover:scale-[1.04]"
        />
      </div>
      
      {/* Category Overlay for Vertical or Mobile Horizontal */}
      {category && (
        <div class:list={[
          "absolute z-10 top-5 left-5",
          isHorizontal ? "md:hidden" : ""
        ]}>
          <Badge intent="surface" size="xs" class="shadow-xs backdrop-blur-md bg-white/80! border-white/40!">{category}</Badge>
        </div>
      )}

      {/* Floating Read Post Indicator */}
      <div class="absolute bottom-5 right-5 z-20 translate-y-4 opacity-0 transition-all duration-500 ease-out group-hover:translate-y-0 group-hover:opacity-100 hidden md:block">
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white text-primary shadow-xl border border-white/50">
          <Icon name="PhArrowRight" class="h-5 w-5" />
        </div>
      </div>
    </div>

    {/* 2. CONTENT SECTION */}
    <div class:list={[
      "flex flex-1 flex-col p-6 sm:p-8 lg:p-10",
      isHorizontal 
        ? "rounded-b-2xl md:rounded-r-2xl md:rounded-bl-none" 
        : "rounded-b-2xl"
    ]}>
      {/* Header Info */}
      <div class="flex items-center justify-between mb-4">
        {isHorizontal && category && (
          <div class="hidden md:block">
            <Badge intent="surface" size="xs" class="bg-surface-muted! border-border-subtle/50!">{category}</Badge>
          </div>
        )}
        <Text variant="metadata" color="muted" class="text-[10px] font-bold tracking-[0.2em] uppercase opacity-60">
          {formattedDate}
        </Text>
      </div>

      {/* Title */}
      <Heading 
        as="h3" 
        size={isHorizontal ? "h3" : "h4"} 
        class="mb-4 transition-colors duration-500 group-hover:text-primary leading-tight line-clamp-2"
      >
        {title}
      </Heading>

      {/* Excerpt */}
      <Text variant="paragraph" color="muted" class="mb-8 line-clamp-3 text-sm leading-relaxed max-w-prose opacity-80 group-hover:opacity-100 transition-opacity">
        {excerpt}
      </Text>

      {/* Footer Info: Author & Read Time */}
      <div class="mt-auto flex items-center justify-between pt-6 border-t border-(--color-border-subtle)/30">
        <div class="flex items-center gap-3">
          {/* Author Avatar with Ring */}
          <div class="h-9 w-9 shrink-0 overflow-hidden rounded-full border border-(--color-border-subtle) bg-surface-muted ring-2 ring-white ring-offset-2 ring-offset-surface-muted/10 shadow-xs">
            <Image 
              src={authorData?.avatar || "/images/authors/placeholder.jpg"} 
              alt={authorData?.name || authorName}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
          </div>
          <div class="flex flex-col">
            <Text variant="label" weight="semibold" color="main" class="text-xs leading-none mb-1">{authorData?.name || authorName}</Text>
            <Text variant="metadata" class="text-[9px] opacity-50 uppercase tracking-wider">{readTime}</Text>
          </div>
        </div>

        {/* Mobile Read More Link */}
        <div class="md:hidden flex items-center gap-1 text-primary">
          <Text variant="label" weight="bold" class="text-[10px] uppercase tracking-widest">{readMoreLabel}</Text>
          <Icon name="PhArrowRight" class="h-3 w-3" />
        </div>
      </div>
    </div>
  </div>
</article>
