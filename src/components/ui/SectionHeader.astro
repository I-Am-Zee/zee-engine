---
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Link from "../primitives/Link.astro";

interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  class?: string;
  actionLabel?: string;
  linkUrl?: string;
}

const { title, subtitle, align = "center", class: className = "", actionLabel, linkUrl } = Astro.props;
---

<div class:list={["mb-6 md:mb-8", className]}>
  <div class:list={["flex flex-col gap-6", align === "center" ? "items-center text-center" : "md:flex-row md:items-center md:justify-between text-left"]}>
    <div class:list={["flex flex-col flex-1", align === "center" ? "items-center" : "items-start"]}>
      <Heading as="h2" class="mb-2 md:mb-3">
        {title}
      </Heading>
      {subtitle && (
        <Text variant="caption" color="muted" italic class:list={["max-w-[45rem]", align === "center" ? "mx-auto" : ""]}>
          {subtitle}
        </Text>
      )}
      <slot />
    </div>
    
    {(Astro.slots.has("action") || (actionLabel && linkUrl)) && (
      <div class:list={["w-full md:w-auto", align === "center" ? "mt-4" : ""]}>
        {Astro.slots.has("action") ? (
          <slot name="action" />
        ) : (
          /* Premium Standard Link Style */
          <Link href={linkUrl!} class="group flex items-center gap-2">
            <Text variant="label" weight="semibold" class="group-hover:text-(--color-accent) transition-colors">
              {actionLabel}
            </Text>
            <span class="group-hover:translate-x-2 transition-transform inline-block text-xs">&rarr;</span>
          </Link>
        )}
      </div>
    )}
  </div>
</div>
