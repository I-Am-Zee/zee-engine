---
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";

interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  class?: string;
}

const { title, subtitle, align = "center", class: className = "" } = Astro.props;
---

<div class:list={["mb-6 md:mb-8", className]}>
  <div class:list={["flex flex-col gap-6", align === "center" ? "items-center text-center" : "md:flex-row md:items-end md:justify-between text-left"]}>
    <div class:list={["flex flex-col flex-1", align === "center" ? "items-center" : "items-start"]}>
      <Heading as="h2" class="mb-2 md:mb-3">
        {title}
      </Heading>
      {subtitle && (
        <Text class:list={["max-w-3xl italic text-text-muted text-sm md:text-base", align === "center" ? "mx-auto" : ""]}>
          {subtitle}
        </Text>
      )}
      <slot />
    </div>
    
    {Astro.slots.has("action") && (
      <div class:list={["w-full md:w-auto", align === "center" ? "mt-4" : ""]}>
        <slot name="action" />
      </div>
    )}
  </div>
</div>
