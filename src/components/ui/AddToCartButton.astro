---
/**
 * AddToCartButton - UI Molecule
 *
 * Snipcart-powered add to cart button built on Button primitive.
 * Supports object-based variant slots with dynamic custom fields.
 *
 * @component Molecule (ui/)
 * @uses Button (primitive)
 * @uses Icon (primitive)
 */

import { getSnipcartHTMLAttrs } from "../../config/ecommerce";
import { getEntry } from "astro:content";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
import Text from "../primitives/Text.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  product: CollectionEntry<"products">; // Raw product object
  variant?: "primary" | "secondary" | "neutral";
  size?: "sm" | "md" | "lg";
  showIcon?: boolean;
  class?: string;
  disabled?: boolean;
}

const {
  product,
  variant = "primary",
  size = "md",
  showIcon = true,
  class: className,
  disabled = false,
  ...rest
} = Astro.props;

// Fetch HSN from brand settings
const brandEntry = await getEntry("settings", "brand");
const hsnCode = brandEntry?.data?.tax_hsn_code || "0000";

// Build standardized Snipcart attributes using SSOT logic
const snipcartAttributes = getSnipcartHTMLAttrs(product, hsnCode);
---

<Button
  type={variant}
  size={size}
  variant={showIcon ? "icon-left" : "default"}
  class:list={["snipcart-add-item", className]}
  disabled={disabled}
  {...snipcartAttributes}
  {...rest}
>
  {showIcon && <Icon name="PhShoppingCart" size={size === "sm" ? 16 : size === "lg" ? 20 : 18} />}
  <Text variant="label" color="inherit">
    <slot>Add to Cart</slot>
  </Text>
</Button>
