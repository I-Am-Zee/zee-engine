---
/**
 * AddToCartButton - UI Molecule
 *
 * Snipcart-powered add to cart button built on Button primitive.
 * Supports object-based variant slots with dynamic custom fields.
 *
 * @component Molecule (ui/)
 * @uses Button (primitive)
 * @uses Icon (primitive)
 */

import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
import Text from "../primitives/Text.astro";
import { siteConfig } from "../../lib/site.config";

interface VariantSlot {
  name: string;
  values: string; // Comma-separated
  price_modifiers?: string;
  is_checkbox?: boolean;
}

interface Props {
  product: any; // Product collection entry from getCollection('products')
  variant?: "primary" | "secondary" | "neutral";
  size?: "sm" | "md" | "lg";
  showIcon?: boolean;
  class?: string;
  disabled?: boolean;
}

const {
  product,
  variant = "primary",
  size = "md",
  showIcon = true,
  class: className,
  disabled = false,
} = Astro.props;

// Snipcart product URL validation: Use relative URL to support multiple environments
const productUrl = `/products/${product.slug}`;

// Build Snipcart custom fields from object-based variant slots
const buildVariantAttributes = () => {
  const attrs: Record<string, string> = {};
  let customIndex = 1;

  // Helper to process a variant slot
  const processVariant = (slot: VariantSlot | undefined) => {
    if (!slot?.name || !slot?.values) return;

    const optionName = slot.name;
    // Convert comma-separated values to pipe-separated for Snipcart
    const optionValues = slot.values
      .split(",")
      .map((v) => v.trim())
      .join("|");

    attrs[`data-item-custom${customIndex}-name`] = optionName;
    attrs[`data-item-custom${customIndex}-options`] = optionValues;

    // If checkbox type, mark as optional (not required)
    if (slot.is_checkbox) {
      attrs[`data-item-custom${customIndex}-required`] = "false";
    }

    customIndex++;
  };

  // Process each variant slot
  processVariant(product.data.variant_1);
  processVariant(product.data.variant_2);
  processVariant(product.data.variant_3);

  return attrs;
};

// Build data attributes object
const snipcartAttributes = {
  "data-item-id": product.slug,
  "data-item-name": product.data.title,
  "data-item-price": product.data.salePrice || product.data.price,
  "data-item-url": productUrl,
  "data-item-description": product.data.description,
  "data-item-image": product.data.image,
  ...(product.data.weight && { "data-item-weight": product.data.weight }),
  ...(product.data.sku && { "data-item-sku": product.data.sku }),
  // Dynamic variant fields from slots
  ...buildVariantAttributes(),
};
---

<Button
  type={variant}
  size={size}
  variant={showIcon ? "icon-left" : "default"}
  class:list={["snipcart-add-item", className]}
  disabled={disabled}
  {...snipcartAttributes}
>
  {showIcon && <Icon name="PhShoppingCart" size={size === "sm" ? 16 : size === "lg" ? 20 : 18} />}
  <Text variant="label" color="inherit">
    <slot>Add to Cart</slot>
  </Text>
</Button>
