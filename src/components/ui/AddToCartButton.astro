---
/**
 * AddToCartButton - UI Molecule
 *
 * Snipcart-powered add to cart button built on Button primitive.
 * Automatically generates data attributes for Snipcart from product data.
 *
 * @component Molecule (ui/)
 * @uses Button (primitive)
 * @uses Icon (primitive)
 */

import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
import { siteConfig } from "../../lib/site.config";

interface Props {
  product: any; // Product collection entry from getCollection('products')
  variant?: "primary" | "secondary" | "neutral";
  size?: "sm" | "md" | "lg";
  showIcon?: boolean;
  class?: string;
}

const {
  product,
  variant = "primary",
  size = "md",
  showIcon = true,
  class: className,
} = Astro.props;

// Snipcart product URL validation: Use PRODUCTION URL from site config
// Snipcart crawls the production site to verify prices, so we MUST use the production URL.
// For Draft deploys: Add "*.netlify.app" to Snipcart Dashboard > Domains & URLs
const productUrl = new URL(Astro.url.pathname, siteConfig.url).toString();

// Format options for Snipcart (e.g., "6|7|8|9")
const formatOptions = (options: { name: string; values: string[] }[]) => {
  if (!options || options.length === 0) return null;
  return options[0].values.join("|");
};

// Build data attributes object
const snipcartAttributes = {
  "data-item-id": product.slug,
  "data-item-name": product.data.title,
  "data-item-price": product.data.salePrice || product.data.price,
  "data-item-url": productUrl,
  "data-item-description": product.data.description,
  "data-item-image": product.data.image,
  ...(product.data.weight && { "data-item-weight": product.data.weight }),
  ...(product.data.sku && { "data-item-sku": product.data.sku }),
  // Note: data-item-quantity is NOT set here - Snipcart defaults to 1
  // To support quantity picker, we'd need JavaScript to update this dynamically
  ...(product.data.taxable !== undefined && { "data-item-taxable": product.data.taxable }),
  // Custom fields (product options)
  ...(product.data.options &&
    product.data.options[0] && {
      "data-item-custom1-name": product.data.options[0].name,
      "data-item-custom1-options": formatOptions(product.data.options),
    }),
};
---

<Button
  type={variant}
  size={size}
  variant={showIcon ? "icon-left" : "default"}
  class:list={["snipcart-add-item", className]}
  {...snipcartAttributes}
>
  {showIcon && <Icon name="PhShoppingCart" size={size === "sm" ? 16 : size === "lg" ? 20 : 18} />}
  <slot>Add to Cart</slot>
</Button>
