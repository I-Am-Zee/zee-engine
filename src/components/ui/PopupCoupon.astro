---
import Modal from "../primitives/Modal.astro";
import CopyButton from '../ui/CopyButton.astro';
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Button from "../primitives/Button.astro";
import Image from "../primitives/Image.astro";

interface Props {
  data: {
    enabled?: boolean;
    title: string;
    description: string;
    image?: string;
    coupon_code: string;
    cta_text?: string;
    denylist?: string[];
  };
}

const { data } = Astro.props;
if (!data?.enabled || !data?.coupon_code) return null;

const config = {
  id: 'discount',
  trigger: data.trigger || 'timed',
  delay_seconds: data.delay_seconds,
  denylist: data.denylist,
  couponCode: data.coupon_code
};
---

<Modal
  id={`popupBehavior(${JSON.stringify(config)})`}
  isOpen="open"
  onClose="closePopup()"
>
  <div class="flex flex-col md:flex-row h-full">
    {data.image && (
      <div class="w-full md:w-2/5 h-48 md:h-auto relative bg-gray-100">
        <Image src={data.image} alt="" class="absolute inset-0 w-full h-full object-cover" />
      </div>
    )}

    <div class="w-full p-6 md:p-8 flex flex-col justify-center" class:list={[data.image ? 'md:w-3/5' : 'md:w-full']}>
      <Heading as="h3" class="mb-2">{data.title}</Heading>
      <Text variant="caption" color="muted" class="mb-6 leading-relaxed">{data.description}</Text>

      <div class="bg-gray-50 border border-gray-200 rounded p-3 mb-6 flex items-center justify-between">
        <Text as="code" variant="code" weight="bold" class="text-lg tracking-widest text-gray-900">{data.coupon_code}</Text>
        <CopyButton text={data.coupon_code} class="underline" />
      </div>

      <Button
        type="primary"
        @click="applyCoupon()"
        class="w-full py-4 uppercase tracking-widest"
      >
        <Text variant="label" color="inverse">
          {data.cta_text || 'Claim My Discount'}
        </Text>
      </Button>
    </div>
  </div>
</Modal>
