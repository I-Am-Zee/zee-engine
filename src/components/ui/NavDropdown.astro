---
/**
 * NavDropdown - Desktop navigation dropdown
 * Shows sub-links when hovering over parent nav item
 */

import Icon from "../primitives/Icon.astro";
import Text from "../primitives/Text.astro";
import type { NavItem } from "../../config/navigation";

interface Props {
  trigger: string;
  items: NavItem[];
  class?: string;
}

const { trigger, items, class: className, ...rest } = Astro.props;
---

<div
  class:list={["relative", className]}
  x-data="{ isOpen: false }"
  @mouseenter="isOpen = true"
  @mouseleave="isOpen = false"
  {...rest}
>
  {/* Trigger button */}
  <button
    type="button"
    class="inline-flex items-center gap-1 rounded-md px-3 py-2 transition-all duration-200 hover:text-(--color-text-muted) focus-glow outline-none"
    @click="isOpen = !isOpen"
    :aria-expanded="isOpen"
  >
    <Text variant="label" color="inherit">
      {trigger}
    </Text>
    <Icon
      name="PhCaretDown"
      class="h-4 w-4 transition-transform duration-200"
      x-bind:class="isOpen ? 'rotate-180' : ''"
    />
  </button>

  {/* Dropdown panel */}
  <div
    x-show="isOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 translate-y-1"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 translate-y-1"
    class="absolute top-full left-0 z-50 mt-1 min-w-[180px] rounded-lg border border-(--color-border-subtle) bg-(--color-background) p-2 shadow-lg"
    x-cloak
  >
    {
      items.map((item) => (
        <a
          href={item.href}
          class="block rounded-md px-3 py-2 transition-colors duration-150 hover:bg-(--color-surface)"
        >
          <Text variant="paragraph" color="inherit">
            {item.label}
          </Text>
        </a>
      ))
    }
  </div>
</div>
