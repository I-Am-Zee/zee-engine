---
/**
 * NavDropdown - Desktop navigation dropdown
 */

import Icon from "../primitives/Icon.astro";
import Text from "../primitives/Text.astro";
import type { NavItem } from "../../types/navigation";

interface Props {
  trigger: string;
  items: NavItem[];
  class?: string;
  dark?: boolean;
}

const { trigger, items, class: className, dark = false, ...rest } = Astro.props;
---

<div
  class:list={["relative", className]}
  x-data="{ isOpen: false }"
  @mouseenter="isOpen = true"
  @mouseleave="isOpen = false"
  {...rest}
>
  <button
    type="button"
    class:list={[
      "inline-flex items-center gap-1 rounded-md px-3 py-2 transition-all duration-200 focus-glow outline-none cursor-pointer disabled:cursor-not-allowed",
      dark ? "text-white hover:text-white/70" : "text-(--color-text-main) hover:text-(--color-text-muted)"
    ]}
    @click="isOpen = !isOpen"
    :aria-expanded="isOpen"
  >
    <Text variant="label" color="inherit">
      {trigger}
    </Text>
    <Icon
      name="PhCaretDown"
      class="h-4 w-4 transition-transform duration-200"
      x-bind:class="isOpen ? 'rotate-180' : ''"
    />
  </button>

  <div
    x-show="isOpen"
    x-transition:enter="transition ease-out duration-300 transform"
    x-transition:enter-start="opacity-0 scale-95 -translate-y-2"
    x-transition:enter-end="opacity-100 scale-100 translate-y-0"
    x-transition:leave="transition ease-in duration-200 transform"
    x-transition:leave-start="opacity-100 scale-100 translate-y-0"
    x-transition:leave-end="opacity-0 scale-95 -translate-y-2"
    class:list={[
      "absolute top-full left-0 mt-1 min-w-[200px] rounded-xl border p-2 shadow-2xl z-[60]",
      dark ? "bg-(--color-primary) border-white/10 text-white" : "bg-background border-border-subtle/60 text-(--color-text-main)"
    ]}
    x-cloak
  >
    {
      items.map((ddItem) => (
        <a
          href={ddItem.href}
          class:list={[
            "block rounded-md px-3 py-2 transition-colors duration-150",
            dark ? "hover:bg-white/5" : "hover:bg-surface"
          ]}
        >
          <Text variant="caption" color="inherit">
            {ddItem.label}
          </Text>
        </a>
      ))
    }
  </div>
</div>
