---
import Modal from "../primitives/Modal.astro";
import NewsletterWidget from "../features/NewsletterWidget.astro";

interface Props {
  data: {
    enabled?: boolean;
    title: string;
    description: string;
    image?: string;
    denylist?: string[];
  };
}

const { data } = Astro.props;
if (!data?.enabled) return null;

const config = {
  id: 'newsletter',
  trigger: data.trigger || 'exit',
  delay_seconds: data.delay_seconds,
  denylist: data.denylist
};
---

<Modal
  id={`popupBehavior(${JSON.stringify(config)})`}
  isOpen="open"
  onClose="closePopup()"
  maxWidth="max-w-2xl"
>
  <NewsletterWidget variant="modal" class="p-0 border-none rounded-none" />
</Modal>
