---
/**
 * CompleteTheLook - UI Molecule
 *
 * Displays CMS-controlled related products as upsells.
 * Uses atomic design components for consistency.
 *
 * @component Molecule (ui/)
 */

import { getCollection } from "astro:content";
import GlassProductCard from "./GlassProductCard.astro";
import ProductGrid from "../features/ProductGrid.astro";
import ProductCarousel from "../features/ProductCarousel.astro";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import BuySetButton from "../features/BuySetButton.astro";
import SectionHeader from "./SectionHeader.astro";

interface Props {
  productSlugs: string[];
  currentProduct?: {
    id: string;
    title: string;
    price: number;
    salePrice?: number;
    image: string;
  };
  class?: string;
}

const { productSlugs, currentProduct, class: className } = Astro.props;

// Get all products and filter by slugs
const allProducts = await getCollection("products");
const relatedProducts = productSlugs
  .map((slug) => allProducts.find((p) => p.slug === slug))
  .filter((p): p is NonNullable<typeof p> => !!p)
  .slice(0, 4); // Max 4 products

// Transform for BuySetButton (needs id, title, price, salePrice, image)
const productsForButton = [
  // CRITICAL: Include the MAIN product first (what user came to view)
  ...(() => {
    if (!currentProduct) return [];
    const p = allProducts.find((item) => item.slug === currentProduct.id);
    return [
      {
        ...currentProduct,
        description: p?.data?.description,
        variant_1: p?.data?.variant_1,
        variant_2: p?.data?.variant_2,
        variant_3: p?.data?.variant_3,
        weight: p?.data?.weight,
        shipping_slab: p?.data?.shipping_slab,
      },
    ];
  })(),
  // Then add the related products (to complete the look)
  ...relatedProducts.map((p: any) => ({
    id: p.slug,
    title: p.data.title,
    price: p.data.price,
    salePrice: p.data.salePrice,
    image: p.data.image,
    description: p.data.description,
    variant_1: p.data.variant_1,
    variant_2: p.data.variant_2,
    variant_3: p.data.variant_3,
    weight: p.data.weight,
    shipping_slab: p.data.shipping_slab,
  })),
];
---

{
  relatedProducts.length > 0 && (
    <section 
      class:list={["mt-12 md:mt-16 border-t border-(--color-border-subtle) pt-12 md:pt-16 pb-8 md:pb-12", className]}
      id="perfect-pairings"
    >
      <script is:inline define:vars={{ 
        relatedItems: productsForButton.slice(1)
      }}>
        // Expose related products for the Upsell Drawer with relative URLs
        // This ensures Snipcart's crawler resolves them against the CURRENT origin (tunnel, dev, or production)
        window.ZELIA_UPSELL_CONTEXT = relatedItems.map(item => ({
          ...item,
          url: `/products/${item.id}`
        }));
      </script>

      <SectionHeader 
        title="Perfect Pairings" 
        subtitle="Curated pieces to elevate your ensemble"
        align="left"
        class="mb-8 lg:mb-12"
      >
        <span class="text-text-muted capitalize tracking-widest text-xs mt-2 font-bold block">
          {productsForButton.length} Items Total
        </span>
        <Fragment slot="action">
          <BuySetButton products={productsForButton} class="w-full" hideSavingsText={true} />
        </Fragment>
      </SectionHeader>

      <ProductCarousel products={relatedProducts} columns={4} />
    </section>
  )
}
