---
/**
 * NewsletterForm - Email subscription form
 * Responsive layout: side-by-side on desktop, stacked on mobile
 */

import Input from "../primitives/Input.astro";
import Button from "../primitives/Button.astro";
import Text from "../primitives/Text.astro";

interface Props {
  id?: string;
  placeholder?: string;
  buttonText?: string;
  layout?: 'row' | 'col';
  class?: string;
}

const { 
  placeholder = "Your email...", 
  buttonText = "Subscribe", 
  layout = 'row',
  class: className, 
  ...rest 
} = Astro.props;
---

<form
  x-data="newsletterWidget()"
  @submit.prevent="submitForm"
  class:list={[
    "flex gap-3",
    layout === 'row' ? "flex-col sm:flex-row items-stretch sm:items-start" : "flex-col",
    className
  ]}
  {...rest}
>
  <div class="flex-1 flex flex-col gap-1">
    <Input
      id="newsletter-email"
      type="email"
      name="email"
      placeholder={placeholder}
      x-model="email"
      @input="hideEmailError"
      @blur="validateEmail"
      class="w-full h-11"
    />
    <p 
      data-email-error 
      class="text-xs text-red-500 font-medium"
      x-show="emailError"
      x-cloak
    >
      Enter valid Gmail address
    </p>
    <p 
      class="text-xs text-red-500 font-medium"
      x-show="formError"
      x-cloak
    >
      Failed to subscribe. Try again.
    </p>
  </div>
  <Button type="primary" class="h-11" :disabled="isSubmitting">
    <Text variant="label" color="inverse" x-text="submitLabel">{buttonText}</Text>
  </Button>
</form>

