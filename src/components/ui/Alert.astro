---
import Text from "../primitives/Text.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  intent?: "info" | "warning" | "success";
  title?: string;
  class?: string;
}

const { intent = "info", title, class: className, ...rest } = Astro.props;

// Intent styles for background and border
const intentStyles = {
  info: "bg-[var(--color-surface)] border-[var(--color-border-subtle)]",
  warning: "bg-amber-50 border-amber-200",
  success: "bg-green-50 border-green-200",
};

// Intent icon mapping (Phosphor names with Ph prefix)
const intentIcons = {
  info: "PhInfo",
  warning: "PhWarning",
  success: "PhCheck",
} as const;

// Intent text colors
const intentTextColors = {
  info: "text-[var(--color-text-main)]",
  warning: "text-amber-800",
  success: "text-green-800",
};
---

<div
  class:list={["flex items-start gap-3 rounded-lg border p-4", intentStyles[intent], className]}
  role="alert"
  {...rest}
>
  <Icon name={intentIcons[intent]} class:list={["mt-0.5 shrink-0", intentTextColors[intent]]} />
  <div class="flex-1">
    {
      title && (
        <Text as="span" class:list={["font-medium", intentTextColors[intent]]}>
          {title}
        </Text>
      )
    }
    <div class:list={[intentTextColors[intent], title ? "mt-1" : ""]}>
      <slot />
    </div>
  </div>
</div>
