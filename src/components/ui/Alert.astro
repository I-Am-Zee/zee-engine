---
import Text from "../primitives/Text.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  intent?: "info" | "warning" | "success";
  title?: string;
  class?: string;
}

const { intent = "info", title, class: className, ...rest } = Astro.props;

// Intent styles for background and border
const intentStyles = {
  info: "bg-surface border-border-subtle",
  warning: "bg-accent-amber/10 border-accent-amber/20",
  success: "bg-(--color-success)/10 border-(--color-success)/20",
};

// Intent icon mapping (Phosphor names with Ph prefix)
const intentIcons = {
  info: "PhInfo",
  warning: "PhWarning",
  success: "PhCheck",
} as const;

// Intent text colors
const intentTextColors = {
  info: "text-text-main",
  warning: "text-accent-amber",
  success: "text-(--color-success)",
};
---

<div
  class:list={["flex items-start gap-3 rounded-lg border p-4", intentStyles[intent], className]}
  role="alert"
  {...rest}
>
  <Icon name={intentIcons[intent]} class:list={["mt-0.5 shrink-0", intentTextColors[intent]]} />
  <div class="flex-1">
    {
      title && (
        <Text as="span" variant="paragraph" weight="medium" class={intentTextColors[intent]}>
          {title}
        </Text>
      )
    }
    <div class:list={[intentTextColors[intent], title ? "mt-1" : ""]}>
      <Text variant="caption" color="inherit">
        <slot />
      </Text>
    </div>
  </div>
</div>
