---
/**
 * PopupModal - Marketing Molecule
 * 
 * Exit-intent popup with Alpine.js logic:
 * - Desktop: Triggers on mouse leaving viewport (top edge)
 * - Mobile: Triggers after 8 seconds
 * - Frequency cap: Shows once every 3 days (localStorage)
 * - Coupon code support with copy-to-clipboard
 * 
 * @component Molecule (marketing/)
 */

interface Props {
  data?: {
    active?: boolean;
    title?: string;
    description?: string;
    image?: string;
    coupon_code?: string;
    cta_text?: string;
  };
}

const { data } = Astro.props;

// Don't render if not active
if (!data?.active) return null;
---

<div
  x-data={`{
    open: false,
    applied: false,
    error: false,
    snipcartReady: false,
    hasSeen: localStorage.getItem('zaviona_popup_seen'),
    init() {
      // Wait for Snipcart to be ready
      if (typeof Snipcart !== 'undefined') {
        Snipcart.events.on('snipcart.ready', () => {
          this.snipcartReady = true;
        });
      }
      
      // Logic: If user hasn't seen it recently, start triggers
      if (!this.hasSeen) {
        // 1. Mobile Timer (8 seconds)
        setTimeout(() => this.open = true, 8000);

        // 2. Desktop Exit Intent (Mouse leaves top)
        document.addEventListener('mouseleave', (e) => {
          if (e.clientY <= 0) this.open = true;
        });
      }
    },
    closePopup() {
      this.open = false;
      // Save "Seen" state for 1 day (balanced frequency - not too aggressive)
      const now = new Date();
      const expiryTime = now.getTime() + (1 * 24 * 60 * 60 * 1000); // 1 day in ms
      localStorage.setItem('zaviona_popup_seen', expiryTime.toString());
    },
    async applyCoupon() {
      // User feedback: Actually apply the coupon to cart!
      if (!this.snipcartReady || typeof Snipcart === 'undefined') {
        this.error = true;
        setTimeout(() => {
          this.error = false;
        }, 3000);
        return;
      }

      try {
        // CRITICAL USER REQUIREMENT: Check if user is logged in
        // Strategy: SHOW discounts to everyone, APPLY only for logged in
        // The "Haha! Gotcha" moment - they see the savings, want it, sign in!
        const customer = Snipcart.store.getState().customer;
        
        if (!customer || !customer.email) {
          // Friendly nudge, not a hard block
          alert('🎉 Want to save with this offer?\\n\\nPlease sign in to apply this discount to your order!\\n\\n(We\\'ll open your cart where you can sign in or continue as guest)');
          this.closePopup();
          Snipcart.api.theme.cart.open();
          return;
        }

        // Apply discount code to cart
        await Snipcart.api.discounts.applyCoupon('${data.coupon_code}');
        
        // Show success message
        this.applied = true;
        
        // Wait 1.5s to show success, then close popup and open cart
        setTimeout(() => {
          this.closePopup();
          Snipcart.api.theme.cart.open();
        }, 1500);
      } catch (error) {
        console.error('Failed to apply coupon:', error);
        this.error = true;
        setTimeout(() => {
          this.error = false;
        }, 3000);
      }
    },
    copyCode() {
      navigator.clipboard.writeText('${data.coupon_code}');
      // Simple alert - could be replaced with toast notification
      alert('Code ${data.coupon_code} copied to clipboard!');
    }
  }`}
  x-show="open"
  x-transition.opacity.duration.500ms
  class="fixed inset-0 z-[100] flex items-center justify-center px-4"
  style="display: none;"
>
  <!-- Backdrop -->
  <div 
    class="absolute inset-0 bg-black/60 backdrop-blur-sm" 
    @click="closePopup()"
  ></div>

  <!-- Modal Content -->
  <div
    class="relative bg-white w-full max-w-lg overflow-hidden shadow-2xl transform transition-all rounded-lg"
    x-transition:enter="ease-out duration-300"
    x-transition:enter-start="opacity-0 scale-95 translate-y-4"
    x-transition:enter-end="opacity-100 scale-100 translate-y-0"
  >
    <!-- Close Button (LARGE for mobile - Gemini Pro 3 UX) -->
    <button
      @click="closePopup()"
      class="absolute top-4 right-4 w-10 h-10 md:w-8 md:h-8 flex items-center justify-center rounded-full bg-white/90 text-gray-600 hover:text-black hover:bg-white shadow-md transition-all z-10"
      aria-label="Close popup"
    >
      <svg class="w-6 h-6 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div class="flex flex-col md:flex-row">
      <!-- Optional Hero Image -->
      {data.image && (
        <div class="w-full md:w-2/5 h-48 md:h-auto bg-gray-100 relative">
          <img
            src={data.image}
            alt="Exclusive Offer"
            class="absolute inset-0 w-full h-full object-cover"
          />
        </div>
      )}

      <!-- Content -->
      <div class:list={[
        "w-full p-8 flex flex-col justify-center text-center md:text-left",
        data.image ? "md:w-3/5" : "md:w-full"
      ]}>
        <h3 class="text-2xl font-heading font-bold text-gray-900 mb-2">
          {data.title}
        </h3>
        <p class="text-gray-600 mb-6 text-sm leading-relaxed">
          {data.description}
        </p>

        <!-- Coupon Code Box -->
        {data.coupon_code && (
          <div class="bg-gray-50 border border-gray-200 p-3 mb-6 rounded flex items-center justify-between">
            <code class="font-mono text-lg font-bold text-primary tracking-widest">
              {data.coupon_code}
            </code>
            <button
              @click="copyCode()"
              class="text-xs uppercase font-bold text-gray-500 hover:text-black underline transition-colors"
            >
              Copy
            </button>
          </div>
        )}

        <!-- CTA Button (User feedback: Actually apply coupon!) -->
        <button
          @click="applyCoupon()"
          :disabled="!snipcartReady || applied || error"
          class="w-full bg-black text-white font-bold py-3 px-6 hover:bg-gray-800 disabled:bg-gray-400 disabled:cursor-not-allowed transition-colors uppercase tracking-widest text-sm rounded flex items-center justify-center gap-2"
          :class="{
            'bg-green-600 hover:bg-green-600': applied,
            'bg-red-600 hover:bg-red-600': error
          }"
        >
          <!-- Loading State (Snipcart not ready) -->
          <template x-if="!snipcartReady && !applied && !error">
            <span class="flex items-center gap-2">
              <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Loading...
            </span>
          </template>

          <!-- Success State -->
          <template x-if="applied">
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              Offer Applied to Cart!
            </span>
          </template>

          <!-- Error State -->
          <template x-if="error && snipcartReady">
            <span>Failed - Try Again</span>
          </template>

          <!-- Default State (Snipcart ready) -->
          <template x-if="snipcartReady && !applied && !error">
            <span>{data.cta_text || 'Claim Discount'}</span>
          </template>
        </button>
      </div>
    </div>
  </div>
</div>
