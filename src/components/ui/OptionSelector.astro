---
/**
 * OptionSelector - Generic Variant Picker
 * A flexible chip/pill-based selector for product options (sizes, materials, colors, etc.)
 * Uses Alpine.js for headless state management
 */

interface Props {
  legend: string;
  options: string[];
  name: string;
  selected?: string;
  class?: string;
}

const { legend, options, name, selected, class: className, ...rest } = Astro.props;

const defaultSelected = selected || (options.length > 0 ? options[0] : "");
---

<fieldset
  class:list={["flex flex-col gap-2", className]}
  x-data={`{ selected: '${defaultSelected}' }`}
  {...rest}
>
  <legend class="mb-4 font-sans text-sm font-medium text-(--color-text-main)">
    {legend}
  </legend>

  <div class="flex flex-wrap gap-2" role="radiogroup" aria-label={legend}>
    {
      options.map((option) => (
        <label
          class="relative cursor-pointer"
        >
          <input type="radio" name={name} value={option} x-model="selected" class="peer sr-only" />
          <span
            class="inline-flex items-center justify-center rounded-md border px-4 py-2 text-sm font-medium transition-all duration-200 peer-focus-visible:shadow-[0_0_0_2px_var(--color-background),0_0_0_4px_var(--color-ring),0_0_12px_var(--color-ring-glow)]"
            x-bind:class={`selected === '${option}'
            ? 'border-(--color-primary) bg-(--color-surface) text-(--color-text-main) shadow-[0_0_0_2px_var(--color-background),0_0_0_3px_var(--color-ring),0_0_10px_var(--color-ring-glow)]'
            : 'border-(--color-border-subtle) bg-(--color-background) text-(--color-text-main) hover:border-(--color-border-strong) hover:bg-(--color-surface)'`}
          >
            {option}
          </span>
        </label>
      ))
    }
  </div>

  {/* Hidden input to ensure form submission includes the selected value */}
  <input type="hidden" name={`${name}_selected`} x-bind:value="selected" />
</fieldset>
