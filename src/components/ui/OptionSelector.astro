---
/**
 * OptionSelector - Generic Variant Picker
 * A flexible chip/pill-based selector for product options (sizes, materials, colors, etc.)
 * Uses Alpine.js for headless state management
 */

import Text from "../primitives/Text.astro";

interface Props {
  legend: string;
  options: string[];
  name: string;
  selected?: string;
  class?: string;
}

const { legend, options, name, selected, class: className, ...rest } = Astro.props;

const defaultSelected = selected || "";
---

<fieldset
  class:list={["flex flex-col gap-2", className]}
  x-data={`{ selected: '${defaultSelected}' }`}
  {...rest}
>
  <Text as="legend" variant="label" class="mb-4">
    {legend}
  </Text>

  <div class="flex flex-wrap gap-2" role="radiogroup" aria-label={legend}>
    {
      options.map((option) => (
        <label class="relative cursor-pointer">
          <input type="radio" name={name} value={option} x-model="selected" class="peer sr-only" />
          <span
            class="inline-flex items-center justify-center rounded-md border px-4 py-2 text-sm font-medium transition-all duration-200 peer-focus-visible:ring-2 peer-focus-visible:ring-primary/50"
            x-bind:class={`selected === '${option}'
            ? 'border-(--color-primary) bg-(--color-primary) text-(--color-text-inverse) shadow-xs'
            : 'border-(--color-border-subtle) bg-(--color-background) text-(--color-text-main) hover:border-(--color-border-strong) hover:bg-(--color-surface)'`}
          >
            {option}
          </span>
        </label>
      ))
    }
  </div>

  {/* Simple Hidden input to store chosen value for form submission/scraping */}
  <input
    type="hidden"
    name={`${name}_selected`}
    x-bind:value="selected"
    class="product-variant-selector"
    data-variant-name={name}
  />
</fieldset>
