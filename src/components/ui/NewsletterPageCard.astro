---
/**
 * NewsletterPageCard — UI Component
 * The shared card shell for newsletter-related pages.
 * Provides the page centering, card border, wordmark eyebrow,
 * brass rule divider, heading, and a content slot.
 *
 * No logic. No API calls. No event listeners.
 * Used by: confirm.astro (via NewsletterConfirmForm feature), success.astro
 */

import Text from "../primitives/Text.astro";
import Heading from "../primitives/Heading.astro";
import { getBrandSettings } from "../../scripts/utils/brand";

interface Props {
  heading: string;
  description?: string;
  emblem?: boolean;  // Renders the Polished Brass checkmark circle (success state)
}

const { heading, description, emblem = false } = Astro.props;
const brand = await getBrandSettings();
---

<div class="min-h-[80dvh] flex items-center justify-center bg-background px-4 py-16 md:py-24">
  <div class="w-full max-w-md border border-border-subtle bg-surface px-8 py-12 md:px-12 text-center">

    {emblem && (
      <div class="mx-auto mb-6 flex h-12 w-12 items-center justify-center rounded-full border border-accent-brass">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--color-accent-brass)"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </div>
    )}

    <Text variant="eyebrow" class="mb-4 block">{brand.name}</Text>

    <div class="mx-auto mb-8 h-px w-8 bg-accent-brass"></div>

    <Heading as="h1" class="mb-4">
      {heading}
    </Heading>

    {description && (
      <Text variant="caption" color="muted" class="mb-8 block leading-relaxed">
        {description}
      </Text>
    )}

    <slot />

  </div>
</div>
