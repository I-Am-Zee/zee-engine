---
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  categoryName: string;
  heading?: string;
  description?: string;
  cta_primary_label?: string;
  cta_primary_link?: string;
  cta_secondary_label?: string;
  cta_secondary_link?: string;
  class?: string;
}

const { 
  categoryName, 
  heading = `Our {category} is on the way`, 
  description = "New pieces are currently being finished. Stay tuned for the release.",
  cta_primary_label = "Continue Exploring",
  cta_primary_link = "/shop",
  cta_secondary_label = "Join the List",
  cta_secondary_link = "/newsletter/confirm",
  class: className, 
  ...rest 
} = Astro.props;
---

<div
  class:list={[
    "flex flex-col items-center justify-center text-center py-20 px-6 bg-(--color-surface)/30 rounded-3xl border border-(--color-border-subtle)",
    className,
  ]}
  {...rest}
>
  {/* Large muted icon */}
  <div class="mb-10 text-(--color-accent) opacity-60">
    <Icon name="PhSparkle" class="h-16 w-16" />
  </div>

  {/* Heading */}
  <Heading as="h3" class="mb-4">
    {heading.replace('{category}', categoryName)}
  </Heading>

  {/* Description */}
  <Text variant="lead" color="muted" class="mb-10 max-w-lg italic font-serif">
    {description.replace('{category}', categoryName)}
  </Text>

  {/* CTA button to keep them browsing */}
  <div class="flex flex-wrap items-center justify-center gap-4">
    <Button as="a" href={cta_primary_link} type="primary">
      {cta_primary_label}
    </Button>
    <Button as="a" href={cta_secondary_link} type="ghost">
      {cta_secondary_label}
    </Button>
  </div>
</div>
