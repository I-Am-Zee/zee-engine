---
import { getEntry } from "astro:content";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  categoryName: string;
  class?: string;
}

const { categoryName, class: className, ...rest } = Astro.props;

const uiEntry = await getEntry("component_hub", "coming_soon");
const { 
  heading = `Our {category} is on the way`, 
  description = "We’re putting the final polish on some exquisite new pieces. They’re worth the wait—stay tuned for the drop.",
  cta_primary_label = "Continue Exploring Shop",
  cta_primary_link = "/shop",
  cta_secondary_label = "Get Notified of Drops",
  cta_secondary_link = "/newsletter/confirm"
} = uiEntry?.data || {};
---

<div
  class:list={[
    "flex flex-col items-center justify-center text-center py-20 px-6 bg-surface/30 rounded-3xl border border-border-subtle",
    className,
  ]}
  {...rest}
>
  {/* Large muted icon */}
  <div class="mb-10 text-accent-brass opacity-60">
    <Icon name="PhSparkle" class="h-16 w-16" />
  </div>

  {/* Heading */}
  <Heading as="h3" class="mb-4">
    {heading.replace('{category}', categoryName)}
  </Heading>

  {/* Description */}
  <Text variant="lead" color="muted" class="mb-10 max-w-lg italic font-serif">
    {description.replace('{category}', categoryName)}
  </Text>

  {/* CTA button to keep them browsing */}
  <div class="flex flex-wrap items-center justify-center gap-4">
    <Button as="a" href={cta_primary_link} type="primary">
      {cta_primary_label}
    </Button>
    <Button as="a" href={cta_secondary_link} type="ghost">
      {cta_secondary_label}
    </Button>
  </div>
</div>
