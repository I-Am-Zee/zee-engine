---
/**
 * Pagination Component
 * Displays page numbers for navigating through paginated content
 */

interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

// Generate page numbers to display
const getPageNumbers = () => {
  const pages: (number | "...")[] = [];
  
  if (totalPages <= 7) {
    // Show all pages if 7 or less
    for (let i = 1; i <= totalPages; i++) {
      pages.push(i);
    }
  } else {
    // Show first, last, current and surrounding pages
    pages.push(1);
    
    if (currentPage > 3) {
      pages.push("...");
    }
    
    for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) {
      pages.push(i);
    }
    
    if (currentPage < totalPages - 2) {
      pages.push("...");
    }
    
    pages.push(totalPages);
  }
  
  return pages;
};

const pageNumbers = getPageNumbers();
const hasPrev = currentPage > 1;
const hasNext = currentPage < totalPages;

const getUrl = (pg: number) => {
  if (pg === 1) return baseUrl;
  // Ensure baseUrl doesn't end with slash before appending
  const cleanBase = baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl;
  return `${cleanBase}/${pg}`;
};
---

<nav class="mt-12 flex items-center justify-center gap-2" aria-label="Pagination">
  {/* Previous Button */}
  <a
    href={hasPrev ? getUrl(currentPage - 1) : "#"}
    class:list={[
      "flex h-10 w-10 items-center justify-center rounded-md border transition-colors",
      hasPrev 
        ? "border-(--color-border-subtle) hover:border-(--color-primary) hover:text-(--color-primary)" 
        : "pointer-events-none border-(--color-border-subtle) opacity-50"
    ]}
    aria-disabled={!hasPrev}
    aria-label="Previous page"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </a>

  {/* Page Numbers */}
  {
    pageNumbers.map((page) => (
      page === "..." ? (
        <span class="flex h-10 w-10 items-center justify-center text-(--color-text-muted)">...</span>
      ) : (
        <a
          href={page === currentPage ? "#" : getUrl(page)}
          class:list={[
            "flex h-10 w-10 items-center justify-center rounded-md border text-sm font-medium transition-colors",
            page === currentPage
              ? "border-(--color-primary) bg-(--color-primary) text-white"
              : "border-(--color-border-subtle) hover:border-(--color-primary) hover:text-(--color-primary)"
          ]}
          aria-current={page === currentPage ? "page" : undefined}
        >
          {page}
        </a>
      )
    ))
  }

  {/* Next Button */}
  <a
    href={hasNext ? getUrl(currentPage + 1) : "#"}
    class:list={[
      "flex h-10 w-10 items-center justify-center rounded-md border transition-colors",
      hasNext 
        ? "border-(--color-border-subtle) hover:border-(--color-primary) hover:text-(--color-primary)" 
        : "pointer-events-none border-(--color-border-subtle) opacity-50"
    ]}
    aria-disabled={!hasNext}
    aria-label="Next page"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </a>
</nav>
