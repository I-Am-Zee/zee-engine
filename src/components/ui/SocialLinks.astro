---
import { getEntry } from "astro:content";
import Icon from "../primitives/Icon.astro";
import Link from "../primitives/Link.astro";

interface Props {
  orientation?: "horizontal" | "vertical";
  class?: string;
}

const { orientation = "horizontal", class: className, ...rest } = Astro.props;

// Fetch Title from Content Layer
const site = await getEntry("settings", "site");
const social = site?.data?.social || {};

// Social platform configuration (mapping settings to icons)
const socialPlatforms = [
  social.instagram && {
    name: "PhInstagramLogo",
    href: social.instagram,
    label: "Follow us on Instagram",
  },
  social.pinterest && {
    name: "PhPinterestLogo",
    href: social.pinterest,
    label: "Follow us on Pinterest",
  },
  social.facebook && {
    name: "PhFacebookLogo",
    href: social.facebook,
    label: "Follow us on Facebook",
  },
  social.twitter && {
    name: "PhTwitterLogo",
    href: social.twitter,
    label: "Follow us on Twitter",
  }
].filter(Boolean) as { name: any, href: string, label: string }[];

const layoutClasses = orientation === "horizontal" ? "flex-row gap-4" : "flex-col gap-3";
---


<div class:list={["flex items-center", layoutClasses, className]} {...rest}>
  {
    socialPlatforms.map((platform) => (
      <Link
        href={platform.href}
        variant="plain"
        class="text-text-muted hover:text-text-main"
        aria-label={platform.label}
        isExternal
      >
        <Icon name={platform.name} class="h-5 w-5" />
      </Link>
    ))
  }
</div>
