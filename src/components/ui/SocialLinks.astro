---
/**
 * SocialLinks - Social media icon links
 * Reusable in Footer and Mobile Drawer
 */

import Icon from "../primitives/Icon.astro";
import Link from "../primitives/Link.astro";
import { siteConfig } from "../../lib/site.config";

interface Props {
  orientation?: "horizontal" | "vertical";
  class?: string;
}

const { orientation = "horizontal", class: className, ...rest } = Astro.props;

// Social platform configuration (using Phosphor icon names)
// Uses siteConfig.social for URLs - add more in site.config.ts
const socialPlatforms = [
  {
    name: "PhInstagramLogo",
    href: siteConfig.social.instagram,
    label: "Follow us on Instagram",
  },
  {
    name: "PhPinterestLogo",
    href: siteConfig.social.pinterest,
    label: "Follow us on Pinterest",
  },
  // Uncomment and add to site.config.ts social object to enable:
  // { name: "PhWhatsappLogo", href: siteConfig.social.whatsapp, label: "Chat on WhatsApp" },
  // { name: "PhFacebookLogo", href: siteConfig.social.facebook, label: "Follow us on Facebook" },
] as const;

const layoutClasses = orientation === "horizontal" ? "flex-row gap-4" : "flex-col gap-3";
---

<div class:list={["flex items-center", layoutClasses, className]} {...rest}>
  {
    socialPlatforms.map((platform) => (
      <Link
        href={platform.href}
        variant="plain"
        class="text-text-muted hover:text-text-main"
        aria-label={platform.label}
        isExternal
      >
        <Icon name={platform.name} class="h-5 w-5" />
      </Link>
    ))
  }
</div>
