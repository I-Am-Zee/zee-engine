---
import Icon from "../primitives/Icon.astro";
import Link from "../primitives/Link.astro";

interface Props {
  social?: any[];
  orientation?: "horizontal" | "vertical";
  class?: string;
}

const { orientation = "horizontal", social = [], class: className, ...rest } = Astro.props;


// Social platform configuration (mapping array to elements)
const socialPlatforms = social.map((link: any) => ({
  name: link.platform,
  href: link.url,
  label: `Follow us on ${link.platform.replace('Ph', '').replace('Logo', '')}`,
}));

const layoutClasses = orientation === "horizontal" ? "flex-row gap-4" : "flex-col gap-3";
---


<div class:list={["flex items-center", layoutClasses, className]} {...rest}>
  {
    socialPlatforms.map((platform) => (
      <Link
        href={platform.href}
        variant="plain"
        class="text-text-muted hover:text-text-main"
        aria-label={platform.label}
        isExternal
      >
        <Icon name={platform.name} class="h-5 w-5" />
      </Link>
    ))
  }
</div>
