---
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";
import SectionHeader from "../ui/SectionHeader.astro";
import ProductCarousel from "./ProductCarousel.astro";

interface Props {
  title: string;
  subtitle?: string;
  products: CollectionEntry<"products">[];
}

const { title, subtitle, products } = Astro.props;
---

{
  products.length > 0 && (
    <section class="mt-12 md:mt-16 border-t border-border-subtle pt-12 md:pt-16 pb-8 md:pb-12 px-4 lg:px-8 max-w-7xl mx-auto">
      <SectionHeader 
        title={title} 
        subtitle={subtitle} 
        align="left"
      />

      <ProductCarousel products={products} columns={4} />
    </section>
  )
}
