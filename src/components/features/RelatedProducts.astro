---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ProductGrid from "./ProductGrid.astro";
import ProductCarousel from "./ProductCarousel.astro";
import Carousel from "../ui/Carousel.astro";
import GlassProductCard from "../ui/GlassProductCard.astro";
import Heading from "../primitives/Heading.astro";

import GlassProductCard from "../ui/GlassProductCard.astro";
import Heading from "../primitives/Heading.astro";
import SectionHeader from "../ui/SectionHeader.astro";

interface Props {
  currentProduct: CollectionEntry<"products">;
}

const { currentProduct } = Astro.props;
const allProducts = await getCollection("products");

// 1. Score products based on shared tags
const displayProducts = allProducts
  .filter((p) => p.id !== currentProduct.id)
  .map((p) => {
    const currentTags = currentProduct.data.tags || [];
    const targetTags = p.data.tags || [];
    const sharedTags = targetTags.filter((tag) => currentTags.includes(tag));
    return { product: p, score: sharedTags.length };
  })
  .sort((a, b) => b.score - a.score || Math.random() - 0.5) // Sort by score (tags), then shuffle
  .slice(0, 4)
  .map((p) => p.product);
---

{
  displayProducts.length > 0 && (
    <section class="mt-12 md:mt-16 border-t border-(--color-border-subtle) pt-12 md:pt-16 pb-8 md:pb-12 px-4 lg:px-8 max-w-7xl mx-auto">
      <SectionHeader 
        title="You May Also Like" 
        subtitle="Complement your look with these handpicked pieces" 
        align="center"
      />

      <ProductCarousel products={displayProducts} columns={4} />
    </section>
  )
}
