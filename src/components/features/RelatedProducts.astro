---
import type { CollectionEntry } from "astro:content";
import SectionHeader from "../ui/SectionHeader.astro";
import ProductCarousel from "./ProductCarousel.astro";
import Section from "../primitives/Section.astro";

interface Props {
  title: string;
  subtitle?: string;
  products: CollectionEntry<"products">[];
}

const { title, subtitle, products } = Astro.props;
---

{
  products.length > 0 && (
    <Section variant="standard" class="mt-4 border-t border-(--color-border-subtle)">
      <SectionHeader 
        title={title} 
        subtitle={subtitle} 
        align="left"
      />

      <ProductCarousel products={products} columns={4} />
    </Section>
  )
}
