---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ProductGrid from "./ProductGrid.astro";
import Carousel from "../ui/Carousel.astro";
import GlassProductCard from "../ui/GlassProductCard.astro";
import Heading from "../primitives/Heading.astro";

interface Props {
  currentProduct: CollectionEntry<"products">;
}

const { currentProduct } = Astro.props;
const allProducts = await getCollection("products");

// 1. Score products based on shared tags
const displayProducts = allProducts
  .filter((p) => p.id !== currentProduct.id)
  .map((p) => {
    const currentTags = currentProduct.data.tags || [];
    const targetTags = p.data.tags || [];
    const sharedTags = targetTags.filter((tag) => currentTags.includes(tag));
    return { product: p, score: sharedTags.length };
  })
  .sort((a, b) => b.score - a.score || Math.random() - 0.5) // Sort by score (tags), then shuffle
  .slice(0, 4)
  .map((p) => p.product);
---

{
  displayProducts.length > 0 && (
    <section class="mt-12 md:mt-16 border-t border-(--color-border-subtle) pt-12 md:pt-16 pb-8 md:pb-12">
      <div class="mb-8 md:mb-12 flex flex-col items-center text-center md:items-start md:text-left">
        <Heading as="h2" class="mb-2">
          You May Also Like
        </Heading>
        <p class="text-text-muted">Complement your look with these handpicked pieces</p>
      </div>

      <Carousel
        x-data="carousel({ perPage: 4, gap: '2rem', type: 'slide', pagination: true, breakpoints: { 1024: { perPage: 3, gap: '1.5rem' }, 768: { perPage: 2 }, 640: { perPage: 1, padding: '10vw', gap: '1rem' } } })"
        class="w-full pb-12"
        trackClass="!py-4"
        showArrows={true}
      >
        {displayProducts.map((p) => (
          <li class="splide__slide group flex h-auto flex-col">
            <GlassProductCard
              id={p.slug}
              title={p.data.title}
              price={p.data.price}
              salePrice={p.data.salePrice}
              image={p.data.image}
              href={`/products/${p.slug}`}
              badges={p.data.badges}
            />
          </li>
        ))}
      </Carousel>
    </section>
  )
}
