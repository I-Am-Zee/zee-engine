---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ProductGrid from "./ProductGrid.astro";
import ProductCarousel from "./ProductCarousel.astro";
import Carousel from "../ui/Carousel.astro";
import GlassProductCard from "../ui/GlassProductCard.astro";
import Heading from "../primitives/Heading.astro";


import SectionHeader from "../ui/SectionHeader.astro";

interface Props {
  currentProduct?: CollectionEntry<"products">;
  collectionTags?: string[];
  category?: string;
}

const { currentProduct, collectionTags = [], category } = Astro.props;
const allProducts = await getCollection("products");

// 1. Contextually gather "other" tags based on where this component is placed
let expandedTags: string[] = [];
if (!currentProduct) {
  let productsInContext: CollectionEntry<"products">[] = [];
  
  if (collectionTags.length > 0) {
    productsInContext = allProducts.filter(p => p.data.tags?.some(tag => collectionTags.includes(tag)));
  } else if (category) {
    productsInContext = allProducts.filter(p => p.data.category === category);
  }
  
  // Extract all tags from the context products, then dedupe
  const allContextTags = productsInContext.flatMap(p => p.data.tags || []);
  expandedTags = [...new Set(allContextTags)].filter(tag => !collectionTags.includes(tag));
}

// 2. Score products and block the current context correctly
const displayProducts = allProducts
  .filter((p) => {
    if (currentProduct) return p.id !== currentProduct.id; // Block same product
    if (collectionTags.length > 0) {
       // BLOCK products already in the tag collection
       return !(p.data.tags?.some(tag => collectionTags.includes(tag)));
    }
    if (category) {
       // BLOCK products already in the category
       return p.data.category !== category;
    }
    return true;
  })
  .map((p) => {
    const targetTags = p.data.tags || [];
    let sharedTags: string[] = [];
    
    if (currentProduct) {
      const currentTags = currentProduct.data.tags || [];
      sharedTags = targetTags.filter((tag) => currentTags.includes(tag));
    } else if (collectionTags.length > 0 || category) {
      // Score based on how many of the "Expanded Pool" tags they hit
      sharedTags = targetTags.filter((tag) => expandedTags.includes(tag));
    }

    return { product: p, score: sharedTags.length };
  })
  .sort((a, b) => b.score - a.score || Math.random() - 0.5) // Sort by score, then shuffle
  .slice(0, 8) // Limit to 8 items
  .map((p) => p.product);

// Smart UI Copy
let sectionTitle = "Expand Your Look";
let sectionSubtitle = "Discover complementary styles curated just for you";
if (currentProduct) {
  sectionTitle = "You May Also Like";
  sectionSubtitle = "Complement your look with these handpicked pieces";
} else if (category) {
  sectionTitle = "Pair With Your Selection";
  sectionSubtitle = "Discover stunning pieces that elevate these styles";
}
---

{
  displayProducts.length > 0 && (
    <section class="mt-12 md:mt-16 border-t border-(--color-border-subtle) pt-12 md:pt-16 pb-8 md:pb-12 px-4 lg:px-8 max-w-7xl mx-auto">
      <SectionHeader 
        title={sectionTitle} 
        subtitle={sectionSubtitle} 
        align="left"
      />

      <ProductCarousel products={displayProducts} columns={4} />
    </section>
  )
}
