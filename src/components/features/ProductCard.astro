---
/**
 * ProductCard - Premium jewelry product card organism
 * Features: Image zoom on hover, wishlist toggle, conditional rating
 */

import Heading from "../primitives/Heading.astro";
import Badge from "../primitives/Badge.astro";
import PriceTag from "../ui/PriceTag.astro";
import RatingStars from "../ui/RatingStars.astro";
import WishlistButton from "./WishlistButton.astro";

interface Props {
  id: string;
  title: string;
  price: number;
  salePrice?: number;
  image: string;
  href: string;
  badges?: string[];
  rating?: number;
  class?: string;
}

const {
  id,
  title,
  price,
  salePrice,
  image,
  href,
  badges = [],
  rating,
  class: className,
  ...rest
} = Astro.props;
---

<article class:list={["group relative flex flex-col", className]} {...rest}>
  {
    /* Image Container - Overflow hidden for zoom effect + relative wrapper for absolute positioned button */
  }
  <div class="relative mb-3">
    <a href={href} class="block overflow-hidden rounded-lg bg-[var(--color-surface)]">
      {/* Image with hover zoom */}
      <img
        src={image}
        alt={title}
        class="aspect-[4/5] w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
        loading="lazy"
      />

      {/* Top-left badges overlay */}
      {
        badges.length > 0 && (
          <div class="pointer-events-none absolute top-3 left-3 flex flex-col gap-2">
            {badges.map((badgeText) => (
              <Badge intent="primary" size="sm">
                {badgeText}
              </Badge>
            ))}
          </div>
        )
      }
    </a>

    {/* Top-right wishlist button - Uses global store */}
    <div class="absolute top-3 right-3 z-10">
      <WishlistButton productId={id} size="md" />
    </div>
  </div>

  {/* Content */}
  <div class="flex flex-1 flex-col">
    <a href={href} class="mb-2 block">
      <Heading
        as="h3"
        class="line-clamp-2 text-base font-medium transition-colors duration-200 group-hover:text-[var(--color-text-muted)]"
      >
        {title}
      </Heading>
    </a>

    <PriceTag price={price} salePrice={salePrice} class="mb-2" />

    {/* Conditional rating - only show if rating exists */}
    {
      rating && rating > 0 && (
        <div class="flex items-center gap-2">
          <RatingStars rating={rating} />
          <span class="text-xs text-[var(--color-text-muted)]">({rating.toFixed(1)})</span>
        </div>
      )
    }
  </div>
</article>
