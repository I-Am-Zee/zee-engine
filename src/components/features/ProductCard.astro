---
/**
 * ProductCard - Premium jewelry product card organism
 * Features: Image zoom on hover, wishlist toggle, conditional rating
 */

import Heading from "../primitives/Heading.astro";
import Badge from "../primitives/Badge.astro";
import Icon from "../primitives/Icon.astro";
import PriceTag from "../ui/PriceTag.astro";
import RatingStars from "../ui/RatingStars.astro";

interface Props {
  title: string;
  price: number;
  salePrice?: number;
  image: string;
  href: string;
  badges?: string[];
  rating?: number;
  class?: string;
}

const {
  title,
  price,
  salePrice,
  image,
  href,
  badges = [],
  rating,
  class: className,
  ...rest
} = Astro.props;
---

<article
  class:list={["group relative flex flex-col", className]}
  x-data="{ liked: false }"
  {...rest}
>
  {/* Image Container - Overflow hidden for zoom effect + relative wrapper for absolute positioned button */}
  <div class="relative mb-3">
    <a href={href} class="block overflow-hidden rounded-lg bg-[var(--color-surface)]">
      {/* Image with hover zoom */}
      <img
        src={image}
        alt={title}
        class="aspect-[4/5] w-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
        loading="lazy"
      />

      {/* Top-left badges overlay */}
      {badges.length > 0 && (
        <div class="absolute left-3 top-3 flex flex-col gap-2 pointer-events-none">
          {badges.map((badgeText) => (
            <Badge intent="primary" size="sm">
              {badgeText}
            </Badge>
          ))}
        </div>
      )}
    </a>

    {/* Top-right wishlist button - Outside link to prevent navigation */}
    <button
      type="button"
      @click="liked = !liked"
      class="absolute right-3 top-3 z-10 flex h-9 w-9 items-center justify-center rounded-full bg-white/90 text-[var(--color-text-main)] shadow-md backdrop-blur-sm transition-all duration-200 hover:scale-110 hover:bg-white focus-visible:outline-none focus-visible:shadow-[0_0_0_2px_var(--color-background),0_0_0_4px_var(--color-ring),0_0_12px_var(--color-ring-glow)]"
      :aria-label="liked ? 'Remove from wishlist' : 'Add to wishlist'"
    >
      <Icon name="heart" class="h-5 w-5 transition-opacity duration-200" x-show="!liked" />
      <Icon name="heart-fill" class="h-5 w-5 text-red-500 transition-opacity duration-200" x-show="liked" x-cloak />
    </button>
  </div>

  {/* Content */}
  <div class="flex flex-1 flex-col">
    <a href={href} class="mb-2 block">
      <Heading as="h3" class="line-clamp-2 text-base font-medium transition-colors duration-200 group-hover:text-[var(--color-text-muted)]">
        {title}
      </Heading>
    </a>

    <PriceTag price={price} salePrice={salePrice} class="mb-2" />

    {/* Conditional rating - only show if rating exists */}
    {rating && rating > 0 && (
      <div class="flex items-center gap-2">
        <RatingStars rating={rating} />
        <span class="text-xs text-[var(--color-text-muted)]">({rating.toFixed(1)})</span>
      </div>
    )}
  </div>
</article>
