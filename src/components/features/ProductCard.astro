---
/**
 * ProductCard - Premium jewelry product card organism
 * Features: Image zoom on hover, wishlist toggle, conditional rating
 */

import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Badge from "../primitives/Badge.astro";
import Icon from "../primitives/Icon.astro";
import Image from "../primitives/Image.astro";
import PriceTag from "../ui/PriceTag.astro";
import RatingStars from "../ui/RatingStars.astro";
import { sortBadgesByHierarchy, getBadgeIntent } from "../../scripts/utils/badges";
import WishlistButton from "./WishlistButton.astro";

interface Props {
  id: string;
  title: string;
  price: number;
  salePrice?: number;
  image: string;
  href: string;
  badges?: string[];
  rating?: number;
  variant_1?: any;
  variant_2?: any;
  variant_3?: any;
  variant?: 'standard' | 'editorial';
  class?: string;
}

const {
  id,
  title,
  price,
  salePrice,
  image,
  href,
  badges = [],
  rating,
  variant_1,
  variant_2,
  variant_3,
  variant = 'standard',
  class: className,
  ...rest
} = Astro.props;

// Sort badges by hierarchy (Urgency → Prestige → Attributes → State)
const sortedBadges = sortBadgesByHierarchy(badges);

// Prepare data for Quick Shop
const productData = {
  id,
  title,
  price,
  salePrice,
  image,
  variant_1,
  variant_2,
  variant_3,
  variant
};

const isEditorial = variant === 'editorial';
---

<article 
  class:list={["group relative flex flex-col", className]} 
  {...rest}
  x-data="{ hovered: false }"
  @mouseenter="hovered = true"
  @mouseleave="hovered = false"
>
  {
    /* Image Container - Overflow hidden for zoom effect + relative wrapper for absolute positioned button */
  }
  <div class="relative mb-2 overflow-hidden rounded-xl bg-surface shadow-sm">
    <a href={href} class="block focus-glow rounded-xl aspect-4/5">
      {/* Image with hover zoom */}
      <Image
        src={image || "/images/placeholder.jpg"}
        alt={title}
        width={800}
        height={1000}
        ratio="portrait"
        class:list={[
          "transition-transform duration-700 group-hover:scale-110",
          !image && "bg-surface p-12 opacity-50 contrast-50"
        ]}
      />

      {/* Top-left badges overlay */}
      {
        badges.length > 0 && (
          <div class="pointer-events-none absolute top-4 left-4 flex flex-col gap-2 z-10">
            {sortedBadges.map((badgeText) => (
              <Badge intent={getBadgeIntent(badgeText)} size="xs">
                {badgeText}
              </Badge>
            ))}
          </div>
        )
      }
    </a>

    {/* Zone: ACTION OVERLAYS */}
    <div class="absolute bottom-4 right-4 z-20 flex gap-2">
      {/* Quick Shop Button - Moved to bottom-right per user request */}
      <button
        @click=`$dispatch('zaviona:quick-shop', ${JSON.stringify(productData)})`
        class:list={[
          "bg-white/95 backdrop-blur-sm p-2.5 rounded-full shadow-md text-primary hover:bg-white hover:scale-110 transition-all focus-glow",
          "md:opacity-0 md:translate-y-2 md:group-hover:opacity-100 md:group-hover:translate-y-0 duration-300",
          "flex items-center justify-center"
        ]}
        aria-label="Quick Shop"
      >
        <Icon name="PhShoppingBagOpen" size={20} weight="bold" />
      </button>

      {/* Wishlist Button - Parallel to Quick Shop */}
      <WishlistButton productId={id} size="md" />
    </div>
  </div>

  {/* Content (Zone A - Atomic Structure) */}
  <div class:list={["flex flex-1 flex-col mt-2", isEditorial ? "items-center text-center px-4" : "px-0"]}>
    <a href={href} class="mb-3 block group/title focus-glow rounded">
      <Heading
        as="h3"
        class:list={[
          "line-clamp-2 min-h-[2.4rem] tracking-tight transition-colors duration-300 group-hover/title:text-accent-brass",
        ]}
      >
        {title}
      </Heading>
    </a>

    {/* Vertical Hierarchy: Rating (Trust) → Price (Value) */}
    <div class:list={["flex flex-col gap-2.5 mt-auto w-full"]}>
      {/* Trust Tier (Above Price) */}
      {
        (rating !== undefined && rating > 0) && (
          <div class="flex items-center gap-2 bg-surface-muted/30 px-3 py-1.5 rounded-full border border-border-subtle/20 w-fit">
            <RatingStars rating={rating} />
            <Text variant="metadata">({rating.toFixed(1)})</Text>
          </div>
        )
      }

      {/* Value Tier */}
      <div class="flex items-center justify-between gap-4">
        <PriceTag price={price} salePrice={salePrice} />
      </div>
    </div>
  </div>
</article>
