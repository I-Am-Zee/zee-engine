---
/**
 * AffiliateQuickView - Feature Organism
 * 
 * A simplified side drawer for Affiliate-mode brands.
 * Redesigned to use DrawerProductCard for a consistent, premium "Quick Shop" experience.
 * No cart logic, no variants, no upsells.
 */

import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Icon from "../primitives/Icon.astro";
import Button from "../primitives/Button.astro";
import DrawerProductCard from "../ui/DrawerProductCard.astro";
import AffiliateProductCTA from "./AffiliateProductCTA.astro";
---

<div
  id="engine-quick-view"
  x-data="affiliateQuickView"
  x-show="isOpen"
  x-effect="document.body.style.overflow = isOpen ? 'hidden' : ''"
  x-cloak
  @keydown.escape.window="close()"
  class="fixed inset-0 flex items-center justify-end overflow-hidden z-200"
  aria-labelledby="quick-view-title"
  role="dialog"
  aria-modal="true"
>
  <!-- Background backdrop (Shared structure with SideDrawer) -->
  <div
    x-show="isOpen"
    x-transition:enter="ease-in-out duration-500"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="ease-in-out duration-500"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="close()"
    class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity"
    x-cloak
  ></div>

  <div class="fixed inset-y-0 right-0 flex max-w-full pl-6 sm:pl-10">
    <div
      x-show="isOpen"
      x-transition:enter="transform-gpu transition-transform ease-out duration-500"
      x-transition:enter-start="translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transform-gpu transition-transform ease-in duration-400"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="translate-x-full"
      class="w-full max-w-md will-change-transform"
      x-cloak
    >
      <div class="bg-(--color-surface) lg:bg-(--color-background) flex h-full flex-col overflow-hidden shadow-2xl">
        <!-- Header -->
        <div class="border-(--color-border-subtle) bg-(--color-surface)/50 border-b px-5 py-6 sm:px-8">
          <div class="flex items-center justify-between">
            <Heading as="h2" id="quick-view-title">Quick Look</Heading>
            <Button
              type="ghost"
              variant="icon-only"
              size="md"
              @click="close()"
              class="-mr-2"
              aria-label="Close"
            >
              <Icon name="PhX" size={24} />
            </Button>
          </div>
        </div>

        <!-- Scrollable Content -->
        <div class="relative flex-1 overflow-y-auto px-4 py-8 sm:px-8">
          <div x-show="isLoading" class="flex items-center justify-center py-12" x-cloak>
            <div class="animate-spin text-(--color-accent)">
              <Icon name="PhCircleNotch" size={32} weight="bold" />
            </div>
          </div>

          <template x-if="!isLoading && product">
            <div class="space-y-8">
              <!-- Compact Identity block via DrawerProductCard -->
              <div class="space-y-6">
                <template x-for="item in [product]" :key="item.id">
                  <DrawerProductCard mode="affiliate" />
                </template>
              </div>

              <!-- Editorial context (Optional Description) -->
              <div class="border-(--color-border-subtle)/30 border-t pt-8">
                <Text variant="eyebrow" class="mb-4 block">Editor's Note</Text>
                <Text variant="paragraph" color="muted" class="text-sm leading-relaxed italic" x-text="product.description" />
              </div>
            </div>
          </template>
        </div>

        <!-- Sticky Footer CTA -->
        <div class="border-(--color-border-subtle) bg-(--color-surface)/80 border-t px-5 py-8 backdrop-blur-md sm:px-8">
           <template x-if="product">
              <div class="space-y-4">
                <AffiliateProductCTA 
                  alpineLinks="product.affiliate_links || []" 
                  class="w-full shadow-xl" 
                />
                <Text variant="caption" color="muted" class="block text-center opacity-70">
                  Redirecting to verified partner platform.
                </Text>
              </div>
           </template>
           
           <div class="mt-6 flex justify-center text-center">
            <button
              @click="close()"
              class="focus-glow cursor-pointer rounded p-2"
            >
              <Text variant="eyebrow" color="muted" class="hover:text-(--color-primary) transition-colors">Return to Shop</Text>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { affiliateQuickView } from "../../scripts/behaviors/affiliate-quick-view";
  
  // Register behavior
  if (!(window as any).Alpine) {
    // Safety check handled by Astro island entry
  }
  
  (window as any).Alpine.data("affiliateQuickView", affiliateQuickView);
</script>
