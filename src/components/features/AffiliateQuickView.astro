---
/**
 * AffiliateQuickView - Feature Organism
 * 
 * A simplified side drawer for Affiliate-mode brands.
 * Shows high-level product details and a direct outbound CTA.
 * No cart logic, no variants, no upsells.
 */

import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Icon from "../primitives/Icon.astro";
import Button from "../primitives/Button.astro";
---

<div
  id="engine-quick-view"
  x-data="affiliateQuickView"
  x-show="isOpen"
  x-effect="document.body.style.overflow = isOpen ? 'hidden' : ''"
  x-cloak
  @keydown.escape.window="close()"
  class="fixed inset-0 flex items-center justify-end overflow-hidden z-200"
  aria-labelledby="quick-view-title"
  role="dialog"
  aria-modal="true"
>
  <!-- Background backdrop -->
  <div
    x-show="isOpen"
    x-transition:enter="ease-in-out duration-500"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="ease-in-out duration-500"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    @click="close()"
    class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity"
  ></div>

  <div class="fixed inset-y-0 right-0 flex max-w-full pl-10">
    <div
      x-show="isOpen"
      x-transition:enter="transform-gpu transition-transform ease-out duration-500"
      x-transition:enter-start="translate-x-full"
      x-transition:enter-end="translate-x-0"
      x-transition:leave="transform-gpu transition-transform ease-in duration-400"
      x-transition:leave-start="translate-x-0"
      x-transition:leave-end="translate-x-full"
      class="w-screen max-w-md will-change-transform"
    >
      <div class="bg-surface lg:bg-background flex h-full flex-col overflow-hidden shadow-2xl">
        <!-- Header -->
        <div class="border-border-subtle bg-surface/50 border-b px-6 py-6 sm:px-8">
          <div class="flex items-center justify-between">
            <Heading as="h2" id="quick-view-title">Quick Look</Heading>
            <Button
              type="ghost"
              variant="icon-only"
              size="md"
              @click="close()"
              class="-mr-2"
              aria-label="Close"
            >
              <Icon name="PhX" size={24} />
            </Button>
          </div>
        </div>

        <!-- Scrollable Content -->
        <div class="relative flex-1 overflow-y-auto px-6 py-8 sm:px-8">
          <div x-show="isLoading" class="flex items-center justify-center py-12">
            <div class="animate-spin text-accent-brass">
              <Icon name="PhCircleNotch" size={32} weight="bold" />
            </div>
          </div>

          <div x-show="!isLoading && product" class="space-y-8">
            <!-- Product Image -->
            <div class="aspect-square relative overflow-hidden rounded-2xl bg-gray-100 shadow-inner">
               <img :src="product.image" :alt="product.title" class="absolute inset-0 h-full w-full object-cover" />
            </div>

            <!-- Product Info -->
            <div>
              <div class="mb-4 flex items-start justify-between gap-4">
                <div class="min-w-0 flex-1">
                  <Heading as="h3" class="mb-1 truncate text-2xl" x-text="product.title" />
                  <Text variant="caption" color="muted" x-text="product.category" />
                </div>
                <div class="text-right">
                   <template x-if="product.salePrice">
                      <div class="flex flex-col items-end">
                        <span class="text-text-muted text-sm line-through decoration-red-500/30" x-text="formatCurrency(product.price)"></span>
                        <span class="text-accent-emerald text-xl font-bold" x-text="formatCurrency(product.salePrice)"></span>
                      </div>
                   </template>
                   <template x-if="!product.salePrice">
                      <span class="text-text text-xl font-bold" x-text="formatCurrency(product.price)"></span>
                   </template>
                </div>
              </div>

              <Text variant="paragraph" color="muted" class="leading-relaxed" x-text="product.description" />
            </div>

            <!-- Features / Tags -->
            <div class="flex flex-wrap gap-2">
                <template x-for="tag in product.tags" :key="tag">
                    <span class="border-border text-text-muted rounded-full border px-3 py-1 text-xs font-medium lowercase" x-text="tag"></span>
                </template>
            </div>
          </div>
        </div>

        <!-- Footer Footer CTA -->
        <div class="border-border-subtle bg-surface/80 border-t p-6 sm:p-8 backdrop-blur-md">
           <template x-if="product">
              <Button
                as="a"
                :href="product.affiliate_url"
                target="_blank"
                rel="noopener noreferrer"
                class="w-full py-4 text-center uppercase tracking-widest"
              >
                <div class="flex items-center justify-center gap-2">
                  <span x-text="`Shop on ${product.platform || 'Partner'}`"></span>
                  <Icon name="PhArrowUpRight" size={18} weight="bold" />
                </div>
              </Button>
           </template>
           <Text variant="caption" color="muted" class="mt-4 block text-center opacity-70">
              You will be redirected to our partner platform.
           </Text>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { affiliateQuickView } from "../../scripts/behaviors/affiliate-quick-view";
  import Alpine from "alpinejs";

  // Register behavior if not already registered
  if (!window.Alpine) {
    // This shouldn't happen with our Astro/Alpine setup, but safety first
  }
  
  Alpine.data("affiliateQuickView", affiliateQuickView);
</script>
