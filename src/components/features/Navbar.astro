---
/**
 * Navbar - Main site header controller
 * Implements the Airy Cream Strategy with a Cinematic "Swap" animation.
 * Consolidates AnnouncementBar and Navigation logic for perfect orchestration.
 */

import Logo from "../primitives/Logo.astro";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
import Text from "../primitives/Text.astro";
import NavDropdown from "../ui/NavDropdown.astro";
import MobileMenu from "./MobileMenu.astro";
import AnnouncementBar from "../ui/AnnouncementBar.astro";
import type { NavItem } from "../../types/navigation";
import { getEntry } from "astro:content";
import { slugify } from "../../scripts/utils/slugify";

interface Props {
  class?: string;
  isTransparent?: boolean;
}

const { class: className, isTransparent = false, ...rest } = Astro.props;

// Fetch Data
const taxonomy = await getEntry("settings", "taxonomy");
const brandSettings = await getEntry("settings", "brand");
const navigationEntry = await getEntry("settings", "navigation");
const marketingSettings = await getEntry("settings", "marketing");
const shippingSettings = await getEntry("settings", "shipping");

const categories = (taxonomy?.data as any)?.categories || [];
const brandName = brandSettings?.data?.name || "Brand";
const navigationData = navigationEntry?.data || { main_menus: [], support_links: [], labels: {} };
const announcement_bar = marketingSettings?.data?.announcement_bar;
const threshold = shippingSettings?.data?.free_shipping_threshold || 3000;

const labels = {
  shop: 'Shop',
  allJewelry: (navigationData as any).labels?.allJewelry ?? 'All Jewelry',
  search: 'Search',
  wishlist: 'Wishlist',
  cart: 'Cart',
  account: 'Account',
  menu: 'Menu',
  close: 'Close',
};

const shopCategoryItems: NavItem[] = categories.map((cat: string) => ({
  label: cat.charAt(0).toUpperCase() + cat.slice(1),
  href: `/shop/${slugify(cat)}`,
}));

const isAffiliate = import.meta.env.PUBLIC_AFFILIATE === "true";

const dynamicNavigation: NavItem[] = [
  {
    label: labels.shop,
    href: "/shop",
    items: [
      { label: labels.allJewelry, href: "/shop" },
      ...shopCategoryItems
    ],
  },
  ...(navigationData.main_menus || []),
];
---

<div
  x-data={`{ scrolled: false, isTransparent: ${isTransparent}, mobileMenuOpen: false }`}
  x-init="scrolled = (window.pageYOffset > (window.innerHeight - 80))"
  @scroll.window="scrolled = (window.pageYOffset > (window.innerHeight - 80))"
  class:list={[
    "z-[100]",
    isTransparent ? "relative" : "contents"
  ]}
>
  {/* ── Announcement Bar: Always static at the top ── */}
  <AnnouncementBar announcement={announcement_bar} threshold={threshold} />

  {/* ── State 1: Cinematic Transparent (Home Hero only) ── */}
  {isTransparent && (
    <header
      x-show="!scrolled"
      x-transition:leave="motion-soft opacity"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      class:list={["absolute top-full left-0 w-full bg-transparent border-b border-transparent py-2 text-white z-[101]", className]}
      {...rest}
    >
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 lg:px-8">
        <Logo variant="full" brandName={brandName} color="white" />
        
        <nav class="hidden items-center gap-1 md:flex">
          {dynamicNavigation.map((tItem) => (
            tItem.items && tItem.items.length > 0 ? (
              <NavDropdown trigger={tItem.label} items={tItem.items} dark={true} />
            ) : (
              <a href={tItem.href} class="inline-flex items-center justify-center rounded-md px-3 py-2 transition-all duration-200 hover:text-white/70 text-white">
                <Text variant="label" color="inherit">{tItem.label}</Text>
              </a>
            )
          ))}
        </nav>

        <div class="hidden items-center gap-4 md:flex text-white">
          <Button as="a" href="/search" type="ghost" variant="icon-only" size="sm" class="text-white! hover:bg-white/10!"><Icon name="PhMagnifyingGlass" /></Button>
          <Button as="a" href="/wishlist" type="ghost" variant="icon-only" size="sm" class="relative text-white! hover:bg-white/10!"><Icon name="PhHeart" /><span x-show="$store.wishlist.count > 0" x-cloak class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-(--color-danger) text-[10px] font-bold text-white shadow-xs" x-text="$store.wishlist.count"></span></Button>
          {!isAffiliate && (
            <>
              <Button type="ghost" variant="icon-only" size="sm" class="snipcart-customer-signin text-white! hover:bg-white/10!"><Icon name="PhUser" /></Button>
              <button class="snipcart-checkout relative cursor-pointer" aria-label={labels.cart}><Button type="ghost" variant="icon-only" size="sm" as="span" class="text-white! hover:bg-white/10!"><Icon name="PhShoppingCart" /></Button><span class="snipcart-items-count absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-white text-[10px] font-bold text-(--color-primary) shadow-xs"></span></button>
            </>
          )}
        </div>

        <div class="flex items-center gap-2 md:hidden">
          <Button as="a" href="/search" type="ghost" variant="icon-only" size="sm" class="text-white! hover:bg-white/10!"><Icon name="PhMagnifyingGlass" /></Button>
          {isAffiliate ? (
            <Button as="a" href="/wishlist" type="ghost" variant="icon-only" size="sm" class="relative text-white! hover:bg-white/10!"><Icon name="PhHeart" /><span x-show="$store.wishlist.count > 0" x-cloak class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-(--color-danger) text-[10px] font-bold text-white shadow-xs" x-text="$store.wishlist.count"></span></Button>
          ) : (
            <button class="snipcart-checkout relative cursor-pointer" aria-label={labels.cart}>
              <Button type="ghost" variant="icon-only" size="sm" as="span" class="text-white! hover:bg-white/10!">
                <Icon name="PhShoppingCart" />
              </Button>
              <span class="snipcart-items-count absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-white text-[10px] font-bold text-(--color-primary) shadow-xs"></span>
            </button>
          )}
          <Button type="ghost" variant="icon-only" size="sm" class="text-white! hover:bg-white/10!" @click="mobileMenuOpen = true"><Icon name="PhList" /></Button>
        </div>
      </div>
    </header>
  )}

  {/* ── State 2: Solid Airy Cream (Standard & Scrolled Home) ── */}
  <div
    x-show={isTransparent ? "scrolled" : undefined}
    x-cloak={isTransparent ? true : undefined}
    x-transition:enter={isTransparent ? "motion-soft transform" : undefined}
    x-transition:enter-start={isTransparent ? "-translate-y-full" : undefined}
    x-transition:enter-end={isTransparent ? "translate-y-0" : undefined}
    x-transition:leave={isTransparent ? "motion-soft transform" : undefined}
    x-transition:leave-start={isTransparent ? "translate-y-0" : undefined}
    x-transition:leave-end={isTransparent ? "-translate-y-full" : undefined}
    class:list={[
      "w-full z-[100]",
      isTransparent ? "fixed top-0" : "sticky top-0"
    ]}
  >
    <header
      class:list={[
        "w-full bg-(--color-background) border-b border-(--color-border-subtle) py-0 shadow-xs text-(--color-text-main)",
        className
      ]}
      {...rest}
    >
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 lg:px-8">
        <Logo variant="full" brandName={brandName} color="black" />

        <nav class="hidden items-center gap-1 md:flex">
          {dynamicNavigation.map((sItem) => (
            sItem.items && sItem.items.length > 0 ? (
              <NavDropdown trigger={sItem.label} items={sItem.items} dark={false} />
            ) : (
              <a href={sItem.href} class="inline-flex items-center justify-center rounded-md px-3 py-2 transition-all duration-200 hover:text-(--color-text-muted) text-(--color-text-main)">
                <Text variant="label" color="inherit">{sItem.label}</Text>
              </a>
            )
          ))}
        </nav>

        <div class="hidden items-center gap-4 md:flex text-(--color-text-main)">
          <Button as="a" href="/search" type="ghost" variant="icon-only" size="sm" class="text-(--color-text-main)! hover:bg-black/5!"><Icon name="PhMagnifyingGlass" /></Button>
          <Button as="a" href="/wishlist" type="ghost" variant="icon-only" size="sm" class="relative text-(--color-text-main)! hover:bg-black/5!"><Icon name="PhHeart" /><span x-show="$store.wishlist.count > 0" x-cloak class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-(--color-danger) text-[10px] font-bold text-white shadow-xs" x-text="$store.wishlist.count"></span></Button>
          {!isAffiliate && (
            <>
              <Button type="ghost" variant="icon-only" size="sm" class="snipcart-customer-signin text-(--color-text-main)! hover:bg-black/5!"><Icon name="PhUser" /></Button>
              <button class="snipcart-checkout relative cursor-pointer" aria-label={labels.cart}><Button type="ghost" variant="icon-only" size="sm" as="span" class="text-(--color-text-main)! hover:bg-black/5!"><Icon name="PhShoppingCart" /></Button><span class="snipcart-items-count absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-(--color-primary) text-[10px] font-bold text-(--color-primary-foreground) shadow-xs"></span></button>
            </>
          )}
        </div>
        
        <div class="flex items-center gap-2 md:hidden">
          <Button as="a" href="/search" type="ghost" variant="icon-only" size="sm" class="text-(--color-text-main)! hover:bg-black/5!"><Icon name="PhMagnifyingGlass" /></Button>
          {isAffiliate ? (
            <Button as="a" href="/wishlist" type="ghost" variant="icon-only" size="sm" class="relative text-(--color-text-main)! hover:bg-black/5!"><Icon name="PhHeart" /><span x-show="$store.wishlist.count > 0" x-cloak class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-(--color-danger) text-[10px] font-bold text-white shadow-xs" x-text="$store.wishlist.count"></span></Button>
          ) : (
            <button class="snipcart-checkout relative cursor-pointer" aria-label={labels.cart}>
              <Button type="ghost" variant="icon-only" size="sm" as="span" class="text-(--color-text-main)! hover:bg-black/5!">
                <Icon name="PhShoppingCart" />
              </Button>
              <span class="snipcart-items-count absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-(--color-primary) text-[10px] font-bold text-(--color-primary-foreground) shadow-xs"></span>
            </button>
          )}
          <Button type="ghost" variant="icon-only" size="sm" @click="mobileMenuOpen = true" class="text-(--color-text-main)! hover:bg-black/5!"><Icon name="PhList" /></Button>
        </div>
      </div>
    </header>
  </div>

  <MobileMenu 
    brandName={brandName} 
    dynamicNavigation={dynamicNavigation} 
    isAffiliate={isAffiliate}
    labels={labels}
  />
</div>
