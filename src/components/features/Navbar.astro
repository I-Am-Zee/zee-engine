---
/**
 * Navbar - Main site header
 * Desktop: Logo (left) - Nav (center) - Actions (right)
 * Mobile: Logo (left) - Actions + MenuToggle (right) with slide-over drawer
 */

import Logo from "../primitives/Logo.astro";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
import Link from "../primitives/Link.astro";
import NavDropdown from "../ui/NavDropdown.astro";
import { navigation } from "../../config/navigation";

interface Props {
  class?: string;
}

const { class: className, ...rest } = Astro.props;
---

<header
  class:list={[
    "sticky top-0 z-40 w-full border-b border-[var(--color-border-subtle)] bg-[var(--color-background)]",
    className,
  ]}
  {...rest}
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 lg:px-8">
    {/* Logo */}
    <Logo variant="full" />

    {/* Desktop Navigation - Hidden on mobile */}
    <nav class="hidden items-center gap-1 md:flex">
      {
        navigation.map((item) =>
          item.items && item.items.length > 0 ? (
            <NavDropdown trigger={item.label} items={item.items} />
          ) : (
            <a
              href={item.href}
              class="px-3 py-2 font-sans text-sm font-medium text-[var(--color-text-main)] transition-colors duration-200 hover:text-[var(--color-text-muted)]"
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>

    {/* Desktop Actions - Hidden on mobile */}
    <div class="hidden items-center gap-2 md:flex">
      <Button type="ghost" variant="icon-only" size="sm">
        <Icon name="PhMagnifyingGlass" />
      </Button>
      <a href="/wishlist" class="relative">
        <Button type="ghost" variant="icon-only" size="sm" as="span">
          <Icon name="PhHeart" />
        </Button>
        <span
          x-data
          x-show="$store.wishlist.count > 0"
          x-text="$store.wishlist.count"
          x-cloak
          class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-xs font-bold text-white"
        ></span>
      </a>
      <Button type="ghost" variant="icon-only" size="sm">
        <Icon name="PhShoppingCart" />
      </Button>
    </div>

    {/* Mobile: Actions + Menu Toggle */}
    <div class="flex items-center gap-2 md:hidden" x-data="{ mobileMenuOpen: false }">
      <Button type="ghost" variant="icon-only" size="sm">
        <Icon name="PhMagnifyingGlass" />
      </Button>
      <Button type="ghost" variant="icon-only" size="sm">
        <Icon name="PhShoppingCart" />
      </Button>

      {/* Mobile Menu Toggle */}
      <Button type="ghost" variant="icon-only" size="sm" @click="mobileMenuOpen = true">
        <Icon name="PhList" />
      </Button>

      {/* Mobile Drawer Overlay */}
      <div
        x-show="mobileMenuOpen"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="fixed inset-0 z-50 bg-black/50"
        @click="mobileMenuOpen = false"
        x-cloak
      >
      </div>

      {/* Mobile Drawer Panel */}
      <div
        x-show="mobileMenuOpen"
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="translate-x-full"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="translate-x-full"
        class="fixed inset-y-0 right-0 z-50 w-full max-w-sm overflow-y-auto bg-[var(--color-background)] shadow-xl"
        x-cloak
      >
        <div class="flex h-full flex-col" x-data="{ activeAccordion: null }">
          {/* Drawer Header */}
          <div
            class="flex items-center justify-between border-b border-[var(--color-border-subtle)] px-4 py-4"
          >
            <Logo variant="full" />
            <Button type="ghost" variant="icon-only" size="sm" @click="mobileMenuOpen = false">
              <Icon name="PhX" />
            </Button>
          </div>

          {/* Mobile Navigation */}
          <nav class="flex-1 px-4 py-6">
            <ul class="space-y-1">
              {
                navigation.map((item) => (
                  <li>
                    {item.items && item.items.length > 0 ? (
                      <div>
                        <button
                          type="button"
                          class="flex w-full items-center justify-between rounded-md px-3 py-3 font-sans text-base font-medium text-[var(--color-text-main)] transition-colors hover:bg-[var(--color-surface)]"
                          @click={`activeAccordion = activeAccordion === '${item.label}' ? null : '${item.label}'`}
                        >
                          {item.label}
                          <Icon
                            name="PhCaretDown"
                            class="h-4 w-4 transition-transform duration-200"
                            x-bind:class={`activeAccordion === '${item.label}' ? 'rotate-180' : ''`}
                          />
                        </button>
                        <ul
                          x-show={`activeAccordion === '${item.label}'`}
                          x-collapse
                          class="mt-1 ml-4 space-y-1"
                        >
                          {item.items.map((subItem) => (
                            <li>
                              <a
                                href={subItem.href}
                                class="block rounded-md px-3 py-2 text-sm text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-surface)] hover:text-[var(--color-text-main)]"
                              >
                                {subItem.label}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ) : (
                      <a
                        href={item.href}
                        class="block rounded-md px-3 py-3 font-sans text-base font-medium text-[var(--color-text-main)] transition-colors hover:bg-[var(--color-surface)]"
                      >
                        {item.label}
                      </a>
                    )}
                  </li>
                ))
              }
            </ul>
          </nav>

          {/* Drawer Footer */}
          <div class="border-t border-[var(--color-border-subtle)] px-4 py-4">
            <div class="flex items-center gap-4">
              <a href="/wishlist" class="relative">
                <Button type="ghost" variant="icon-only" size="sm" as="span">
                  <Icon name="PhHeart" />
                </Button>
                <span
                  x-show="$store.wishlist.count > 0"
                  x-text="$store.wishlist.count"
                  x-cloak
                  class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-xs font-bold text-white"
                ></span>
              </a>
              <Button type="ghost" variant="icon-only" size="sm">
                <Icon name="PhUser" />
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
