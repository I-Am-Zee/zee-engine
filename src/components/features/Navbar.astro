---
/**
 * Navbar - Main site header
 * Atomic & De-hardcoded.
 */

import Logo from "../primitives/Logo.astro";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
import Link from "../primitives/Link.astro";
import Text from "../primitives/Text.astro";
import NavDropdown from "../ui/NavDropdown.astro";
import type { NavItem } from "../../types/navigation";
import { getEntry } from "astro:content";
import { slugify } from "../../scripts/utils/slugify";

interface Props {
  class?: string;
}

const { class: className, ...rest } = Astro.props;

// ── Smart Logic: Build Dynamic Navigation ───────────────────
const taxonomy = await getEntry("settings", "taxonomy");
const brandSettings = await getEntry("settings", "brand");
const navigationEntry = await getEntry("settings", "navigation");

const categories = (taxonomy?.data as any)?.categories || [];
const brandName = brandSettings?.data?.name;
const navigationData = navigationEntry?.data || { 
  main_menus: [], 
  support_links: [],
  labels: {
    shop: "Shop",
    allJewelry: "All Jewelry",
    search: "Search",
    wishlist: "Wishlist",
    cart: "Cart",
    account: "Account",
    menu: "Menu",
    close: "Close"
  }
};

const shopCategoryItems: NavItem[] = categories.map((cat: string) => ({
  label: cat.charAt(0).toUpperCase() + cat.slice(1),
  href: `/shop/${slugify(cat)}`,
}));

const isAffiliate = import.meta.env.PUBLIC_AFFILIATE === "true";

const dynamicNavigation: NavItem[] = [
  {
    label: navigationData.labels.shop,
    href: "/shop",
    items: [
      { label: navigationData.labels.allJewelry, href: "/shop" },
      ...shopCategoryItems
    ],
  },
  ...(navigationData.main_menus || []),
];
---

<header
  class:list={[
    "sticky top-0 w-full border-b border-border-subtle bg-navbar-glass z-[100] transition-all",
    className,
  ]}
  {...rest}
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 lg:px-8">
    {/* Logo */}
    <Logo variant="full" brandName={brandName} />

    {/* Desktop Navigation - Hidden on mobile */}
    <nav class="hidden items-center gap-1 md:flex">
      {
        dynamicNavigation.map((item) =>
          item.items && item.items.length > 0 ? (
            <NavDropdown trigger={item.label} items={item.items} />
          ) : (
            <a
              href={item.href}
              class="inline-flex items-center justify-center rounded-md px-3 py-2 transition-all duration-200 hover:text-(--color-text-muted)"
            >
              <Text variant="label">
                {item.label}
              </Text>
            </a>
          )
        )
      }
    </nav>

    {/* Desktop Actions - Hidden on mobile */}
    <div class="hidden items-center gap-4 md:flex">
      <Button as="a" href="/search" type="ghost" variant="icon-only" size="sm" aria-label={navigationData.labels.search}>
        <Icon name="PhMagnifyingGlass" />
      </Button>
      <Button as="a" href="/wishlist" type="ghost" variant="icon-only" size="sm" class="relative" aria-label={navigationData.labels.wishlist}>
        <Icon name="PhHeart" />
        <span
          x-data
          x-show="$store.wishlist.count > 0"
          x-text="$store.wishlist.count"
          x-cloak
          class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-accent-coral text-[10px] font-bold text-white shadow-xs"
        ></span>
      </Button>
      { !isAffiliate && (
        <>
          <Button
            type="ghost"
            variant="icon-only"
            size="sm"
            class="snipcart-customer-signin"
            aria-label={navigationData.labels.account}
          >
            <Icon name="PhUser" />
          </Button>
          <button class="snipcart-checkout relative cursor-pointer disabled:cursor-not-allowed" aria-label={navigationData.labels.cart}>
            <Button type="ghost" variant="icon-only" size="sm" as="span">
              <Icon name="PhShoppingCart" />
            </Button>
            <span class="snipcart-items-count absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-primary text-xs font-bold text-white"></span>
          </button>
        </>
      )}
    </div>

    {/* Mobile: Actions + Menu Toggle */}
    <div 
      class="flex items-center gap-2 md:hidden" 
      x-data="{ mobileMenuOpen: false }"
      x-effect="mobileMenuOpen ? document.body.classList.add('overflow-hidden') : document.body.classList.remove('overflow-hidden')"
    >
      <Button as="a" href="/search" type="ghost" variant="icon-only" size="sm" aria-label={navigationData.labels.search}>
        <Icon name="PhMagnifyingGlass" />
      </Button>
      { !isAffiliate && (
        <button class="snipcart-checkout relative cursor-pointer disabled:cursor-not-allowed" aria-label={navigationData.labels.cart}>
          <Button type="ghost" variant="icon-only" size="sm" as="span">
            <Icon name="PhShoppingCart" />
          </Button>
          <span class="snipcart-items-count absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-primary text-xs font-bold text-white"></span>
        </button>
      )}

      {/* Mobile Menu Toggle */}
      <Button type="ghost" variant="icon-only" size="sm" @click="mobileMenuOpen = true" aria-label={navigationData.labels.menu}>
        <Icon name="PhList" />
      </Button>

      {/* Mobile Drawer */}
      <template x-teleport="body">
        <div class="relative z-[110]">
          {/* Mobile Drawer Overlay */}
          <div
            x-show="mobileMenuOpen"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 bg-black/20 backdrop-blur-sm"
            @click="mobileMenuOpen = false"
            x-cloak
          >
          </div>

          {/* Mobile Drawer Panel */}
          <div
            x-show="mobileMenuOpen"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="translate-x-full"
            x-transition:enter-end="translate-x-0"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="translate-x-0"
            x-transition:leave-end="translate-x-full"
            class="fixed inset-y-0 right-0 w-full max-w-sm overflow-y-auto bg-background shadow-xl"
            x-cloak
          >
            <div class="flex h-full flex-col" x-data="{ activeAccordion: null }">
              {/* Drawer Header */}
              <div class="flex items-center justify-between border-b border-border-subtle px-4 py-4">
                <Logo variant="full" brandName={brandName} />
                <Button type="ghost" variant="icon-only" size="sm" @click="mobileMenuOpen = false" aria-label={navigationData.labels.close}>
                  <Icon name="PhX" />
                </Button>
              </div>

              {/* Mobile Navigation */}
              <nav class="flex-1 px-4 py-6">
                <ul class="space-y-1">
                  {
                    dynamicNavigation.map((item) => (
                      <li>
                        {item.items && item.items.length > 0 ? (
                          <div>
                            <button
                              type="button"
                              class="flex w-full items-center justify-between rounded-md px-3 py-3 transition-colors hover:bg-surface cursor-pointer disabled:cursor-not-allowed"
                              @click={`activeAccordion = activeAccordion === '${item.label}' ? null : '${item.label}'`}
                            >
                              <Text variant="paragraph" weight="medium">{item.label}</Text>
                              <Icon
                                name="PhCaretDown"
                                class="h-4 w-4 transition-transform duration-200"
                                x-bind:class={`activeAccordion === '${item.label}' ? 'rotate-180' : ''`}
                              />
                            </button>
                            <ul
                              x-show={`activeAccordion === '${item.label}'`}
                              x-collapse
                              class="mt-1 ml-4 space-y-1"
                              x-cloak
                            >
                              {item.items.map((subItem) => (
                                <li>
                                  <a
                                    href={subItem.href}
                                    class="block rounded-md px-3 py-2 transition-colors hover:bg-surface hover:text-text-main"
                                  >
                                    <Text variant="caption" color="muted">{subItem.label}</Text>
                                  </a>
                                </li>
                              ))}
                            </ul>
                          </div>
                        ) : (
                          <a
                            href={item.href}
                            class="block rounded-md px-3 py-3 transition-colors hover:bg-surface"
                          >
                            <Text variant="paragraph" weight="medium">{item.label}</Text>
                          </a>
                        )}
                      </li>
                    ))
                  }
                </ul>
              </nav>

              {/* Drawer Footer */}
              <div class="border-t border-border-subtle px-4 py-4">
                <div class="flex items-center gap-4">
                  <Button as="a" href="/wishlist" type="ghost" variant="icon-only" size="sm" class="relative" aria-label={navigationData.labels.wishlist}>
                    <Icon name="PhHeart" />
                    <span
                      x-show="$store.wishlist.count > 0"
                      x-text="$store.wishlist.count"
                      x-cloak
                      class="absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-red-500 text-xs font-bold text-white"
                    ></span>
                  </Button>
                  { !isAffiliate && (
                    <Button
                      type="ghost"
                      variant="icon-only"
                      size="sm"
                      class="snipcart-customer-signin"
                      aria-label={navigationData.labels.account}
                    >
                      <Icon name="PhUser" />
                    </Button>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      </template>
    </div>
  </div>
</header>
