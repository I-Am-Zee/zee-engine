---
/**
 * AffiliateProductCTA - Multi-Platform Action Button
 * 
 * Standardized button for Affiliate-mode products.
 * Handles:
 * 1. Regional link selection via Alpine.js global store.
 * 2. Platform-specific labeling (e.g. "Shop on Amazon").
 * 3. Consistent "Coming Soon" states.
 * 
 * @component Feature (features/)
 * @uses Alpine.js $store.region
 */
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  links?: any[]; // Optional if static data is available (e.g., PDP)
  alpineLinks?: string; // Optional if data is dynamic inside Alpine (e.g., "product.affiliate_links")
  isComingSoon?: boolean;
  size?: "sm" | "md" | "lg";
  class?: string;
  [key: string]: any; 
}

const { links = [], alpineLinks, isComingSoon = false, size = "lg", class: className, ...rest } = Astro.props;

// If an alpine string expression is provided, use it directly. 
// Otherwise, serialize the static Astro props into JSON for Alpine.
const linksExpression = alpineLinks ? alpineLinks : JSON.stringify(links);
---

<div class:list={[className]} {...rest}>
  <Button
    as="a"
    x-bind:href={`$store.region.getActiveLink(${linksExpression})?.url || '#'`}
    target="_blank"
    rel="noopener noreferrer"
    size={size}
    class="w-full whitespace-nowrap h-full"
    disabled={isComingSoon}
  >
    {isComingSoon ? (
      "Coming Soon"
    ) : (
      <div class="flex items-center justify-center gap-2">
        <span x-text={`'Shop on ' + ($store.region.getActiveLink(${linksExpression})?.platform || 'Partner')`}>Shop on Partner</span>
        <Icon name="PhArrowUpRight" size={size === "sm" ? 14 : 18} weight="bold" />
      </div>
    )}
  </Button>
</div>
