---
interface Props {
  images: string[];
  alt: string;
  class?: string;
}

import Image from "../primitives/Image.astro";

const { images, alt, class: className = "" } = Astro.props;
---

<div
  class:list={[`product-gallery`, className]}
  x-data={`{ activeImage: ${JSON.stringify(images[0])} }`}
>
  {/* Mobile Layout: Main Image Top, Thumbnails Bottom */}
  <div class="flex flex-col gap-4 lg:hidden">
    <div class="relative aspect-4/5 max-h-[70vh] overflow-hidden rounded-lg bg-(--color-surface)">
      <Image
        src={images[0]}
        :src="activeImage"
        alt={alt}
        @click={`$dispatch('open-lightbox', { src: activeImage, alt: ${JSON.stringify(alt)} })`}
        class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02] cursor-zoom-in active:scale-[0.98]"
        ratio="auto"
      />
    </div>

    {/* Thumbnails (Mobile - Horizontal Scroll) */}
    <div class="flex gap-2 overflow-x-auto pb-3 pt-1 px-1 custom-scrollbar">
      {images.map((image) => (
        <button
          type="button"
          @click={`activeImage = ${JSON.stringify(image)}`}
          class="aspect-4/5 w-20 shrink-0 overflow-hidden rounded-md bg-(--color-surface) transition-all duration-300 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--color-ring) cursor-pointer disabled:cursor-not-allowed border-2 border-transparent"
          :class={`activeImage === ${JSON.stringify(image)} ? 'border-(--color-accent) opacity-100' : 'opacity-40 hover:opacity-80'`}
        >
          <Image
            src={image}
            alt={`${alt} thumbnail`}
            class="h-full w-full object-cover"
          />
        </button>
      ))}
    </div>
  </div>

  {/* Desktop Layout: Thumbnails Left, Main Image Right */}
  <div class="hidden gap-4 lg:flex lg:flex-row lg:max-h-[85vh]">
    <div class="flex w-22 shrink-0 flex-col gap-3 overflow-y-auto px-1 py-1 custom-scrollbar">
      {images.map((image) => (
        <button
          type="button"
          @click={`activeImage = ${JSON.stringify(image)}`}
          class="aspect-4/5 w-20 shrink-0 overflow-hidden rounded-md bg-(--color-surface) transition-all duration-300 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--color-ring) cursor-pointer disabled:cursor-not-allowed border-2 border-transparent"
          :class={`activeImage === ${JSON.stringify(image)} ? 'border-(--color-accent) opacity-100' : 'opacity-40 hover:opacity-80'`}
        >
          <Image
            src={image}
            alt={`${alt} thumbnail`}
            class="h-full w-full object-cover"
          />
        </button>
      ))}
    </div>

    <div class="relative aspect-4/5 flex-1 overflow-hidden rounded-lg bg-(--color-surface)">
      <Image
        src={images[0]}
        :src="activeImage"
        alt={alt}
        @click={`$dispatch('open-lightbox', { src: activeImage, alt: ${JSON.stringify(alt)} })`}
        class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02] cursor-zoom-in active:scale-[0.98]"
        ratio="auto"
      />
    </div>
  </div>
</div>
