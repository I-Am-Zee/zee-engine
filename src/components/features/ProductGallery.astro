---
interface Props {
  images: string[];
  alt: string;
  class?: string;
}

import Image from "../primitives/Image.astro";

const { images, alt, class: className = "" } = Astro.props;
---

<div
  class={`product-gallery ${className}`}
  x-data=`{ activeImage: '${images[0]}' }`
>
  {/* Mobile Layout: Main Image Top, Thumbnails Bottom */}
  <div class="flex flex-col gap-4 lg:hidden">
    <div class="relative aspect-4/5 max-h-[70vh] overflow-hidden rounded-lg bg-(--color-surface)">
      <img
        :src="activeImage"
        alt={alt}
        @click={`$dispatch('open-lightbox', { src: activeImage, alt: '${alt}' })`}
        class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02] cursor-zoom-in active:scale-[0.98]"
      />
    </div>

    {/* Thumbnails (Mobile - Horizontal Scroll) */}
    <div class="flex gap-2 overflow-x-auto pb-3 pt-1 px-1">
      {images.map((image) => (
        <button
          type="button"
          @click={`activeImage = '${image}'`}
          class="aspect-4/5 w-20 shrink-0 overflow-hidden rounded-md bg-(--color-surface) transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--color-ring) cursor-pointer disabled:cursor-not-allowed"
          :class={`activeImage === '${image}' ? 'ring-2 ring-accent-brass opacity-100 scale-105 z-10' : 'opacity-40 hover:opacity-80'`}
        >
          <Image
            src={image}
            alt={`${alt} thumbnail`}
            class="h-full w-full object-cover"
          />
        </button>
      ))}
    </div>
  </div>

  {/* Desktop Layout: Thumbnails Left, Main Image Right */}
  <div class="hidden gap-4 lg:flex lg:flex-row lg:max-h-[85vh]">
    <div class="flex w-22 shrink-0 flex-col gap-3 overflow-y-auto px-1 py-1">
      {images.map((image) => (
        <button
          type="button"
          @click={`activeImage = '${image}'`}
          class="aspect-4/5 w-20 shrink-0 overflow-hidden rounded-md bg-(--color-surface) transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-(--color-ring) cursor-pointer disabled:cursor-not-allowed"
          :class={`activeImage === '${image}' ? 'ring-2 ring-accent-brass opacity-100 scale-105 z-10' : 'opacity-40 hover:opacity-80'`}
        >
          <Image
            src={image}
            alt={`${alt} thumbnail`}
            class="h-full w-full object-cover"
          />
        </button>
      ))}
    </div>

    <div class="relative aspect-4/5 flex-1 overflow-hidden rounded-lg bg-(--color-surface)">
      <img
        :src="activeImage"
        alt={alt}
        @click={`$dispatch('open-lightbox', { src: activeImage, alt: '${alt}' })`}
        class="h-full w-full object-cover transition-transform duration-300 hover:scale-[1.02] cursor-zoom-in active:scale-[0.98]"
      />
    </div>
  </div>
</div>

<style>
  /* Custom scrollbar for thumbnails */
  .product-gallery ::-webkit-scrollbar {
    width: 4px;
    height: 4px;
  }

  .product-gallery ::-webkit-scrollbar-track {
    background: var(--color-surface);
    border-radius: 2px;
  }

  .product-gallery ::-webkit-scrollbar-thumb {
    background: var(--color-border-strong);
    border-radius: 2px;
  }

  .product-gallery ::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-muted);
  }
</style>
