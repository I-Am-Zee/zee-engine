---
import Carousel from "../ui/Carousel.astro";
import Image from "../primitives/Image.astro";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  lookbooks: CollectionEntry<"lookbooks">[];
  class?: string;
}

const { lookbooks, class: className } = Astro.props;

const options = { 
  perPage: 3, 
  gap: 32, 
  type: lookbooks.length > 3 ? 'loop' : 'slide', 
  pagination: true, 
  breakpoints: { 
    1024: { perPage: 2, gap: 24 }, 
    768: { perPage: 2, gap: 16, padding: { left: '1rem', right: '2rem' } },
    640: { perPage: 1, gap: 16, padding: { left: '1rem', right: '5rem' } }
  } 
};
---

<Carousel 
  options={options} 
  class:list={["w-[calc(100%+2rem)] -mx-4 md:w-full md:mx-0 pb-16 related-carousel", className]}
  trackClass="py-4"
  showArrows={lookbooks.length > 3}
>
  {lookbooks.map(lb => (
    <li class="splide__slide flex justify-center h-auto">
    <a href={`/lookbooks/${lb.id}`} class="group block relative w-full aspect-4/5 overflow-hidden rounded-3xl bg-black focus-glow">
        <Image src={lb.data.hero_image} alt={lb.data.title} class="absolute inset-0 w-full h-full object-cover opacity-70 transition-transform duration-1000 group-hover:scale-[1.05]" />
        <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-black/10"></div>
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center p-8">
          <Text variant="caption" class="text-accent-brass mb-3 uppercase tracking-widest block font-bold drop-shadow-md">Editorial Story</Text>
          <Heading as="h3" class="text-white font-serif tracking-tight text-3xl md:text-4xl mb-6 drop-shadow-lg">{lb.data.title}</Heading>
          <div class="h-0.5 w-12 bg-white/50 mx-auto group-hover:w-24 group-hover:bg-accent-brass transition-all duration-500"></div>
        </div>
      </a>
    </li>
  ))}
</Carousel>
