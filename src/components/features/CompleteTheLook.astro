---
/**
 * CompleteTheLook - Feature Organism
 *
 * Displays CMS-controlled related products as upsells.
 * Fetches its own data via getCollection() and orchestrates
 * ProductCarousel, BuySetButton, and SectionHeader.
 *
 * Moved from ui/ to features/ (Atomic Design: Organism, not Molecule).
 * A Molecule cannot call getCollection() or import other Organisms.
 *
 * @component Organism (features/)
 */

import { getCollection, getEntry, type CollectionEntry } from "astro:content";
import { mapProduct } from "../../config/ecommerce";
import ProductCarousel from "./ProductCarousel.astro";
import BuySetButton from "./BuySetButton.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import Section from "../primitives/Section.astro";
import Text from "../primitives/Text.astro";

interface Props {
  productSlugs: string[];
  currentProduct?: {
    id: string;
    title: string;
    price: number;
    salePrice?: number;
    image: string;
  };
  class?: string;
}

const { productSlugs, currentProduct, class: className } = Astro.props;

// Load Component Header (Hub Strategy)
const header = await getEntry("section_headers", "pdp-upsell");
const data = header?.data || {
  title: "Heading Level 3",
  subtitle: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
  action_label: "Action Button"
};

const isAffiliate = import.meta.env.PUBLIC_AFFILIATE === "true";

// Get all products and filter by slugs
const allProducts = await getCollection("products");
const relatedProducts = productSlugs
  .map((slug) => allProducts.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => !!p)
  .slice(0, 4); // Max 4 products

// Transform for BuySetButton
const productsForButton = ([
  // Include the MAIN product
  ...(currentProduct ? [allProducts.find(p => p.id === currentProduct.id)].filter((p): p is CollectionEntry<"products"> => !!p) : []),
  // Then the related products
  ...relatedProducts
] as CollectionEntry<"products">[]);
---

{
  relatedProducts.length > 0 && (
    <Section 
      variant="standard"
      class={`mt-12 md:mt-16 border-t border-(--color-border-subtle) ${className || ""}`}
      id="perfect-pairings"
    >
      <script is:inline define:vars={{ 
        relatedItems: productsForButton.slice(1).map(item => mapProduct(item))
      }}>
        // Expose related products for the Upsell Drawer with relative URLs
        // This ensures Snipcart's crawler resolves them against the CURRENT origin (tunnel, dev, or production)
        window.ENGINE_UPSELL_CONTEXT = relatedItems.map(item => ({
          ...item,
          url: `/products/${item.id}`
        }));
      </script>

      <SectionHeader 
        title={data.title} 
        subtitle={data.subtitle}
        align="left"
        class="mb-10 lg:mb-14"
      >
        {!isAffiliate && (
          <Text variant="metadata" weight="bold" class="mt-2 block uppercase">
            {productsForButton.length} Items Total
          </Text>
        )}
        {data.button_mode === "feature" && (
          <Fragment slot="action">
            <BuySetButton 
              products={productsForButton} 
              label={data.action_label}
              class="w-full" 
              hideSavingsText={true} 
            />
          </Fragment>
        )}
      </SectionHeader>

      <ProductCarousel products={relatedProducts} columns={4} />
    </Section>
  )
}
