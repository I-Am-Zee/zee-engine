---
/**
 * TableOfContents - Atomic Organism
 * 
 * A dual-mode component that renders:
 * 1. A sticky sidebar on desktop (above 1024px)
 * 2. A floating sticky pill on mobile (below 1024px)
 * 
 * Features dynamic accordion nesting and scroll-synchronized highlighting.
 */

import Icon from "../primitives/Icon.astro";
import Text from "../primitives/Text.astro";
import { nestHeadings, type RawHeading } from "../../scripts/utils/headings";

interface Props {
  headings: RawHeading[];
}

const { headings } = Astro.props;
const nestedHeadings = nestHeadings(headings);
---

{/* Desktop Sidebar (lg+) */}
<nav class="hidden lg:block w-full pr-4" aria-label="Table of Contents">
  <Text variant="metadata" weight="bold" color="muted" class="mb-6 block uppercase tracking-widest text-xs">
    IN THIS ARTICLE
  </Text>

  <ul class="space-y-4 relative border-l border-(--color-border-subtle)/30 ml-1">
    {nestedHeadings.map((h2) => (
      <li class="group/h2-item" data-toc-group={h2.slug}>
        <a
          href={`#${h2.slug}`}
          class:list={[
            "block transition-all duration-300 -ml-[1.5px] border-l-2 border-transparent pl-4 py-1 text-[0.9375rem] font-medium text-(--color-text-muted)",
            "hover:text-(--color-primary)",
            "data-[toc-active=true]:text-(--color-primary) data-[toc-active=true]:font-bold data-[toc-active=true]:border-(--color-primary)"
          ]}
        >
          {h2.text}
        </a>

        {h2.children.length > 0 && (
          <ul 
            class="mt-2 space-y-2 overflow-hidden transition-all duration-500 ease-in-out max-h-0 opacity-0 group-[.is-active-group]/h2-item:max-h-[500px] group-[.is-active-group]/h2-item:opacity-100 lg:max-h-none lg:opacity-100"
          >
            {h2.children.map((h3) => (
              <li>
                <a
                  href={`#${h3.slug}`}
                  class:list={[
                    "block transition-all duration-200 pl-8 py-0.5 text-[0.85rem] text-(--color-text-muted)/60",
                    "hover:text-(--color-primary)",
                    "lg:group-[.is-active-group]/h2-item:text-(--color-text-muted)/90",
                    "data-[toc-active=true]:text-(--color-primary)! data-[toc-active=true]:font-semibold"
                  ]}
                >
                  {h3.text}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
</nav>

{/* Mobile TOC Container (< lg) */}
<div 
  id="toc-mobile-bar"
  class="lg:hidden"
  x-data="{ open: false }"
>
  {/* Floating Pill Trigger */}
  <div 
    class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 transition-all duration-500 translate-y-20 opacity-0 pointer-events-none data-[toc-visible=true]:translate-y-0 data-[toc-visible=true]:opacity-100 data-[toc-visible=true]:pointer-events-auto"
    id="toc-mobile-trigger"
  >
    <button 
      @click="open = !open"
      class="flex items-center gap-3 px-6 py-3 bg-(--color-background) rounded-full border border-(--color-border-subtle) shadow-2xl text-sm font-semibold text-(--color-text-main) transition-all active:scale-95"
    >
      <Icon name="PhList" />
      <span>Contents</span>
      <Icon 
        name="PhCaretUp" 
        class="transition-transform duration-300" 
        x-bind:class="open ? 'rotate-180' : ''" 
      />
    </button>
  </div>

  {/* Backdrop */}
  <div 
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 bg-black/40 z-[110]"
    @click="open = false"
  ></div>

  {/* Content Sheet */}
  <div 
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-y-full"
    x-transition:enter-end="translate-y-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-y-0"
    x-transition:leave-end="translate-y-full"
    class="fixed bottom-0 left-0 right-0 z-[120] h-[70vh] bg-(--color-background) rounded-t-[2.5rem] shadow-2xl flex flex-col border-t border-(--color-border-subtle)/30"
  >
    {/* Handle */}
    <div class="w-12 h-1 bg-(--color-border-subtle)/50 rounded-full mx-auto mt-4 mb-2"></div>

    <div class="px-8 py-4 flex justify-between items-center border-b border-(--color-border-subtle)/20">
      <Text variant="metadata" weight="bold" color="muted" class="uppercase tracking-widest">
        Table of Contents
      </Text>
      <button @click="open = false" class="p-2 -mr-2 text-(--color-text-muted) hover:text-(--color-text-main) transition-colors">
        <Icon name="PhX" size={24} />
      </button>
    </div>
    
    <div class="flex-1 overflow-y-auto overscroll-contain p-8 pb-32">
      <ul class="space-y-4 relative border-l border-(--color-border-subtle)/30 ml-1">
        {nestedHeadings.map((h2) => (
          <li class="group/h2-item" data-toc-group={h2.slug}>
            <a
              href={`#${h2.slug}`}
              @click="open = false"
              class:list={[
                "block transition-all duration-300 -ml-[1.5px] border-l-2 border-transparent pl-4 py-1 text-[0.9375rem] font-medium text-(--color-text-muted)",
                "hover:text-(--color-primary)",
                "data-[toc-active=true]:text-(--color-primary) data-[toc-active=true]:font-bold data-[toc-active=true]:border-(--color-primary)"
              ]}
            >
              {h2.text}
            </a>

            {h2.children.length > 0 && (
              <ul 
                class="mt-2 space-y-2 overflow-hidden transition-all duration-500 ease-in-out max-h-0 opacity-0 group-[.is-active-group]/h2-item:max-h-[500px] group-[.is-active-group]/h2-item:opacity-100"
              >
                {h2.children.map((h3) => (
                  <li>
                    <a
                      href={`#${h3.slug}`}
                      @click="open = false"
                      class:list={[
                        "block transition-all duration-200 pl-8 py-0.5 text-[0.85rem] text-(--color-text-muted)/70",
                        "hover:text-(--color-primary)",
                        "data-[toc-active=true]:text-(--color-primary) data-[toc-active=true]:font-semibold"
                      ]}
                    >
                      {h3.text}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<script>
  import { initTOC } from '../../scripts/behaviors/toc';
  
  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => initTOC());
  } else {
    initTOC();
  }
</script>
