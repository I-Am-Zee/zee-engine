---
/**
 * LookbookCarousel - Editorial Showcase
 * 
 * Displays multiple lookbooks in a horizontal carousel with 
 * smooth transitions and navigation controls.
 * 
 * @component Feature (features/)
 */

import { getCollection } from "astro:content";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";
import Carousel from "../ui/Carousel.astro";

const lookbooks = await getCollection("lookbooks");
---

<section class="relative bg-black py-24 px-4 lg:px-8 overflow-hidden">
  <div class="relative mx-auto max-w-7xl h-150 md:h-175">
    <Carousel 
      x-data="carousel"
      class="h-full rounded-2xl overflow-hidden"
    >
      {lookbooks.map((lookbook, index) => (
        <li class="splide__slide shrink-0 w-full m-0 relative list-none h-full">
          {/* Background Image */}
          <div class="absolute inset-0 z-0">
            <img 
              src={lookbook.data.hero_image} 
              alt={lookbook.data.title} 
              class="h-full w-full object-cover object-center brightness-50 transition-transform duration-1000 ease-out"
              x-bind:class={`currentIndex === ${index} ? 'scale-100 opacity-100' : 'scale-105 opacity-0'`}
            />
          </div>

          <div class="relative z-10 flex h-full flex-col items-center justify-center p-6 text-center text-white md:p-12">
            <Text variant="caption" color="inverse" class="text-white/70 uppercase tracking-widest mb-4">Editorial</Text>
            <Heading as="h2" color="inverse" class="mb-6 uppercase">
              {lookbook.data.title}
            </Heading>
            <Text variant="paragraph" color="inverse" class="mb-10 max-w-2xl text-lg md:text-xl italic font-serif opacity-90">
              "{lookbook.data.description}"
            </Text>
            <Button 
              as="a" 
              href={`/lookbooks/${lookbook.slug || lookbook.id}`}
              type="primary"
              variant="default"
              size="lg" 
              class="bg-white text-black hover:bg-gray-100 px-12 transition-all capitalize"
            >
              Explore Lookbook
            </Button>
          </div>
        </li>
      ))}

      {/* Custom Slide Indicators */}
      <div slot="indicators" class="absolute bottom-8 left-1/2 z-20 flex -translate-x-1/2 gap-3">
        {lookbooks.map((_, index) => (
          <button 
            @click={`goTo(${index})`}
            class="h-1.5 transition-all duration-300 rounded-full bg-white"
            x-bind:class={`currentIndex === ${index} ? 'w-8 opacity-100' : 'w-2 opacity-40 hover:opacity-60'`}
            title={`Go to slide ${index + 1}`}
          ></button>
        ))}
      </div>
    </Carousel>
  </div>
</section>

<script>
  import "../../scripts/behaviors/carousel";
</script>


