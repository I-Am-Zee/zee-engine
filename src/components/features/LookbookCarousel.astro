---
import { getCollection, getEntry } from "astro:content";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Button from "../primitives/Button.astro";
import Carousel from "../ui/Carousel.astro";
import Image from "../primitives/Image.astro";

interface Props {
  class?: string;
}

const { class: className, ...rest } = Astro.props;

// ── Smart Logic: Self-Fetching (Component Hub Strategy) ──
const lookbooks = await getCollection("lookbooks");
const lookbookHeader = await getEntry("page_headers", "lookbook-index");
const lookbookLabels = await getEntry("settings", "lookbook_settings");

const header = {
  title: lookbookHeader?.data?.title || "Editorial Showcase",
  subtitle: lookbookHeader?.data?.subtitle || "Explore our latest lifestyle and lookbook collections."
};

const eyebrowLabel = lookbookLabels?.data?.carousel_eyebrow || "Curated Story";
const ctaLabel = lookbookLabels?.data?.carousel_cta_label || "Explore Look";
---

<section class="relative bg-surface/30 py-32 px-4 lg:px-8 overflow-hidden">
  <div class="relative mx-auto max-w-7xl h-150 sm:h-140 md:h-175">
    <Carousel 
      options={{}}
      class="h-full rounded-[2.5rem] overflow-hidden shadow-2xl border border-border-subtle/50"
    >
      {lookbooks.map((lookbook, index) => (
        <li class="splide__slide shrink-0 w-full m-0 relative list-none h-full bg-surface-muted">
          {/* Background Image */}
          <div class="absolute inset-0 z-0 overflow-hidden">
            <Image 
              src={lookbook.data.hero_image}
              loading="eager"
              fetchpriority="high"
              sizes="(max-width: 768px) 100vw, 1200px"
              alt={lookbook.data.title} 
              class="lookbook-bg h-full w-full object-cover object-center brightness-95 absolute inset-0"
            />
            {/* Subtle Gradient Overlay for depth */}
            <div class="absolute inset-x-0 bottom-0 h-2/3 bg-linear-to-t from-black/20 to-transparent"></div>
          </div>

          {/* Luxury Glassmorphic Content Card */}
          <div class="absolute inset-0 z-10 flex items-center justify-center p-4 pb-14 md:p-12">
            <div 
              class="lookbook-card max-w-2xl w-full bg-surface/60 backdrop-blur-xl border border-white/30 p-8 md:p-16 rounded-4xl shadow-[0_32px_64px_-16px_rgba(0,0,0,0.2)] text-center flex flex-col items-center"
            >
              <Text variant="eyebrow" class="mb-6 inline-block border-b border-accent-brass/40 pb-2 [text-shadow:0.5px_0.5px_0px_rgba(5,43,34,0.3)] [box-shadow:0_0.5px_0_0_rgba(5,43,34,0.2)]">
                {eyebrowLabel}
              </Text>
              
              <Heading as="h2" class="mb-4">
                {lookbook.data.title}
              </Heading>
              
              <Text variant="lead" color="muted" class="mb-10 max-w-lg opacity-90">
                {lookbook.data.description}
              </Text>
              
              <Button 
                as="a" 
                href={`/lookbooks/${lookbook.id}`}
                type="primary"
                size="md"
              >
                {ctaLabel}
              </Button>
            </div>
          </div>
        </li>
      ))}

      {/* Custom Slide Indicators - Refined for Luxury */}
      <div slot="indicators" class="absolute bottom-6 md:bottom-12 left-1/2 z-20 flex -translate-x-1/2 gap-4 items-center bg-white/10 backdrop-blur-md px-6 py-3 rounded-full border border-white/20">
        {lookbooks.map((_, index) => (
          <button 
            @click={`goTo(${index})`}
            class="h-1 transition-all duration-500 rounded-full cursor-pointer disabled:cursor-not-allowed"
            x-bind:class={`currentIndex === ${index} ? 'w-10 bg-accent-brass' : 'w-2 bg-white/40 hover:bg-white/60'`}
            title={`Go to slide ${index + 1}`}
          ></button>
        ))}
      </div>
    </Carousel>
  </div>
</section>

<style>
  /* Splide native CSS Transition Overrides - Handles clones perfectly */
  .lookbook-bg {
    transform: scale(1.1);
    transition: transform 2000ms cubic-bezier(0.19, 1, 0.22, 1);
  }
  :global(.splide__slide.is-active) .lookbook-bg {
    transform: scale(1);
  }
  
  .lookbook-card {
    opacity: 0;
    transform: translateY(3rem) scale(0.95);
    filter: blur(4px);
    transition: all 1000ms cubic-bezier(0.23, 1, 0.32, 1);
    pointer-events: none;
  }
  :global(.splide__slide.is-active) .lookbook-card {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
    transition-delay: 300ms;
    pointer-events: auto;
  }
</style>
