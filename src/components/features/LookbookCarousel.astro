---
/**
 * LookbookCarousel - Editorial Showcase
 * 
 * Displays multiple lookbooks in a horizontal carousel with 
 * smooth transitions and navigation controls.
 * 
 * @component Feature (features/)
 */

import { getCollection } from "astro:content";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";

const lookbooks = await getCollection("lookbooks");
---

<section 
  class="relative bg-black py-24 px-4 lg:px-8 overflow-hidden"
  x-data="lookbookCarousel"
>
  <div class="relative mx-auto max-w-7xl h-150 md:h-175">
    {/* Slides Container */}
    <div 
      class="relative h-full w-full overflow-hidden rounded-2xl"
      x-ref="slides"
    >
      {lookbooks.map((lookbook, index) => (
        <div 
          class="absolute inset-0 w-full h-full"
          x-show={`currentIndex === ${index}`}
          x-transition:enter="transition ease-out duration-700 transform"
          x-transition:enter-start="opacity-0 translate-x-full"
          x-transition:enter-end="opacity-100 translate-x-0"
          x-transition:leave="transition ease-in duration-700 transform"
          x-transition:leave-start="opacity-100 translate-x-0"
          x-transition:leave-end="opacity-0 -translate-x-full"
          style={index !== 0 ? "display: none;" : ""}
        >
          {/* Background Image */}
          <div class="absolute inset-0 z-0">
            <img 
              src={lookbook.data.hero_image} 
              alt={lookbook.data.title} 
              class="h-full w-full object-cover object-center brightness-50 transition-transform duration-10000 ease-linear scale-110"
              x-bind:class={`currentIndex === ${index} ? 'scale-100' : 'scale-110'`}
            />
          </div>

          {/* Content Overlay */}
          <div class="relative z-10 flex h-full flex-col items-center justify-center p-6 text-center text-white md:p-12">
            <Text variant="caption" class="text-white/70 uppercase tracking-widest mb-4">Editorial</Text>
            <Heading as="h2" class="mb-6 uppercase">
              {lookbook.data.title}
            </Heading>
            <Text class="mb-10 max-w-2xl text-lg md:text-xl text-gray-200 italic font-serif">
              "{lookbook.data.description}"
            </Text>
            <Button 
              as="a" 
              href={`/lookbooks/${lookbook.slug || lookbook.id}`}
              size="lg" 
              class="bg-white text-black hover:bg-gray-100 px-12 transition-all hover:tracking-widest capitalize"
            >
              Explore Lookbook
            </Button>
          </div>
        </div>
      ))}
    </div>

    {/* Navigation Arrows */}
    <div class="absolute inset-y-0 left-4 right-4 z-20 flex items-center justify-between pointer-events-none">
      <Button 
        type="ghost" 
        variant="icon-only" 
        size="lg"
        @click="prev()"
        class="pointer-events-auto bg-black/20 text-white hover:bg-white/20 backdrop-blur-md border border-white/10 rounded-full"
      >
        <Icon name="PhCaretLeft" size={24} weight="bold" />
      </Button>
      <Button 
        type="ghost" 
        variant="icon-only" 
        size="lg"
        @click="next()"
        class="pointer-events-auto bg-black/20 text-white hover:bg-white/20 backdrop-blur-md border border-white/10 rounded-full"
      >
        <Icon name="PhCaretRight" size={24} weight="bold" />
      </Button>
    </div>

    {/* Slide Indicators */}
    <div class="absolute bottom-8 left-1/2 z-20 flex -translate-x-1/2 gap-3">
      {lookbooks.map((_, index) => (
        <button 
          @click={`goTo(${index})`}
          class="h-1.5 transition-all duration-300 rounded-full"
          class:list={[
            "bg-white",
          ]}
          x-bind:class={`currentIndex === ${index} ? 'w-8 opacity-100' : 'w-2 opacity-40 hover:opacity-60'`}
          title={`Go to slide ${index + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<script>
  // Import the behavior script to ensure it's bundled and registered
  import "../../scripts/behaviors/lookbook-carousel";
</script>

<style>
  [x-cloak] { display: none !important; }
</style>
