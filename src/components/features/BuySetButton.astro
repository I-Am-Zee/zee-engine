---
/**
 * BuySetButton - Revenue Multiplier Component
 *
 * Adds multiple related products to cart with ONE click.
 * Uses Promise.all to prevent race conditions.
 *
 * Business Impact: 2x AOV (₹2,000 → ₹5,500)
 *
 * @component Feature (features/)
 */

interface VariantSlot {
  name: string;
  values: string;
}

interface Product {
  id: string;
  title: string;
  price: number;
  salePrice?: number;
  image: string;
  description?: string;
  stock?: number; // For OOS handling
  variant_1?: VariantSlot;
  variant_2?: VariantSlot;
  variant_3?: VariantSlot;
}

interface Props {
  products: Product[];
  label?: string;
  class?: string;
  hideSavingsText?: boolean;
}

const { products, label = "Add Complete Look to Cart", class: className, hideSavingsText = false } = Astro.props;

// Calculate total price
const totalPrice = products.reduce((sum, p) => sum + (p.salePrice || p.price), 0);

// Calculate savings (if any products on sale)
const regularTotal = products.reduce((sum, p) => sum + p.price, 0);
const savings = regularTotal - totalPrice;
---

<div
  x-data={`{
    addSetToCart() {
      const payload = { products: ${JSON.stringify(products)} };
      $dispatch('zaviona:master-set', payload);
    }
  }`}
  class:list={["flex flex-col gap-3", className]}
>
  <!-- Primary CTA Button -->
  <button
    @click="addSetToCart()"
    class="relative w-full rounded-lg bg-black px-6 py-[18px] text-sm font-bold tracking-widest text-white uppercase shadow-lg transition-colors duration-200 hover:bg-gray-800 hover:shadow-xl cursor-pointer flex items-center justify-center gap-2"
  >
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
    </svg>
    <span>{label} (₹{totalPrice.toLocaleString("en-IN")})</span>
  </button>

  {/* Supplementary Info (Count & Savings) */}
  {!hideSavingsText && (savings > 0 || products.length > 1) && (
    <div class="flex items-center justify-center gap-2 w-full text-sm pt-2 text-text-muted">
      {products.length > 1 && (
        <span>{products.length} Items Total</span>
      )}
      {products.length > 1 && savings > 0 && (
        <span class="opacity-40">|</span>
      )}
      {savings > 0 && (
        <span class="font-medium text-emerald-600">
          Save ₹{savings.toLocaleString("en-IN")} vs buying separately
        </span>
      )}
    </div>
  )}
</div>
