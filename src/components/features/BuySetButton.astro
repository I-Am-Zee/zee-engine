---
/**
 * BuySetButton - Revenue Multiplier Component
 *
 * Adds multiple related products to cart with ONE click.
 * Uses Promise.all to prevent race conditions.
 *
 * Business Impact: 2x AOV (₹2,000 → ₹5,500)
 *
 * @component Feature (features/)
 */

import type { CollectionEntry } from "astro:content";
import { mapProduct } from "../../config/ecommerce";
import Button from "../primitives/Button.astro";
import Icon from "../primitives/Icon.astro";

interface Props {
  products: CollectionEntry<"products">[] | any[];
  label?: string;
  class?: string;
  hideSavingsText?: boolean;
}

const { 
  products, 
  label = "Add Complete Look to Cart", 
  class: className, 
  hideSavingsText = false 
} = Astro.props;

// Flatten to plain client-safe objects BEFORE serialization
// This is crucial — raw CollectionEntry objects serialize as { slug, data: {...} }
// which the client-side SideDrawer cannot read.
const flatProducts = products.map(p => mapProduct(p));

// Calculate total price from flat objects
const totalPrice = flatProducts.reduce((sum, p) => sum + (p.salePrice || p.price || 0), 0);
const regularTotal = flatProducts.reduce((sum, p) => sum + (p.price || 0), 0);
const savings = regularTotal - totalPrice;
---

<div
  x-data={`{
    addSetToCart() {
      const payload = { products: ${JSON.stringify(flatProducts)} };
      $dispatch('engine:master-set', payload);
    }
  }`}
  class:list={["flex flex-col gap-3", className]}
>
  <!-- Primary CTA Button -->
  <Button
    type="primary"
    size="lg"
    @click="addSetToCart()"
    class="w-full py-4 uppercase tracking-[0.2em] text-xs font-bold shadow-md shadow-primary/10 hover:shadow-lg hover:shadow-primary/20 transition-all duration-300"
  >
    <Icon name="PhShoppingBagOpen" size={20} weight="bold" />
    <span>{label} (₹{totalPrice.toLocaleString("en-IN")})</span>
  </Button>

  {/* Supplementary Info (Count & Savings) */}
  {!hideSavingsText && (savings > 0 || products.length > 1) && (
    <div class="flex items-center justify-center gap-2 w-full text-sm pt-2 text-(--color-text-muted)">
      {products.length > 1 && (
        <span>{products.length} Items Total</span>
      )}
      {products.length > 1 && savings > 0 && (
        <span class="opacity-40">|</span>
      )}
      {savings > 0 && (
        <span class="font-medium text-(--color-success)">
          Save ₹{savings.toLocaleString("en-IN")} vs buying separately
        </span>
      )}
    </div>
  )}
</div>
