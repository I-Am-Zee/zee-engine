---
/**
 * FreeShippingNudge - Conversion Optimizer
 *
 * Displays progress bar and message encouraging customers
 * to add more items to qualify for free shipping.
 *
 * Business Impact: Drives cart value to hit free shipping threshold
 *
 * @component Feature (features/)
 */

interface Props {
  threshold?: number; // Free shipping threshold (default ₹10,000)
  class?: string;
}

const { threshold = 10000, class: className } = Astro.props;
---

<div
  x-data={`{
    cartTotal: 0,
    threshold: ${threshold},

    get amountNeeded() {
      return Math.max(0, this.threshold - this.cartTotal);
    },

    get progressPercent() {
      return Math.min(100, (this.cartTotal / this.threshold) * 100);
    },

    get isQualified() {
      return this.cartTotal >= this.threshold;
    },

    updateCartTotal() {
      if (typeof Snipcart === 'undefined') return;
      const state = Snipcart.store.getState();
      this.cartTotal = state.cart.total || 0;
    },

    init() {
      if (typeof Snipcart !== 'undefined') {
        Snipcart.events.on('snipcart.ready', () => { this.updateCartTotal(); });
        Snipcart.events.on('item.added',     () => this.updateCartTotal());
        Snipcart.events.on('item.removed',   () => this.updateCartTotal());
        Snipcart.events.on('cart.confirmed', () => this.updateCartTotal());
      }
    }
  }`}
  x-init="init()"
  class:list={[
    "p-4 sm:px-5 bg-(--color-surface) border-l-3 border-(--color-accent-brass) rounded-xs animate-nudge-in", 
    className
  ]}
>

  <!-- Qualified: Dopamine hit — success state -->
  <div x-show="isQualified" class="flex items-center gap-3" x-cloak>
    <svg class="w-6 h-6 shrink-0 text-(--color-accent-emerald)" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
    </svg>
    <div class="flex-1">
      <p class="text-sm font-semibold text-(--color-text-main) m-0">🎉 Free shipping unlocked!</p>
      <p class="text-xs text-(--color-text-muted) mt-0.5 m-0">Your order ships at no extra cost</p>
    </div>
  </div>

  <!-- Progress: Motivation state -->
  <div x-show="!isQualified" class="flex flex-col gap-2" x-cloak>
    <div class="flex items-center justify-between">
      <p class="text-[0.8125rem] font-medium text-(--color-text-muted) m-0">
        <span class="font-bold text-(--color-accent-brass)" x-text="`₹${amountNeeded.toLocaleString('en-IN')}`"></span>
        away from free shipping
      </p>
      <svg class="w-5 h-5 shrink-0 text-(--color-accent-brass)" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
      </svg>
    </div>

    <!-- Progress Bar -->
    <div class="w-full h-1 bg-(--color-border-subtle) rounded-xs overflow-hidden" role="progressbar" :aria-valuenow="progressPercent" aria-valuemin="0" aria-valuemax="100">
      <div class="h-full bg-linear-to-r from-(--color-primary) to-(--color-accent-brass) rounded-xs transition-[width] duration-500 ease-out" :style="`width: ${progressPercent}%`"></div>
    </div>

    <p class="text-[0.6875rem] text-(--color-text-muted) m-0 tracking-tight">
      Free shipping on orders above ₹<span x-text="threshold.toLocaleString('en-IN')"></span>
    </p>
  </div>

</div>
