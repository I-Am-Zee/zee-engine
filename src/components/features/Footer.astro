---
/**
 * Master Footer - Pure Engine Refined Layout
 * Airy Cream Theme.
 */

import { getEntry } from "astro:content";
import Logo from "../primitives/Logo.astro";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Link from "../primitives/Link.astro";
import Image from "../primitives/Image.astro";
import Icon from "../primitives/Icon.astro";
import Section from "../primitives/Section.astro";
import NewsletterForm from "../ui/NewsletterForm.astro";
import { slugify } from "../../scripts/utils/slugify";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

// Fetch Data
const siteSettings = await getEntry("settings", "brand");
const legalSettings = await getEntry("settings", "legal");
const navigationEntry = await getEntry("settings", "navigation");
const taxonomy = await getEntry("settings", "taxonomy");
const newsletterVariant = await getEntry("newsletter_variants", "footer");

const brandName = siteSettings?.data?.name || "Brand";
const legalEntity = legalSettings?.data?.legal_entity || (siteSettings?.data as any)?.legal_entity || brandName;

const socialLinks: any[] = siteSettings?.data?.social || [];
const copyright = `Copyright © ${new Date().getFullYear()} ${legalEntity}. All rights reserved.`;

const navigationData = navigationEntry?.data || { main_menus: [], support_links: [], legal_links: [], labels: {} };
const newsletterData = newsletterVariant?.data || { 
  heading: "Subscribe", 
  description: "", 
  placeholder: "Email", 
  button_text: "Join", 
  image: "" 
};

const columnHeaders = { 
  shop: "Shop", 
  explore: "Explore", 
  support: "Support", 
  social: "Social" 
};

const categories = (taxonomy?.data as any)?.categories || [];
const allJewelryLabel = (navigationData as any).labels?.allJewelry || "All Jewelry";

const shopCategories: any[] = [
  { label: allJewelryLabel, href: "/shop" },
  ...categories.map((cat: string) => ({
    label: cat.charAt(0).toUpperCase() + cat.slice(1),
    href: `/shop/${slugify(cat)}`,
  }))
];

const exploreLinks: any[] = navigationData.main_menus || [];
const supportLinks: any[] = navigationData.support_links || [];
const legalLinks: any[] = navigationData.legal_links || [];
---

<Section 
  as="footer" 
  variant="standard" 
  pt="pt-12 sm:pt-16" 
  pb="pb-0" 
  class={`bg-(--color-surface) text-(--color-text-main) ${className || ""}`}
>
  
  {/* ── Section 1: The Newsletter Card ───────────────── */}
  <div class="bg-(--color-background) rounded-xs overflow-hidden mb-16 sm:mb-20 lg:mb-24 border border-(--color-border-subtle) shadow-xs">
    <div class="flex flex-col md:flex-row">
      <div class="flex-1 p-4 pt-10 pb-10 sm:p-8 sm:pt-12 sm:pb-12 lg:p-14">
        <div class="max-w-md md:max-w-lg text-center md:text-left mx-auto md:mx-0">
          <Heading as="h2" color="main" class="mb-3 text-2xl sm:text-3xl lg:text-4xl">
            {newsletterData.heading}
          </Heading>
          <Text variant="body" color="muted" class="mb-8 text-sm sm:text-base leading-relaxed">
            {newsletterData.description}
          </Text>
          <div class="max-w-md md:max-w-lg mx-auto md:mx-0">
            <NewsletterForm 
              placeholder={newsletterData.placeholder} 
              buttonText={newsletterData.button_text}
              buttonType="primary"
            />
          </div>
        </div>
      </div>
      <div class="hidden md:block md:w-1/3 lg:w-2/5 relative">
        <Image src={newsletterData.image} alt={`${brandName} Editorial`} ratio="auto" class="absolute inset-0 w-full h-full object-cover" />
      </div>
    </div>
  </div>

  {/* ── Section 2: The Link Grid ────────── */}
  <div class="grid grid-cols-1 md:grid-cols-4 gap-10 lg:gap-12 mb-24">
    {/* Shop */}
    <div x-data="{ open: false }">
      <button class="flex w-full items-center justify-between py-4 border-b border-(--color-border-subtle) md:hidden" @click="open = !open">
        <Heading as="h5" color="main">{columnHeaders.shop}</Heading>
        <Icon name="PhCaretDown" class="h-4 w-4 text-(--color-text-muted) transition-transform duration-300" :class="open && 'rotate-180'" />
      </button>
      <Heading as="h5" size="h6" color="main" class="hidden md:block mb-8 uppercase tracking-[0.2em] font-bold opacity-80">{columnHeaders.shop}</Heading>
      <div x-show="open" x-collapse class="md:hidden!" x-cloak>
        <ul class="pt-2 border-l border-(--color-border-subtle) ml-1">
          {shopCategories.map((footerItem) => (
            <li><Link href={footerItem.href} variant="plain" class="block py-3 px-4 active:bg-(--color-surface-muted) transition-colors"><Text variant="caption" color="muted">{footerItem.label}</Text></Link></li>
          ))}
        </ul>
      </div>
      <ul class="hidden md:flex flex-col space-y-4">
        {shopCategories.map((footerItem) => (
          <li><Link href={footerItem.href} variant="plain" class="hover:translate-x-1 transition-transform inline-block group"><Text variant="caption" color="muted" class="group-hover:text-(--color-text-main) transition-colors">{footerItem.label}</Text></Link></li>
        ))}
      </ul>
    </div>

    {/* Explore */}
    <div x-data="{ open: false }">
      <button class="flex w-full items-center justify-between py-4 border-b border-(--color-border-subtle) md:hidden" @click="open = !open">
        <Heading as="h5" color="main">{columnHeaders.explore}</Heading>
        <Icon name="PhCaretDown" class="h-4 w-4 text-(--color-text-muted) transition-transform duration-300" :class="open && 'rotate-180'" />
      </button>
      <Heading as="h5" size="h6" color="main" class="hidden md:block mb-8 uppercase tracking-[0.2em] font-bold opacity-80">{columnHeaders.explore}</Heading>
      <div x-show="open" x-collapse class="md:hidden!" x-cloak>
        <ul class="pt-2 border-l border-(--color-border-subtle) ml-1">
          {exploreLinks.map((footerItem) => (
            <li><Link href={footerItem.href} variant="plain" class="block py-3 px-4 active:bg-(--color-surface-muted) transition-colors"><Text variant="caption" color="muted">{footerItem.label}</Text></Link></li>
          ))}
        </ul>
      </div>
      <ul class="hidden md:flex flex-col space-y-4">
        {exploreLinks.map((footerItem) => (
          <li><Link href={footerItem.href} variant="plain" class="hover:translate-x-1 transition-transform inline-block group"><Text variant="caption" color="muted" class="group-hover:text-(--color-text-main) transition-colors">{footerItem.label}</Text></Link></li>
        ))}
      </ul>
    </div>

    {/* Support */}
    <div x-data="{ open: false }">
      <button class="flex w-full items-center justify-between py-4 border-b border-(--color-border-subtle) md:hidden" @click="open = !open">
        <Heading as="h5" color="main">{columnHeaders.support}</Heading>
        <Icon name="PhCaretDown" class="h-4 w-4 text-(--color-text-muted) transition-transform duration-300" :class="open && 'rotate-180'" />
      </button>
      <Heading as="h5" size="h6" color="main" class="hidden md:block mb-8 uppercase tracking-[0.2em] font-bold opacity-80">{columnHeaders.support}</Heading>
      <div x-show="open" x-collapse class="md:hidden!" x-cloak>
        <ul class="pt-2 border-l border-(--color-border-subtle) ml-1">
          {supportLinks.map((footerItem) => (
            <li><Link href={footerItem.href} variant="plain" class="block py-3 px-4 active:bg-(--color-surface-muted) transition-colors"><Text variant="caption" color="muted">{footerItem.label}</Text></Link></li>
          ))}
        </ul>
      </div>
      <ul class="hidden md:flex flex-col space-y-4">
        {supportLinks.map((footerItem) => (
          <li><Link href={footerItem.href} variant="plain" class="hover:translate-x-1 transition-transform inline-block group"><Text variant="caption" color="muted" class="group-hover:text-(--color-text-main) transition-colors">{footerItem.label}</Text></Link></li>
        ))}
      </ul>
    </div>

    {/* Social */}
    <div x-data="{ open: false }">
      <button class="flex w-full items-center justify-between py-4 border-b border-(--color-border-subtle) md:hidden" @click="open = !open">
        <Heading as="h5" color="main">{columnHeaders.social}</Heading>
        <Icon name="PhCaretDown" class="h-4 w-4 text-(--color-text-muted) transition-transform duration-300" :class="open && 'rotate-180'" />
      </button>
      <Heading as="h5" size="h6" color="main" class="hidden md:block mb-8 uppercase tracking-[0.2em] font-bold opacity-80">{columnHeaders.social}</Heading>
      <div x-show="open" x-collapse class="md:hidden!" x-cloak>
        <ul class="pt-2 border-l border-(--color-border-subtle) ml-1">
          {socialLinks.map((footerItem) => (
            <li><Link href={footerItem.url} variant="plain" target="_blank" class="block py-3 px-4 active:bg-(--color-surface-muted) transition-colors"><Text variant="caption" color="muted">{footerItem.platform}</Text></Link></li>
          ))}
        </ul>
      </div>
      <ul class="hidden md:flex flex-col space-y-4">
        {socialLinks.map((footerItem) => (
          <li><Link href={footerItem.url} variant="plain" target="_blank" class="hover:translate-x-1 transition-transform inline-block group"><Text variant="caption" color="muted" class="group-hover:text-(--color-text-main) transition-colors">{footerItem.platform}</Text></Link></li>
        ))}
      </ul>
    </div>
  </div>

  {/* ── Section 3: Signature ────────────────────────── */}
  <div class="pt-12 border-t border-(--color-border-subtle) flex flex-col sm:flex-row items-center justify-between gap-8 mb-12">
    <Logo variant="full" brandName={brandName} color="black" class="h-9 md:h-10 w-auto" />
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
      {legalLinks.map((footerItem) => (
        <Link href={footerItem.href} variant="plain"><Text variant="metadata" color="muted" class="hover:text-(--color-text-main) transition-colors">{footerItem.label}</Text></Link>
      ))}
    </div>
  </div>

  {/* ── Section 4: Copyright ───────────────────── */}
  <div class="border-t border-(--color-border-subtle)/30 bg-(--color-surface-muted)/30 py-8 -mx-4 lg:-mx-8">
    <div class="mx-auto max-w-7xl px-4 text-center">
      <Text variant="metadata" color="muted" class="opacity-60 text-[0.75rem] uppercase tracking-[0.2em]">{copyright}</Text>
    </div>
  </div>
</Section>
