---
/**
 * Footer - Kaleido-inspired premium layout
 *
 * Structure:
 * 1. Newsletter strip (full-width, airy)
 * 2. Navigation row: brand tagline left, link columns center, socials right
 * 3. Bottom bar: copyright + legal
 * 4. Giant "Zelia Vance" brand name watermark
 */

import Logo from "../primitives/Logo.astro";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Link from "../primitives/Link.astro";
import SocialLinks from "../ui/SocialLinks.astro";
import NewsletterWidget from "./NewsletterWidget.astro";
import { navigation, supportLinks } from "../../config/navigation";
import { siteConfig } from "../../lib/site.config";

interface Props {
  class?: string;
}

const { class: className, ...rest } = Astro.props;

const shopNav = navigation.find((item) => item.label === "Shop");
const shopCategories = shopNav?.items || [];

const exploreLinks = navigation.filter((item) => item.label !== "Shop");
---

<footer
  class:list={["bg-surface overflow-hidden", className]}
  {...rest}
>

  {/* ── Section 1: Newsletter Strip ─────────────────────────────── */}
  <div class="border-t border-border-subtle">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-16 lg:py-20">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 lg:gap-10">
        <div class="w-full lg:flex-1 lg:pr-10 max-w-2xl">
          <Heading as="h2">
            Get drop alerts & Zee's style notes straight to your inbox.
          </Heading>
        </div>
        <div class="w-full lg:max-w-md flex flex-col">
          <NewsletterWidget variant="footer" hideHeading hideDisclaimer />
        </div>
      </div>
      
      {/* Social Links Row */}
      <div class="mt-8 flex flex-col lg:flex-row lg:justify-end w-full">
        <div class="w-full lg:max-w-md flex flex-col gap-3">
          <Text variant="metadata" class="block font-medium uppercase tracking-wider text-text-main">
            Follow Us
          </Text>
          <SocialLinks orientation="horizontal" />
        </div>
      </div>
    </div>
  </div>

  {/* ── Section 2: Nav Row and Images (50/50 Split) ────────────────── */}
  <div class="border-t border-border-subtle relative z-10 overflow-hidden bg-surface">
    <div class="mx-auto max-w-7xl px-6 lg:px-12 py-10 lg:py-20">
      <div class="flex flex-col lg:flex-row-reverse gap-16 lg:gap-8 w-full items-start">
        
        {/* Right side (Desktop) / Top (Mobile): Imagery Block */}
        <div class="w-full lg:w-1/2 flex justify-center lg:justify-end gap-3 sm:gap-6 mb-12 lg:mb-0">
          <img 
            src="/images/products/1515562141207-7a88fb7ce338.jpg" 
            alt="Zelia Vance Curated Style"
            class="w-1/2 aspect-square lg:max-w-70 lg:aspect-4/5 object-cover rounded-sm shadow-sm"
            loading="lazy"
          />
          <img 
            src="/images/products/1535632066927-ab7c9ab60908.jpg" 
            alt="Zelia Vance Authentic Detail"
            class="w-1/2 aspect-square lg:max-w-70 lg:aspect-4/5 object-cover rounded-sm shadow-sm lg:translate-y-12"
            loading="lazy"
          />
        </div>

        {/* Left side (Desktop) / Bottom (Mobile): Link Grid, Watermark, Legal */}
        <div class="w-full lg:w-1/2 flex flex-col justify-between h-full min-h-75">
          
          {/* Top Half: 3-Column Link Grid */}
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12 mb-16 lg:mb-24 w-full">
            
            {/* Column 1: Shop */}
            <div x-data="{ open: false }">
              <button
                class="flex w-full items-center justify-between py-4 border-b border-border-subtle lg:hidden"
                @click="open = !open"
              >
                <Heading as="h5">Shop</Heading>
                <svg
                  class="h-4 w-4 text-text-muted shrink-0 transition-transform duration-300"
                  :class="open && 'rotate-180'"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <Heading as="h5" class="hidden lg:block mb-5">Shop</Heading>
              <div x-show="open" x-collapse class="lg:hidden!">
                <ul class="space-y-3 pt-3 pb-4">
                  {shopCategories.map((item) => (
                    <li>
                      <Link href={item.href} variant="plain">
                        <Text variant="caption" color="muted" class="hover:text-text-main transition-colors">
                          {item.label}
                        </Text>
                      </Link>
                    </li>
                  ))}
                </ul>
              </div>
              <ul class="hidden lg:flex flex-col space-y-3">
                {shopCategories.map((item) => (
                  <li>
                    <Link href={item.href} variant="plain">
                      <Text variant="caption" color="muted" class="hover:text-text-main transition-colors">
                        {item.label}
                      </Text>
                    </Link>
                  </li>
                ))}
              </ul>
            </div>

            {/* Column 2: Explore */}
            <div x-data="{ open: false }">
              <button
                class="flex w-full items-center justify-between py-4 border-b border-border-subtle lg:hidden"
                @click="open = !open"
              >
                <Heading as="h5">Explore</Heading>
                <svg
                  class="h-4 w-4 text-text-muted shrink-0 transition-transform duration-300"
                  :class="open && 'rotate-180'"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <Heading as="h5" class="hidden lg:block mb-5">Explore</Heading>
              <div x-show="open" x-collapse class="lg:hidden!">
                <ul class="space-y-3 pt-3 pb-4">
                  {exploreLinks.map((item) => (
                    <li>
                      <Link href={item.href} variant="plain">
                        <Text variant="caption" color="muted" class="hover:text-text-main transition-colors">
                          {item.label}
                        </Text>
                      </Link>
                    </li>
                  ))}
                </ul>
              </div>
              <ul class="hidden lg:flex flex-col space-y-3">
                {exploreLinks.map((item) => (
                  <li>
                    <Link href={item.href} variant="plain">
                      <Text variant="caption" color="muted" class="hover:text-text-main transition-colors">
                        {item.label}
                      </Text>
                    </Link>
                  </li>
                ))}
              </ul>
            </div>

            {/* Column 3: Support */}
            <div x-data="{ open: false }">
              <button
                class="flex w-full items-center justify-between py-4 border-b border-border-subtle lg:hidden"
                @click="open = !open"
              >
                <Heading as="h5">Support</Heading>
                <svg
                  class="h-4 w-4 text-text-muted shrink-0 transition-transform duration-300"
                  :class="open && 'rotate-180'"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <Heading as="h5" class="hidden lg:block mb-5">Support</Heading>
              <div x-show="open" x-collapse class="lg:hidden!">
                <ul class="space-y-3 pt-3 pb-4">
                  {supportLinks.map((item) => (
                    <li>
                      <Link href={item.href} variant="plain">
                        <Text variant="caption" color="muted" class="hover:text-text-main transition-colors">
                          {item.label}
                        </Text>
                      </Link>
                    </li>
                  ))}
                </ul>
              </div>
              <ul class="hidden lg:flex flex-col space-y-3">
                {supportLinks.map((item) => (
                  <li>
                    <Link href={item.href} variant="plain">
                      <Text variant="caption" color="muted" class="hover:text-text-main transition-colors">
                        {item.label}
                      </Text>
                    </Link>
                  </li>
                ))}
              </ul>
            </div>

          </div>

          {/* Bottom Half: Watermark Area & Copyright Anchored strict left */}
          <div class="flex flex-col gap-6 items-start justify-end w-full">
             <div class="pointer-events-none select-none opacity-20 transform -translate-x-1 lg:-translate-x-3 w-full overflow-hidden">
               <Logo variant="full" class="text-[17vw]! min-[400px]:text-[4rem]! md:text-[6rem]! lg:text-[5.5rem]! xl:text-[6.5rem]! leading-[0.8]! tracking-tighter whitespace-nowrap" />
             </div>
             
             <div class="flex flex-row flex-wrap items-center justify-between gap-y-4 gap-x-8 pt-2 2xl:pt-4 w-full">
                <Text variant="metadata" color="muted">{siteConfig.copyright}</Text>
                <div class="flex flex-wrap gap-4 sm:gap-5">
                  <Link href="/privacy-policy" variant="plain">
                    <Text variant="metadata" color="muted">Privacy Policy</Text>
                  </Link>
                  <Link href="/terms-of-service" variant="plain">
                    <Text variant="metadata" color="muted">Terms of Service</Text>
                  </Link>
                </div>
             </div>
          </div>

        </div>

      </div>
    </div>
  </div>

</footer>
