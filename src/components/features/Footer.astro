---
/**
 * Footer - Main site footer
 * Responsive grid: 1 column mobile, 4 columns desktop
 */

import Logo from "../primitives/Logo.astro";
import Heading from "../primitives/Heading.astro";
import Text from "../primitives/Text.astro";
import Link from "../primitives/Link.astro";
import SocialLinks from "../ui/SocialLinks.astro";
import NewsletterForm from "../ui/NewsletterForm.astro";
import { navigation, supportLinks } from "../../config/navigation";
import { siteConfig } from "../../lib/site.config";

interface Props {
  class?: string;
}

const { class: className, ...rest } = Astro.props;

// Get shop categories from navigation
const shopNav = navigation.find((item) => item.label === "Shop");
const shopCategories = shopNav?.items || [];
---

<footer
  class:list={[
    "border-t border-border-subtle bg-surface",
    className,
  ]}
  {...rest}
>
  <div class="mx-auto max-w-7xl px-4 py-12 md:py-16 lg:px-8">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4 text-center md:text-left">
      {/* Brand Column */}
      <div class="flex flex-col items-center md:items-start">
        <Logo variant="full" class="mb-2" />
        <Text as="p" variant="caption" color="muted" class="max-w-xs leading-relaxed">
          Handcrafted celestial jewelry for those who seek to adorn themselves with the beauty of the cosmos.
        </Text>
        <div class="mt-6">
          <SocialLinks orientation="horizontal" class="justify-center md:justify-start" />
        </div>
      </div>

      {/* Shop Column */}
      <div>
        <Heading as="h6" class="mb-4">Shop</Heading>
        <ul class="space-y-2">
          {shopCategories.map((item) => (
            <li>
              <Link href={item.href} variant="plain">
                <Text variant="caption" color="muted" class="hover:text-text-main transition-colors">
                  {item.label}
                </Text>
              </Link>
            </li>
          ))}
        </ul>
      </div>

      {/* Support Column */}
      <div>
        <Heading as="h6" class="mb-4">Support</Heading>
        <ul class="space-y-2">
          {supportLinks.map((item) => (
            <li>
              <Link href={item.href} variant="plain">
                <Text variant="caption" color="muted" class="hover:text-text-main transition-colors">
                  {item.label}
                </Text>
              </Link>
            </li>
          ))}
        </ul>
      </div>

      {/* Newsletter Column */}
      <div>
        <Heading as="h6" class="mb-4">Join the Celestial Club</Heading>
        <Text variant="caption" color="muted" class="mb-4">
          Subscribe to get exclusive offers, new arrivals, and celestial inspirations.
        </Text>
        <NewsletterForm />
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="mt-12 border-t border-border-subtle pt-8">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <Text variant="metadata">
          {siteConfig.copyright}
        </Text>
        <div class="flex gap-4">
          <Link href="/privacy" variant="plain" class="text-text-muted">
            <Text variant="metadata">Privacy Policy</Text>
          </Link>
          <Link href="/terms" variant="plain" class="text-text-muted">
            <Text variant="metadata">Terms of Service</Text>
          </Link>
        </div>
      </div>
    </div>
  </div>
</footer>
