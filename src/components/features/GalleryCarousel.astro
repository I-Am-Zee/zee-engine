---
import Carousel from "../ui/Carousel.astro";
import Image from "../primitives/Image.astro";

interface Props {
  images: string[];
  title: string;
  class?: string;
}

const { images, title, class: className } = Astro.props;

// We use the exact same responsive math as ProductCarousel.astro
// This ensures visual consistency across the entire website.
// No aggressive 'center focus' or extreme percentages that shrink the images.
const options = {
  perPage: 3, 
  gap: 24, 
  type: images.length > 3 ? 'loop' : 'slide', 
  pagination: true, 
  arrows: false,
  breakpoints: { 
    1024: { perPage: 2, gap: 20 }, 
    768: { perPage: 2, gap: 16, padding: { left: '1rem', right: '2rem' } },
    640: { perPage: 1, gap: 16, padding: { left: '1rem', right: '5rem' } } // Clean, standard peek
  } 
};
---

<Carousel 
  options={options} 
  class:list={["w-[calc(100%+2rem)] -mx-4 md:w-full md:mx-0 pb-8", className]}
  trackClass="py-4"
  showArrows={images.length > 3}
>
  {images.map((img) => (
    <li class="splide__slide flex justify-center items-center h-auto">
      <div class="aspect-4/5 w-full rounded-2xl overflow-hidden cursor-zoom-in active:scale-[0.98] transition-all">
        <Image 
          src={img} 
          alt={`${title} Editorial Detail`} 
          class="w-full h-full object-cover transition-transform duration-1000 hover:scale-[1.03]"
          @click={`$dispatch('open-lightbox', { src: '${img}', alt: '${title} Editorial Detail' })`}
        />
      </div>
    </li>
  ))}
</Carousel>
