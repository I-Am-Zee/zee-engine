---
/**
 * NewsletterConfirmForm — Feature Component
 * The newsletter subscription confirmation form.
 *
 * Two modes:
 *  - Locked (email prop supplied): pre-fills the email from the delivery link.
 *    Uses a readonly Input for display. Skips Gmail restriction — the customer's
 *    order email may not be a Gmail.
 *  - Open (no email prop): shows an editable Input with Gmail-only validation.
 *
 * Layer: Feature (has API calls, event listeners via behavior script)
 * Uses: NewsletterPageCard (UI), Input, Button, Text (Primitives)
 * Behavior: scripts/behaviors/newsletter.ts → initNewsletterConfirm()
 */

import NewsletterPageCard from "../ui/NewsletterPageCard.astro";
import Input from "../primitives/Input.astro";
import Button from "../primitives/Button.astro";
import Text from "../primitives/Text.astro";

interface Props {
  email?: string;
  // Content Props (Hub Strategy)
  headingLocked?: string;
  headingOpen?: string;
  descriptionLocked?: string;
  descriptionOpen?: string;
  emailPlaceholder?: string;
  emailError?: string;
  submitLabel?: string;
  footerNote?: string;
}

const { 
  email = "",
  headingLocked = "Confirm your subscription",
  headingOpen = "Join the list",
  descriptionLocked = "",
  descriptionOpen = "",
  emailPlaceholder = "Enter your email address",
  emailError = "Please enter a valid Gmail address.",
  submitLabel = "Join the Loop",
  footerNote = ""
} = Astro.props;

const hasEmail = email.length > 0;
---

<NewsletterPageCard
  heading={hasEmail ? headingLocked : headingOpen}
  description={hasEmail ? descriptionLocked : descriptionOpen}
>
  <form
    id="newsletter-confirm-form"
    x-data={`newsletterConfirm({ locked: ${hasEmail ? 'true' : 'false'}, email: '${email}' })`}
    @submit.prevent="submitForm"
    class="flex flex-col gap-3"
    novalidate
  >
    {hasEmail ? (
      <>
        <input type="hidden" name="email" value={email} />
        <Input
          id="newsletter-email-display"
          :value="email"
          type="email"
          name="_display"
          value={email}
          class="text-center cursor-default!"
          readonly
        />
      </>
    ) : (
      <div class="flex flex-col gap-1 text-left">
        <Input
          id="newsletter-email-input"
          type="email"
          name="email"
          autocomplete="email"
          placeholder={emailPlaceholder}
          x-model="email"
          @input="hideEmailError"
          @blur="validateEmail"
        />
        <p id="newsletter-email-error" class="px-1 font-sans text-xs text-(--color-danger)" x-show="emailError" x-cloak>
          {emailError}
        </p>
      </div>
    )}

    <Button
      id="newsletter-submit-btn"
      type="primary"
      size="lg"
      class="w-full uppercase tracking-widest text-xs!"
      :disabled="isSubmitting"
    >
      <span x-text={`isSubmitting ? 'Processing...' : '${submitLabel}'`}>{submitLabel}</span>
    </Button>

    <p id="newsletter-form-error" class="text-center font-sans text-xs text-(--color-danger)" x-show="formError" x-cloak>
      Something went wrong. Please try again in a moment.
    </p>
  </form>

  <Text variant="metadata" class="mt-8 block whitespace-pre-line leading-relaxed opacity-70">
    {footerNote}
  </Text>
</NewsletterPageCard>

