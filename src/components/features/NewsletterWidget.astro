---
/**
 * NewsletterWidget - Multi-variant, brand-aware newsletter feature.
 * 
 * Variants:
 * - 'section': Full-width call-to-action with background image.
 * - 'footer': Minimal, single-column for layout-confined areas.
 * - 'sidebar': Compressed vertical for constrained widths.
 * - 'modal': Floating (future/planned).
 * 
 * Data:
 * - Brand-specific copy is loaded from src/content/{brand}/newsletter.json.
 */

import { getEntry } from 'astro:content';
import Heading from '../primitives/Heading.astro';
import Text from '../primitives/Text.astro';
import NewsletterForm from '../ui/NewsletterForm.astro';

interface Props {
  variant?: 'section' | 'footer' | 'sidebar' | 'modal';
  brand?: string;
  hideHeading?: boolean;
  hideDisclaimer?: boolean;
  class?: string;
  id?: string;
}

const { 
  variant = 'section', 
  brand = 'zelia-vance', 
  hideHeading = false,
  hideDisclaimer = false,
  class: className,
  id: customId 
} = Astro.props;

// Generate a unique ID for targeting the behavior
const uid = customId || `newsletter-${variant}-${Math.random().toString(36).substring(2, 7)}`;

// Each variant is its own file: footer.json, modal.json, section.json, sidebar.json
const entry = await getEntry('newsletter_variants', variant);
const copy = entry?.data || {
  heading: "Heading Level 2",
  description: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
  success_message: "Success Notification Text"
};

const isSection = variant === 'section';
const isFooter = variant === 'footer';
const isSidebar = variant === 'sidebar';
const isModal = variant === 'modal';
---

<section 
  id={uid}
  class:list={[
    "relative overflow-hidden w-full",
    isSection && "py-24 px-6 bg-linear-to-b from-surface to-background-soft",
    isModal && "p-6 md:p-10 bg-white",
    isFooter && "py-0",
    isSidebar && "p-6 bg-white border border-(--color-divider) rounded-xl",
    className
  ]}
>
  <div class:list={[
    "mx-auto",
    isSection && "max-w-2xl text-center",
    isModal && "max-w-xl text-center",
    isFooter && "w-full",
    isSidebar && "w-full"
  ]}>
    
    {!hideHeading && (
      <div class:list={[
        (isSection || isModal) && "mb-8",
        isSidebar && "text-center mb-6",
        isFooter && "mb-4"
      ]}>
        <Heading 
          as={isSection || isFooter || isModal ? "h2" : "h4"}
          class="mb-3"
        >
          {copy.heading}
        </Heading>
        <Text 
          variant="body" 
          class:list={[
            "text-text-muted",
            (isSection || isModal) && "text-lg",
            isFooter && "leading-relaxed",
            isSidebar && "text-sm"
          ]}
        >
          {copy.description}
        </Text>
      </div>
    )}

    <div class:list={[
      (isSection || isModal) && "mx-auto max-w-md",
      isFooter && "w-full",
      isSidebar && "w-full"
    ]}>
      <NewsletterForm
        id={`${uid}-form`}
        placeholder="Enter your Gmail address"
        buttonText={isSection || isModal ? "Join the Inner Circle" : "Subscribe"}
        layout={isModal ? "col" : "row"}
      />
      {!hideDisclaimer && (
        <Text 
          variant="caption" 
          class:list={[
            "mt-4 block opacity-60",
            (isSection || isModal) && "text-center",
            isFooter && "text-left"
          ]}
        >
          We only accept Gmail addresses for high-intent delivery.
        </Text>
      )}
    </div>
    
  </div>


</section>

