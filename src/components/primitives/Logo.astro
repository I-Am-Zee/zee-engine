---
import { getEntry } from "astro:content";

interface Props {
  variant?: "full" | "mark";
  color?: "black" | "white";
  class?: string;
}

const { variant = "full", color = "black", class: className, ...rest } = Astro.props;

// Fetch Title from Content Layer (Fail-fast is already in config.ts)
const site = await getEntry("settings", "brand");
const brandName = site?.data?.name || "Brand";
const brandMark = brandName.charAt(0).toUpperCase();

const textColor = color === "white" ? "text-white" : "text-(--color-text-main)";
---

{variant === "full" ? (
  <a
    href="/"
    class:list={["inline-flex items-center font-serif text-2xl font-medium tracking-tight whitespace-nowrap", textColor, className]}
    {...rest}
  >
    {brandName}
  </a>
) : (
  <a
    href="/"
    class:list={["inline-flex items-center justify-center font-serif text-xl font-bold", textColor, className]}
    {...rest}
  >
    {brandMark}
  </a>
)}

