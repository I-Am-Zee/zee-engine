---
interface Props {
  variant?: "full" | "mark";
  color?: "black" | "white";
  brandName?: string;
  class?: string;
}

const {
  variant = "full",
  color = "black",
  brandName = "Brand",
  class: className,
  ...rest
} = Astro.props;

const brandMark = brandName.charAt(0).toUpperCase();

const colorMap = {
  black: "text-(--color-text-main)",
  white: "text-(--color-text-inverse)",
  inverse: "text-(--color-text-inverse)"
};

const textColor = colorMap[color as keyof typeof colorMap] || colorMap.black;
---

{variant === "full" ? (
  <a
    href="/"
    class:list={["inline-flex items-center font-serif text-2xl font-medium tracking-tight whitespace-nowrap", textColor, className]}
    {...rest}
  >
    {brandName}
  </a>
) : (
  <a
    href="/"
    class:list={["inline-flex items-center justify-center font-serif text-xl font-bold", textColor, className]}
    {...rest}
  >
    {brandMark}
  </a>
)}

