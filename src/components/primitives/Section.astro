---
/**
 * Section - Layout Primitive
 * 
 * Standardizes vertical spacing and horizontal containment across the brand.
 * Every major page section should use this instead of raw divs.
 */

interface Props {
  id?: string;
  variant?: "standard" | "compact" | "hero" | "full";
  py?: string;
  pt?: string;
  pb?: string;
  class?: string;
  containerClass?: string;
  as?: "section" | "div" | "footer" | "header" | "main" | "nav" | "article";
  [key: string]: any;
}

const { 
  id, 
  variant = "standard", 
  py,
  pt,
  pb,
  class: className,
  containerClass: customContainerClass,
  as: Tag = "section",
  ...rest
} = Astro.props as Props;

// Vertical padding tokens
const verticalSpacing = {
  standard: "py-12 md:py-16 lg:py-24",
  compact: "py-8 md:py-12",
  hero: "pt-24 pb-16 md:pt-32 md:pb-24",
  full: "py-0"
};

// Determine applied spacing: props override variant
let appliedSpacing = verticalSpacing[variant as keyof typeof verticalSpacing];
if (py) appliedSpacing = py;
if (pt || pb) {
  const top = pt || (py ? "" : appliedSpacing.split(" ").find(s => s.startsWith("pt-") || s.startsWith("py-"))?.replace("py-", "pt-") || "");
  const bottom = pb || (py ? "" : appliedSpacing.split(" ").find(s => s.startsWith("pb-") || s.startsWith("py-"))?.replace("py-", "pb-") || "");
  appliedSpacing = `${top} ${bottom}`.trim();
}

const containerStyles = variant === "full" 
  ? (customContainerClass || "w-full") 
  : `mx-auto ${customContainerClass?.includes("max-w-") ? "" : "max-w-7xl"} px-4 lg:px-8 ${customContainerClass || ""}`.trim();

const combinedClasses = `${appliedSpacing} ${className || ""}`.trim();
---

<Tag id={id} class={combinedClasses} {...rest}>
  <div class={containerStyles}>
    <slot />
  </div>
</Tag>
