---
import * as PhosphorIcons from "phosphor-icons-astro";
import Icon from "./Icon.astro";

export interface Props {
  id: string;
  type?: "text" | "password" | "email" | "number" | "tel" | "search" | "url";
  placeholder?: string;
  error?: boolean;
  class?: string;
  name?: string;
  value?: string;
  readonly?: boolean;
  icon?: keyof typeof PhosphorIcons;
  iconPosition?: "left" | "right";
  autocomplete?: string;
  [key: string]: any;
}

const {
  id,
  type = "text",
  placeholder,
  error = false,
  class: className,
  name,
  value,
  readonly = false,
  icon,
  iconPosition = "left",
  autocomplete,
  ...rest
} = Astro.props;

// Base input styles - using shadow glow for focus
const baseStyles =
  "w-full font-sans px-4 py-2 rounded-md bg-transparent text-(--color-text-main) border border-(--color-border-subtle) hover:border-(--color-border-strong) transition-colors outline-none focus:shadow-[0_0_0_2px_var(--color-background),0_0_0_4px_var(--color-ring),0_0_12px_var(--color-ring-glow)] disabled:opacity-50 disabled:cursor-not-allowed placeholder:text-(--color-text-muted)";

// Padding adjustments for icons
const paddingStyles = icon 
  ? (iconPosition === "left" ? "pl-11" : "pr-11") 
  : "";

// Error state changes border color
const stateStyles = error
  ? "border-red-500 focus:border-red-500"
  : "border-(--color-border-subtle) hover:border-(--color-border-strong) focus:border-(--color-primary)";

const combinedClasses = `${baseStyles} ${paddingStyles} ${stateStyles} ${className || ""}`.trim();
---

<div class="relative w-full">
  {icon && (
    <div class:list={[
      "pointer-events-none absolute inset-y-0 flex items-center z-10",
      iconPosition === "left" ? "left-4" : "right-4"
    ]}>
      <Icon name={icon as any} class="h-5 w-5 text-(--color-text-muted)" />
    </div>
  )}
  <input
    id={id}
    type={type}
    placeholder={placeholder}
    name={name}
    value={value}
    readonly={readonly || undefined}
    class={combinedClasses}
    aria-invalid={error ? "true" : undefined}
    autocomplete={autocomplete}
    {...rest}
  />
</div>
