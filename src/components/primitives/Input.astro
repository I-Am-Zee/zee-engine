---
export interface Props {
  id: string;
  type?: "text" | "password" | "email" | "number" | "tel" | "search" | "url";
  placeholder?: string;
  error?: boolean;
  class?: string;
  name?: string;
  value?: string;
}

const {
  id,
  type = "text",
  placeholder,
  error = false,
  class: className,
  name,
  value,
  ...rest
} = Astro.props;

// Base input styles - using shadow glow for focus
const baseStyles =
  "w-full font-sans px-4 py-2 rounded-md bg-background border transition-all duration-200 outline-none focus:shadow-[0_0_0_2px_var(--color-background),0_0_0_4px_var(--color-ring),0_0_12px_var(--color-ring-glow)] disabled:opacity-50 disabled:cursor-not-allowed placeholder:text-text-muted";

// Error state changes border color
const stateStyles = error
  ? "border-red-500 focus:border-red-500"
  : "border-border-strong focus:border-primary";

const combinedClasses = `${baseStyles} ${stateStyles} ${className || ""}`.trim();
---

<input
  id={id}
  type={type}
  placeholder={placeholder}
  name={name}
  value={value}
  class={combinedClasses}
  aria-invalid={error ? "true" : undefined}
  {...rest}
/>
