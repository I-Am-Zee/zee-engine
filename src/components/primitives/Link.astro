---
interface Props {
  href: string;
  variant?: "plain" | "underline";
  class?: string;
}

const { href, variant = "plain", class: className, ...rest } = Astro.props;

// Base styles - inherits font size from parent, using shadow glow for focus
const baseStyles =
  "inline font-sans text-[var(--color-text-main)] transition-all duration-200 hover:text-[var(--color-text-muted)] focus-visible:outline-none focus-visible:rounded-sm focus-visible:shadow-[0_0_0_2px_var(--color-background),0_0_0_4px_var(--color-ring),0_0_12px_var(--color-ring-glow)]";

// Variant styles
const variantStyles = {
  plain: "no-underline",
  underline: "underline decoration-1 underline-offset-2 [text-decoration-skip-ink:auto]",
};

const combinedClasses = `${baseStyles} ${variantStyles[variant]} ${className || ""}`.trim();
---

<a href={href} class={combinedClasses} {...rest}>
  <slot />
</a>
