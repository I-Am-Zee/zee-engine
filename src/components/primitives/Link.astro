---
interface Props {
  href: string;
  variant?: "plain" | "underline";
  class?: string;
  isExternal?: boolean;
  target?: string;
  rel?: string;
}

const { href, variant = "plain", class: className, isExternal: isExternalProp, target, rel, ...rest } = Astro.props;

// Smart detection for external links if not explicitly provided
const isExternal = isExternalProp ?? (href.startsWith("http") || href.startsWith("//"));

// Base styles - inherits font size from parent, using shadow glow for focus
const baseStyles =
  "inline font-sans text-text-main transition-all duration-200 hover:text-text-muted focus-visible:outline-none focus-visible:rounded-sm focus-visible:shadow-[0_0_0_2px_var(--color-background),0_0_0_4px_var(--color-ring),0_0_12px_var(--color-ring-glow)]";

// Variant styles
const variantStyles = {
  plain: "no-underline",
  underline: "underline decoration-1 underline-offset-2 [text-decoration-skip-ink:auto]",
};

const combinedClasses = `${baseStyles} ${variantStyles[variant]} ${className || ""}`.trim();

const externalProps = isExternal ? { target: target || "_blank", rel: rel || "noopener noreferrer" } : (target ? { target, rel } : {});
---

<a href={href} class={combinedClasses} {...externalProps} {...rest}>
  <slot />
</a>
