---
export interface Props {
  as?: "p" | "span" | "div" | "label" | "blockquote" | "cite" | "code" | "time" | "i" | "em" | "strong" | "small";
  variant?:
    | "paragraph" // Standard body text
    | "body" // Alias for paragraph
    | "lead" // Introductory/Lead text
    | "caption" // Secondary smaller text
    | "muted" // Dimmed/Secondary intent
    | "eyebrow" // Small header labels (accent color)
    | "metadata" // Meta information/Context
    | "price" // Active price
    | "price_sale" // Comparison price
    | "label" // UI labels
    | "callout" // Highlighted sidebar/callout
    | "quote" // Semantic blockquotes
    | "code" // Technical/Monospace snippets
    | "tag"; // Small rounded identifiers
  class?: string;
  weight?: "light" | "normal" | "medium" | "semibold" | "bold" | "black";
  color?: "main" | "muted" | "inverse" | "accent" | "coral" | "emerald";
  italic?: boolean;
}

const {
  as,
  variant = "paragraph",
  weight,
  color,
  italic = false,
  class: className,
  ...rest
} = Astro.props;

// Intent-specific styles (Atomic Design)
const variantStyles: Record<string, string> = {
  paragraph: "text-base leading-relaxed text-pretty",
  body: "text-base leading-relaxed text-pretty",
  lead: "text-lg md:text-xl leading-relaxed font-light text-pretty",
  caption: "text-sm leading-normal text-pretty",
  muted: "text-base leading-relaxed text-pretty",
  eyebrow: "text-[10px] md:text-xs uppercase tracking-[0.2em] font-bold text-(--color-accent) text-pretty",
  metadata: "text-[10px] md:text-[11px] font-semibold leading-none tracking-[0.15em] uppercase text-(--color-text-muted)",
  price: "text-lg md:text-xl font-bold tracking-tight leading-none text-(--color-primary)",
  price_sale: "text-xs md:text-sm line-through opacity-50 font-normal leading-none",
  label: "text-[11px] font-semibold uppercase tracking-[0.2em] text-(--color-text-main)",
  callout: "text-base font-semibold leading-relaxed italic border-l-4 border-(--color-accent) pl-6",
  quote: "text-lg md:text-xl font-serif italic leading-relaxed text-(--color-text-muted) text-pretty",
  code: "font-mono text-sm bg-(--color-surface-muted) px-1.5 py-0.5 rounded border border-(--color-border-subtle) text-(--color-primary)",
  tag: "inline-flex items-center text-[10px] font-bold uppercase tracking-wider bg-(--color-surface) px-2 py-0.5 rounded-full border border-(--color-border-subtle)",
};

// Smart Semantic Mapping based on Intent
const defaultTagMap: Record<string, any> = {
  paragraph: "p",
  body: "p",
  lead: "p",
  quote: "blockquote",
  label: "span",
  code: "code",
  metadata: "span",
  eyebrow: "span",
  tag: "span",
  muted: "p",
  callout: "p"
};

const Tag = as || defaultTagMap[variant] || "span";

// Base styles - uses Plus Jakarta Sans (sans-serif)
const baseStyles = variant === "code" ? "font-mono" : (variant === "quote" ? "font-serif" : "font-sans");

// Weight mappings
const weightStyles = weight
  ? ({
      light: "font-light",
      normal: "font-normal",
      medium: "font-medium",
      semibold: "font-semibold",
      bold: "font-bold",
      black: "font-black",
    } as Record<string, string>)[weight]
  : "";

// Color mappings - standardized to Tailwind v4 theme variables
const colorChoices: Record<string, string> = {
  main: "text-(--color-text-main)",
  muted: "text-(--color-text-muted)",
  inverse: "text-(--color-text-inverse)",
  accent: "text-(--color-accent)",
  coral: "text-(--color-danger)",
  emerald: "text-(--color-success)",
  inherit: "text-inherit",
};

const colorStyles = colorChoices[color || (variant === "muted" ? "muted" : "")] || "";
const italicStyle = italic ? "italic" : "";

// Resolve weight and color - if props exist, strip variant defaults to prevent conflicts
const activeWeightStyle = weightStyles || "";
const activeColorStyle = colorStyles || "";

let filteredVariantStyle = variantStyles[variant] || "";

// If weight prop is provided, remove any existing font-weight classes
if (activeWeightStyle) {
  filteredVariantStyle = filteredVariantStyle.replace(/font-\w+/g, "");
}

// If color prop is provided, remove any existing brand-specific text-color classes
// We use a specific pattern to avoid stripping font-size classes like text-sm or text-[10px]
if (color) {
  filteredVariantStyle = filteredVariantStyle.replace(/text-\(--color-\S+\)/g, "");
}

const combinedClasses = `${baseStyles} ${filteredVariantStyle.trim()} ${activeWeightStyle} ${activeColorStyle} ${italicStyle} ${className || ""}`.trim();
---

<Tag class={combinedClasses} {...rest}>
  <slot />
</Tag>
