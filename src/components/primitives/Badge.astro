---
interface Props {
  intent?: "surface" | "primary" | "accent" | "outline" | "coral" | "brass";
  size?: "xs" | "sm" | "md";
  class?: string;
}

const { intent = "surface", size = "sm", class: className, ...rest } = Astro.props;

// Base pill-shaped styles with "eyebrow" typography
const baseStyles =
  "inline-flex items-center justify-center rounded-full uppercase tracking-[0.15em] font-sans font-bold leading-none";

// Intent determines color scheme (updated for premium contrast)
const intentStyles = {
  surface:
    "bg-surface/90 text-text-main border border-border-subtle shadow-xs backdrop-blur-sm",
  primary: "bg-primary text-primary-foreground shadow-xs",
  accent: "bg-secondary text-primary border border-primary/20 shadow-xs",
  outline:
    "bg-background/80 text-text-main border border-border-strong backdrop-blur-sm",
  coral:
    "bg-accent-coral/90 text-white border border-accent-coral shadow-md backdrop-blur-sm",
  brass:
    "bg-accent-brass/90 text-primary border border-accent-brass shadow-md backdrop-blur-sm",
};

// Size variants
const sizeStyles = {
  xs: "text-[9px] px-2 py-1 h-5",
  sm: "text-[10px] px-2.5 py-1.5 h-6",
  md: "text-xs px-3 py-2 h-7",
};

const combinedClasses =
  `${baseStyles} ${intentStyles[intent]} ${sizeStyles[size]} ${className || ""}`.trim();
---

<span class={combinedClasses} {...rest}>
  <slot />
</span>

