---
interface Props {
  intent?: "surface" | "primary" | "accent" | "outline" | "coral" | "brass";
  size?: "xs" | "sm" | "md";
  class?: string;
}

const { intent = "surface", size = "sm", class: className, ...rest } = Astro.props;

// Base pill-shaped styles with "eyebrow" typography
const baseStyles =
  "inline-flex items-center justify-center rounded-full uppercase tracking-[0.15em] font-sans font-bold leading-none";

// Intent determines color scheme (updated for premium contrast)
const intentStyles = {
  surface:
    "bg-(--color-surface)/90 text-(--color-text-main) border border-(--color-border-subtle) shadow-sm backdrop-blur-sm",
  primary: "bg-(--color-primary) text-(--color-primary-foreground) shadow-sm",
  accent: "bg-(--color-secondary) text-(--color-primary) border border-(--color-primary)/20 shadow-sm",
  outline:
    "bg-(--color-background)/80 text-(--color-text-main) border border-(--color-border-strong) backdrop-blur-sm",
  coral:
    "bg-(--color-accent-coral)/90 text-white border border-(--color-accent-coral) shadow-md backdrop-blur-sm",
  brass:
    "bg-(--color-accent-brass)/90 text-(--color-primary) border border-(--color-accent-brass) shadow-md backdrop-blur-sm",
};

// Size variants
const sizeStyles = {
  xs: "text-[9px] px-2 py-1 h-5",
  sm: "text-[10px] px-2.5 py-1.5 h-6",
  md: "text-xs px-3 py-2 h-7",
};

const combinedClasses =
  `${baseStyles} ${intentStyles[intent]} ${sizeStyles[size]} ${className || ""}`.trim();
---

<span class={combinedClasses} {...rest}>
  <slot />
</span>

