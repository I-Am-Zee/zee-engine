---
interface Props {
  intent?: "surface" | "primary" | "accent" | "outline" | "danger" | "success" | "coral" | "brass";
  size?: "xs" | "sm" | "md";
  variant?: "stretchy" | "fixed";
  onDark?: boolean;
  class?: string;
}

const { 
  intent: rawIntent = "surface", 
  size = "sm", 
  variant = "stretchy",
  onDark = false, 
  class: className, 
  ...rest 
} = Astro.props;

// Backward-compatibility mapping for literal color names
const intentMap: Record<string, string> = {
  coral: "danger",
  brass: "accent",
};
const intent = (intentMap[rawIntent] || rawIntent) as keyof typeof intentStyles;

// Base pill-shaped styles with "eyebrow" typography
const baseStyles =
  "inline-flex items-center justify-center rounded-full uppercase tracking-[0.12em] font-sans font-bold leading-none shrink-0";

// Intent determines color scheme
const intentStyles = {
  surface: onDark
    ? "bg-white/10 text-(--color-text-inverse) border border-white/20 shadow-xs backdrop-blur-md"
    : "bg-(--color-surface)/90 text-(--color-text-main) border border-(--color-border-subtle) shadow-xs backdrop-blur-sm",
  primary: "bg-(--color-primary) text-(--color-primary-foreground) shadow-xs",
  accent: "bg-(--color-secondary) text-(--color-primary) border border-(--color-primary)/20 shadow-xs",
  outline: onDark
    ? "bg-transparent text-(--color-text-inverse) border border-white/30"
    : "bg-transparent text-(--color-text-main) border border-(--color-border-subtle)",
  danger:
    "bg-(--color-danger)/90 text-white border border-(--color-danger) shadow-md backdrop-blur-sm",
  success:
    "bg-(--color-success)/90 text-white border border-(--color-success) shadow-md backdrop-blur-sm",
};

// Size variants
const sizeStyles = {
  xs: "text-[9px] px-2 h-5",
  sm: "text-[10px] px-2.5 h-6",
  md: "text-xs px-3 h-7",
};

// Luxury Standard: Fixed width ensures visual rhythm
const variantStyles = {
  stretchy: "w-auto",
  fixed: "w-20", // Standardized luxury stamp width (80px)
};

const combinedClasses =
  `${baseStyles} ${intentStyles[intent]} ${sizeStyles[size]} ${variantStyles[variant]} ${className || ""}`.trim();
---

<span class={combinedClasses} {...rest}>
  <span class="truncate block w-full text-center px-0.5">
    <slot />
  </span>
</span>

