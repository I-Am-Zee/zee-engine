---
/**
 * Icon - Phosphor Icons wrapper component
 * Uses phosphor-icons-astro for the official Phosphor Icons library
 *
 * Usage:
 *   <Icon name="MagnifyingGlass" />
 *   <Icon name="Heart" weight="fill" />
 *   <Icon name="ShoppingCart" size={24} />
 */

import * as PhosphorIcons from "phosphor-icons-astro";

interface Props {
  name: keyof typeof PhosphorIcons;
  size?: number | string;
  weight?: "thin" | "light" | "regular" | "bold" | "fill" | "duotone";
  class?: string;
  [key: string]: any;
}

const { name, size = "1.2em", weight = "regular", class: className, ...rest } = Astro.props;

// Get the icon component from Phosphor
const IconComponent = PhosphorIcons[name];

// Default icon styles for optical balance with text
const baseStyles = "inline-block align-middle shrink-0";
const combinedClasses = `${baseStyles} ${className || ""}`.trim();
---

{
  IconComponent ? (
    <IconComponent size={size} weight={weight} class={combinedClasses} {...rest} />
  ) : (
    <span
      class={combinedClasses}
      title={`Icon: ${name}`}
      style="display: inline-block; background: var(--color-border-subtle); width: 1.2em; height: 1.2em;"
      {...rest}
    >
      ?
    </span>
  )
}
