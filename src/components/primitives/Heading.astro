---
export interface Props {
  as: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  color?: "main" | "muted" | "inverse" | "accent";
  class?: string;
}

const { as: Tag, color = "main", class: className, ...rest } = Astro.props;

// Color mappings
const colorChoices: Record<string, string> = {
  main: "text-(--color-text-main)",
  muted: "text-(--color-text-muted)",
  inverse: "text-(--color-text-inverse)",
  accent: "text-accent-brass",
};

const colorStyles = colorChoices[color as string] || colorChoices.main;

// Responsive heading styles using clamp() for fluid typography
const baseStyles =
  `font-serif font-medium tracking-normal leading-[1.15] ${colorStyles} antialiased`;

const sizeStyles: Record<string, string> = {
  h1: "text-[clamp(2rem,5vw,3.5rem)]",
  h2: "text-[clamp(1.75rem,4vw,2.5rem)]",
  h3: "text-[clamp(1.5rem,3.5vw,2rem)] font-semibold",
  h4: "text-[clamp(1.25rem,3vw,1.5rem)] font-semibold",
  h5: "text-[clamp(1.125rem,2.5vw,1.25rem)] font-bold",
  h6: "text-[clamp(1rem,2vw,1.125rem)] font-bold",
};

const combinedClasses = `${baseStyles} ${sizeStyles[Tag]} ${className || ""}`.trim();
---

<Tag class={combinedClasses} {...rest}>
  <slot />
</Tag>
