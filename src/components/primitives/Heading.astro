---
export interface Props {
  as: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  size?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  color?: "main" | "muted" | "inverse" | "accent";
  class?: string;
}

const { as: Tag, size, color = "main", class: className, ...rest } = Astro.props;

// Use explicit size if provided, otherwise fallback to Tag for semantic/visual alignment
const visualSize = size || Tag;

// Color mappings
const colorChoices: Record<string, string> = {
  main: "text-(--color-text-main)",
  muted: "text-(--color-text-muted)",
  inverse: "text-(--color-text-inverse)",
  accent: "text-(--color-accent-brass)",
};

const colorStyles = colorChoices[color as string] || colorChoices.main;

// Responsive heading styles using clamp() for fluid typography
const baseStyles =
  `font-serif font-medium tracking-normal leading-[1.3] ${colorStyles} antialiased`;

const sizeStyles: Record<string, string> = {
  h1: "text-[clamp(1.75rem,8vw,4.5rem)]",
  h2: "text-[clamp(1.5rem,6vw,3rem)]",
  h3: "text-[clamp(1.375rem,5vw,2.25rem)] font-semibold",
  h4: "text-[clamp(1.25rem,4vw,1.75rem)] font-semibold",
  h5: "text-[clamp(1.125rem,3vw,1.25rem)] font-bold",
  h6: "text-[clamp(1rem,2vw,1.125rem)] font-bold",
};

const combinedClasses = `${baseStyles} ${sizeStyles[visualSize]} ${className || ""}`.trim();
---

<Tag class={combinedClasses} {...rest}>
  <slot />
</Tag>
