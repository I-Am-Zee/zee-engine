---
interface Props {
  as: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  class?: string;
}

const { as: Tag, class: className, ...rest } = Astro.props;

// Responsive heading styles using clamp() for fluid typography
const baseStyles =
  "font-serif font-bold tracking-tight leading-tight text-(--color-text-main)";

const sizeStyles = {
  h1: "text-[clamp(2rem,5vw,3.5rem)]",
  h2: "text-[clamp(1.75rem,4vw,2.5rem)]",
  h3: "text-[clamp(1.5rem,3.5vw,2rem)]",
  h4: "text-[clamp(1.25rem,3vw,1.5rem)]",
  h5: "text-[clamp(1.125rem,2.5vw,1.25rem)]",
  h6: "text-[clamp(1rem,2vw,1.125rem)]",
};

const combinedClasses = `${baseStyles} ${sizeStyles[Tag]} ${className || ""}`.trim();
---

<Tag class={combinedClasses} {...rest}>
  <slot />
</Tag>
