---
import Icon from "./Icon.astro";

interface Props {
  id?: string; // Optional Alpine x-data context (e.g. "popupBehavior(...)")
  isOpen?: string; // The variable controlling visibility (default: 'open')
  onClose?: string; // The function to call for closing (default: 'closePopup()')
  maxWidth?: string;
  closeOnOverlayClick?: boolean;
  class?: string;
}

const { 
  id, 
  isOpen = "open", 
  onClose = "closePopup()", 
  maxWidth = "max-w-lg", 
  closeOnOverlayClick = true,
  class: className
} = Astro.props;
---

<div
  x-data={id}
  x-show={isOpen}
  style="display: none;"
  class:list={["fixed inset-0 flex items-center justify-center px-4 z-[110]", className]}
>
  <!-- Backdrop (Overlay) -->
  <div 
    x-show={isOpen}
    x-transition.opacity.duration.300ms
    class="absolute inset-0 bg-black/60 backdrop-blur-sm" 
    @click={closeOnOverlayClick ? onClose : null}
  ></div>

  <!-- Modal Content Container -->
  <div
    x-show={isOpen}
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 translate-y-4 scale-95"
    x-transition:enter-end="opacity-100 translate-y-0 scale-100"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100 translate-y-0 scale-100"
    x-transition:leave-end="opacity-0 translate-y-4 scale-95"
    class:list={[
      "relative bg-white w-full overflow-hidden shadow-2xl rounded-lg z-10",
      maxWidth
    ]}
  >
    <!-- Standard Close Button Overlay -->
    <button
      @click={onClose}
      class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center p-0 bg-white/80 hover:bg-white rounded-full text-gray-500 hover:text-black transition-colors z-20 shadow-sm cursor-pointer disabled:cursor-not-allowed border-none"
      aria-label="Close"
    >
      <Icon name="PhX" size={16} />
    </button>

    <slot />
  </div>
</div>
