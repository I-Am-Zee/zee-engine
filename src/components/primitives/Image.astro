---
import { Image as AstroImage } from "astro:assets";

interface Props {
  src: any; // Can be a local import or remote string
  alt: string;
  ratio?: "portrait" | "square" | "landscape" | "auto";
  class?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  decoding?: "async" | "sync" | "auto";
  sizes?: string;
  widths?: number[];
  draggable?: boolean | "true" | "false"; // Corrected type for draggable
  fade?: boolean; // Control whether to show the fade-in animation
  [key: string]: any; // Catch-all for Alpine attributes like :src, :alt, etc.
}

const { 
  src: srcProp, 
  alt, 
  ratio = "auto", 
  class: className = "", 
  loading = "lazy", 
  fetchpriority = "auto", 
  decoding = "async",
  sizes,
  widths,
  draggable,
  fade = true,
  ...rest 
} = Astro.props;

// Normalize src: empty strings or null/undefined should be treated as missing
const src = srcProp || null;

// Guard: If no source is provided and no Alpine dynamic source exists, skip rendering to prevent Astro crash
if (!src && !rest[':src']) return null;

// Determine if we should use Astro's optimized Image or a raw img tag
// Remote if it's a string starting with http or /, or if it has an Alpine :src attribute
const isRemote = (typeof src === "string" && (src.startsWith("http") || src.startsWith("/"))) || !!rest[':src'];

const resolveSrc = (path: string, width?: number) => {
  if (!path) return "";
  const gateway = import.meta.env.PUBLIC_IMAGE_GATEWAY_URL || "";
  const brandId = import.meta.env.PUBLIC_BRAND_ID;
  
  if (path.startsWith("http")) return path;
  
  let resolvedPath = path;
  if (path.startsWith("/")) {
    // Transform path: /images/products/photo.jpg -> /zelia-vance/products/photo.jpg
    const r2Path = path.replace(/^\/images\//, `/${brandId}/`);
    resolvedPath = r2Path !== path ? r2Path : `/${brandId}${path}`;
  }
  
  const url = `${gateway}${resolvedPath.startsWith("/") ? "" : "/"}${resolvedPath}`;
  return width ? `${url}?w=${width}` : url;
};

const finalSrc = isRemote && typeof src === "string" ? resolveSrc(src) : (src || "");

// Generate srcset for remote images if it's a gateway URL
const remoteWidths = widths || [400, 800, 1200];
const srcset = (isRemote && typeof src === "string" && finalSrc.includes(import.meta.env.PUBLIC_IMAGE_GATEWAY_URL))
  ? remoteWidths.map(w => `${resolveSrc(src, w)} ${w}w`).join(", ")
  : undefined;

const aspectClasses = {
  portrait: "aspect-2/3",
  square: "aspect-square",
  landscape: "aspect-16/9",
  auto: "",
};

const combinedClasses = `${aspectClasses[ratio]} ${className} object-cover`.trim();
---

{isRemote ? (
  <img
    src={finalSrc}
    srcset={srcset}
    sizes={sizes || "(max-width: 800px) 100vw, 800px"}
    alt={alt}
    loading={loading}
    class={combinedClasses}
    decoding={decoding}
    fetchpriority={fetchpriority}
    draggable={draggable}
    onload={fade ? "this.style.opacity=1" : ""}
    style={fade ? "opacity: 0; transition-property: opacity; transition-duration: 0.8s; transition-timing-function: ease-out;" : ""}
    onerror="this.onerror=null; this.srcset=''; this.src='https://placehold.co/800x800?text=Placeholder';"
    {...rest}
  />
) : (
  <AstroImage
    src={src}
    alt={alt}
    loading={loading}
    class={combinedClasses}
    widths={widths || [400, 800, 1200]}
    sizes={sizes || "(max-width: 800px) 100vw, 800px"}
    decoding={decoding}
    fetchpriority={fetchpriority}
    draggable={draggable}
    onload={fade ? "this.style.opacity=1" : ""}
    style={fade ? "opacity: 0; transition-property: opacity; transition-duration: 0.8s; transition-timing-function: ease-out;" : ""}
    onerror="this.onerror=null; this.srcset=''; this.src='https://placehold.co/800x800?text=Placeholder';"
    {...rest} 
  />
)}
