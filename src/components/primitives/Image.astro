---
import { Image as AstroImage } from "astro:assets";

interface Props {
  src: any; // Can be a local import or remote string
  alt: string;
  ratio?: "portrait" | "square" | "landscape" | "auto";
  class?: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
}

const { 
  src, 
  alt, 
  ratio = "square", 
  class: className, 
  width, 
  height, 
  loading = "lazy", 
  decoding = "async", 
  fetchpriority, 
  ...rest 
} = Astro.props;

// Base styles with object-fit cover - removed h-full to respect aspect-ratio
const baseStyles = "w-full object-cover";

// Aspect ratio enforcement
const ratioStyles = {
  portrait: "aspect-[4/5]",
  square: "aspect-square",
  landscape: "aspect-video",
  auto: "",
};

const combinedClasses = `${baseStyles} ${ratioStyles[ratio]} ${className || ""}`.trim();

const gateway = import.meta.env.IMAGE_GATEWAY_URL || "";
const isString = typeof src === "string";
const isPublicFile = isString && src.startsWith("/");
const isRemote = isString && src.startsWith("http");
const isGatewayImage = isPublicFile && gateway !== "";
const bypassAstroImage = isGatewayImage || isPublicFile || (import.meta.env.DEV && isRemote);

let gatewaySrc = src;
let gatewaySrcset = undefined;

if (isGatewayImage) {
  gatewaySrc = `${gateway}${src}?w=800`;
  gatewaySrcset = `${gateway}${src}?w=200 200w, ${gateway}${src}?w=400 400w, ${gateway}${src}?w=800 800w, ${gateway}${src}?w=1200 1200w`;
}
---

{
  isGatewayImage ? (
    <img
      src={gatewaySrc}
      srcset={gatewaySrcset}
      alt={alt}
      class={combinedClasses}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...rest}
    />
  ) : bypassAstroImage ? (
    <img 
      src={src} 
      alt={alt} 
      class={combinedClasses} 
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...rest}
    />
  ) : isString ? (
    <AstroImage 
      src={src} 
      alt={alt} 
      class={combinedClasses} 
      width={width || 800}
      height={height || 800}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...rest}
    />
  ) : (
    <AstroImage 
      src={src} 
      alt={alt} 
      class={combinedClasses} 
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...rest} 
    />
  )
}
