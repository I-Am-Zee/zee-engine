---
import { Image as AstroImage } from "astro:assets";

interface Props {
  src: any; // Can be a local import or remote string
  alt: string;
  ratio?: "portrait" | "square" | "landscape" | "auto";
  class?: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  fetchpriority?: "high" | "low" | "auto";
  /**
   * The sizes attribute for responsive srcset.
   * Tells the browser what size the image will render at each breakpoint.
   * Defaults to '100vw' (safe baseline). Override for partial-width images.
   * Example: '(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw'
   */
  sizes?: string;
}

const { 
  src, 
  alt, 
  ratio = "square", 
  class: className, 
  width, 
  height, 
  loading = "lazy", 
  decoding = "async", 
  fetchpriority,
  sizes = "100vw",
  ...rest 
} = Astro.props;

// Base styles with object-fit cover - removed h-full to respect aspect-ratio
const baseStyles = "w-full object-cover";

// Aspect ratio enforcement
const ratioStyles = {
  portrait: "aspect-[4/5]",
  square: "aspect-square",
  landscape: "aspect-video",
  auto: "",
};

const combinedClasses = `${baseStyles} ${ratioStyles[ratio]} ${className || ""}`.trim();

const gateway = import.meta.env.IMAGE_GATEWAY_URL || "";
const brandId = import.meta.env.PUBLIC_BRAND_ID || "default";
const isDev = import.meta.env.DEV;

const isString = typeof src === "string";
const isPublicFile = isString && src.startsWith("/");
const isRemote = isString && src.startsWith("http");

// Logic: 
// 1. If it starts with /images/, it needs to be mapped to the brand-prefixed R2 path
// 2. We only use the gateway in PRODUCTION or if the user explicitly wants R2 in Dev
const isGatewayImage = isPublicFile && gateway !== "" && !isDev;
const bypassAstroImage = isGatewayImage || isPublicFile || (isDev && isRemote);

let gatewaySrc = src;
let gatewaySrcset = undefined;

if (isGatewayImage) {
  // Transform path: /images/products/photo.jpg -> /zelia-vance/products/photo.jpg
  // This aligns the project's local-path structure with the R2 multi-tenant structure
  const r2Path = src.replace(/^\/images\//, `/${brandId}/`);
  
  gatewaySrc = `${gateway}${r2Path}?w=800`;
  // 3 widths only: 400, 800, 1200 — keeps unique transformations under the 5k/mo free tier limit.
  // 200w is intentionally excluded per IMAGE-ENGINE R2 WORKER.md architecture rules.
  gatewaySrcset = `${gateway}${r2Path}?w=400 400w, ${gateway}${r2Path}?w=800 800w, ${gateway}${r2Path}?w=1200 1200w`;
}
---

{
  isGatewayImage ? (
    <img
      src={gatewaySrc}
      srcset={gatewaySrcset}
      sizes={sizes}
      alt={alt}
      class={combinedClasses}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...rest}
    />
  ) : bypassAstroImage ? (
    <img 
      src={src} 
      alt={alt} 
      class={combinedClasses} 
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...rest}
    />
  ) : isString ? (
    <AstroImage 
      src={src} 
      alt={alt} 
      class={combinedClasses} 
      width={width || 800}
      height={height || 800}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...rest}
    />
  ) : (
    <AstroImage 
      src={src} 
      alt={alt} 
      class={combinedClasses} 
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      {...rest} 
    />
  )
}
