---
import { Image as AstroImage } from "astro:assets";

interface Props {
  src: any; // Can be a local import or remote string
  alt: string;
  ratio?: "portrait" | "square" | "landscape" | "auto";
  class?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  decoding?: "async" | "sync" | "auto";
  sizes?: string;
  widths?: number[];
  draggable?: boolean | "true" | "false"; // Corrected type for draggable
  [key: string]: any; // Catch-all for Alpine attributes like :src, :alt, etc.
}

const { 
  src: srcProp, 
  alt, 
  ratio = "auto", 
  class: className = "", 
  loading = "lazy", 
  fetchpriority = "auto", 
  decoding = "async",
  sizes,
  widths,
  draggable,
  ...rest 
} = Astro.props;

// Normalize src: empty strings or null/undefined should be treated as missing
const src = srcProp || null;

// Guard: If no source is provided and no Alpine dynamic source exists, skip rendering to prevent Astro crash
if (!src && !rest[':src']) return null;

// Determine if we should use Astro's optimized Image or a raw img tag
// Remote if it's a string starting with http or /, or if it has an Alpine :src attribute
const isRemote = (typeof src === "string" && (src.startsWith("http") || src.startsWith("/"))) || !!rest[':src'];

// Logic to resolve R2 paths through the gateway
const resolveSrc = (path: string) => {
  if (!path) return "";
  const gateway = import.meta.env.PUBLIC_IMAGE_GATEWAY_URL || "";
  const brandId = import.meta.env.PUBLIC_BRAND_ID;
  
  if (path.startsWith("http")) return path;
  
  if (path.startsWith("/")) {
    // Transform path: /images/products/photo.jpg -> /zelia-vance/products/photo.jpg
    // This aligns local public paths with the R2 multi-tenant structure
    const r2Path = path.replace(/^\/images\//, `/${brandId}/`);
    
    // If the path was transformed, prepend the gateway
    if (r2Path !== path) {
      return `${gateway}${r2Path}`;
    }
    
    // If it's a root path but not in /images/ (unlikely for assets), still prefix with brandId
    return `${gateway}/${brandId}${path}`;
  }
  
  return path;
};

const finalSrc = isRemote && typeof src === "string" ? resolveSrc(src) : (src || "");

const aspectClasses = {
  portrait: "aspect-2/3",
  square: "aspect-square",
  landscape: "aspect-16/9",
  auto: "",
};

const combinedClasses = `${aspectClasses[ratio]} ${className} object-cover`.trim();
---

{isRemote ? (
  <img
    src={finalSrc}
    alt={alt}
    loading={loading}
    class={combinedClasses}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
    draggable={draggable}
    onload="this.style.opacity=1"
    style="opacity: 0; transition-property: opacity; transition-duration: 0.8s; transition-timing-function: ease-out;"
    {...rest}
  />
) : (
  <AstroImage
    src={src}
    alt={alt}
    loading={loading}
    class={combinedClasses}
    widths={widths || [400, 800, 1200]}
    sizes={sizes || "(max-width: 800px) 100vw, 800px"}
    decoding={decoding}
    fetchpriority={fetchpriority}
    draggable={draggable}
    onload="this.style.opacity=1"
    style="opacity: 0; transition-property: opacity; transition-duration: 0.8s; transition-timing-function: ease-out;"
    {...rest} 
  />
)}
