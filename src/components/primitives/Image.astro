---
import { Image as AstroImage } from "astro:assets";
import { resolveImage, resolveSrcset } from "../../scripts/utils/images";

interface Props {
  src: any; // Can be a local import or remote string
  alt: string;
  ratio?: "portrait" | "square" | "landscape" | "auto";
  class?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  decoding?: "async" | "sync" | "auto";
  sizes?: string;
  widths?: number[];
  draggable?: boolean | "true" | "false"; 
  fade?: boolean; 
  [key: string]: any; 
}

const { 
  src: srcProp, 
  alt, 
  ratio = "auto", 
  class: className = "", 
  loading = "lazy", 
  fetchpriority = "auto", 
  decoding = "async",
  sizes,
  widths = [400, 800, 1200],
  draggable,
  fade = true,
  ...rest 
} = Astro.props;

// Normalize src: empty strings or null/undefined should be treated as missing
const src = srcProp || null;

// Guard: If no source is provided and no Alpine dynamic source exists, skip rendering to prevent Astro crash
if (!src && !rest[':src']) return null;

// Determine if we should use Astro's optimized Image or a raw img tag
// Remote if it's a string starting with http or /, or if it has an Alpine :src attribute
const isRemote = (typeof src === "string" && (src.startsWith("http") || src.startsWith("/"))) || !!rest[':src'];

// Server-side resolve (Astro)
const finalSrc = isRemote && typeof src === "string" ? resolveImage(src) : (src || "");
const srcset = (isRemote && typeof src === "string" && finalSrc.includes(import.meta.env.PUBLIC_IMAGE_GATEWAY_URL))
  ? resolveSrcset(src, widths)
  : undefined;

// Client-side resolve (Alpine)
// If :src is passed, we intelligently inject the engine resolver
const alpineSrc = rest[':src'] ? `$engine.image(${rest[':src']})` : undefined;
const alpineSrcset = rest[':src'] ? `$engine.srcset(${rest[':src']}, [${widths.join(", ")}])` : undefined;

const aspectClasses = {
  portrait: "aspect-2/3",
  square: "aspect-square",
  landscape: "aspect-16/9",
  auto: "",
};

const combinedClasses = `${aspectClasses[ratio]} ${className} object-cover`.trim();
---

{isRemote ? (
  <img
    src={finalSrc}
    srcset={srcset}
    x-bind:src={alpineSrc}
    x-bind:srcset={alpineSrcset}
    sizes={sizes || "(max-width: 800px) 100vw, 800px"}
    alt={alt}
    loading={loading}
    class={combinedClasses}
    decoding={decoding}
    fetchpriority={fetchpriority}
    draggable={draggable}
    onload={fade ? "this.style.opacity=1" : ""}
    style={fade ? "opacity: 0; transition-property: opacity; transition-duration: 0.8s; transition-timing-function: ease-out;" : ""}
    onerror="this.onerror=null; this.srcset=''; this.src='https://placehold.co/800x800?text=Placeholder';"
    {...rest}
  />
) : (
  <AstroImage
    src={src}
    alt={alt}
    loading={loading}
    class={combinedClasses}
    widths={widths}
    sizes={sizes || "(max-width: 800px) 100vw, 800px"}
    decoding={decoding}
    fetchpriority={fetchpriority}
    draggable={draggable}
    onload={fade ? "this.style.opacity=1" : ""}
    style={fade ? "opacity: 0; transition-property: opacity; transition-duration: 0.8s; transition-timing-function: ease-out;" : ""}
    onerror="this.onerror=null; this.srcset=''; this.src='https://placehold.co/800x800?text=Placeholder';"
    {...rest} 
  />
)}
