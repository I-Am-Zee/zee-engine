---
import { Image as AstroImage } from "astro:assets";

interface Props {
  src: any; // Can be a local import or remote string
  alt: string;
  ratio?: "portrait" | "square" | "landscape" | "auto";
  class?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  decoding?: "async" | "sync" | "auto";
  sizes?: string;
  widths?: number[];
  draggable?: boolean | "true" | "false"; // Corrected type for draggable
  [key: string]: any; // Catch-all for Alpine attributes like :src, :alt, etc.
}

const { 
  src, 
  alt, 
  ratio = "auto", 
  class: className = "", 
  loading = "lazy", 
  fetchpriority = "auto", 
  decoding = "async",
  sizes,
  widths,
  draggable,
  ...rest 
} = Astro.props;

// Determine if we should use Astro's optimized Image or a raw img tag (for remote R2 paths)
// If it's a string starting with http or /, it's likely a remote/R2 path
const isRemote = typeof src === "string" && (src.startsWith("http") || src.startsWith("/"));

// Logic to resolve R2 paths through the gateway
const resolveSrc = (path: string) => {
  const gateway = import.meta.env.PUBLIC_IMAGE_GATEWAY_URL || "";
  const brandId = import.meta.env.PUBLIC_BRAND_ID || "default";
  
  if (path.startsWith("http")) return path;
  if (path.startsWith("/")) return `${gateway}/${brandId}${path}`;
  return path;
};

const finalSrc = isRemote ? resolveSrc(src as string) : src;

const aspectClasses = {
  portrait: "aspect-2/3",
  square: "aspect-square",
  landscape: "aspect-16/9",
  auto: "",
};

const combinedClasses = `${aspectClasses[ratio]} ${className} object-cover`.trim();
---

{isRemote ? (
  <img
    src={finalSrc}
    alt={alt}
    loading={loading}
    class={combinedClasses}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
    draggable={draggable}
    onload="this.style.opacity=1"
    style="opacity: 0; transition-property: opacity; transition-duration: 0.8s; transition-timing-function: ease-out;"
    {...rest}
  />
) : (
  <AstroImage
    src={src}
    alt={alt}
    loading={loading}
    class={combinedClasses}
    widths={widths || [400, 800, 1200]}
    sizes={sizes || "(max-width: 800px) 100vw, 800px"}
    decoding={decoding}
    fetchpriority={fetchpriority}
    draggable={draggable}
    onload="this.style.opacity=1"
    style="opacity: 0; transition-property: opacity; transition-duration: 0.8s; transition-timing-function: ease-out;"
    {...rest} 
  />
)}
