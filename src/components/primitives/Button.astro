---
interface Props {
  as?: "button" | "a";
  type?: "primary" | "secondary" | "neutral" | "ghost";
  variant?: "default" | "icon-left" | "icon-right" | "icon-only";
  size?: "sm" | "md" | "lg";
  disabled?: boolean;
  class?: string;
  href?: string;
}

const {
  as: Tag = "button",
  type = "primary",
  variant = "default",
  size = "md",
  disabled = false,
  class: className,
  href,
  ...rest
} = Astro.props;

// Base styles shared across all buttons - using shadow glow for focus
const baseStyles =
  "inline-flex items-center justify-center font-sans font-medium transition-all duration-200 rounded-md outline-none disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none focus-visible:shadow-[0_0_0_2px_var(--color-background),0_0_0_4px_var(--color-ring),0_0_12px_var(--color-ring-glow)]";

// Paint logic - type determines color scheme
const typeStyles = {
  primary:
    "bg-(--color-primary) text-(--color-primary-foreground) hover:bg-black active:scale-[0.98]",
  secondary:
    "bg-(--color-accent-brass) text-(--color-primary) hover:bg-(--color-accent-brass)/90 active:scale-[0.98]",
  neutral:
    "bg-(--color-surface) text-(--color-text-main) border border-(--color-border-subtle) hover:bg-(--color-surface-muted) active:border-(--color-border-strong)",
  ghost:
    "bg-transparent text-(--color-text-main) hover:bg-(--color-ghost-hover) active:bg-(--color-surface-muted)",
};

// Size styles
const sizeStyles = {
  sm: variant === "icon-only" ? "h-8 w-8 text-sm" : "h-8 px-3 text-sm gap-2",
  md: variant === "icon-only" ? "h-10 w-10 text-base" : "h-10 px-4 text-base gap-2",
  lg: variant === "icon-only" ? "h-12 w-12 text-lg" : "h-12 px-6 text-lg gap-3",
};

// Layout logic - variant determines icon position
const variantStyles = {
  default: "",
  "icon-left": "flex-row",
  "icon-right": "flex-row-reverse",
  "icon-only": "",
};

const combinedClasses =
  `${baseStyles} ${typeStyles[type]} ${sizeStyles[size]} ${variantStyles[variant]} ${className || ""}`.trim();

const componentProps = Tag === "a" ? { href, ...rest } : { type: "button", disabled, ...rest };
---

<Tag class={combinedClasses} {...componentProps}>
  <slot />
</Tag>
