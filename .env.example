# Snipcart (Get your keys from https://app.snipcart.com/dashboard/account/credentials)
PUBLIC_SNIPCART_API_KEY=your_test_public_key_here
SNIPCART_SECRET_API_KEY=your_secret_key_here

# Razorpay (Get your keys from https://dashboard.razorpay.com/app/keys)
PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_secret_here

# Site Configuration (Update for production or ngrok URL)
PUBLIC_SITE_URL=http://localhost:4321

